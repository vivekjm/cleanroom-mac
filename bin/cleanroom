pip_cache() {
  local command_label output status
  local -a pip_cmd
  if command -v pip3 >/dev/null 2>&1; then
    pip_cmd=(pip3)
  elif command -v pip >/dev/null 2>&1; then
    pip_cmd=(pip)
  elif command -v python3 >/dev/null 2>&1 && python3 -m pip --version >/dev/null 2>&1; then
    pip_cmd=(python3 -m pip)
  else
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":false,"apply":%s,"command":"","exit_code":127,"output":"%s"}\n' \
        "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "pip command not found" | json_escape)"
      return 0
    fi
    die "pip command not found"
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    command_label="${pip_cmd[*]} cache purge"
  else
    command_label="${pip_cmd[*]} cache info"
  fi

  if [[ "$APPLY" -eq 1 && "$ASSUME_YES" -ne 1 ]]; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":true,"apply":true,"command":"%s","exit_code":2,"output":"%s"}\n' \
        "$(printf '%s' "$command_label" | json_escape)" \
        "$(printf '%s' "confirmation required; pass --yes to use --json with --apply" | json_escape)"
      return 2
    fi
    warn "Apply mode enabled for pip cache cleanup."
    warn "pip cache purge removes cached wheels and downloads; projects may need to download packages again."
    printf 'Continue? Type "clean" to proceed: '
    local answer
    IFS= read -r answer
    [[ "$answer" == "clean" ]] || die "Aborted."
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    if output="$("${pip_cmd[@]}" cache purge 2>&1)"; then
      status=0
      record_apply "pip-cache" "ok" "0" "$command_label" ""
    else
      status=$?
      record_apply "pip-cache" "failed" "0" "$command_label" ""
    fi
  else
    if output="$("${pip_cmd[@]}" cache info 2>&1)"; then
      status=0
    else
      status=$?
    fi
  fi

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"available":true,"apply":%s,"command":"%s","exit_code":%s,"output":"%s"}\n' \
      "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(printf '%s' "$command_label" | json_escape)" \
      "$status" \
      "$(printf '%s' "$output" | json_escape)"
    return "$status"
  fi

  printf '%s\n' "${BOLD}cleanroom pip cache${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    printf 'Running: %s\n\n' "$command_label"
  else
    warn "Dry-run mode. Pass --apply --yes to run ${pip_cmd[*]} cache purge."
    printf 'Running: %s\n\n' "$command_label"
  fi
  if [[ -n "$output" ]]; then
    printf '%s\n' "$output"
  else
    printf 'pip reported no cache output.\n'
  fi
  return "$status"
}

receipt_roots() {
  printf '%s\t%s\n' "system-receipts" "/var/db/receipts"
  printf '%s\t%s\n' "local-receipts" "/Library/Receipts"
  printf '%s\t%s\n' "user-receipts" "~/Library/Receipts"
}

receipt_rows() {
  local root_id root_template root path kind name id kb epoch
  while IFS=$'\t' read -r root_id root_template; do
    root="$(expand_path "$root_template")"
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      name="$(basename "$path")"
      kind="${name##*.}"
      [[ "$kind" == "plist" || "$kind" == "bom" ]] || continue
      id="${name%.$kind}"
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      printf '%012d\t%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$id" "$kind" "$root_id" "$path"
    done < <(find "$root" -maxdepth 1 -type f \( -name '*.plist' -o -name '*.bom' \) -print0 2>/dev/null)
  done < <(receipt_roots) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

receipts() {
  local rows
  rows="$(receipt_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch id kind root_id path kb_num epoch_num command guidance
    while IFS=$'\t' read -r kb epoch id kind root_id path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      command="$(printf 'cleanroom leftovers %s' "$(shell_quote "$id")")"
      guidance="Receipts are install records, not uninstall targets. Use vendor uninstallers first, then review leftovers."
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","kind":"%s","root":"%s","path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","review_command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$root_id" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf '%s' "$command" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom package receipts${RESET}"
  printf 'Review-only inventory. Receipts are installer records; cleanroom does not delete them.\n'
  printf 'Use vendor uninstallers first, then run leftovers review for matching package IDs.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No package receipts found in readable receipt folders.\n'
    return 0
  fi
  printf '%-10s %-8s %-12s %-18s %s\n' "size" "kind" "modified" "root" "package id"
  local kb epoch id kind root_id path epoch_num
  while IFS=$'\t' read -r kb epoch id kind root_id path; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    printf '%-10s %-8s %-12s %-18s %s\n' "$(human_kb "$kb")" "$kind" "$(file_mtime_iso "${epoch_num:-0}")" "$root_id" "$id"
    printf '  path: %s\n' "$path"
    printf '  review: cleanroom leftovers %s\n' "$(shell_quote "$id")"
  done <<<"$rows"
}

homebrew_rows() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-cache" "cache" "~/Library/Caches/Homebrew" "cleanroom clean" "cleanroom clean --apply --trash" "Downloaded bottles, source archives, and build cache. Rebuildable."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-logs" "logs" "~/Library/Logs/Homebrew" "cleanroom clean" "cleanroom clean --apply --trash" "Homebrew build logs. Usually safe to remove when old."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-cellar-arm" "cellar" "/opt/homebrew/Cellar" "brew cleanup -n" "brew cleanup" "Installed formula versions on Apple Silicon Homebrew. Use brew cleanup to remove old versions."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-cellar-intel" "cellar" "/usr/local/Cellar" "brew cleanup -n" "brew cleanup" "Installed formula versions on Intel Homebrew. Use brew cleanup to remove old versions."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-caskroom-arm" "casks" "/opt/homebrew/Caskroom" "brew cleanup -n" "brew cleanup" "Homebrew Cask app/download staging data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-caskroom-intel" "casks" "/usr/local/Caskroom" "brew cleanup -n" "brew cleanup" "Homebrew Cask app/download staging data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-var-arm" "services" "/opt/homebrew/var" "manual review" "manual review" "Databases, service state, and runtime data for installed formulae. Review carefully."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-var-intel" "services" "/usr/local/var" "manual review" "manual review" "Databases, service state, and runtime data for installed formulae. Review carefully."
}

homebrew_counts_json_fields() {
  local formulae=0 casks=0 prefix=""
  if command -v brew >/dev/null 2>&1; then
    formulae="$(brew list --formula 2>/dev/null | awk 'END {print NR + 0}')"
    casks="$(brew list --cask 2>/dev/null | awk 'END {print NR + 0}')"
    prefix="$(brew --prefix 2>/dev/null || true)"
  fi
  printf '"installed_formulae":%s,"installed_casks":%s,"active_prefix":"%s"' \
    "${formulae:-0}" \
    "${casks:-0}" \
    "$(printf '%s' "$prefix" | json_escape)"
}

homebrew() {
  local rows
  rows="$(homebrew_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    homebrew_counts_json_fields
    printf ',"buckets":['
    local first=1 id category path preview apply description expanded kb
    while IFS=$'\t' read -r id category path preview apply description; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$expanded")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","category":"%s","path":"%s","exists":%s,"size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$(if [[ -e "$expanded" ]]; then echo true; else echo false; fi)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']}'
    printf '\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Homebrew storage${RESET}"
  printf 'Review-only inventory. cleanroom only clears Homebrew cache through the normal safe clean flow.\n\n'
  if command -v brew >/dev/null 2>&1; then
    printf '%-20s %s\n' "active prefix" "$(brew --prefix 2>/dev/null || true)"
    printf '%-20s %s\n' "formulae" "$(brew list --formula 2>/dev/null | awk 'END {print NR + 0}')"
    printf '%-20s %s\n\n' "casks" "$(brew list --cask 2>/dev/null | awk 'END {print NR + 0}')"
  else
    printf 'brew command not found. Filesystem buckets are still shown when present.\n\n'
  fi

  printf '%-10s %-22s %-10s %s\n' "size" "id" "category" "path"
  local id category path preview apply description expanded kb
  while IFS=$'\t' read -r id category path preview apply description; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] || continue
    kb="$(size_kb "$expanded")"
    printf '%-10s %-22s %-10s %s\n' "$(human_kb "$kb")" "$id" "$category" "$expanded"
    printf '  preview: %s\n' "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  %s\n' "$description"
  done <<<"$rows"
  printf '\nUse `cleanroom homebrew-cleanup` for Homebrew-native dry-run details. Use `cleanroom clean --apply --trash` for cache cleanup through cleanroom.\n'
}

homebrew_cleanup() {
  local command_label output status
  if ! command -v brew >/dev/null 2>&1; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":false,"apply":%s,"command":"","exit_code":127,"output":"%s"}\n' \
        "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "brew command not found" | json_escape)"
      return 0
    fi
    die "brew command not found"
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    command_label="brew cleanup"
  else
    command_label="brew cleanup -n"
  fi

  if [[ "$APPLY" -eq 1 && "$ASSUME_YES" -ne 1 ]]; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":true,"apply":true,"command":"%s","exit_code":2,"output":"%s"}\n' \
        "$(printf '%s' "$command_label" | json_escape)" \
        "$(printf '%s' "confirmation required; pass --yes to use --json with --apply" | json_escape)"
      return 2
    fi
    warn "Apply mode enabled for Homebrew cleanup."
    printf 'Continue? Type "clean" to proceed: '
    local answer
    IFS= read -r answer
    [[ "$answer" == "clean" ]] || die "Aborted."
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    if output="$(brew cleanup 2>&1)"; then
      status=0
      record_apply "homebrew-cleanup" "ok" "0" "$command_label" ""
    else
      status=$?
      record_apply "homebrew-cleanup" "failed" "0" "$command_label" ""
    fi
  else
    if output="$(brew cleanup -n 2>&1)"; then
      status=0
    else
      status=$?
    fi
  fi

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"available":true,"apply":%s,"command":"%s","exit_code":%s,"output":"%s"}\n' \
      "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(printf '%s' "$command_label" | json_escape)" \
      "$status" \
      "$(printf '%s' "$output" | json_escape)"
    return "$status"
  fi

  printf '%s\n' "${BOLD}cleanroom Homebrew cleanup${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    printf 'Running: %s\n\n' "$command_label"
  else
    warn "Dry-run mode. Pass --apply --yes to run Homebrew cleanup."
    printf 'Running: %s\n\n' "$command_label"
  fi
  if [[ -n "$output" ]]; then
    printf '%s\n' "$output"
  else
    printf 'Homebrew reported no cleanup output.\n'
  fi
  return "$status"
}

toolchains() {
  local rows
  rows="$(toolchain_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id ecosystem paths category preview apply description kb
    while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb="$(paths_field_kb "$paths")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","ecosystem":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$ecosystem" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom language toolchains${RESET}"
  printf 'Review-only inventory. Use the preview command before applying cleanup.\n\n'
  printf '%-10s %-18s %-10s %s\n' "size" "id" "ecosystem" "preview command"
  local id ecosystem paths category preview apply description kb
  while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%-10s %-18s %-10s %s\n' "$(human_kb "$kb")" "$id" "$ecosystem" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

toolchains_fast() {
  local rows
  rows="$(toolchain_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id ecosystem paths category preview apply description present status size summary
    while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      if paths_field_present "$paths"; then
        present=true
        status="Review"
        size="Present"
        summary="$description"
      else
        present=false
        status="Clear"
        size="Not found"
        summary="No known local cache root found for this toolchain."
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","ecosystem":"%s","present":%s,"status":"%s","category":"Developer Cache","size":"%s","summary":"%s","mode":"fast"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$id" | sed 's/-/ /g' | json_escape)" \
        "$(printf '%s' "$ecosystem" | json_escape)" \
        "$present" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$size" | json_escape)" \
        "$(printf '%s' "$summary" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}quick language toolchains${RESET}"
  printf 'Fast presence check. Exact sizing is skipped to keep the app responsive.\n\n'
  local id ecosystem paths category preview apply description status
  while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    if paths_field_present "$paths"; then
      status="present"
    else
      status="not found"
    fi
    printf '%-12s %-18s %s\n' "$status" "$ecosystem" "$id"
  done <<<"$rows"
}

toolchain_total_kb() {
  local id ecosystem paths category preview apply description total=0 kb
  while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    total=$((total + kb))
  done < <(toolchain_rows)
  printf '%s\n' "$total"
}

