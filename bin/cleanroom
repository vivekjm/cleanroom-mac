  cleanroom savedstate [--json]
  cleanroom savedstate-fast [--json]
  cleanroom projectcaches [PATH] [--limit N] [--json]
  cleanroom projectcaches-fast [PATH] [--limit N] [--json]
  cleanroom developer-fast [PATH] [--days N] [--limit N] [--json]
  cleanroom updaters [--json]
  cleanroom updaters-fast [--json]
  cleanroom browsercaches [--json]
  cleanroom browsercaches-fast [--json]
  cleanroom duplicates [PATH] [--min-mb N] [--limit N] [--json]
  cleanroom duplicates-fast [PATH] [--min-mb N] [--limit N] [--json]
  cleanroom documents [PATH] [--limit N] [--json]
  cleanroom documents-fast [PATH] [--limit N] [--json]
  cleanroom desktop [--limit N] [--json]
  cleanroom desktop-fast [--limit N] [--json]
  cleanroom screenshots [PATH] [--days N] [--limit N] [--json]
  cleanroom archives [PATH] [--days N] [--limit N] [--json]
  cleanroom archives-fast [PATH] [--days N] [--limit N] [--json]
  cleanroom screenshots-fast [PATH] [--days N] [--limit N] [--json]
  cleanroom downloads [--days N] [--limit N] [--json]
  cleanroom downloads-fast [--days N] [--limit N] [--json]
  cleanroom installers [--days N] [--limit N] [--json]
  cleanroom nodes [PATH] [--days N] [--limit N] [--json]
  cleanroom nodes-fast [PATH] [--days N] [--limit N] [--json]
  cleanroom venvs [PATH] [--days N] [--limit N] [--json]
  cleanroom venvs-fast [PATH] [--days N] [--limit N] [--json]
