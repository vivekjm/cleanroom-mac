PREFLIGHT=0
RUN_ID="$(date '+%Y%m%d-%H%M%S')-$$"
EXCLUDES=()
PATH_ARGS=()
INCLUDE_DEV_HEAVY=0
INCLUDE_NODE_STALE=0
INCLUDE_VENV_STALE=0
INCLUDE_GEMINI=0
