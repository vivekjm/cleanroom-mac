container_total_kb() {
  local id runtime paths safety preview apply description total=0 kb
  while IFS=$'\t' read -r id runtime paths safety preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    total=$((total + kb))
  done < <(container_rows)
  printf '%s\n' "$total"
}

container_present_count() {
  local id runtime paths safety preview apply description count=0
  while IFS=$'\t' read -r id runtime paths safety preview apply description; do
    [[ -z "${id:-}" ]] && continue
    paths_field_present "$paths" && count=$((count + 1))
  done < <(container_rows)
  printf '%s\n' "$count"
}

package_total_kb() {
  local id manager paths category preview apply total=0 kb
  while IFS=$'\t' read -r id manager paths category preview apply; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    total=$((total + kb))
  done < <(package_rows)
  printf '%s\n' "$total"
}

snapshot_rows() {
  command -v tmutil >/dev/null 2>&1 || return 0
  tmutil listlocalsnapshots / 2>/dev/null |
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local name date_part
      name="${line##* }"
      [[ "$name" == com.apple.* ]] || continue
      date_part="${name#com.apple.TimeMachine.}"
      printf '%s\t%s\n' "$name" "$date_part"
    done
}

snapshot_count() {
  snapshot_rows | awk 'END {print NR + 0}'
}

protected_present_count() {
  local file id type path reason expanded count=0
  file="$(protected_file)"
  [[ -f "$file" ]] || { printf '0\n'; return 0; }
  while IFS=$'\t' read -r id type path reason; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] && count=$((count + 1))
  done < <(tail -n +2 "$file")
  printf '%s\n' "$count"
}

app_bundle_count() {
  local total=0 root count
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    count="$(app_rows "$root" | awk 'END {print NR + 0}')"
    total=$((total + count))
  done < <(app_roots)
  printf '%s\n' "$total"
}

tab_rows_total_kb() {
  awk -F '\t' '{
    value = $1
    sub(/^0+/, "", value)
    if (value == "") value = 0
    total += value
  } END {print total + 0}'
}

tab_rows_count() {
  awk 'END {print NR + 0}'
}

review_rows() {
  local documents_kb desktop_kb downloads_rows_value downloads_kb downloads_count screenshots_rows_value screenshots_kb screenshots_count archives_rows_value archives_kb archives_count installers_rows_value installers_kb installers_count appdata_rows_value appdata_kb appdata_count communications_kb app_count

  documents_kb="$(size_kb "$HOME/Documents")"
  desktop_kb="$(size_kb "$HOME/Desktop")"
  downloads_rows_value="$(downloads_rows)"
  downloads_kb="$(printf '%s\n' "$downloads_rows_value" | tab_rows_total_kb)"
  downloads_count="$(printf '%s\n' "$downloads_rows_value" | sed '/^$/d' | tab_rows_count)"
  screenshots_rows_value="$(screenshot_rows)"
  screenshots_kb="$(printf '%s\n' "$screenshots_rows_value" | tab_rows_total_kb)"
  screenshots_count="$(printf '%s\n' "$screenshots_rows_value" | sed '/^$/d' | tab_rows_count)"
  archives_rows_value="$(archive_rows)"
  archives_kb="$(printf '%s\n' "$archives_rows_value" | tab_rows_total_kb)"
  archives_count="$(printf '%s\n' "$archives_rows_value" | sed '/^$/d' | tab_rows_count)"
  installers_rows_value="$(installer_rows)"
  installers_kb="$(printf '%s\n' "$installers_rows_value" | tab_rows_total_kb)"
  installers_count="$(printf '%s\n' "$installers_rows_value" | sed '/^$/d' | tab_rows_count)"
  appdata_rows_value="$(appdata_rows)"
  appdata_kb="$(printf '%s\n' "$appdata_rows_value" | tab_rows_total_kb)"
  appdata_count="$(printf '%s\n' "$appdata_rows_value" | sed '/^$/d' | tab_rows_count)"
  communications_kb="$(communications_total_kb)"
  app_count="$(app_bundle_count)"

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$documents_kb" "documents" "Documents folder" "cleanroom documents ~/Documents --limit 50" "Top-level Documents folders and files with guard status." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$desktop_kb" "desktop" "Desktop clutter" "cleanroom desktop --limit 50" "Top-level Desktop folders and files with guard status." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$downloads_kb" "downloads" "Old Downloads" "cleanroom downloads --days $DAYS --limit $LIMIT" "Top ${downloads_count} old Downloads files from the current review limit." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$screenshots_kb" "screenshots" "Screenshots and recordings" "cleanroom screenshots --days $DAYS --limit $LIMIT" "Top ${screenshots_count} screenshot and screen recording files from Desktop, Downloads, and Documents." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$archives_kb" "archives" "Archives and disk images" "cleanroom archives --days $DAYS --limit $LIMIT" "Top ${archives_count} archive and disk image files from Downloads, Desktop, and Documents." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$installers_kb" "installers" "Old installers" "cleanroom installers --days $DAYS --limit $LIMIT" "Top ${installers_count} downloaded installers that have an opt-in cleanup path." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$appdata_kb" "appdata" "Large app data folders" "cleanroom appdata --limit $LIMIT" "Top ${appdata_count} app support/container folders with guard status." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$communications_kb" "communications" "Mail and Messages" "cleanroom communications" "Protected Mail, Mail Downloads, Messages, and Messages attachments. Review-only." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$app_count" "apps" "Installed app bundles" "cleanroom apps --limit $LIMIT" "Count of app bundles found in application folders; run the command for sizes." "count"
}

review() {
  local rows
  rows="$(review_rows | sort -rn)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 estimate id title command description kind
    while IFS=$'\t' read -r estimate id title command description kind; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      if [[ "$kind" == "count" ]]; then
        printf '{"id":"%s","title":"%s","kind":"%s","count":%s,"command":"%s","description":"%s"}' \
          "$(printf '%s' "$id" | json_escape)" \
          "$(printf '%s' "$title" | json_escape)" \
          "$(printf '%s' "$kind" | json_escape)" \
          "${estimate:-0}" \
          "$(printf '%s' "$command" | json_escape)" \
          "$(printf '%s' "$description" | json_escape)"
      else
        printf '{"id":"%s","title":"%s","kind":"%s","estimate_kb":%s,"estimate":"%s","command":"%s","description":"%s"}' \
          "$(printf '%s' "$id" | json_escape)" \
          "$(printf '%s' "$title" | json_escape)" \
          "$(printf '%s' "$kind" | json_escape)" \
          "${estimate:-0}" \
          "$(human_kb "${estimate:-0}" | json_escape)" \
          "$(printf '%s' "$command" | json_escape)" \
          "$(printf '%s' "$description" | json_escape)"
      fi
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom review${RESET}"
  printf 'Read-only personal storage checklist. Nothing is deleted.\n\n'
  printf '%-10s %-14s %-28s %s\n' "estimate" "id" "title" "next command"
  local estimate id title command description kind display
  while IFS=$'\t' read -r estimate id title command description kind; do
    [[ -z "${id:-}" ]] && continue
    if [[ "$kind" == "count" ]]; then
      display="${estimate:-0} apps"
    else
      display="$(human_kb "${estimate:-0}")"
    fi
    printf '%-10s %-14s %-28s %s\n' "$display" "$id" "$title" "$command"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

overview() {
  local plan_rows_sorted package_total toolchain_total container_total diagnostic_total protected_count snapshots app_count startup_items trash_total
  plan_rows_sorted="$(plan_rows | sort -rn | head -5)"
  package_total="$(package_total_kb)"
  toolchain_total="$(toolchain_total_kb)"
  container_total="$(container_total_kb)"
  diagnostic_total="$(diagnostic_total_kb)"
  protected_count="$(protected_present_count)"
  snapshots="$(snapshot_count)"
  app_count="$(app_bundle_count)"
  startup_items="$(startup_count)"
  trash_total="$(trash_total_kb)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    disk_json
    printf ',"summary":{"package_store_kb":%s,"package_store":"%s","toolchain_kb":%s,"toolchain":"%s","container_kb":%s,"container":"%s","diagnostic_kb":%s,"diagnostic":"%s","trash_kb":%s,"trash":"%s","protected_present":%s,"snapshot_count":%s,"app_bundle_count":%s,"startup_item_count":%s}' \
      "$package_total" \
      "$(human_kb "$package_total" | json_escape)" \
      "$toolchain_total" \
      "$(human_kb "$toolchain_total" | json_escape)" \
      "$container_total" \
      "$(human_kb "$container_total" | json_escape)" \
      "$diagnostic_total" \
      "$(human_kb "$diagnostic_total" | json_escape)" \
      "$trash_total" \
      "$(human_kb "$trash_total" | json_escape)" \
      "$protected_count" \
      "$snapshots" \
      "$app_count" \
      "$startup_items"
    printf ',"recommendations":['
    local first=1 kb id title preview_command apply_command description
    while IFS=$'\t' read -r kb id title preview_command apply_command description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","estimate_kb":%s,"estimate":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "${kb:-0}" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview_command" | json_escape)" \
        "$(printf '%s' "$apply_command" | json_escape)"
    done <<<"$plan_rows_sorted"
    printf ']}'
    printf '\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom overview${RESET}"
  printf 'Read-only dashboard. Nothing is deleted.\n\n'
  printf '%s\n' "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Summary${RESET}"
  printf '%-24s %s\n' "package stores" "$(human_kb "$package_total")"
  printf '%-24s %s\n' "toolchain caches" "$(human_kb "$toolchain_total")"
  printf '%-24s %s\n' "container storage" "$(human_kb "$container_total")"
  printf '%-24s %s\n' "diagnostics" "$(human_kb "$diagnostic_total")"
  printf '%-24s %s\n' "Trash" "$(human_kb "$trash_total")"
  printf '%-24s %s\n' "protected paths present" "$protected_count"
  printf '%-24s %s\n' "local snapshots" "$snapshots"
  printf '%-24s %s\n' "app bundles" "$app_count"
  printf '%-24s %s\n' "startup items" "$startup_items"

  printf '\n%s\n' "${BOLD}Top cleanup recommendations${RESET}"
  printf '%-10s %-18s %-32s %s\n' "estimate" "id" "title" "preview command"
  local kb id title preview_command apply_command description
  while IFS=$'\t' read -r kb id title preview_command apply_command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-18s %-32s %s\n' "$(human_kb "${kb:-0}")" "$id" "$title" "$preview_command"
  done <<<"$plan_rows_sorted"

  printf '\n%s\n' "${BOLD}Useful next commands${RESET}"
  printf 'cleanroom map\n'
  printf 'cleanroom snapshot\n'
  printf 'cleanroom diff\n'
  printf 'cleanroom state\n'
  printf 'cleanroom permissions\n'
  printf 'cleanroom review\n'
  printf 'cleanroom plan\n'
  printf 'cleanroom system-data\n'
  printf 'cleanroom brokenlinks --limit 50\n'
  printf 'cleanroom quarantine --limit 50\n'
  printf 'cleanroom documents ~/Documents --limit 50\n'
  printf 'cleanroom large ~/Documents --min-mb 250 --limit 50\n'
  printf 'cleanroom downloads --days 30 --limit 50\n'
  printf 'cleanroom venvs --days 30 --limit 50\n'
  printf 'cleanroom appdata --limit 30\n'
  printf 'cleanroom uninstallers --limit 50\n'
  printf 'cleanroom libraries\n'
  printf 'cleanroom trash\n'
  printf 'cleanroom startup\n'
  printf 'cleanroom loginitems\n'
  printf 'cleanroom packages\n'
  printf 'cleanroom receipts --limit 50\n'
  printf 'cleanroom homebrew\n'
  printf 'cleanroom toolchains\n'
  printf 'cleanroom updaters\n'
  printf 'cleanroom containers\n'
  printf 'cleanroom cloud\n'
  printf 'cleanroom cloudfiles-fast --min-mb 250 --limit 50\n'
  printf 'cleanroom personal\n'
  printf 'cleanroom communications\n'
  printf 'cleanroom browsercaches\n'
  printf 'cleanroom diagnostics\n'
  printf 'cleanroom protect\n'
}

dashboard() {
  local protected_count
  protected_count="$(protected_present_count)"

  if [[ "$JSON" -eq 1 ]]; then
    local cards rows first=1 total=0 kb id title value detail
    cards="$(dashboard_card_rows)"
    while IFS=$'\t' read -r kb id title value detail; do
      [[ -z "${id:-}" ]] && continue
      total=$((total + ${kb:-0}))
    done <<<"$cards"
    printf '{'
    disk_json
    printf ',"summary":{"protected_present":%s,"safe_mode":true,"deep_scan_required":false,"reclaimable_kb":%s,"reclaimable":"%s"}' \
      "$protected_count" \
      "$total" \
      "$(human_kb "$total" | json_escape)"
    printf ',"cards":['
    while IFS=$'\t' read -r kb id title value detail; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","estimate_kb":%s,"value":"%s","detail":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "${kb:-0}" \
        "$(printf '%s' "$value" | json_escape)" \
        "$(printf '%s' "$detail" | json_escape)"
    done <<<"$cards"
    printf ']'
    printf '}\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom dashboard${RESET}"
  printf 'Fast read-only desktop summary. Nothing is deleted.\n\n'
  printf '%s\n' "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Safety${RESET}"
  printf '%-24s %s\n' "protected paths present" "$protected_count"
  printf '%-24s %s\n' "safe mode" "on"
  printf '%-24s %s\n' "reclaimable estimate" "run scan"
}

dashboard_card_rows() {
  local cache app_data media cloud apps system
  local cache_value cache_detail app_data_value app_data_detail media_value media_detail cloud_value cloud_detail apps_value apps_detail system_value system_detail
  cache="$(paths_present_count "~/.cache" "~/Library/Logs" "~/.npm/_cacache" "~/.yarn/cache" "~/Library/pnpm/store")"
  if [[ "$cache" -gt 0 ]]; then
    cache_value="Review"
    cache_detail="Cache locations found; open Caches for a focused review."
  else
    cache_value="Clear"
    cache_detail="No common cache locations found."
  fi

  app_data="$(paths_present_count "~/Library/Application Support" "~/Library/Containers" "~/Library/Group Containers" "~/Library/HTTPStorages" "~/Library/Saved Application State" "~/Library/WebKit")"
  if [[ "$app_data" -gt 0 ]]; then
    app_data_value="Review"
    app_data_detail="App support and container locations found; open App Data for a focused review."
  else
    app_data_value="Clear"
    app_data_detail="No common app data locations found."
  fi

  media="$(paths_present_count "~/Pictures/Photos Library.photoslibrary" "~/Music/Music Library.musiclibrary" "~/Music/iTunes" "~/Movies/TV Library.tvlibrary" "~/Movies/iMovie Library.imovielibrary" "~/Music/GarageBand" "~/Music/Logic")"
  if [[ "$media" -gt 0 ]]; then
    media_value="Protected"
    media_detail="Media libraries found. Review them in their owning apps or Finder after backup."
  else
    media_value="Clear"
    media_detail="No common media libraries found."
  fi

  cloud="$(paths_present_count "~/Library/Mobile Documents" "~/Library/CloudStorage" "~/Dropbox" "~/Google Drive" "~/OneDrive" "~/Box" "~/Sync")"
  if [[ "$cloud" -gt 0 ]]; then
    cloud_value="Review"
    cloud_detail="Cloud-sync locations found. Review local files without deleting synced data."
  else
    cloud_value="Clear"
    cloud_detail="No common cloud-sync locations found."
  fi

  apps="$(paths_present_count "/Applications" "~/Applications")"
  if [[ "$apps" -gt 0 ]]; then
    apps_value="Review"
    apps_detail="Application folders found; open Apps for a focused review."
  else
    apps_value="Clear"
    apps_detail="No application folders found."
  fi

  system="$(paths_present_count "~/Library" "~/Library/Developer" "~/Library/Application Support/MobileSync/Backup" "~/Library/Containers" "~/Library/Group Containers" "~/Library/Logs")"
  if [[ "$system" -gt 0 ]]; then
    system_value="Review"
    system_detail="System Data buckets found; open System Data for the safe breakdown."
  else
    system_value="Clear"
    system_detail="No common System Data buckets found."
  fi

  printf '0\t%s\t%s\t%s\t%s\n' "caches" "Caches" "$cache_value" "$cache_detail"
  printf '0\t%s\t%s\t%s\t%s\n' "documents" "Documents" "Review" "Open Documents for large files and folders to review first."
  printf '0\t%s\t%s\t%s\t%s\n' "app-data" "App Data" "$app_data_value" "$app_data_detail"
  printf '0\t%s\t%s\t%s\t%s\n' "media-libraries" "Media Libraries" "$media_value" "$media_detail"
  printf '0\t%s\t%s\t%s\t%s\n' "project-dependencies" "Project Dependencies" "Review" "Open Project Dependencies for stale dependency folders."
  printf '0\t%s\t%s\t%s\t%s\n' "downloads" "Downloads" "Review" "Open Downloads for old downloadable artifacts."
  printf '0\t%s\t%s\t%s\t%s\n' "large-files" "Large Files" "Review" "Open Large Files for a focused large-file review."
  printf '0\t%s\t%s\t%s\t%s\n' "cloud-files" "Cloud Files" "$cloud_value" "$cloud_detail"
  printf '0\t%s\t%s\t%s\t%s\n' "archives" "Archives" "Review" "Open Archives for old archives and disk images."
  printf '0\t%s\t%s\t%s\t%s\n' "apps" "Apps" "$apps_value" "$apps_detail"
  printf '0\t%s\t%s\t%s\t%s\n' "developer-files" "Developer Files" "Review" "Open Developer Files for build artifacts and SDK caches."
  printf '0\t%s\t%s\t%s\t%s\n' "system-data" "System Data" "$system_value" "$system_detail"
  printf '0\t%s\t%s\t%s\t%s\n' "screenshots" "Screenshots" "Review" "Open Screenshots for old screenshots and recordings."
  printf '0\t%s\t%s\t%s\t%s\n' "trash" "Trash" "Review" "Open Trash for current Trash contents."
}

snapshots() {
  local rows
  rows="$(snapshot_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 name date_part
    while IFS=$'\t' read -r name date_part; do
      [[ -z "${name:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","date":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$date_part" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom local snapshots${RESET}"
  printf 'Review-only list. Snapshot thinning is opt-in and may not be restorable through cleanroom.\n\n'
  if ! command -v tmutil >/dev/null 2>&1; then
    printf 'tmutil is not available on this system.\n'
    return 0
  fi
  if [[ -z "$rows" ]]; then
    printf 'No local Time Machine snapshots found.\n'
    return 0
  fi
  local name date_part
  printf '%-32s %s\n' "date" "snapshot"
  while IFS=$'\t' read -r name date_part; do
    [[ -z "${name:-}" ]] && continue
    printf '%-32s %s\n' "$date_part" "$name"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-snapshots\n'
  printf 'Apply thinning with: cleanroom clean --include-snapshots --apply\n'
}

plan_rows() {
  local safe package toolchain app browsercache_total installers download_artifacts screenshots_total cleanroom_state_total metadata_total quicklook_total fontcache_total webcache_total savedstate_total projectcache_total updatercache_total devicebackup_total node venv dev diagnostics ai_workspaces ai_models containers user_trash
  safe="$(sum_existing_kb \
    "~/Library/Caches" "~/.cache" "~/.npm/_cacache" "~/.npm/_logs" "~/.npm/_npx" \
    "~/.yarn/cache" "~/.yarn/berry" "~/.gradle/caches" "~/.gradle/daemon" \
    "~/.gradle/native" "~/.gradle/workers" "~/Library/pnpm/store" \
    "~/Library/Developer/Xcode/DerivedData" "~/Library/Developer/CoreSimulator/Caches" \
    "~/Library/Caches/Homebrew" "~/Library/Logs")"
  package="$(sum_existing_kb "~/Library/pnpm/store" "~/.pnpm-store" "~/.cocoapods/repos" "~/.cargo/registry/cache")"
  toolchain="$(toolchain_total_kb)"
  app="$(app_cache_kb)"
  browsercache_total="$(browsercache_total_kb)"
  installers="$(installer_total_kb)"
  download_artifacts="$(download_artifact_total_kb)"
  screenshots_total="$(screenshot_total_kb)"
  cleanroom_state_total="$(cleanroom_state_cleanup_total_kb)"
  metadata_total="$(metadata_total_kb)"
  quicklook_total="$(quicklook_total_kb)"
  fontcache_total="$(fontcache_total_kb)"
  webcache_total="$(webcache_total_kb)"
  savedstate_total="$(savedstate_total_kb)"
  projectcache_total="$(projectcache_total_kb)"
  updatercache_total="$(updatercache_total_kb)"
  devicebackup_total="$(backup_cleanup_rows | tab_rows_total_kb)"
  node="$(stale_node_kb)"
  venv="$(stale_venv_kb)"
  dev="$(sum_existing_kb \
    "~/Library/Developer/Xcode/iOS DeviceSupport" "~/Library/Developer/Xcode/watchOS DeviceSupport" \
    "~/Library/Developer/Xcode/tvOS DeviceSupport" "~/Library/Android/sdk/ndk" \
    "~/Library/Android/sdk/system-images" "~/Library/Android/sdk/.downloadIntermediates" \
    "~/Library/Android/sdk/.temp")"
  diagnostics="$(sum_existing_kb "~/Library/DiagnosticReports" "~/Library/Application Support/CrashReporter")"
  ai_workspaces="$(ai_workspace_rows | while IFS=$'\t' read -r id app kind safety path preview apply description; do [[ "$safety" == "generated-workspace" ]] && printf '%012d\t%s\n' "$(size_kb "$path")" "$path"; done | tab_rows_total_kb)"
  ai_models="$(ai_model_rows | while IFS=$'\t' read -r id app kind safety path preview apply description; do [[ "$safety" == "downloaded-models" ]] && printf '%012d\t%s\n' "$(size_kb "$path")" "$path"; done | tab_rows_total_kb)"
  containers="$(container_total_kb)"
  user_trash="$(trash_total_kb)"

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$safe" "safe" "Default safe cleanup" "cleanroom clean" "cleanroom clean --apply --trash" "Rebuildable caches and old logs. Recommended first step."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$app" "app-caches" "Safe app cache folders" "cleanroom clean --include-app-caches" "cleanroom clean --apply --trash --include-app-caches" "Nested cache folders only; browser profiles and passwords stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$browsercache_total" "browser-caches" "Chromium/Firefox browser caches" "cleanroom browsercaches" "cleanroom clean --apply --trash --include-browser-caches" "Rebuildable browser cache folders only. Profiles, passwords, cookies, bookmarks, sessions, extensions, and settings stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$installers" "old-installers" "Old downloaded installers" "cleanroom clean --include-installers --days $DAYS" "cleanroom clean --apply --trash --include-installers --days $DAYS" "Downloaded .dmg, .pkg, .mpkg, .xip, .ipsw, and .iso files older than $DAYS days in ~/Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$download_artifacts" "download-artifacts" "Old downloadable artifacts" "cleanroom downloads --days $DAYS" "cleanroom clean --apply --trash --include-download-artifacts --days $DAYS" "Old installers, disk images, and archive files directly under ~/Downloads. Arbitrary documents and folders stay untouched."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$screenshots_total" "screenshots" "Old screenshots and screen recordings" "cleanroom screenshots --days $DAYS" "cleanroom clean --apply --trash --include-screenshots --days $DAYS" "Known screenshot and screen recording files older than $DAYS days under Desktop, Downloads, and Documents."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$cleanroom_state_total" "cleanroom-state" "Old cleanroom-created state" "cleanroom state" "cleanroom clean --apply --include-cleanroom-state --days $DAYS" "Old cleanroom run logs, storage snapshots, and recoverable Trash folders created by previous --trash runs."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$metadata_total" "metadata" "Filesystem metadata clutter" "cleanroom metadata" "cleanroom metadata --apply --trash" ".DS_Store, AppleDouble, Thumbs.db, Desktop.ini, and similar clutter under Desktop, Documents, and Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$quicklook_total" "quicklook" "Quick Look caches" "cleanroom quicklook" "cleanroom clean --apply --trash --include-quicklook" "Rebuildable Quick Look thumbnail and preview caches."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$fontcache_total" "font-caches" "Font cache databases" "cleanroom fontcaches" "cleanroom clean --apply --trash --include-font-caches" "Rebuildable Apple Type Services and font registry caches. Actual font files stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$webcache_total" "web-caches" "Safari/WebKit caches" "cleanroom webcaches" "cleanroom clean --apply --trash --include-web-caches" "Rebuildable Safari and WebKit cache folders. Browser history, cookies, bookmarks, passwords, website data, and profiles stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$savedstate_total" "saved-state" "Saved Application State" "cleanroom savedstate" "cleanroom clean --apply --trash --include-saved-state" "Rebuildable app window/session restoration state. Documents and app profiles stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$projectcache_total" "project-caches" "Project cache artifacts" "cleanroom projectcaches" "cleanroom clean --apply --trash --include-project-caches" "Rebuildable project caches such as __pycache__, pytest, mypy, ruff, tox, nox, and coverage artifacts."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$updatercache_total" "updater-caches" "App updater caches" "cleanroom updaters" "cleanroom clean --apply --trash --include-updater-caches" "Rebuildable Sparkle/Squirrel updater cache and staging data. Apps and profiles stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$devicebackup_total" "device-backups" "Old local iPhone/iPad backups" "cleanroom backups" "cleanroom clean --include-device-backups --days $DAYS --apply --trash" "High-impact opt-in cleanup for direct MobileSync backup folders older than $DAYS days. Confirm another backup exists first."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$package" "package-stores" "Package-manager stores" "cleanroom clean --include-package-stores" "cleanroom clean --apply --trash --include-package-stores" "Rebuildable package stores such as pnpm, CocoaPods, Cargo, and Gradle-related stores."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$toolchain" "toolchains" "Language toolchain caches" "cleanroom toolchains" "cleanroom clean --apply --trash --include-toolchains" "Rebuildable caches for Go, Python, SwiftPM, Maven, Composer, RubyGems, Bundler, uv, and Poetry."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$node" "node-stale" "Stale node_modules" "cleanroom clean --include-node-stale --days $DAYS" "cleanroom clean --apply --trash --include-node-stale --days $DAYS" "node_modules older than $DAYS days under Desktop, Documents, and Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$venv" "venv-stale" "Stale Python virtualenvs" "cleanroom venvs --days $DAYS" "cleanroom clean --apply --trash --include-venv-stale --days $DAYS" "Python virtualenv folders older than $DAYS days under Desktop, Documents, and Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$dev" "dev-heavy" "Heavy SDK and simulator artifacts" "cleanroom clean --include-dev-heavy" "cleanroom clean --apply --trash --include-dev-heavy" "Opt-in cleanup that may require re-downloading SDKs or resetting simulator app data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$diagnostics" "diagnostics" "Old diagnostic reports" "cleanroom diagnostics" "cleanroom clean --apply --trash --include-diagnostics --days $DAYS" "Opt-in cleanup for user diagnostic reports and CrashReporter files older than $DAYS days."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$ai_workspaces" "ai-workspaces" "Generated AI workspace state" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Generated AI-agent recordings, scratch, brain/memory, implicit data, and conversation caches where known."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$ai_models" "ai-models" "Downloaded local AI models" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-models" "Large local model stores and backend extensions that may need to be downloaded again."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$containers" "containers" "Container VM disks and stores" "cleanroom containers" "cleanroom clean --apply --trash --include-containers" "High-impact opt-in cleanup that can remove local containers, images, and volumes."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$user_trash" "user-trash" "Current user Trash" "cleanroom trash" "cleanroom clean --include-user-trash --apply" "Already-deleted user Trash contents. Emptying Trash is explicit and irreversible."
}

plan() {
  local rows
  rows="$(plan_rows | sort -rn)"
  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title preview_command apply_command description
    while IFS=$'\t' read -r kb id title preview_command apply_command description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","estimate_kb":%s,"estimate":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "${kb:-0}" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview_command" | json_escape)" \
        "$(printf '%s' "$apply_command" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom plan${RESET}"
  printf 'Commands shown are dry-runs. Add --apply --trash only after reviewing output.\n\n'
  printf '%-10s %-18s %-32s %s\n' "estimate" "id" "title" "preview command"
  while IFS=$'\t' read -r kb id title preview_command apply_command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-18s %-32s %s\n' "$(human_kb "${kb:-0}")" "$id" "$title" "$preview_command"
    printf '  apply: %s\n' "$apply_command"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

