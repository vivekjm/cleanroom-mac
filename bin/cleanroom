clean_node_stale() {
  [[ "$INCLUDE_NODE_STALE" -eq 1 ]] || return 0
  log "${BOLD}Stale node_modules older than ${DAYS} days${RESET}"
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print 2>/dev/null |
      while IFS= read -r path; do
        run_rm "$path"
      done
  done
  return 0
}

scan() {
  local paths=()
  local candidate
  while IFS= read -r candidate; do paths+=("$candidate"); done < <(candidate_paths)
  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    disk_json
    printf ',"candidates":['
    local first=1
    local path expanded kb
    for path in "${paths[@]}"; do
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$path")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s}' "$(printf '%s' "$expanded" | json_escape)" "$kb"
    done
    printf ']}'
    printf '\n'
    return 0
  fi

  log "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Common cleanup candidates${RESET}"
  local path
  for path in "${paths[@]}"; do print_size "$path"; done

  printf '\n%s\n' "${BOLD}Largest home folders${RESET}"
  du -x -d 1 -h "$HOME" 2>/dev/null | sort -h | tail -25 || true

  printf '\n%s\n' "${BOLD}Largest user files over 500MB${RESET}"
  find "$HOME" -xdev -type f -size +500M -print0 2>/dev/null |
    xargs -0 du -h 2>/dev/null | sort -h | tail -30 || true
}

large_rows() {
  local root="$1"
  find "$root" -xdev -type f -size "+${MIN_MB}M" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\n' "$(size_kb "$path")" "$path"
    done |
    sort -rn |
    head -n "$LIMIT"
}

large() {
  local root
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    root="$(expand_path "${PATH_ARGS[0]}")"
  else
    root="$HOME"
  fi
  [[ -e "$root" ]] || die "large path not found: $root"

  local rows
  rows="$(large_rows "$root")"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb kb_num path
    while IFS=$'\t' read -r kb path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom large files${RESET}"
  printf 'Review-only list. cleanroom does not delete these files.\n'
  printf 'Path: %s\n' "$root"
  printf 'Minimum: %sMB  Limit: %s\n\n' "$MIN_MB" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No files found over %sMB.\n' "$MIN_MB"
    return 0
  fi
  local kb path
  while IFS=$'\t' read -r kb path; do
    [[ -z "${path:-}" ]] && continue
    printf '%8s  %s\n' "$(human_kb "$kb")" "$path"
  done <<<"$rows"
}

path_mtime_epoch() {
  local path="$1" epoch
  epoch="$(stat -f '%m' "$path" 2>/dev/null || stat -c '%Y' "$path" 2>/dev/null || true)"
  [[ "$epoch" =~ ^[0-9]+$ ]] || epoch=0
  printf '%s\n' "$epoch"
}

node_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "$HOME/Documents"
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Downloads"
  fi
}

node_rows() {
  local now root path kb epoch age_days
  now="$(date '+%s')"
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        kb="$(size_kb "$path")"
        epoch="$(path_mtime_epoch "$path")"
        if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
          age_days=$(((now - epoch) / 86400))
        else
          age_days=0
        fi
        printf '%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path"
      done
  done < <(node_roots) | sort -rn | head -n "$LIMIT"
}

nodes() {
  local rows
  rows="$(node_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path kb_num
    while IFS=$'\t' read -r kb epoch age_days path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"age_days":%s,"preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "${age_days:-0}" \
        "$(printf 'cleanroom clean --include-node-stale --days %s' "$DAYS" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-node-stale --days %s' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom stale node_modules${RESET}"
  printf 'Review-only list. cleanroom only removes these with --include-node-stale and --apply.\n'
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf 'Path: %s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf 'Paths: ~/Documents, ~/Desktop, ~/Downloads\n'
  fi
  printf 'Older than: %s days  Limit: %s\n\n' "$DAYS" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No stale node_modules folders found.\n'
    return 0
  fi
  printf '%-10s %-9s %s\n' "size" "age" "path"
  local kb epoch age_days path
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$path"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-node-stale --days %s\n' "$DAYS"
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-node-stale --days %s\n' "$DAYS"
}

duplicate_candidates() {
  local root="$1"
  find "$root" -xdev -type f -size "+${MIN_MB}M" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      local hash kb
      hash="$(shasum -a 256 "$path" 2>/dev/null | awk '{print $1}' || true)"
      [[ -n "$hash" ]] || continue
      kb="$(size_kb "$path")"
      printf '%s\t%012d\t%s\n' "$hash" "$kb" "$path"
    done |
    sort -k1,1 -k2,2nr
}

duplicates_json_group() {
  local hash="$1"
  local size_kb="$2"
  shift 2
  local count="$#"
  [[ "$count" -gt 1 ]] || return 0
  local reclaim_kb
  reclaim_kb=$((size_kb * (count - 1)))
  printf '{"hash":"%s","size_kb":%s,"size":"%s","count":%s,"potential_reclaim_kb":%s,"potential_reclaim":"%s","paths":[' \
    "$(printf '%s' "$hash" | json_escape)" \
    "$size_kb" \
    "$(human_kb "$size_kb" | json_escape)" \
    "$count" \
    "$reclaim_kb" \
    "$(human_kb "$reclaim_kb" | json_escape)"
  local first=1 path
  for path in "$@"; do
    [[ "$first" -eq 0 ]] && printf ','
    first=0
    printf '"%s"' "$(printf '%s' "$path" | json_escape)"
  done
  printf ']}'
}

duplicates_text_group() {
  local hash="$1"
  local size_kb="$2"
  shift 2
  local count="$#"
  [[ "$count" -gt 1 ]] || return 0
  local reclaim_kb path
  reclaim_kb=$((size_kb * (count - 1)))
  printf 'duplicate group  count=%s  each=%s  potential reclaim=%s\n' "$count" "$(human_kb "$size_kb")" "$(human_kb "$reclaim_kb")"
  printf '  hash: %s\n' "$hash"
  for path in "$@"; do
    printf '  %s\n' "$path"
  done
  printf '\n'
}

duplicates() {
  local root
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    root="$(expand_path "${PATH_ARGS[0]}")"
  else
    root="$HOME"
  fi
  [[ -e "$root" ]] || die "duplicates path not found: $root"
  command -v shasum >/dev/null 2>&1 || die "duplicates requires shasum"

  local rows_file
  rows_file="$(mktemp)"
  duplicate_candidates "$root" >"$rows_file"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
  else
    printf '%s\n' "${BOLD}cleanroom duplicate files${RESET}"
    printf 'Review-only list. cleanroom does not delete duplicate files.\n'
    printf 'Path: %s\n' "$root"
    printf 'Minimum: %sMB  Limit: %s groups\n\n' "$MIN_MB" "$LIMIT"
  fi

  local current_hash="" current_size=0 hash kb path emitted=0 json_first=1
  local group_paths=()

  flush_duplicate_group() {
    [[ -n "$current_hash" ]] || return 0
    [[ "${#group_paths[@]}" -gt 1 ]] || return 0
    [[ "$emitted" -lt "$LIMIT" ]] || return 0
    if [[ "$JSON" -eq 1 ]]; then
      [[ "$json_first" -eq 0 ]] && printf ','
      json_first=0
      duplicates_json_group "$current_hash" "$current_size" "${group_paths[@]}"
    else
      duplicates_text_group "$current_hash" "$current_size" "${group_paths[@]}"
    fi
    emitted=$((emitted + 1))
  }

  while IFS=$'\t' read -r hash kb path; do
    [[ -z "${hash:-}" || -z "${path:-}" ]] && continue
    if [[ -n "$current_hash" && "$hash" != "$current_hash" ]]; then
      flush_duplicate_group
      group_paths=()
    fi
    current_hash="$hash"
    current_size="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
    group_paths+=("$path")
  done <"$rows_file"
  flush_duplicate_group

  rm -f "$rows_file"
  if [[ "$JSON" -eq 1 ]]; then
    printf ']\n'
  elif [[ "$emitted" -eq 0 ]]; then
    printf 'No exact duplicates found over %sMB.\n' "$MIN_MB"
  fi
}

app_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "/Applications"
    printf '%s\n' "$HOME/Applications"
  fi
}

app_rows() {
  local root="$1"
  [[ -d "$root" ]] || return 0
  find "$root" -maxdepth 2 -type d -name '*.app' -prune -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\t%s\n' "$(size_kb "$path")" "$(basename "$path" .app)" "$path"
    done
}

apps() {
  local rows
  rows="$(
    while IFS= read -r root; do
      app_rows "$root"
    done < <(app_roots) | sort -rn | head -n "$LIMIT"
  )"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb kb_num name path
    while IFS=$'\t' read -r kb name path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom app bundles${RESET}"
  printf 'Review-only list. cleanroom does not uninstall apps.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No app bundles found.\n'
    return 0
  fi
  local kb name path
  while IFS=$'\t' read -r kb name path; do
    [[ -z "${path:-}" ]] && continue
    printf '%8s  %s\n  %s\n' "$(human_kb "$kb")" "$name" "$path"
  done <<<"$rows"
}

plist_value() {
  local file="$1"
  local key="$2"
  plutil -extract "$key" raw -o - "$file" 2>/dev/null || true
}

startup_program() {
  local plist="$1" program
  program="$(plist_value "$plist" "Program")"
  if [[ -z "$program" ]]; then
    program="$(plutil -p "$plist" 2>/dev/null | awk '
      /"ProgramArguments"/ {in_args=1; next}
      in_args && /\]/ {exit}
      in_args && /=>/ {
        sub(/^[[:space:]]*[0-9]+ => "/, "")
        sub(/"$/, "")
        print
        exit
      }
    ' || true)"
  fi
  printf '%s\n' "$program"
}

startup_rows() {
  local entries=(
    "user	LaunchAgent	$HOME/Library/LaunchAgents"
    "local	LaunchAgent	/Library/LaunchAgents"
    "local	LaunchDaemon	/Library/LaunchDaemons"
  )
  local entry scope type dir plist label disabled status program
  for entry in "${entries[@]}"; do
    IFS=$'\t' read -r scope type dir <<<"$entry"
    [[ -d "$dir" ]] || continue
    find "$dir" -maxdepth 1 -type f -name '*.plist' -print0 2>/dev/null |
      while IFS= read -r -d '' plist; do
        label="$(plist_value "$plist" "Label")"
        [[ -n "$label" ]] || label="$(basename "$plist" .plist)"
        disabled="$(plist_value "$plist" "Disabled")"
        if [[ "$disabled" == "true" ]]; then
          status="disabled"
        else
          status="enabled"
        fi
        program="$(startup_program "$plist")"
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$scope" "$type" "$status" "$label" "$program" "$plist"
      done
  done | awk -v limit="$LIMIT" 'NR <= limit'
}

startup_count() {
  startup_rows | awk 'END {print NR + 0}'
}

startup() {
  local rows
  rows="$(startup_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 scope type status label program plist
    while IFS=$'\t' read -r scope type status label program plist; do
      [[ -z "${plist:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"scope":"%s","type":"%s","status":"%s","label":"%s","program":"%s","path":"%s"}' \
        "$(printf '%s' "$scope" | json_escape)" \
        "$(printf '%s' "$type" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$label" | json_escape)" \
        "$(printf '%s' "$program" | json_escape)" \
        "$(printf '%s' "$plist" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom startup items${RESET}"
  printf 'Review-only list. cleanroom does not unload, disable, or remove startup items.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No LaunchAgents or LaunchDaemons found.\n'
    return 0
  fi
  printf '%-8s %-13s %-9s %-36s %s\n' "scope" "type" "status" "label" "path"
  local scope type status label program plist
  while IFS=$'\t' read -r scope type status label program plist; do
    [[ -z "${plist:-}" ]] && continue
    printf '%-8s %-13s %-9s %-36s %s\n' "$scope" "$type" "$status" "$label" "$plist"
    [[ -n "$program" ]] && printf '  program: %s\n' "$program"
  done <<<"$rows"
  printf '\nReview login items in System Settings > General > Login Items.\n'
}

package_rows() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "npm-cache" "npm" "~/.npm/_cacache; ~/.npm/_logs; ~/.npm/_npx" "default" "cleanroom clean" "cleanroom clean --apply --trash"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "yarn-cache" "yarn" "~/.yarn/cache; ~/.yarn/berry" "default" "cleanroom clean" "cleanroom clean --apply --trash"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "pnpm-store" "pnpm" "~/Library/pnpm/store; ~/.pnpm-store" "package-stores" "cleanroom clean --include-package-stores" "cleanroom clean --apply --trash --include-package-stores"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "gradle-cache" "gradle" "~/.gradle/caches; ~/.gradle/daemon; ~/.gradle/native; ~/.gradle/workers; ~/.gradle-tangibly-release/caches; ~/.gradle-tangibly-release/wrapper; ~/.gradle-tangibly-release/native" "package-stores" "cleanroom clean --include-package-stores" "cleanroom clean --apply --trash --include-package-stores"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "cocoapods-repos" "cocoapods" "~/.cocoapods/repos" "package-stores" "cleanroom clean --include-package-stores" "cleanroom clean --apply --trash --include-package-stores"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "cargo-cache" "cargo" "~/.cargo/registry/cache" "package-stores" "cleanroom clean --include-package-stores" "cleanroom clean --apply --trash --include-package-stores"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-cache" "homebrew" "~/Library/Caches/Homebrew" "default" "cleanroom clean" "cleanroom clean --apply --trash"
}

cache_rows() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "user-caches" "default" "~/Library/Caches; ~/.cache" "cleanroom clean" "cleanroom clean --apply --trash" "Standard user cache folders. Recreated automatically by apps."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "old-logs" "default" "~/Library/Logs" "cleanroom clean" "cleanroom clean --apply --trash" "User log files. Apply removes only log files older than seven days."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "npm-cache" "default" "~/.npm/_cacache; ~/.npm/_logs; ~/.npm/_npx" "cleanroom clean" "cleanroom clean --apply --trash" "npm caches, temporary npx installs, and npm logs."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "yarn-cache" "default" "~/.yarn/cache; ~/.yarn/berry" "cleanroom clean" "cleanroom clean --apply --trash" "Yarn package caches and Berry state."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "gradle-cache" "default" "~/.gradle/caches; ~/.gradle/daemon; ~/.gradle/native; ~/.gradle/workers" "cleanroom clean" "cleanroom clean --apply --trash" "Gradle caches, daemons, native caches, and worker state."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "pnpm-store" "default" "~/Library/pnpm/store" "cleanroom clean" "cleanroom clean --apply --trash" "Default pnpm content-addressable package store."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "xcode-derived-data" "default" "~/Library/Developer/Xcode/DerivedData" "cleanroom clean" "cleanroom clean --apply --trash" "Xcode build intermediates and indexes."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "simulator-caches" "default" "~/Library/Developer/CoreSimulator/Caches" "cleanroom clean" "cleanroom clean --apply --trash" "CoreSimulator rebuildable cache data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-cache" "default" "~/Library/Caches/Homebrew" "cleanroom clean" "cleanroom clean --apply --trash" "Homebrew download and build caches."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "safe-app-caches" "app-caches" "known nested app cache folders" "cleanroom clean --include-app-caches" "cleanroom clean --apply --trash --include-app-caches" "Nested cache folders for apps such as Chrome, Brave, VS Code, Cursor, Slack, Comet, and Trae. Profiles, passwords, cookies, bookmarks, and settings stay protected."
}

paths_field_kb() {
  local field="$1"
  local total=0 path kb
  while IFS= read -r path; do
    path="${path#"${path%%[![:space:]]*}"}"
    path="${path%"${path##*[![:space:]]}"}"
    [[ -z "$path" ]] && continue
    kb="$(size_kb "$path")"
    total=$((total + kb))
  done < <(printf '%s\n' "$field" | tr ';' '\n')
  printf '%s\n' "$total"
}

caches() {
  local rows
  rows="$(cache_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id category paths preview apply description kb
    while IFS=$'\t' read -r id category paths preview apply description; do
      [[ -z "${id:-}" ]] && continue
      if [[ "$id" == "safe-app-caches" ]]; then
        kb="$(app_cache_kb)"
      else
        kb="$(paths_field_kb "$paths")"
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","category":"%s","paths":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom caches${RESET}"
  printf 'Review-only inventory. Use the preview command before applying cleanup.\n\n'
  printf '%-10s %-20s %-12s %s\n' "size" "id" "category" "preview command"
  local id category paths preview apply description kb
  while IFS=$'\t' read -r id category paths preview apply description; do
    [[ -z "${id:-}" ]] && continue
    if [[ "$id" == "safe-app-caches" ]]; then
      kb="$(app_cache_kb)"
    else
      kb="$(paths_field_kb "$paths")"
    fi
    printf '%-10s %-20s %-12s %s\n' "$(human_kb "$kb")" "$id" "$category" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

packages() {
  local rows
  rows="$(package_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id manager paths category preview apply kb
    while IFS=$'\t' read -r id manager paths category preview apply; do
      [[ -z "${id:-}" ]] && continue
      kb="$(paths_field_kb "$paths")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","manager":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$manager" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom package stores${RESET}"
  printf 'Review-only inventory. Use the preview command before applying cleanup.\n\n'
  printf '%-10s %-18s %-14s %-10s %s\n' "size" "id" "manager" "category" "preview command"
  local id manager paths category preview apply kb
  while IFS=$'\t' read -r id manager paths category preview apply; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%-10s %-18s %-14s %-10s %s\n' "$(human_kb "$kb")" "$id" "$manager" "$category" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
  done <<<"$rows"
}

package_total_kb() {
  local id manager paths category preview apply total=0 kb
  while IFS=$'\t' read -r id manager paths category preview apply; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    total=$((total + kb))
  done < <(package_rows)
  printf '%s\n' "$total"
}

snapshot_rows() {
  command -v tmutil >/dev/null 2>&1 || return 0
  tmutil listlocalsnapshots / 2>/dev/null |
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local name date_part
      name="${line##* }"
      [[ "$name" == com.apple.* ]] || continue
      date_part="${name#com.apple.TimeMachine.}"
      printf '%s\t%s\n' "$name" "$date_part"
    done
}

snapshot_count() {
  snapshot_rows | awk 'END {print NR + 0}'
}

protected_present_count() {
  local file id type path reason expanded count=0
  file="$(protected_file)"
  [[ -f "$file" ]] || { printf '0\n'; return 0; }
  while IFS=$'\t' read -r id type path reason; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] && count=$((count + 1))
  done < <(tail -n +2 "$file")
  printf '%s\n' "$count"
}

app_bundle_count() {
  local total=0 root count
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    count="$(app_rows "$root" | awk 'END {print NR + 0}')"
    total=$((total + count))
  done < <(app_roots)
  printf '%s\n' "$total"
}

overview() {
  local plan_rows_sorted package_total protected_count snapshots app_count startup_items
  plan_rows_sorted="$(plan_rows | sort -rn | head -5)"
  package_total="$(package_total_kb)"
  protected_count="$(protected_present_count)"
  snapshots="$(snapshot_count)"
  app_count="$(app_bundle_count)"
  startup_items="$(startup_count)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    disk_json
    printf ',"summary":{"package_store_kb":%s,"package_store":"%s","protected_present":%s,"snapshot_count":%s,"app_bundle_count":%s,"startup_item_count":%s}' \
      "$package_total" \
      "$(human_kb "$package_total" | json_escape)" \
      "$protected_count" \
      "$snapshots" \
      "$app_count" \
      "$startup_items"
    printf ',"recommendations":['
    local first=1 kb id title preview_command apply_command description
    while IFS=$'\t' read -r kb id title preview_command apply_command description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","estimate_kb":%s,"estimate":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "${kb:-0}" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview_command" | json_escape)" \
        "$(printf '%s' "$apply_command" | json_escape)"
    done <<<"$plan_rows_sorted"
    printf ']}'
    printf '\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom overview${RESET}"
  printf 'Read-only dashboard. Nothing is deleted.\n\n'
  printf '%s\n' "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Summary${RESET}"
  printf '%-24s %s\n' "package stores" "$(human_kb "$package_total")"
  printf '%-24s %s\n' "protected paths present" "$protected_count"
  printf '%-24s %s\n' "local snapshots" "$snapshots"
  printf '%-24s %s\n' "app bundles" "$app_count"
  printf '%-24s %s\n' "startup items" "$startup_items"

  printf '\n%s\n' "${BOLD}Top cleanup recommendations${RESET}"
  printf '%-10s %-18s %-32s %s\n' "estimate" "id" "title" "preview command"
  local kb id title preview_command apply_command description
  while IFS=$'\t' read -r kb id title preview_command apply_command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-18s %-32s %s\n' "$(human_kb "${kb:-0}")" "$id" "$title" "$preview_command"
  done <<<"$plan_rows_sorted"

  printf '\n%s\n' "${BOLD}Useful next commands${RESET}"
  printf 'cleanroom plan\n'
  printf 'cleanroom large ~/Documents --min-mb 250 --limit 50\n'
  printf 'cleanroom startup\n'
  printf 'cleanroom packages\n'
  printf 'cleanroom protect\n'
}

snapshots() {
  local rows
  rows="$(snapshot_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 name date_part
    while IFS=$'\t' read -r name date_part; do
      [[ -z "${name:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","date":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$date_part" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom local snapshots${RESET}"
  printf 'Review-only list. Snapshot thinning is opt-in and may not be restorable through cleanroom.\n\n'
  if ! command -v tmutil >/dev/null 2>&1; then
    printf 'tmutil is not available on this system.\n'
    return 0
  fi
  if [[ -z "$rows" ]]; then
    printf 'No local Time Machine snapshots found.\n'
    return 0
  fi
  local name date_part
  printf '%-32s %s\n' "date" "snapshot"
  while IFS=$'\t' read -r name date_part; do
    [[ -z "${name:-}" ]] && continue
    printf '%-32s %s\n' "$date_part" "$name"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-snapshots\n'
  printf 'Apply thinning with: cleanroom clean --include-snapshots --apply\n'
}

plan_rows() {
  local safe package app node dev ai_workspaces ai_models containers
  safe="$(sum_existing_kb \
    "~/Library/Caches" "~/.cache" "~/.npm/_cacache" "~/.npm/_logs" "~/.npm/_npx" \
    "~/.yarn/cache" "~/.yarn/berry" "~/.gradle/caches" "~/.gradle/daemon" \
    "~/.gradle/native" "~/.gradle/workers" "~/Library/pnpm/store" \
    "~/Library/Developer/Xcode/DerivedData" "~/Library/Developer/CoreSimulator/Caches" \
    "~/Library/Caches/Homebrew" "~/Library/Logs")"
  package="$(sum_existing_kb "~/Library/pnpm/store" "~/.pnpm-store" "~/.cocoapods/repos" "~/.cargo/registry/cache")"
  app="$(app_cache_kb)"
  node="$(stale_node_kb)"
  dev="$(sum_existing_kb \
    "~/Library/Developer/Xcode/iOS DeviceSupport" "~/Library/Developer/Xcode/watchOS DeviceSupport" \
    "~/Library/Developer/Xcode/tvOS DeviceSupport" "~/Library/Android/sdk/ndk" \
    "~/Library/Android/sdk/system-images" "~/Library/Android/sdk/.downloadIntermediates" \
    "~/Library/Android/sdk/.temp")"
  ai_workspaces="$(sum_existing_kb "~/.gemini")"
  ai_models="$(sum_existing_kb "~/.lmstudio/models" "~/.lmstudio/extensions/backends" "~/.ollama/models" "~/.cache/huggingface/hub" "~/.cache/modelscope" "~/.cache/torch/hub" "~/.cache/whisper")"
  containers="$(sum_existing_kb "~/.colima" "~/.lima" "~/Library/Containers/com.docker.docker/Data/vms")"

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$safe" "safe" "Default safe cleanup" "cleanroom clean" "cleanroom clean --apply --trash" "Rebuildable caches and old logs. Recommended first step."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$app" "app-caches" "Safe app cache folders" "cleanroom clean --include-app-caches" "cleanroom clean --apply --trash --include-app-caches" "Nested cache folders only; browser profiles and passwords stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$package" "package-stores" "Package-manager stores" "cleanroom clean --include-package-stores" "cleanroom clean --apply --trash --include-package-stores" "Rebuildable package stores such as pnpm, CocoaPods, Cargo, and Gradle-related stores."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$node" "node-stale" "Stale node_modules" "cleanroom clean --include-node-stale --days $DAYS" "cleanroom clean --apply --trash --include-node-stale --days $DAYS" "node_modules older than $DAYS days under Desktop, Documents, and Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$dev" "dev-heavy" "Heavy SDK and simulator artifacts" "cleanroom clean --include-dev-heavy" "cleanroom clean --apply --trash --include-dev-heavy" "Opt-in cleanup that may require re-downloading SDKs or resetting simulator app data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$ai_workspaces" "ai-workspaces" "Generated AI workspace state" "cleanroom clean --include-ai-workspaces" "cleanroom clean --apply --trash --include-ai-workspaces" "Generated recordings, scratch, brain, implicit data, and conversation caches where known."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$ai_models" "ai-models" "Downloaded local AI models" "cleanroom clean --include-ai-models" "cleanroom clean --apply --trash --include-ai-models" "Large model stores and backend extensions that may need to be downloaded again."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$containers" "containers" "Container VM disks" "cleanroom clean --include-containers" "cleanroom clean --apply --trash --include-containers" "High-impact opt-in cleanup that can remove local containers, images, and volumes."
}

plan() {
  local rows
  rows="$(plan_rows | sort -rn)"
  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title preview_command apply_command description
    while IFS=$'\t' read -r kb id title preview_command apply_command description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","estimate_kb":%s,"estimate":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "${kb:-0}" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview_command" | json_escape)" \
        "$(printf '%s' "$apply_command" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom plan${RESET}"
  printf 'Commands shown are dry-runs. Add --apply --trash only after reviewing output.\n\n'
  printf '%-10s %-18s %-32s %s\n' "estimate" "id" "title" "preview command"
  while IFS=$'\t' read -r kb id title preview_command apply_command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-18s %-32s %s\n' "$(human_kb "${kb:-0}")" "$id" "$title" "$preview_command"
    printf '  apply: %s\n' "$apply_command"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

report_body() {
  local now
  now="$(date '+%Y-%m-%d %H:%M:%S %Z')"
  printf '# cleanroom report\n\n'
  printf '%s\n' "- Generated: $now"
  printf '%s\n\n' "- Version: $VERSION"

  printf '## Disk\n\n```text\n'
  disk_line
  printf '```\n\n'

  printf '## Cleanup Candidates\n\n'
  printf '| Size | Path |\n| ---: | --- |\n'
  local path kb
  while IFS= read -r path; do
    kb="$(size_kb "$path")"
    printf '| %s | `%s` |\n' "$(human_kb "$kb")" "$(expand_path "$path")"
  done < <(report_candidate_paths)

  printf '\n## Largest Cleanup Candidates\n\n```text\n'
  while IFS= read -r path; do
    kb="$(size_kb "$path")"
    printf '%012d\t%s\t%s\n' "$kb" "$(human_kb "$kb")" "$(expand_path "$path")"
  done < <(report_candidate_paths) | sort -n | tail -20 | awk -F '\t' '{printf "%8s  %s\n", $2, $3}'
  printf '```\n\n'

  printf 'Broad personal folders such as `~/Documents`, `~/Desktop`, `~/Downloads`, and `~/Library/Application Support` are intentionally not recursively measured in this quick report. Run `cleanroom scan` when you want the heavier full view.\n\n'

  printf '## Large File Hints Over 500MB\n\n```text\n'
  if command -v mdfind >/dev/null 2>&1; then
    mdfind -onlyin "$HOME" 'kMDItemFSSize > 524288000' 2>/dev/null |
      head -100 |
      while IFS= read -r path; do
        [[ -f "$path" ]] && print_size "$path"
      done | sort -h | tail -30 || true
  else
    printf 'Spotlight mdfind is not available on this system.\n'
  fi
  printf '```\n\n'

  printf '## Safety Notes\n\n'
  printf 'cleanroom does not delete browser profiles, password databases, Keychains, Photos, Mail, or iCloud Drive by default.\n'

  local protected_catalog
  protected_catalog="$(protected_file)"
  if [[ -f "$protected_catalog" ]]; then
    printf '\n## Protected Personal Data\n\n'
    printf '| Status | Type | Size | ID | Path |\n| --- | --- | ---: | --- | --- |\n'
    local id type protected_path reason expanded status protected_kb
    tail -n +2 "$protected_catalog" | while IFS=$'\t' read -r id type protected_path reason; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$protected_path")"
      if [[ -e "$expanded" ]]; then
        status="present"
        protected_kb="$(size_kb "$expanded")"
      else
        status="missing"
        protected_kb=0
      fi
      printf '| %s | %s | %s | `%s` | `%s` |\n' "$status" "$type" "$(human_kb "$protected_kb")" "$id" "$expanded"
    done
  fi
}

report() {
  if [[ -n "$OUTPUT_FILE" ]]; then
    report_body >"$(expand_path "$OUTPUT_FILE")"
    ok "Wrote report: $(expand_path "$OUTPUT_FILE")"
  else
    report_body
  fi
}

rules() {
  local file id category safety default opt_in paths description
  file="$(rules_file)"
  [[ -f "$file" ]] || die "Rule catalog not found."

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1
    tail -n +2 "$file" | while IFS=$'\t' read -r id category safety default opt_in paths description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","category":"%s","safety":"%s","default":%s,"opt_in":"%s","paths":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
        "$(if [[ "$default" == "yes" ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "$opt_in" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom rules${RESET}"
  printf '%-24s %-17s %-20s %-7s %-26s %s\n' "id" "category" "safety" "default" "opt-in" "paths"
  tail -n +2 "$file" | while IFS=$'\t' read -r id category safety default opt_in paths description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-24s %-17s %-20s %-7s %-26s %s\n' "$id" "$category" "$safety" "$default" "${opt_in:--}" "$paths"
  done
}

protect() {
  local file id type path reason expanded status kb
  file="$(protected_file)"
  [[ -f "$file" ]] || die "Protected path catalog not found."

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1
    tail -n +2 "$file" | while IFS=$'\t' read -r id type path reason; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      if [[ -e "$expanded" ]]; then
        status="present"
        kb="$(size_kb "$expanded")"
      else
        status="missing"
        kb=0
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","type":"%s","path":"%s","status":"%s","size_kb":%s,"size":"%s","reason":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$type" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$status" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$reason" | json_escape)"
    done
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom protected data audit${RESET}"
  printf 'These locations are treated as personal state and are not removed wholesale by cleanroom.\n\n'
  printf '%-10s %-18s %-8s %-18s %s\n' "status" "type" "size" "id" "path"
  tail -n +2 "$file" | while IFS=$'\t' read -r id type path reason; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    if [[ -e "$expanded" ]]; then
      status="present"
      kb="$(size_kb "$expanded")"
    else
      status="missing"
      kb=0
    fi
    printf '%-10s %-18s %-8s %-18s %s\n' "$status" "$type" "$(human_kb "$kb")" "$id" "$expanded"
    printf '  %s\n' "$reason"
  done
}

guard_status() {
  local path="$1"
  local reason
  if is_dangerous_path "$path"; then
    printf '%s\t%s\n' "refused-dangerous" "Broad system, home, Library, or personal folder paths are never removed directly."
    return 0
  fi
  reason="$(protected_removal_reason "$path" || true)"
  if [[ -n "$reason" ]]; then
    printf '%s\t%s\n' "refused-protected" "$reason"
    return 0
  fi
  if is_excluded "$path"; then
    printf '%s\t%s\n' "excluded" "Matched a user-provided --exclude or config exclude."
    return 0
  fi
  printf '%s\t%s\n' "allowed" "No built-in guard blocks this path; cleanup still requires a matching rule and --apply."
}

guard() {
  [[ "${#PATH_ARGS[@]}" -gt 0 ]] || die "guard requires at least one path"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 path expanded exists_flag kb status reason line
    for path in "${PATH_ARGS[@]}"; do
      expanded="$(expand_path "$path")"
      if [[ -e "$expanded" ]]; then
        exists_flag=true
        kb="$(size_kb "$expanded")"
      else
        exists_flag=false
        kb=0
      fi
      line="$(guard_status "$expanded")"
      status="${line%%$'\t'*}"
      reason="${line#*$'\t'}"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","exists":%s,"size_kb":%s,"size":"%s","status":"%s","reason":"%s"}' \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$exists_flag" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$reason" | json_escape)"
    done
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom guard${RESET}"
  printf '%-18s %-8s %-8s %s\n' "status" "exists" "size" "path"
  local path expanded exists_label kb status reason line
  for path in "${PATH_ARGS[@]}"; do
    expanded="$(expand_path "$path")"
    if [[ -e "$expanded" ]]; then
      exists_label=yes
      kb="$(size_kb "$expanded")"
    else
      exists_label=no
      kb=0
    fi
    line="$(guard_status "$expanded")"
    status="${line%%$'\t'*}"
    reason="${line#*$'\t'}"
    printf '%-18s %-8s %-8s %s\n' "$status" "$exists_label" "$(human_kb "$kb")" "$expanded"
    printf '  %s\n' "$reason"
  done
}

doctor() {
  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    printf '"version":"%s",' "$(printf '%s' "$VERSION" | json_escape)"
    printf '"platform":{"shell":"%s","macos":"%s","architecture":"%s"},' \
      "$(printf '%s' "${SHELL:-unknown}" | json_escape)" \
      "$(sw_vers -productVersion 2>/dev/null | json_escape || printf 'unknown')" \
      "$(uname -m | json_escape)"
    printf '"config":{"loaded":%s,"path":"%s","excludes":%s},' \
      "$(if [[ "$CONFIG_LOADED" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(printf '%s' "${CONFIG_FILE:-}" | json_escape)" \
      "${#EXCLUDES[@]}"
    disk_json
    printf ',"tools":['
    local first=1 tool required status
    for tool in du find awk sort xargs shasum sqlite3 plutil tmutil brew xcrun; do
      case "$tool" in
        brew|xcrun) required=false ;;
        *) required=true ;;
      esac
      if command -v "$tool" >/dev/null 2>&1; then
        status="ok"
      elif [[ "$required" == true ]]; then
        status="missing"
      else
        status="optional-missing"
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","required":%s,"status":"%s"}' "$tool" "$required" "$status"
    done
    printf ']'
    printf ',"safety":{"protected_present":%s,"rules_catalog":%s,"protected_catalog":%s}' \
      "$(protected_present_count)" \
      "$(if [[ -f "$(rules_file)" ]]; then echo true; else echo false; fi)" \
      "$(if [[ -f "$(protected_file)" ]]; then echo true; else echo false; fi)"
    printf '}\n'
    return 0
  fi

  log "${BOLD}cleanroom doctor${RESET}"
  printf '%-28s %s\n' "version" "$VERSION"
  printf '%-28s %s\n' "shell" "${SHELL:-unknown}"
  printf '%-28s %s\n' "macOS" "$(sw_vers -productVersion 2>/dev/null || echo unknown)"
  printf '%-28s %s\n' "architecture" "$(uname -m)"
  printf '%-28s %s\n' "config" "$(if [[ "$CONFIG_LOADED" -eq 1 ]]; then echo "$CONFIG_FILE"; else echo "not loaded"; fi)"
  printf '%-28s %s\n' "excludes" "${#EXCLUDES[@]}"
  printf '%-28s ' "disk"
  df -h /System/Volumes/Data 2>/dev/null | awk 'NR==2 {print $4 " free, " $5 " used"}' || df -h / | awk 'NR==2 {print $4 " free, " $5 " used"}'

  printf '\n%s\n' "${BOLD}Tools${RESET}"
  local tool
  for tool in du find awk sort xargs sqlite3 plutil tmutil; do
    if command -v "$tool" >/dev/null 2>&1; then
      printf '%-28s %s\n' "$tool" "ok"
    else
      printf '%-28s missing\n' "$tool"
    fi
  done
  if command -v brew >/dev/null 2>&1; then
    printf '%-28s %s\n' "brew" "ok"
  else
    printf '%-28s %s\n' "brew" "optional missing"
  fi
  if command -v xcrun >/dev/null 2>&1; then
    printf '%-28s %s\n' "xcrun" "ok"
  else
    printf '%-28s %s\n' "xcrun" "optional missing"
  fi

  printf '\n%s\n' "${BOLD}Protected data check${RESET}"
  printf 'Run `cleanroom protect` for the full protected path audit.\n'
  local protected=(
    "$HOME/Library/Keychains"
    "$HOME/Library/Application Support/Google/Chrome"
    "$HOME/Library/Mail"
    "$HOME/Library/Mobile Documents"
    "$HOME/Pictures/Photos Library.photoslibrary"
  )
  local p
  for p in "${protected[@]}"; do
    [[ -e "$p" ]] && printf '%-28s present, protected\n' "$(basename "$p")"
  done
  return 0
}

init_config() {
  local file
  file="${CONFIG_FILE:-$(config_default_path)}"
  file="$(expand_path "$file")"
  if [[ -e "$file" && "$ASSUME_YES" -ne 1 ]]; then
    die "Config already exists: $file"
  fi
  mkdir -p "$(dirname "$file")"
  cat >"$file" <<'EOF'
# cleanroom config
# Data only: this file is not executed as shell.

# preset can be: safe, dev, deep
preset=dev

# stale node_modules threshold
days=30

# Optional categories
include_app_caches=true
include_package_stores=true
include_node_stale=true
include_dev_heavy=false
include_snapshots=false
include_ai_workspaces=false
include_ai_models=false
include_containers=false

# Apply safety
trash=false
# log_file=~/.local/state/cleanroom/runs/custom.log

# Protect custom paths from deletion.
# Add one exclude=... line per path.
# exclude=~/Desktop/important-project
EOF
  ok "Wrote config: $file"
}

ask_yes_no() {
  local prompt="$1"
  local answer
  printf '%s [y/N]: ' "$prompt"
  read -r answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

interactive() {
  log "${BOLD}cleanroom interactive${RESET}"
  warn "Interactive mode still dry-runs unless --apply is passed."
  ask_yes_no "Include safe app cache folders?" && INCLUDE_APP_CACHES=1
  ask_yes_no "Include package-manager stores?" && INCLUDE_PACKAGE_STORES=1
  ask_yes_no "Include stale node_modules older than ${DAYS} days?" && INCLUDE_NODE_STALE=1
  ask_yes_no "Include heavy SDK/simulator cleanup?" && INCLUDE_DEV_HEAVY=1
  ask_yes_no "Include local snapshot thinning?" && INCLUDE_SNAPSHOTS=1
  ask_yes_no "Include AI-agent workspace cleanup?" && INCLUDE_AI_WORKSPACES=1
  ask_yes_no "Include downloaded AI model cleanup?" && INCLUDE_AI_MODELS=1
  ask_yes_no "Include container VM disk cleanup?" && INCLUDE_CONTAINERS=1
  clean
}

categories() {
  cat <<'EOF'
cleanroom categories

Default safe cleanup:
  Rebuildable user caches, logs older than 7 days, npm/Yarn/Gradle cache, Xcode DerivedData.

--include-app-caches:
  Nested app cache folders only. Does not remove browser profiles, password databases,
  cookies, bookmarks, or full app profile directories.

--include-package-stores:
  Rebuildable package-manager stores such as pnpm, CocoaPods repos, Gradle caches,
  and Cargo registry cache.

--include-node-stale:
  node_modules older than --days under Desktop/Documents/Downloads.

--include-dev-heavy:
  Xcode device support, unavailable simulators, simulator app data, Android NDK,
  and Android system images.

--include-ai-workspaces:
  Generated AI-agent recordings, scratch data, local brain/memory, implicit data,
  and local conversation caches where known.

--include-ai-models:
  Downloaded local AI model stores such as LM Studio, Ollama, Hugging Face, torch hub,
  ModelScope, and Whisper cache.

--include-containers:
  Local container VM disks for Colima/Lima/Docker Desktop. This can remove containers,
  images, and volumes.

--trash:
  Move cleanroom path removals to ~/.Trash/cleanroom-* during --apply runs.
  Commands delegated to system tools, such as snapshot thinning or simulator reset,
  may still be irreversible.

Presets:
  safe  default cleanup only
  dev   safe + app caches + package stores + stale node_modules
  deep  dev + heavy SDKs + snapshots + AI workspaces
EOF
}

clean() {
  if [[ "$APPLY" -eq 1 ]]; then
    warn "Apply mode enabled."
    [[ "$TRASH" -eq 1 ]] && warn "Trash mode enabled."
  else
    warn "Dry-run mode. Pass --apply to actually delete."
  fi
  confirm_apply
  ensure_apply_log
  [[ "$APPLY" -eq 1 ]] && warn "Apply log: $LOG_FILE"
  disk_line
  safe_clean
  clean_logs
  clean_package_stores
  clean_app_caches
  clean_dev_heavy
  clean_node_stale
  clean_snapshots
  clean_ai_workspaces
  clean_ai_models
  clean_containers
  printf '\n%s\n' "${BOLD}After${RESET}"
  disk_line
  [[ "$APPLY" -eq 1 && "$TRASH" -eq 1 ]] && warn "Review ~/.Trash/cleanroom-$RUN_ID before emptying Trash."
  return 0
}

apply_preset() {
  case "$1" in
    safe)
      ;;
    dev)
      INCLUDE_APP_CACHES=1
      INCLUDE_PACKAGE_STORES=1
      INCLUDE_NODE_STALE=1
      ;;
    deep)
      INCLUDE_APP_CACHES=1
      INCLUDE_PACKAGE_STORES=1
      INCLUDE_NODE_STALE=1
      INCLUDE_DEV_HEAVY=1
      INCLUDE_SNAPSHOTS=1
      INCLUDE_AI_WORKSPACES=1
      ;;
    *)
      die "Unknown preset: $1"
      ;;
  esac
}

if [[ "$#" -eq 0 ]]; then
  usage
  exit 0
fi

case "${1:-}" in
  overview|scan|plan|large|duplicates|nodes|apps|startup|caches|packages|snapshots|report|clean|history|restore|interactive|doctor|protect|guard|rules|categories|init-config|help)
    ACTION="$1"
    shift
    ;;
esac

args=("$@")
for ((i = 0; i < ${#args[@]}; i++)); do
  if [[ "${args[$i]}" == "--config" && $((i + 1)) -lt ${#args[@]} ]]; then
    CONFIG_FILE="${args[$((i + 1))]}"
  fi
done

if [[ -z "$CONFIG_FILE" ]]; then
  default_config="$(config_default_path)"
  [[ -f "$default_config" ]] && CONFIG_FILE="$default_config"
fi

if [[ -n "$CONFIG_FILE" && "$ACTION" != "init-config" ]]; then
  load_config "$CONFIG_FILE"
fi

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --apply) APPLY=1 ;;
    --trash) TRASH=1 ;;
    --yes) ASSUME_YES=1 ;;
    --verbose) VERBOSE=1 ;;
    --json) JSON=1 ;;
    --output)
      shift
      [[ -n "${1:-}" ]] || die "--output requires a path"
      OUTPUT_FILE="${1:-}"
      ;;
    --config)
      shift
      CONFIG_FILE="${1:-}"
      ;;
    --log)
      shift
      [[ -n "${1:-}" ]] || die "--log requires a path"
      LOG_FILE="$(expand_path "${1:-}")"
      ;;
    --exclude)
      shift
      add_exclude "${1:-}"
      ;;
    --preset)
      shift
      apply_preset "${1:-}"
      ;;
    --days)
      shift
      [[ "${1:-}" =~ ^[0-9]+$ ]] || die "--days requires a number"
      DAYS="$1"
      ;;
    --limit)
      shift
      [[ "${1:-}" =~ ^[0-9]+$ ]] || die "--limit requires a number"
      LIMIT="$1"
      ;;
    --min-mb)
      shift
      [[ "${1:-}" =~ ^[0-9]+$ ]] || die "--min-mb requires a number"
      MIN_MB="$1"
      ;;
    --include-dev-heavy) INCLUDE_DEV_HEAVY=1 ;;
    --include-node-stale) INCLUDE_NODE_STALE=1 ;;
    --include-package-stores) INCLUDE_PACKAGE_STORES=1 ;;
    --include-app-caches) INCLUDE_APP_CACHES=1 ;;
    --include-snapshots) INCLUDE_SNAPSHOTS=1 ;;
    --include-ai-workspaces) INCLUDE_AI_WORKSPACES=1 ;;
    --include-ai-models) INCLUDE_AI_MODELS=1 ;;
    --include-containers) INCLUDE_CONTAINERS=1 ;;
    --include-gemini) INCLUDE_GEMINI=1; INCLUDE_AI_WORKSPACES=1 ;;
    --include-lmstudio) INCLUDE_LMSTUDIO=1; INCLUDE_AI_MODELS=1 ;;
    -h|--help) usage; exit 0 ;;
    -v|--version) echo "$VERSION"; exit 0 ;;
    *)
      if [[ "$ACTION" == "guard" || "$ACTION" == "large" || "$ACTION" == "duplicates" || "$ACTION" == "nodes" || "$ACTION" == "apps" ]]; then
        PATH_ARGS+=("$1")
      else
        die "Unknown option: $1"
      fi
      ;;
  esac
  shift
done

case "$ACTION" in
  overview) overview ;;
  scan) scan ;;
  plan) plan ;;
  large) large ;;
  duplicates) duplicates ;;
  nodes) nodes ;;
  apps) apps ;;
  startup) startup ;;
  caches) caches ;;
  packages) packages ;;
  snapshots) snapshots ;;
  report) report ;;
  clean) clean ;;
  history) history ;;
  restore) restore ;;
  interactive) interactive ;;
  doctor) doctor ;;
  protect) protect ;;
  guard) guard ;;
  rules) rules ;;
  categories) categories ;;
  init-config) init_config ;;
  help) usage ;;
  *) die "Unknown action: $ACTION" ;;
esac
