    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Xcode storage${RESET}"
  printf 'Review-only inventory. Cleanup commands are dry-runs unless --apply is passed.\n\n'
  printf '%-10s %-22s %-12s %s\n' "size" "item" "safety" "path"
  local kb id title safety path preview apply notes
  while IFS=$'\t' read -r kb id title safety path preview apply notes; do
