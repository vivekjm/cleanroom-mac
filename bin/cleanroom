  local roots=(antigravity antigravity-backup antigravity-ide)
  local root
  for root in "${roots[@]}"; do
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "gemini-$root-recordings" "Gemini / Antigravity" "recordings" "generated-workspace" "~/.gemini/$root/browser_recordings" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Generated browser recordings from AI-agent workspaces."
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "gemini-$root-scratch" "Gemini / Antigravity" "scratch" "generated-workspace" "~/.gemini/$root/scratch" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Generated scratch files from AI-agent workspaces."
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "gemini-$root-brain" "Gemini / Antigravity" "brain" "generated-workspace" "~/.gemini/$root/brain" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Generated local brain or memory data from AI-agent workspaces."
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "gemini-$root-implicit" "Gemini / Antigravity" "implicit" "generated-workspace" "~/.gemini/$root/implicit" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Generated implicit state from AI-agent workspaces."
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "gemini-$root-conversations" "Gemini / Antigravity" "conversations" "generated-workspace" "~/.gemini/$root/conversations" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Generated local conversation cache for AI-agent workspaces."
  done
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "gemini-browser-graphite-cache" "Gemini / Antigravity" "browser-cache" "generated-workspace" "~/.gemini/antigravity-browser-profile/GraphiteDawnCache" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Rebuildable browser rendering cache inside the generated AI browser profile."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "gemini-browser-grshader-cache" "Gemini / Antigravity" "browser-cache" "generated-workspace" "~/.gemini/antigravity-browser-profile/GrShaderCache" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Rebuildable browser shader cache inside the generated AI browser profile."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "gemini-browser-shader-cache" "Gemini / Antigravity" "browser-cache" "generated-workspace" "~/.gemini/antigravity-browser-profile/ShaderCache" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-workspaces" "Rebuildable browser shader cache inside the generated AI browser profile."
}

