  printf 'Review-only inventory. Cleanup is opt-in with --include-saved-state and does not remove documents or app profile data.\n\n'
  printf '%-10s %-26s %s\n' "size" "bucket" "path"
  local kb id title path category preview apply description
  while IFS=$'\t' read -r kb id title path category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-26s %s\n' "$(human_kb "$kb")" "$title" "$path"
    printf '  %s\n' "$description"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-saved-state\n'
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-saved-state\n'
}

clean_saved_state() {
  [[ "$INCLUDE_SAVED_STATE" -eq 1 ]] || return 0
  log "${BOLD}Saved Application State${RESET}"
  local id title path_template category preview apply description
  while IFS=$'\t' read -r id title path_template category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    run_rm "$path_template"
  done < <(savedstate_specs)
}

projectcache_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    local path
    for path in "${PATH_ARGS[@]}"; do
      printf '%s\n' "$(expand_path "$path")"
    done
  else
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Documents"
    printf '%s\n' "$HOME/Downloads"
  fi
}

projectcache_kind() {
  local name="$1"
  case "$name" in
    __pycache__) printf 'python-bytecode' ;;
    .pytest_cache) printf 'pytest-cache' ;;
    .mypy_cache) printf 'mypy-cache' ;;
    .ruff_cache) printf 'ruff-cache' ;;
    .tox) printf 'tox-cache' ;;
    .nox) printf 'nox-cache' ;;
    .coverage) printf 'coverage-data' ;;
    htmlcov) printf 'coverage-report' ;;
    *) printf '' ;;
  esac
}

projectcache_rows() {
  local root path name kind kb epoch
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    find "$root" -xdev \( \
      -name '.git' -o -name 'node_modules' -o -name '.venv' -o -name 'venv' -o -name 'env' \
    \) -prune -o \( \
      \( -type d \( -name '__pycache__' -o -name '.pytest_cache' -o -name '.mypy_cache' -o -name '.ruff_cache' -o -name '.tox' -o -name '.nox' -o -name 'htmlcov' \) \) \
      -o \( -type f -name '.coverage' \) \
    \) -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        name="$(basename "$path")"
        kind="$(projectcache_kind "$name")"
        [[ -n "$kind" ]] || continue
        kb="$(size_kb "$path")"
        epoch="$(path_mtime_epoch "$path")"
        printf '%012d\t%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$kind" "$name" "$path"
      done
  done < <(projectcache_roots) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

projectcache_total_kb() {
  local total=0 kb epoch kind name path kb_num
  while IFS=$'\t' read -r kb epoch kind name path; do
    [[ -z "${path:-}" ]] && continue
    kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(projectcache_rows)
  printf '%s\n' "$total"
}

projectcaches() {
  local rows
  rows="$(projectcache_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch kind name path kb_num epoch_num
    while IFS=$'\t' read -r kb epoch kind name path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","name":"%s","kind":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf 'cleanroom projectcaches --limit %s' "$LIMIT" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-project-caches --limit %s' "$LIMIT" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom project caches${RESET}"
  printf 'Review-only inventory. Cleanup is opt-in with --include-project-caches and targets only known rebuildable cache artifacts.\n'
  printf 'Limit: %s\n' "$LIMIT"
  printf 'Paths: '
  local root first_root=1
  while IFS= read -r root; do
    [[ "$first_root" -eq 0 ]] && printf '; '
    first_root=0
    printf '%s' "$root"
  done < <(projectcache_roots)
  printf '\n\n'

  if [[ -z "$rows" ]]; then
    printf 'No project cache artifacts found.\n'
    return 0
  fi

  printf '%-10s %-18s %-12s %s\n' "size" "kind" "modified" "path"
  local kb epoch kind name path epoch_num
  while IFS=$'\t' read -r kb epoch kind name path; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    printf '%-10s %-18s %-12s %s\n' "$(human_kb "$kb")" "$kind" "$(file_mtime_iso "${epoch_num:-0}")" "$path"
    printf '  reveal: open -R %s\n' "$(shell_quote "$path")"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-project-caches\n'
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-project-caches\n'
}

clean_project_caches() {
  [[ "$INCLUDE_PROJECT_CACHES" -eq 1 ]] || return 0
  log "${BOLD}Project cache artifacts${RESET}"
  local kb epoch kind name path
  while IFS=$'\t' read -r kb epoch kind name path; do
    [[ -z "${path:-}" ]] && continue
    run_rm "$path"
  done < <(projectcache_rows)
}

updatercache_specs() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "sparkle-cache" "Sparkle cache" "~/Library/Caches/Sparkle" "rebuildable" "cleanroom updaters" "cleanroom clean --apply --trash --include-updater-caches" "Sparkle updater downloaded app updates and temporary cache data. Apps and preferences stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "squirrel-cache" "Squirrel cache" "~/Library/Caches/com.github.Squirrel.ShipIt" "rebuildable" "cleanroom updaters" "cleanroom clean --apply --trash --include-updater-caches" "Squirrel/Electron updater cache data. Apps, profiles, and saved browser passwords stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "squirrel-staging" "Squirrel staging" "~/Library/Application Support/com.github.Squirrel.ShipIt" "rebuildable" "cleanroom updaters" "cleanroom clean --apply --trash --include-updater-caches" "Squirrel/Electron updater staging data that can be recreated by app updates."
}

updatercache_rows() {
  local id title path_template category preview apply description path kb
  while IFS=$'\t' read -r id title path_template category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    path="$(expand_path "$path_template")"
    kb="$(size_kb "$path")"
    printf '%012d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$id" "$title" "$path" "$category" "$preview" "$apply" "$description"
  done < <(updatercache_specs) | sort -rn
}

updatercache_total_kb() {
  local total=0 kb id title path category preview apply description kb_num
  while IFS=$'\t' read -r kb id title path category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(updatercache_rows)
  printf '%s\n' "$total"
}

updaters() {
  local rows
  rows="$(updatercache_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title path category preview apply description kb_num
    while IFS=$'\t' read -r kb id title path category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","path":"%s","exists":%s,"category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$(if [[ -e "$path" ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom app updater caches${RESET}"
  printf 'Review-only inventory. Cleanup is opt-in with --include-updater-caches and targets only Sparkle/Squirrel updater cache and staging data.\n\n'
  printf '%-10s %-20s %s\n' "size" "bucket" "path"
  local kb id title path category preview apply description
  while IFS=$'\t' read -r kb id title path category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-20s %s\n' "$(human_kb "$kb")" "$title" "$path"
    printf '  %s\n' "$description"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-updater-caches\n'
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-updater-caches\n'
}

clean_updater_caches() {
  [[ "$INCLUDE_UPDATER_CACHES" -eq 1 ]] || return 0
  log "${BOLD}App updater cache folders${RESET}"
  local id title path_template category preview apply description
  while IFS=$'\t' read -r id title path_template category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    run_rm "$path_template"
  done < <(updatercache_specs)
}

browsercache_profile_roots() {
  printf '%s\t%s\n' "Google Chrome" "~/Library/Application Support/Google/Chrome"
  printf '%s\t%s\n' "Brave" "~/Library/Application Support/BraveSoftware/Brave-Browser"
  printf '%s\t%s\n' "Microsoft Edge" "~/Library/Application Support/Microsoft Edge"
  printf '%s\t%s\n' "Arc" "~/Library/Application Support/Arc"
}

browsercache_fixed_roots() {
  printf '%s\t%s\t%s\n' "Firefox" "firefox-cache" "~/Library/Caches/Firefox"
  printf '%s\t%s\t%s\n' "Firefox" "firefox-org-cache" "~/Library/Caches/org.mozilla.firefox"
}

browsercache_rows() {
  local browser root_template root path name kb
  while IFS=$'\t' read -r browser root_template; do
    [[ -z "${browser:-}" ]] && continue
    root="$(expand_path "$root_template")"
    [[ -d "$root" ]] || continue
    find "$root" -type d \( \
      -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
      -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
    \) -prune -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        name="$(basename "$path")"
        kb="$(size_kb "$path")"
        printf '%012d\t%s\t%s\t%s\t%s\n' "$kb" "$browser" "chromium-cache" "$name" "$path"
      done
  done < <(browsercache_profile_roots)

  local id
  while IFS=$'\t' read -r browser id root_template; do
    [[ -z "${browser:-}" ]] && continue
    path="$(expand_path "$root_template")"
    [[ -e "$path" ]] || continue
    kb="$(size_kb "$path")"
    printf '%012d\t%s\t%s\t%s\t%s\n' "$kb" "$browser" "$id" "$(basename "$path")" "$path"
  done < <(browsercache_fixed_roots)
}

browsercache_rows_sorted() {
  browsercache_rows | sort -t $'\t' -k1,1rn -k2,2
}

browsercache_total_kb() {
  local total=0 kb browser kind name path kb_num
  while IFS=$'\t' read -r kb browser kind name path; do
    [[ -z "${path:-}" ]] && continue
    kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(browsercache_rows_sorted)
  printf '%s\n' "$total"
}

browsercaches() {
  local rows
  rows="$(browsercache_rows_sorted)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb browser kind name path kb_num
    while IFS=$'\t' read -r kb browser kind name path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"browser":"%s","kind":"%s","name":"%s","path":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$browser" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf 'cleanroom browsercaches' | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-browser-caches' | json_escape)" \
        "$(printf 'Rebuildable browser cache folder. Profiles, passwords, cookies, bookmarks, sessions, extensions, and settings are not removed.' | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom browser caches${RESET}"
  printf 'Review-only inventory. Cleanup is opt-in with --include-browser-caches and targets only Chromium/Firefox cache folders.\n'
  printf 'Profiles, passwords, cookies, bookmarks, sessions, extensions, and settings stay protected.\n\n'

  if [[ -z "$rows" ]]; then
    printf 'No Chromium/Firefox browser cache folders found.\n'
    return 0
  fi

  printf '%-10s %-18s %-16s %s\n' "size" "browser" "cache" "path"
  local kb browser kind name path
  while IFS=$'\t' read -r kb browser kind name path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %-18s %-16s %s\n' "$(human_kb "$kb")" "$browser" "$name" "$path"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-browser-caches\n'
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-browser-caches\n'
}

clean_browser_caches() {
  [[ "$INCLUDE_BROWSER_CACHES" -eq 1 ]] || return 0
  log "${BOLD}Chromium and Firefox browser cache folders${RESET}"
  local kb browser kind name path
  while IFS=$'\t' read -r kb browser kind name path; do
    [[ -z "${path:-}" ]] && continue
    run_rm "$path"
  done < <(browsercache_rows_sorted)
}

clean_dev_heavy() {
  [[ "$INCLUDE_DEV_HEAVY" -eq 1 ]] || return 0
  log "${BOLD}Heavy developer artifacts${RESET}"
  run_rm "~/Library/Developer/Xcode/iOS DeviceSupport"
  run_rm "~/Library/Developer/Xcode/watchOS DeviceSupport"
  run_rm "~/Library/Developer/Xcode/tvOS DeviceSupport"
  run_rm "~/Library/Android/sdk/ndk"
  run_rm "~/Library/Android/sdk/system-images"
  run_rm "~/Library/Android/sdk/.downloadIntermediates"
  run_rm "~/Library/Android/sdk/.temp"

  if [[ "$APPLY" -eq 1 ]] && command -v xcrun >/dev/null 2>&1; then
    xcrun simctl shutdown all >/dev/null 2>&1 || true
    xcrun simctl delete unavailable >/dev/null 2>&1 || true
    xcrun simctl erase all >/dev/null 2>&1 || true
  elif command -v xcrun >/dev/null 2>&1; then
    warn "would reset iOS Simulator app data because --include-dev-heavy is set"
  fi
}

clean_snapshots() {
  [[ "$INCLUDE_SNAPSHOTS" -eq 1 ]] || return 0
  log "${BOLD}Local snapshots${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    tmutil thinlocalsnapshots / 999999999999 4 2>/dev/null || true
  else
    tmutil listlocalsnapshots / 2>/dev/null || true
  fi
}

clean_ai_workspaces() {
  [[ "$INCLUDE_AI_WORKSPACES" -eq 1 || "$INCLUDE_GEMINI" -eq 1 ]] || return 0
  log "${BOLD}AI agent workspace data${RESET}"
  local roots=(antigravity antigravity-backup antigravity-ide)
  local root
  for root in "${roots[@]}"; do
    run_rm "~/.gemini/$root/browser_recordings"
    run_rm "~/.gemini/$root/scratch"
    run_rm "~/.gemini/$root/brain"
    run_rm "~/.gemini/$root/implicit"
    run_rm "~/.gemini/$root/conversations"
  done
  run_rm "~/.gemini/antigravity-browser-profile/GraphiteDawnCache"
  run_rm "~/.gemini/antigravity-browser-profile/GrShaderCache"
  run_rm "~/.gemini/antigravity-browser-profile/ShaderCache"
}

clean_ai_models() {
  [[ "$INCLUDE_AI_MODELS" -eq 1 || "$INCLUDE_LMSTUDIO" -eq 1 ]] || return 0
  log "${BOLD}Local AI models and backends${RESET}"
  run_rm "~/.lmstudio/models"
  run_rm "~/.lmstudio/extensions/backends"
  run_rm "~/.lmstudio/.internal/temp-downloads"
  run_rm "~/.ollama/models"
  run_rm "~/.cache/huggingface/hub"
  run_rm "~/.cache/modelscope"
  run_rm "~/.cache/torch/hub"
  run_rm "~/.cache/whisper"
}

clean_containers() {
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] || return 0
  log "${BOLD}Container VM disks${RESET}"
  local id runtime paths safety preview apply description path
  while IFS=$'\t' read -r id runtime paths safety preview apply description; do
    [[ -z "${id:-}" ]] && continue
    while IFS= read -r path; do
      path="${path#"${path%%[![:space:]]*}"}"
      path="${path%"${path##*[![:space:]]}"}"
      [[ -z "$path" ]] && continue
      run_rm "$path"
    done < <(printf '%s\n' "$paths" | tr ';' '\n')
  done < <(container_rows)
}

clean_node_stale() {
  [[ "$INCLUDE_NODE_STALE" -eq 1 ]] || return 0
  log "${BOLD}Stale node_modules older than ${DAYS} days${RESET}"
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print 2>/dev/null |
      while IFS= read -r path; do
        run_rm "$path"
      done
  done
  return 0
}

clean_venv_stale() {
  [[ "$INCLUDE_VENV_STALE" -eq 1 ]] || return 0
  log "${BOLD}Stale Python virtualenvs older than ${DAYS} days${RESET}"
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root marker path
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 9 -type f -name pyvenv.cfg -mtime +"$DAYS" -print0 2>/dev/null |
      while IFS= read -r -d '' marker; do
        path="$(dirname "$marker")"
        [[ -f "$path/pyvenv.cfg" ]] || continue
        run_rm "$path"
      done
  done
  return 0
}

clean_installers() {
  [[ "$INCLUDE_INSTALLERS" -eq 1 ]] || return 0
  log "${BOLD}Old downloaded installers older than ${DAYS} days${RESET}"
  local path
  if [[ "$APPLY" -eq 1 ]]; then
    installer_find_expr |
      while IFS= read -r -d '' path; do
        run_rm "$path"
      done || true
  else
    installer_rows |
      while IFS=$'\t' read -r kb epoch age_days path; do
        [[ -z "${path:-}" ]] && continue
        printf 'would remove %8s  %s\n' "$(human_kb "$kb")" "$path"
      done
  fi
}

clean_download_artifacts() {
  [[ "$INCLUDE_DOWNLOAD_ARTIFACTS" -eq 1 ]] || return 0
  log "${BOLD}Old downloadable artifacts older than ${DAYS} days${RESET}"
  local rows kb epoch age_days kind path
  rows="$(download_artifact_rows)"
  if [[ -z "$rows" ]]; then
    printf 'No old downloadable artifacts found in ~/Downloads.\n'
    return 0
  fi
  while IFS=$'\t' read -r kb epoch age_days kind path; do
    [[ -z "${path:-}" ]] && continue
    run_rm "$path"
  done <<<"$rows"
  return 0
}

clean_screenshots() {
  [[ "$INCLUDE_SCREENSHOTS" -eq 1 ]] || return 0
  log "${BOLD}Old screenshots and screen recordings older than ${DAYS} days${RESET}"
  local rows kb epoch age_days path
  rows="$(screenshot_rows)"
  if [[ -z "$rows" ]]; then
    printf 'No old screenshot or screen recording files found.\n'
    return 0
  fi
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    run_rm "$path"
  done <<<"$rows"
  return 0
}

clean_user_trash() {
  [[ "$INCLUDE_USER_TRASH" -eq 1 ]] || return 0
  log "${BOLD}User Trash${RESET}"
  local dir="$HOME/.Trash"
  [[ -d "$dir" ]] || return 0
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$TRASH" -eq 1 ]] && warn "--trash is ignored for --include-user-trash because items are already in Trash."
    find "$dir" -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_user_trash_child "$path"
      done || true
  else
    print_size "~/.Trash"
  fi
}

scan() {
  local paths=()
  local candidate
  while IFS= read -r candidate; do paths+=("$candidate"); done < <(candidate_paths)
  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    disk_json
    printf ',"candidates":['
    local first=1
    local path expanded kb
    for path in "${paths[@]}"; do
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$path")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s}' "$(printf '%s' "$expanded" | json_escape)" "$kb"
    done
    printf ']}'
    printf '\n'
    return 0
  fi

  log "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Common cleanup candidates${RESET}"
  local path
  for path in "${paths[@]}"; do print_size "$path"; done

  printf '\n%s\n' "${BOLD}Largest home folders${RESET}"
  du -x -d 1 -h "$HOME" 2>/dev/null | sort -h | tail -25 || true

  printf '\n%s\n' "${BOLD}Largest user files over 500MB${RESET}"
  find "$HOME" -xdev -type f -size +500M -print0 2>/dev/null |
    xargs -0 du -h 2>/dev/null | sort -h | tail -30 || true
}

system_data_rows() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "application-support" "Application Support" "~/Library/Application Support" "review" "cleanroom leftovers APPNAME" "manual review" "Large app support folders often appear as System Data. Review by app name; cleanroom does not remove the whole folder."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "caches" "User Caches" "~/Library/Caches; ~/.cache" "rebuildable" "cleanroom caches" "cleanroom clean --apply --trash" "Standard user caches and rebuildable app caches."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "quicklook" "Quick Look Caches" "~/Library/Caches/com.apple.QuickLook.thumbnailcache; ~/Library/Caches/com.apple.quicklook.ThumbnailsAgent; ~/Library/Caches/com.apple.QuickLookDaemon; ~/Library/Containers/com.apple.QuickLook.thumbnailcache/Data/Library/Caches; ~/Library/Containers/com.apple.quicklook.ThumbnailsAgent/Data/Library/Caches" "rebuildable" "cleanroom quicklook" "cleanroom clean --apply --trash --include-quicklook" "Quick Look thumbnail and preview caches. macOS rebuilds them as needed."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "font-caches" "Font Caches" "~/Library/Caches/com.apple.ATS; ~/Library/Caches/com.apple.FontRegistry; ~/Library/Caches/com.apple.FontWorker; ~/Library/Caches/com.apple.FontServices" "rebuildable" "cleanroom fontcaches" "cleanroom clean --apply --trash --include-font-caches" "User font cache databases. Actual font files stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "web-caches" "Safari/WebKit Caches" "~/Library/Caches/com.apple.Safari; ~/Library/Containers/com.apple.Safari/Data/Library/Caches; ~/Library/Containers/com.apple.Safari/Data/Library/WebKit/NetworkCache; ~/Library/Caches/com.apple.WebKit.Networking; ~/Library/Caches/com.apple.WebKit.WebContent" "rebuildable" "cleanroom webcaches" "cleanroom clean --apply --trash --include-web-caches" "Safari and WebKit cache folders. History, cookies, bookmarks, passwords, website data, and profiles stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "developer" "Developer Data" "~/Library/Developer" "mixed" "cleanroom xcode" "cleanroom clean --apply --trash --include-dev-heavy" "Xcode, simulator, DerivedData, DeviceSupport, and archives."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "android" "Android SDK" "~/Library/Android; ~/.android" "dev-heavy" "cleanroom android" "cleanroom clean --apply --trash --include-dev-heavy" "Android SDK, emulator, AVD, NDKs, system images, and temporary SDK downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "containers" "Container Storage" "~/.colima; ~/.lima; ~/.local/share/containers; ~/.local/share/podman; ~/Library/Containers/com.docker.docker/Data/vms" "high-impact" "cleanroom containers" "cleanroom clean --apply --trash --include-containers" "Docker Desktop, Colima, Lima, and Podman container storage."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "diagnostics" "Logs and Diagnostics" "~/Library/Logs; ~/Library/DiagnosticReports; ~/Library/Application Support/CrashReporter" "low-risk" "cleanroom diagnostics" "cleanroom clean --apply --trash --include-diagnostics --days $DAYS" "User logs, diagnostic reports, and crash reports."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "mobile-backups" "Device Backups" "~/Library/Application Support/MobileSync/Backup" "protected" "cleanroom backups" "manual review" "Local iPhone and iPad backups are protected because they may be the only copy of device data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "media-libraries" "Media Libraries" "~/Pictures/Photos Library.photoslibrary; ~/Music/Music Library.musiclibrary; ~/Music/iTunes; ~/Movies/TV Library.tvlibrary; ~/Movies/iMovie Library.imovielibrary; ~/Music/GarageBand" "protected" "cleanroom libraries" "manual review" "Photos, Music, TV, iMovie, and GarageBand libraries are protected personal media."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "cloud-sync" "Cloud Sync Storage" "~/Library/Mobile Documents; ~/Library/CloudStorage; ~/Dropbox; ~/Google Drive; ~/OneDrive; ~/Box" "protected" "cleanroom cloud" "manual review" "Cloud-synced folders can remove files remotely if changed locally, so cleanroom only inventories them."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "personal-data" "Personal App Data" "~/Library/Mail; ~/Library/Messages; ~/Library/Application Support/AddressBook; ~/Library/Calendars; ~/Library/Group Containers/group.com.apple.notes; ~/Library/Group Containers/group.com.apple.reminders; ~/Library/Group Containers/group.com.apple.VoiceMemos.shared" "protected" "cleanroom personal" "manual review" "Mail, Messages, Contacts, Calendars, Notes, Reminders, and Voice Memos are protected personal data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "group-containers" "Group Containers" "~/Library/Group Containers" "review" "cleanroom leftovers APPNAME" "manual review" "Shared app containers can hold account data and should be reviewed by app or vendor."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "http-storages" "HTTPStorages" "~/Library/HTTPStorages" "review" "cleanroom leftovers APPNAME" "manual review" "Per-app HTTP storage and cookies. Review carefully; cleanroom does not remove this wholesale."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "saved-state" "Saved Application State" "~/Library/Saved Application State" "rebuildable" "cleanroom savedstate" "cleanroom clean --apply --trash --include-saved-state" "Window/session restoration state for apps. Apps can recreate it; documents and app profiles stay protected."
}

system_data() {
  local rows
  rows="$(system_data_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title paths category preview apply description kb
    while IFS=$'\t' read -r id title paths category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb="$(paths_field_kb "$paths")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom System Data breakdown${RESET}"
  printf 'Review-only inventory of common folders macOS may count as System Data.\n\n'
  printf '%-10s %-22s %-12s %s\n' "size" "id" "category" "next command"
  local id title paths category preview apply description kb
  while IFS=$'\t' read -r id title paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%-10s %-22s %-12s %s\n' "$(human_kb "$kb")" "$id" "$category" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

map_rows() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "documents" "Documents" "$HOME/Documents" "review" "cleanroom documents ~/Documents --limit 50" "User documents and project folders. Review manually."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "desktop" "Desktop" "$HOME/Desktop" "review" "cleanroom desktop --limit 50" "Desktop exports, screenshots, archives, and working files."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "downloads" "Downloads" "$HOME/Downloads" "review" "cleanroom downloads --days $DAYS --limit 50" "Downloads can hold installers, archives, exports, and temporary files."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "broken-links" "Broken Symlinks" "$HOME/Documents; $HOME/Desktop; $HOME/Downloads; $HOME/Applications" "review" "cleanroom brokenlinks --limit 50" "Dangling symlinks left by moved projects, removed apps, or old exports. Review manually."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "quarantine" "Quarantined Files" "$HOME/Downloads; $HOME/Desktop; $HOME/Documents; $HOME/Applications" "review" "cleanroom quarantine --limit 50" "Downloaded files and apps carrying macOS quarantine metadata. Review manually."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "user-applications" "User Applications" "$HOME/Applications" "review" "cleanroom apps --limit 50" "Per-user app bundles. Run cleanroom apps to review system-wide applications too."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "app-support" "Application Support" "$HOME/Library/Application Support" "review" "cleanroom appdata --limit 50" "Large app support folders. Use app-specific review before removing anything."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "containers" "App Containers" "$HOME/Library/Containers; $HOME/Library/Group Containers" "review" "cleanroom appdata --limit 50" "Sandbox and shared app containers can contain account data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "cloud" "Cloud Storage" "$HOME/Library/Mobile Documents; $HOME/Library/CloudStorage; $HOME/Dropbox; $HOME/Google Drive; $HOME/OneDrive; $HOME/Box; $HOME/Sync" "protected" "cleanroom cloud" "Cloud-synced files can change remote data if changed locally."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "cloud-files" "Large Cloud Files" "$HOME/Library/Mobile Documents; $HOME/Library/CloudStorage; $HOME/Dropbox; $HOME/Google Drive; $HOME/OneDrive; $HOME/Box; $HOME/Sync" "protected" "cleanroom cloudfiles --min-mb 250 --limit 50" "Large local copies inside cloud-sync roots. Review through Finder or provider UI."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "media" "Media Libraries" "$HOME/Pictures; $HOME/Music; $HOME/Movies" "protected" "cleanroom libraries" "Photos, music, videos, and creative projects."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "communications" "Mail and Messages" "$HOME/Library/Mail; $HOME/Library/Mail Downloads; $HOME/Library/Containers/com.apple.mail/Data/Library/Mail Downloads; $HOME/Library/Messages" "protected" "cleanroom communications" "Mail, chats, and communication attachments are protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "developer" "Developer Data" "$HOME/Library/Developer; $HOME/Library/Android; $HOME/.android" "mixed" "cleanroom system-data" "Xcode, simulators, Android SDKs, and emulator data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "login-items" "Login Items" "System Events Login Items" "review" "cleanroom loginitems" "Apps and helpers that macOS starts at login. Review when troubleshooting slow startup."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "uninstallers" "Vendor Uninstallers" "/Applications; $HOME/Applications; /Applications/Utilities; Application Support" "review" "cleanroom uninstallers --limit 50" "Vendor uninstallers, remover apps, and scripts. Review before manual leftover cleanup."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "packages" "Package Stores" "$HOME/.npm; $HOME/.yarn; $HOME/Library/pnpm; $HOME/.gradle; $HOME/.cocoapods; $HOME/.cargo" "rebuildable" "cleanroom packages" "Package-manager caches and stores."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "receipts" "Package Receipts" "/var/db/receipts; /Library/Receipts; $HOME/Library/Receipts" "review" "cleanroom receipts --limit 50" "macOS package installer records. Useful for uninstall investigations; not cleanup targets."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "toolchains" "Toolchains" "$HOME/go; $HOME/.cache/uv; $HOME/.m2; $HOME/.bundle; $HOME/Library/Caches/pip; $HOME/Library/Caches/org.swift.swiftpm" "rebuildable" "cleanroom toolchains" "Language and build-tool caches."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "container-vms" "Container VMs" "$HOME/.colima; $HOME/.lima; $HOME/.local/share/containers; $HOME/.local/share/podman; $HOME/Library/Containers/com.docker.docker/Data/vms" "high-impact" "cleanroom containers" "Docker, Colima, Lima, and Podman VM/image storage."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "trash" "Trash" "$HOME/.Trash" "manual" "cleanroom trash" "Current user Trash. Emptying it is irreversible."
