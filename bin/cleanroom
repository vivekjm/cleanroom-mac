pip_cache() {
  local command_label output status
  local -a pip_cmd
  if command -v pip3 >/dev/null 2>&1; then
    pip_cmd=(pip3)
  elif command -v pip >/dev/null 2>&1; then
    pip_cmd=(pip)
  elif command -v python3 >/dev/null 2>&1 && python3 -m pip --version >/dev/null 2>&1; then
    pip_cmd=(python3 -m pip)
  else
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":false,"apply":%s,"command":"","exit_code":127,"output":"%s"}\n' \
        "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "pip command not found" | json_escape)"
      return 0
    fi
    die "pip command not found"
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    command_label="${pip_cmd[*]} cache purge"
  else
    command_label="${pip_cmd[*]} cache info"
  fi

  if [[ "$APPLY" -eq 1 && "$ASSUME_YES" -ne 1 ]]; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":true,"apply":true,"command":"%s","exit_code":2,"output":"%s"}\n' \
        "$(printf '%s' "$command_label" | json_escape)" \
        "$(printf '%s' "confirmation required; pass --yes to use --json with --apply" | json_escape)"
      return 2
    fi
    warn "Apply mode enabled for pip cache cleanup."
    warn "pip cache purge removes cached wheels and downloads; projects may need to download packages again."
    printf 'Continue? Type "clean" to proceed: '
    local answer
    IFS= read -r answer
    [[ "$answer" == "clean" ]] || die "Aborted."
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    if output="$("${pip_cmd[@]}" cache purge 2>&1)"; then
      status=0
      record_apply "pip-cache" "ok" "0" "$command_label" ""
    else
      status=$?
      record_apply "pip-cache" "failed" "0" "$command_label" ""
    fi
  else
    if output="$("${pip_cmd[@]}" cache info 2>&1)"; then
      status=0
    else
      status=$?
    fi
  fi

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"available":true,"apply":%s,"command":"%s","exit_code":%s,"output":"%s"}\n' \
      "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(printf '%s' "$command_label" | json_escape)" \
      "$status" \
      "$(printf '%s' "$output" | json_escape)"
    return "$status"
  fi

  printf '%s\n' "${BOLD}cleanroom pip cache${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    printf 'Running: %s\n\n' "$command_label"
  else
    warn "Dry-run mode. Pass --apply --yes to run ${pip_cmd[*]} cache purge."
    printf 'Running: %s\n\n' "$command_label"
  fi
  if [[ -n "$output" ]]; then
    printf '%s\n' "$output"
  else
    printf 'pip reported no cache output.\n'
  fi
  return "$status"
}

receipt_roots() {
  printf '%s\t%s\n' "system-receipts" "/var/db/receipts"
  printf '%s\t%s\n' "local-receipts" "/Library/Receipts"
  printf '%s\t%s\n' "user-receipts" "~/Library/Receipts"
}

receipt_rows() {
  local root_id root_template root path kind name id kb epoch
  while IFS=$'\t' read -r root_id root_template; do
    root="$(expand_path "$root_template")"
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      name="$(basename "$path")"
      kind="${name##*.}"
      [[ "$kind" == "plist" || "$kind" == "bom" ]] || continue
      id="${name%.$kind}"
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      printf '%012d\t%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$id" "$kind" "$root_id" "$path"
    done < <(find "$root" -maxdepth 1 -type f \( -name '*.plist' -o -name '*.bom' \) -print0 2>/dev/null)
  done < <(receipt_roots) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

receipts() {
  local rows
  rows="$(receipt_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch id kind root_id path kb_num epoch_num command guidance
    while IFS=$'\t' read -r kb epoch id kind root_id path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      command="$(printf 'cleanroom leftovers %s' "$(shell_quote "$id")")"
      guidance="Receipts are install records, not uninstall targets. Use vendor uninstallers first, then review leftovers."
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","kind":"%s","root":"%s","path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","review_command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$root_id" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf '%s' "$command" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom package receipts${RESET}"
  printf 'Review-only inventory. Receipts are installer records; cleanroom does not delete them.\n'
  printf 'Use vendor uninstallers first, then run leftovers review for matching package IDs.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No package receipts found in readable receipt folders.\n'
    return 0
  fi
  printf '%-10s %-8s %-12s %-18s %s\n' "size" "kind" "modified" "root" "package id"
  local kb epoch id kind root_id path epoch_num
  while IFS=$'\t' read -r kb epoch id kind root_id path; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    printf '%-10s %-8s %-12s %-18s %s\n' "$(human_kb "$kb")" "$kind" "$(file_mtime_iso "${epoch_num:-0}")" "$root_id" "$id"
    printf '  path: %s\n' "$path"
    printf '  review: cleanroom leftovers %s\n' "$(shell_quote "$id")"
  done <<<"$rows"
}

homebrew_rows() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-cache" "cache" "~/Library/Caches/Homebrew" "cleanroom clean" "cleanroom clean --apply --trash" "Downloaded bottles, source archives, and build cache. Rebuildable."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-logs" "logs" "~/Library/Logs/Homebrew" "cleanroom clean" "cleanroom clean --apply --trash" "Homebrew build logs. Usually safe to remove when old."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-cellar-arm" "cellar" "/opt/homebrew/Cellar" "brew cleanup -n" "brew cleanup" "Installed formula versions on Apple Silicon Homebrew. Use brew cleanup to remove old versions."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-cellar-intel" "cellar" "/usr/local/Cellar" "brew cleanup -n" "brew cleanup" "Installed formula versions on Intel Homebrew. Use brew cleanup to remove old versions."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-caskroom-arm" "casks" "/opt/homebrew/Caskroom" "brew cleanup -n" "brew cleanup" "Homebrew Cask app/download staging data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-caskroom-intel" "casks" "/usr/local/Caskroom" "brew cleanup -n" "brew cleanup" "Homebrew Cask app/download staging data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-var-arm" "services" "/opt/homebrew/var" "manual review" "manual review" "Databases, service state, and runtime data for installed formulae. Review carefully."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "homebrew-var-intel" "services" "/usr/local/var" "manual review" "manual review" "Databases, service state, and runtime data for installed formulae. Review carefully."
}

homebrew_counts_json_fields() {
  local formulae=0 casks=0 prefix=""
  if command -v brew >/dev/null 2>&1; then
    formulae="$(brew list --formula 2>/dev/null | awk 'END {print NR + 0}')"
    casks="$(brew list --cask 2>/dev/null | awk 'END {print NR + 0}')"
    prefix="$(brew --prefix 2>/dev/null || true)"
  fi
  printf '"installed_formulae":%s,"installed_casks":%s,"active_prefix":"%s"' \
    "${formulae:-0}" \
    "${casks:-0}" \
    "$(printf '%s' "$prefix" | json_escape)"
}

homebrew() {
  local rows
  rows="$(homebrew_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    homebrew_counts_json_fields
    printf ',"buckets":['
    local first=1 id category path preview apply description expanded kb
    while IFS=$'\t' read -r id category path preview apply description; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$expanded")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","category":"%s","path":"%s","exists":%s,"size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$(if [[ -e "$expanded" ]]; then echo true; else echo false; fi)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']}'
    printf '\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Homebrew storage${RESET}"
  printf 'Review-only inventory. cleanroom only clears Homebrew cache through the normal safe clean flow.\n\n'
  if command -v brew >/dev/null 2>&1; then
    printf '%-20s %s\n' "active prefix" "$(brew --prefix 2>/dev/null || true)"
    printf '%-20s %s\n' "formulae" "$(brew list --formula 2>/dev/null | awk 'END {print NR + 0}')"
    printf '%-20s %s\n\n' "casks" "$(brew list --cask 2>/dev/null | awk 'END {print NR + 0}')"
  else
    printf 'brew command not found. Filesystem buckets are still shown when present.\n\n'
  fi

  printf '%-10s %-22s %-10s %s\n' "size" "id" "category" "path"
  local id category path preview apply description expanded kb
  while IFS=$'\t' read -r id category path preview apply description; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] || continue
    kb="$(size_kb "$expanded")"
    printf '%-10s %-22s %-10s %s\n' "$(human_kb "$kb")" "$id" "$category" "$expanded"
    printf '  preview: %s\n' "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  %s\n' "$description"
  done <<<"$rows"
  printf '\nUse `cleanroom homebrew-cleanup` for Homebrew-native dry-run details. Use `cleanroom clean --apply --trash` for cache cleanup through cleanroom.\n'
}

homebrew_cleanup() {
  local command_label output status
  if ! command -v brew >/dev/null 2>&1; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":false,"apply":%s,"command":"","exit_code":127,"output":"%s"}\n' \
        "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "brew command not found" | json_escape)"
      return 0
    fi
    die "brew command not found"
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    command_label="brew cleanup"
  else
    command_label="brew cleanup -n"
  fi

  if [[ "$APPLY" -eq 1 && "$ASSUME_YES" -ne 1 ]]; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":true,"apply":true,"command":"%s","exit_code":2,"output":"%s"}\n' \
        "$(printf '%s' "$command_label" | json_escape)" \
        "$(printf '%s' "confirmation required; pass --yes to use --json with --apply" | json_escape)"
      return 2
    fi
    warn "Apply mode enabled for Homebrew cleanup."
    printf 'Continue? Type "clean" to proceed: '
    local answer
    IFS= read -r answer
    [[ "$answer" == "clean" ]] || die "Aborted."
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    if output="$(brew cleanup 2>&1)"; then
      status=0
      record_apply "homebrew-cleanup" "ok" "0" "$command_label" ""
    else
      status=$?
      record_apply "homebrew-cleanup" "failed" "0" "$command_label" ""
    fi
  else
    if output="$(brew cleanup -n 2>&1)"; then
      status=0
    else
      status=$?
    fi
  fi

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"available":true,"apply":%s,"command":"%s","exit_code":%s,"output":"%s"}\n' \
      "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(printf '%s' "$command_label" | json_escape)" \
      "$status" \
      "$(printf '%s' "$output" | json_escape)"
    return "$status"
  fi

  printf '%s\n' "${BOLD}cleanroom Homebrew cleanup${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    printf 'Running: %s\n\n' "$command_label"
  else
    warn "Dry-run mode. Pass --apply --yes to run Homebrew cleanup."
    printf 'Running: %s\n\n' "$command_label"
  fi
  if [[ -n "$output" ]]; then
    printf '%s\n' "$output"
  else
    printf 'Homebrew reported no cleanup output.\n'
  fi
  return "$status"
}

toolchains() {
  local rows
  rows="$(toolchain_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id ecosystem paths category preview apply description kb
    while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb="$(paths_field_kb "$paths")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","ecosystem":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$ecosystem" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom language toolchains${RESET}"
  printf 'Review-only inventory. Use the preview command before applying cleanup.\n\n'
  printf '%-10s %-18s %-10s %s\n' "size" "id" "ecosystem" "preview command"
  local id ecosystem paths category preview apply description kb
  while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%-10s %-18s %-10s %s\n' "$(human_kb "$kb")" "$id" "$ecosystem" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

toolchain_total_kb() {
  local id ecosystem paths category preview apply description total=0 kb
  while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    total=$((total + kb))
  done < <(toolchain_rows)
  printf '%s\n' "$total"
}

containers() {
  local rows
  rows="$(container_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id runtime paths safety preview apply description kb
    while IFS=$'\t' read -r id runtime paths safety preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb="$(paths_field_kb "$paths")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","runtime":"%s","paths":"%s","safety":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$runtime" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom container storage${RESET}"
  printf 'Review-only inventory. Container cleanup is high-impact and opt-in.\n\n'
  printf '%-10s %-20s %-16s %s\n' "size" "id" "runtime" "preview command"
  local id runtime paths safety preview apply description kb
  while IFS=$'\t' read -r id runtime paths safety preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%-10s %-20s %-16s %s\n' "$(human_kb "$kb")" "$id" "$runtime" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  safety: %s\n' "$safety"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

container_total_kb() {
  local id runtime paths safety preview apply description total=0 kb
  while IFS=$'\t' read -r id runtime paths safety preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    total=$((total + kb))
  done < <(container_rows)
  printf '%s\n' "$total"
}

package_total_kb() {
  local id manager paths category preview apply total=0 kb
  while IFS=$'\t' read -r id manager paths category preview apply; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    total=$((total + kb))
  done < <(package_rows)
  printf '%s\n' "$total"
}

snapshot_rows() {
  command -v tmutil >/dev/null 2>&1 || return 0
  tmutil listlocalsnapshots / 2>/dev/null |
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local name date_part
      name="${line##* }"
      [[ "$name" == com.apple.* ]] || continue
      date_part="${name#com.apple.TimeMachine.}"
      printf '%s\t%s\n' "$name" "$date_part"
    done
}

snapshot_count() {
  snapshot_rows | awk 'END {print NR + 0}'
}

protected_present_count() {
  local file id type path reason expanded count=0
  file="$(protected_file)"
  [[ -f "$file" ]] || { printf '0\n'; return 0; }
  while IFS=$'\t' read -r id type path reason; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] && count=$((count + 1))
  done < <(tail -n +2 "$file")
  printf '%s\n' "$count"
}

app_bundle_count() {
  local total=0 root count
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    count="$(app_rows "$root" | awk 'END {print NR + 0}')"
    total=$((total + count))
  done < <(app_roots)
  printf '%s\n' "$total"
}

tab_rows_total_kb() {
  awk -F '\t' '{
    value = $1
    sub(/^0+/, "", value)
    if (value == "") value = 0
    total += value
  } END {print total + 0}'
}

tab_rows_count() {
  awk 'END {print NR + 0}'
}

review_rows() {
  local documents_kb desktop_kb downloads_rows_value downloads_kb downloads_count screenshots_rows_value screenshots_kb screenshots_count archives_rows_value archives_kb archives_count installers_rows_value installers_kb installers_count appdata_rows_value appdata_kb appdata_count communications_kb app_count

  documents_kb="$(size_kb "$HOME/Documents")"
  desktop_kb="$(size_kb "$HOME/Desktop")"
  downloads_rows_value="$(downloads_rows)"
  downloads_kb="$(printf '%s\n' "$downloads_rows_value" | tab_rows_total_kb)"
  downloads_count="$(printf '%s\n' "$downloads_rows_value" | sed '/^$/d' | tab_rows_count)"
  screenshots_rows_value="$(screenshot_rows)"
  screenshots_kb="$(printf '%s\n' "$screenshots_rows_value" | tab_rows_total_kb)"
  screenshots_count="$(printf '%s\n' "$screenshots_rows_value" | sed '/^$/d' | tab_rows_count)"
  archives_rows_value="$(archive_rows)"
  archives_kb="$(printf '%s\n' "$archives_rows_value" | tab_rows_total_kb)"
  archives_count="$(printf '%s\n' "$archives_rows_value" | sed '/^$/d' | tab_rows_count)"
  installers_rows_value="$(installer_rows)"
  installers_kb="$(printf '%s\n' "$installers_rows_value" | tab_rows_total_kb)"
  installers_count="$(printf '%s\n' "$installers_rows_value" | sed '/^$/d' | tab_rows_count)"
  appdata_rows_value="$(appdata_rows)"
  appdata_kb="$(printf '%s\n' "$appdata_rows_value" | tab_rows_total_kb)"
  appdata_count="$(printf '%s\n' "$appdata_rows_value" | sed '/^$/d' | tab_rows_count)"
  communications_kb="$(communications_total_kb)"
  app_count="$(app_bundle_count)"

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$documents_kb" "documents" "Documents folder" "cleanroom documents ~/Documents --limit 50" "Top-level Documents folders and files with guard status." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$desktop_kb" "desktop" "Desktop clutter" "cleanroom desktop --limit 50" "Top-level Desktop folders and files with guard status." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$downloads_kb" "downloads" "Old Downloads" "cleanroom downloads --days $DAYS --limit $LIMIT" "Top ${downloads_count} old Downloads files from the current review limit." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$screenshots_kb" "screenshots" "Screenshots and recordings" "cleanroom screenshots --days $DAYS --limit $LIMIT" "Top ${screenshots_count} screenshot and screen recording files from Desktop, Downloads, and Documents." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$archives_kb" "archives" "Archives and disk images" "cleanroom archives --days $DAYS --limit $LIMIT" "Top ${archives_count} archive and disk image files from Downloads, Desktop, and Documents." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$installers_kb" "installers" "Old installers" "cleanroom installers --days $DAYS --limit $LIMIT" "Top ${installers_count} downloaded installers that have an opt-in cleanup path." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$appdata_kb" "appdata" "Large app data folders" "cleanroom appdata --limit $LIMIT" "Top ${appdata_count} app support/container folders with guard status." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$communications_kb" "communications" "Mail and Messages" "cleanroom communications" "Protected Mail, Mail Downloads, Messages, and Messages attachments. Review-only." "review-only"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$app_count" "apps" "Installed app bundles" "cleanroom apps --limit $LIMIT" "Count of app bundles found in application folders; run the command for sizes." "count"
}

review() {
  local rows
  rows="$(review_rows | sort -rn)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 estimate id title command description kind
    while IFS=$'\t' read -r estimate id title command description kind; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      if [[ "$kind" == "count" ]]; then
        printf '{"id":"%s","title":"%s","kind":"%s","count":%s,"command":"%s","description":"%s"}' \
          "$(printf '%s' "$id" | json_escape)" \
          "$(printf '%s' "$title" | json_escape)" \
          "$(printf '%s' "$kind" | json_escape)" \
          "${estimate:-0}" \
          "$(printf '%s' "$command" | json_escape)" \
          "$(printf '%s' "$description" | json_escape)"
      else
        printf '{"id":"%s","title":"%s","kind":"%s","estimate_kb":%s,"estimate":"%s","command":"%s","description":"%s"}' \
          "$(printf '%s' "$id" | json_escape)" \
          "$(printf '%s' "$title" | json_escape)" \
          "$(printf '%s' "$kind" | json_escape)" \
          "${estimate:-0}" \
          "$(human_kb "${estimate:-0}" | json_escape)" \
          "$(printf '%s' "$command" | json_escape)" \
          "$(printf '%s' "$description" | json_escape)"
      fi
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom review${RESET}"
  printf 'Read-only personal storage checklist. Nothing is deleted.\n\n'
  printf '%-10s %-14s %-28s %s\n' "estimate" "id" "title" "next command"
  local estimate id title command description kind display
  while IFS=$'\t' read -r estimate id title command description kind; do
    [[ -z "${id:-}" ]] && continue
    if [[ "$kind" == "count" ]]; then
      display="${estimate:-0} apps"
    else
      display="$(human_kb "${estimate:-0}")"
    fi
    printf '%-10s %-14s %-28s %s\n' "$display" "$id" "$title" "$command"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

overview() {
  local plan_rows_sorted package_total toolchain_total container_total diagnostic_total protected_count snapshots app_count startup_items trash_total
  plan_rows_sorted="$(plan_rows | sort -rn | head -5)"
  package_total="$(package_total_kb)"
  toolchain_total="$(toolchain_total_kb)"
  container_total="$(container_total_kb)"
  diagnostic_total="$(diagnostic_total_kb)"
  protected_count="$(protected_present_count)"
  snapshots="$(snapshot_count)"
  app_count="$(app_bundle_count)"
  startup_items="$(startup_count)"
  trash_total="$(trash_total_kb)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    disk_json
    printf ',"summary":{"package_store_kb":%s,"package_store":"%s","toolchain_kb":%s,"toolchain":"%s","container_kb":%s,"container":"%s","diagnostic_kb":%s,"diagnostic":"%s","trash_kb":%s,"trash":"%s","protected_present":%s,"snapshot_count":%s,"app_bundle_count":%s,"startup_item_count":%s}' \
      "$package_total" \
      "$(human_kb "$package_total" | json_escape)" \
      "$toolchain_total" \
      "$(human_kb "$toolchain_total" | json_escape)" \
      "$container_total" \
      "$(human_kb "$container_total" | json_escape)" \
      "$diagnostic_total" \
      "$(human_kb "$diagnostic_total" | json_escape)" \
      "$trash_total" \
      "$(human_kb "$trash_total" | json_escape)" \
      "$protected_count" \
      "$snapshots" \
      "$app_count" \
      "$startup_items"
    printf ',"recommendations":['
    local first=1 kb id title preview_command apply_command description
    while IFS=$'\t' read -r kb id title preview_command apply_command description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","estimate_kb":%s,"estimate":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "${kb:-0}" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview_command" | json_escape)" \
        "$(printf '%s' "$apply_command" | json_escape)"
    done <<<"$plan_rows_sorted"
    printf ']}'
    printf '\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom overview${RESET}"
  printf 'Read-only dashboard. Nothing is deleted.\n\n'
  printf '%s\n' "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Summary${RESET}"
  printf '%-24s %s\n' "package stores" "$(human_kb "$package_total")"
  printf '%-24s %s\n' "toolchain caches" "$(human_kb "$toolchain_total")"
  printf '%-24s %s\n' "container storage" "$(human_kb "$container_total")"
  printf '%-24s %s\n' "diagnostics" "$(human_kb "$diagnostic_total")"
  printf '%-24s %s\n' "Trash" "$(human_kb "$trash_total")"
  printf '%-24s %s\n' "protected paths present" "$protected_count"
  printf '%-24s %s\n' "local snapshots" "$snapshots"
  printf '%-24s %s\n' "app bundles" "$app_count"
  printf '%-24s %s\n' "startup items" "$startup_items"

  printf '\n%s\n' "${BOLD}Top cleanup recommendations${RESET}"
  printf '%-10s %-18s %-32s %s\n' "estimate" "id" "title" "preview command"
  local kb id title preview_command apply_command description
  while IFS=$'\t' read -r kb id title preview_command apply_command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-18s %-32s %s\n' "$(human_kb "${kb:-0}")" "$id" "$title" "$preview_command"
  done <<<"$plan_rows_sorted"

  printf '\n%s\n' "${BOLD}Useful next commands${RESET}"
  printf 'cleanroom map\n'
  printf 'cleanroom snapshot\n'
  printf 'cleanroom diff\n'
  printf 'cleanroom state\n'
  printf 'cleanroom permissions\n'
  printf 'cleanroom review\n'
  printf 'cleanroom plan\n'
  printf 'cleanroom system-data\n'
  printf 'cleanroom brokenlinks --limit 50\n'
  printf 'cleanroom quarantine --limit 50\n'
  printf 'cleanroom documents ~/Documents --limit 50\n'
  printf 'cleanroom large ~/Documents --min-mb 250 --limit 50\n'
  printf 'cleanroom downloads --days 30 --limit 50\n'
  printf 'cleanroom venvs --days 30 --limit 50\n'
  printf 'cleanroom appdata --limit 30\n'
  printf 'cleanroom uninstallers --limit 50\n'
  printf 'cleanroom libraries\n'
  printf 'cleanroom trash\n'
  printf 'cleanroom startup\n'
  printf 'cleanroom loginitems\n'
  printf 'cleanroom packages\n'
  printf 'cleanroom receipts --limit 50\n'
  printf 'cleanroom homebrew\n'
  printf 'cleanroom toolchains\n'
  printf 'cleanroom updaters\n'
  printf 'cleanroom containers\n'
  printf 'cleanroom cloud\n'
  printf 'cleanroom cloudfiles --min-mb 250 --limit 50\n'
  printf 'cleanroom personal\n'
  printf 'cleanroom communications\n'
  printf 'cleanroom browsercaches\n'
  printf 'cleanroom diagnostics\n'
  printf 'cleanroom protect\n'
}

snapshots() {
  local rows
  rows="$(snapshot_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 name date_part
    while IFS=$'\t' read -r name date_part; do
      [[ -z "${name:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","date":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$date_part" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom local snapshots${RESET}"
  printf 'Review-only list. Snapshot thinning is opt-in and may not be restorable through cleanroom.\n\n'
  if ! command -v tmutil >/dev/null 2>&1; then
    printf 'tmutil is not available on this system.\n'
    return 0
  fi
  if [[ -z "$rows" ]]; then
    printf 'No local Time Machine snapshots found.\n'
    return 0
  fi
  local name date_part
  printf '%-32s %s\n' "date" "snapshot"
  while IFS=$'\t' read -r name date_part; do
    [[ -z "${name:-}" ]] && continue
    printf '%-32s %s\n' "$date_part" "$name"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-snapshots\n'
  printf 'Apply thinning with: cleanroom clean --include-snapshots --apply\n'
}

plan_rows() {
  local safe package toolchain app browsercache_total installers download_artifacts screenshots_total cleanroom_state_total metadata_total quicklook_total fontcache_total webcache_total savedstate_total projectcache_total updatercache_total devicebackup_total node venv dev diagnostics ai_workspaces ai_models containers user_trash
  safe="$(sum_existing_kb \
    "~/Library/Caches" "~/.cache" "~/.npm/_cacache" "~/.npm/_logs" "~/.npm/_npx" \
    "~/.yarn/cache" "~/.yarn/berry" "~/.gradle/caches" "~/.gradle/daemon" \
    "~/.gradle/native" "~/.gradle/workers" "~/Library/pnpm/store" \
    "~/Library/Developer/Xcode/DerivedData" "~/Library/Developer/CoreSimulator/Caches" \
    "~/Library/Caches/Homebrew" "~/Library/Logs")"
  package="$(sum_existing_kb "~/Library/pnpm/store" "~/.pnpm-store" "~/.cocoapods/repos" "~/.cargo/registry/cache")"
  toolchain="$(toolchain_total_kb)"
  app="$(app_cache_kb)"
  browsercache_total="$(browsercache_total_kb)"
  installers="$(installer_total_kb)"
  download_artifacts="$(download_artifact_total_kb)"
  screenshots_total="$(screenshot_total_kb)"
  cleanroom_state_total="$(cleanroom_state_cleanup_total_kb)"
  metadata_total="$(metadata_total_kb)"
  quicklook_total="$(quicklook_total_kb)"
  fontcache_total="$(fontcache_total_kb)"
  webcache_total="$(webcache_total_kb)"
  savedstate_total="$(savedstate_total_kb)"
  projectcache_total="$(projectcache_total_kb)"
  updatercache_total="$(updatercache_total_kb)"
  devicebackup_total="$(backup_cleanup_rows | tab_rows_total_kb)"
  node="$(stale_node_kb)"
  venv="$(stale_venv_kb)"
  dev="$(sum_existing_kb \
    "~/Library/Developer/Xcode/iOS DeviceSupport" "~/Library/Developer/Xcode/watchOS DeviceSupport" \
    "~/Library/Developer/Xcode/tvOS DeviceSupport" "~/Library/Android/sdk/ndk" \
    "~/Library/Android/sdk/system-images" "~/Library/Android/sdk/.downloadIntermediates" \
    "~/Library/Android/sdk/.temp")"
  diagnostics="$(sum_existing_kb "~/Library/DiagnosticReports" "~/Library/Application Support/CrashReporter")"
  ai_workspaces="$(sum_existing_kb "~/.gemini")"
  ai_models="$(sum_existing_kb "~/.lmstudio/models" "~/.lmstudio/extensions/backends" "~/.ollama/models" "~/.cache/huggingface/hub" "~/.cache/modelscope" "~/.cache/torch/hub" "~/.cache/whisper")"
  containers="$(container_total_kb)"
  user_trash="$(trash_total_kb)"

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$safe" "safe" "Default safe cleanup" "cleanroom clean" "cleanroom clean --apply --trash" "Rebuildable caches and old logs. Recommended first step."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$app" "app-caches" "Safe app cache folders" "cleanroom clean --include-app-caches" "cleanroom clean --apply --trash --include-app-caches" "Nested cache folders only; browser profiles and passwords stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$browsercache_total" "browser-caches" "Chromium/Firefox browser caches" "cleanroom browsercaches" "cleanroom clean --apply --trash --include-browser-caches" "Rebuildable browser cache folders only. Profiles, passwords, cookies, bookmarks, sessions, extensions, and settings stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$installers" "old-installers" "Old downloaded installers" "cleanroom clean --include-installers --days $DAYS" "cleanroom clean --apply --trash --include-installers --days $DAYS" "Downloaded .dmg, .pkg, .mpkg, .xip, .ipsw, and .iso files older than $DAYS days in ~/Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$download_artifacts" "download-artifacts" "Old downloadable artifacts" "cleanroom downloads --days $DAYS" "cleanroom clean --apply --trash --include-download-artifacts --days $DAYS" "Old installers, disk images, and archive files directly under ~/Downloads. Arbitrary documents and folders stay untouched."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$screenshots_total" "screenshots" "Old screenshots and screen recordings" "cleanroom screenshots --days $DAYS" "cleanroom clean --apply --trash --include-screenshots --days $DAYS" "Known screenshot and screen recording files older than $DAYS days under Desktop, Downloads, and Documents."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$cleanroom_state_total" "cleanroom-state" "Old cleanroom-created state" "cleanroom state" "cleanroom clean --apply --include-cleanroom-state --days $DAYS" "Old cleanroom run logs, storage snapshots, and recoverable Trash folders created by previous --trash runs."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$metadata_total" "metadata" "Filesystem metadata clutter" "cleanroom metadata" "cleanroom metadata --apply --trash" ".DS_Store, AppleDouble, Thumbs.db, Desktop.ini, and similar clutter under Desktop, Documents, and Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$quicklook_total" "quicklook" "Quick Look caches" "cleanroom quicklook" "cleanroom clean --apply --trash --include-quicklook" "Rebuildable Quick Look thumbnail and preview caches."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$fontcache_total" "font-caches" "Font cache databases" "cleanroom fontcaches" "cleanroom clean --apply --trash --include-font-caches" "Rebuildable Apple Type Services and font registry caches. Actual font files stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$webcache_total" "web-caches" "Safari/WebKit caches" "cleanroom webcaches" "cleanroom clean --apply --trash --include-web-caches" "Rebuildable Safari and WebKit cache folders. Browser history, cookies, bookmarks, passwords, website data, and profiles stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$savedstate_total" "saved-state" "Saved Application State" "cleanroom savedstate" "cleanroom clean --apply --trash --include-saved-state" "Rebuildable app window/session restoration state. Documents and app profiles stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$projectcache_total" "project-caches" "Project cache artifacts" "cleanroom projectcaches" "cleanroom clean --apply --trash --include-project-caches" "Rebuildable project caches such as __pycache__, pytest, mypy, ruff, tox, nox, and coverage artifacts."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$updatercache_total" "updater-caches" "App updater caches" "cleanroom updaters" "cleanroom clean --apply --trash --include-updater-caches" "Rebuildable Sparkle/Squirrel updater cache and staging data. Apps and profiles stay protected."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$devicebackup_total" "device-backups" "Old local iPhone/iPad backups" "cleanroom backups" "cleanroom clean --include-device-backups --days $DAYS --apply --trash" "High-impact opt-in cleanup for direct MobileSync backup folders older than $DAYS days. Confirm another backup exists first."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$package" "package-stores" "Package-manager stores" "cleanroom clean --include-package-stores" "cleanroom clean --apply --trash --include-package-stores" "Rebuildable package stores such as pnpm, CocoaPods, Cargo, and Gradle-related stores."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$toolchain" "toolchains" "Language toolchain caches" "cleanroom toolchains" "cleanroom clean --apply --trash --include-toolchains" "Rebuildable caches for Go, Python, SwiftPM, Maven, Composer, RubyGems, Bundler, uv, and Poetry."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$node" "node-stale" "Stale node_modules" "cleanroom clean --include-node-stale --days $DAYS" "cleanroom clean --apply --trash --include-node-stale --days $DAYS" "node_modules older than $DAYS days under Desktop, Documents, and Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$venv" "venv-stale" "Stale Python virtualenvs" "cleanroom venvs --days $DAYS" "cleanroom clean --apply --trash --include-venv-stale --days $DAYS" "Python virtualenv folders older than $DAYS days under Desktop, Documents, and Downloads."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$dev" "dev-heavy" "Heavy SDK and simulator artifacts" "cleanroom clean --include-dev-heavy" "cleanroom clean --apply --trash --include-dev-heavy" "Opt-in cleanup that may require re-downloading SDKs or resetting simulator app data."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$diagnostics" "diagnostics" "Old diagnostic reports" "cleanroom diagnostics" "cleanroom clean --apply --trash --include-diagnostics --days $DAYS" "Opt-in cleanup for user diagnostic reports and CrashReporter files older than $DAYS days."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$ai_workspaces" "ai-workspaces" "Generated AI workspace state" "cleanroom clean --include-ai-workspaces" "cleanroom clean --apply --trash --include-ai-workspaces" "Generated recordings, scratch, brain, implicit data, and conversation caches where known."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$ai_models" "ai-models" "Downloaded local AI models" "cleanroom clean --include-ai-models" "cleanroom clean --apply --trash --include-ai-models" "Large model stores and backend extensions that may need to be downloaded again."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$containers" "containers" "Container VM disks and stores" "cleanroom containers" "cleanroom clean --apply --trash --include-containers" "High-impact opt-in cleanup that can remove local containers, images, and volumes."
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$user_trash" "user-trash" "Current user Trash" "cleanroom trash" "cleanroom clean --include-user-trash --apply" "Already-deleted user Trash contents. Emptying Trash is explicit and irreversible."
}

plan() {
  local rows
  rows="$(plan_rows | sort -rn)"
  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title preview_command apply_command description
    while IFS=$'\t' read -r kb id title preview_command apply_command description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","estimate_kb":%s,"estimate":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "${kb:-0}" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview_command" | json_escape)" \
        "$(printf '%s' "$apply_command" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom plan${RESET}"
  printf 'Commands shown are dry-runs. Add --apply --trash only after reviewing output.\n\n'
  printf '%-10s %-18s %-32s %s\n' "estimate" "id" "title" "preview command"
  while IFS=$'\t' read -r kb id title preview_command apply_command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-18s %-32s %s\n' "$(human_kb "${kb:-0}")" "$id" "$title" "$preview_command"
    printf '  apply: %s\n' "$apply_command"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

report_body() {
  local now
  now="$(date '+%Y-%m-%d %H:%M:%S %Z')"
  printf '# cleanroom report\n\n'
  printf '%s\n' "- Generated: $now"
  printf '%s\n\n' "- Version: $VERSION"

  printf '## Disk\n\n```text\n'
  disk_line
  printf '```\n\n'

  printf '## Cleanup Candidates\n\n'
  printf '| Size | Path |\n| ---: | --- |\n'
  local path kb
  while IFS= read -r path; do
    kb="$(size_kb "$path")"
    printf '| %s | `%s` |\n' "$(human_kb "$kb")" "$(expand_path "$path")"
  done < <(report_candidate_paths)

  printf '\n## Largest Cleanup Candidates\n\n```text\n'
  while IFS= read -r path; do
    kb="$(size_kb "$path")"
    printf '%012d\t%s\t%s\n' "$kb" "$(human_kb "$kb")" "$(expand_path "$path")"
  done < <(report_candidate_paths) | sort -n | tail -20 | awk -F '\t' '{printf "%8s  %s\n", $2, $3}'
  printf '```\n\n'

  printf 'Broad personal folders such as `~/Documents`, `~/Desktop`, `~/Downloads`, and `~/Library/Application Support` are intentionally not recursively measured in this quick report. Run `cleanroom documents ~/Documents --limit 50` to drill into Documents, or `cleanroom scan` when you want the heavier full view.\n\n'

  printf '## Large File Hints Over 500MB\n\n```text\n'
  if command -v mdfind >/dev/null 2>&1; then
    mdfind -onlyin "$HOME" 'kMDItemFSSize > 524288000' 2>/dev/null |
      head -100 |
      while IFS= read -r path; do
        [[ -f "$path" ]] && print_size "$path"
      done | sort -h | tail -30 || true
  else
    printf 'Spotlight mdfind is not available on this system.\n'
  fi
  printf '```\n\n'

  printf '## Safety Notes\n\n'
  printf 'cleanroom does not delete browser profiles, password databases, Keychains, Photos, Mail, or iCloud Drive by default.\n'

  local protected_catalog
  protected_catalog="$(protected_file)"
  if [[ -f "$protected_catalog" ]]; then
    printf '\n## Protected Personal Data\n\n'
    printf '| Status | Type | Size | ID | Path |\n| --- | --- | ---: | --- | --- |\n'
    local id type protected_path reason expanded status protected_kb
    tail -n +2 "$protected_catalog" | while IFS=$'\t' read -r id type protected_path reason; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$protected_path")"
      if [[ -e "$expanded" ]]; then
        status="present"
        protected_kb="$(size_kb "$expanded")"
      else
        status="missing"
        protected_kb=0
      fi
      printf '| %s | %s | %s | `%s` | `%s` |\n' "$status" "$type" "$(human_kb "$protected_kb")" "$id" "$expanded"
    done
  fi
}

report() {
  if [[ -n "$OUTPUT_FILE" ]]; then
    report_body | redact_stream >"$(expand_path "$OUTPUT_FILE")"
    ok "Wrote report: $(redact_string "$(expand_path "$OUTPUT_FILE")")"
  else
    report_body | redact_stream
  fi
}

rules() {
  local file id category safety default opt_in paths description
  file="$(rules_file)"
  [[ -f "$file" ]] || die "Rule catalog not found."

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1
    tail -n +2 "$file" | while IFS=$'\t' read -r id category safety default opt_in paths description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","category":"%s","safety":"%s","default":%s,"opt_in":"%s","paths":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
        "$(if [[ "$default" == "yes" ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "$opt_in" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom rules${RESET}"
  printf '%-24s %-17s %-20s %-7s %-26s %s\n' "id" "category" "safety" "default" "opt-in" "paths"
  tail -n +2 "$file" | while IFS=$'\t' read -r id category safety default opt_in paths description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-24s %-17s %-20s %-7s %-26s %s\n' "$id" "$category" "$safety" "$default" "${opt_in:--}" "$paths"
  done
}

protect() {
  local file id type path reason expanded status kb
  file="$(protected_file)"
  [[ -f "$file" ]] || die "Protected path catalog not found."

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1
    tail -n +2 "$file" | while IFS=$'\t' read -r id type path reason; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      if [[ -e "$expanded" ]]; then
        status="present"
        kb="$(size_kb "$expanded")"
      else
        status="missing"
        kb=0
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","type":"%s","path":"%s","status":"%s","size_kb":%s,"size":"%s","reason":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$type" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$status" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$reason" | json_escape)"
    done
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom protected data audit${RESET}"
  printf 'These locations are treated as personal state and are not removed wholesale by cleanroom.\n\n'
  printf '%-10s %-18s %-8s %-18s %s\n' "status" "type" "size" "id" "path"
  tail -n +2 "$file" | while IFS=$'\t' read -r id type path reason; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    if [[ -e "$expanded" ]]; then
      status="present"
      kb="$(size_kb "$expanded")"
    else
      status="missing"
      kb=0
    fi
    printf '%-10s %-18s %-8s %-18s %s\n' "$status" "$type" "$(human_kb "$kb")" "$id" "$expanded"
    printf '  %s\n' "$reason"
  done
}

permission_rows() {
  printf '%s\t%s\t%s\t%s\t%s\n' "home-library" "User Library" "~/Library" "cleanroom system-data" "Main hidden user Library. Many macOS storage categories live here."
  printf '%s\t%s\t%s\t%s\t%s\n' "application-support" "Application Support" "~/Library/Application Support" "cleanroom appdata --limit 50" "Large app data and support folders. Some apps protect account state."
  printf '%s\t%s\t%s\t%s\t%s\n' "mail" "Mail" "~/Library/Mail" "cleanroom communications" "Mail data may require Full Disk Access for complete inventory."
  printf '%s\t%s\t%s\t%s\t%s\n' "messages" "Messages" "~/Library/Messages" "cleanroom communications" "Messages chats and attachments may require Full Disk Access for complete inventory."
  printf '%s\t%s\t%s\t%s\t%s\n' "mobile-backups" "Device Backups" "~/Library/Application Support/MobileSync/Backup" "cleanroom backups" "Local iPhone/iPad backups are protected and may require extra access."
  printf '%s\t%s\t%s\t%s\t%s\n' "photos" "Photos Library" "~/Pictures/Photos Library.photoslibrary" "cleanroom libraries" "Photos libraries are protected personal media."
  printf '%s\t%s\t%s\t%s\t%s\n' "cloudstorage" "CloudStorage" "~/Library/CloudStorage" "cleanroom cloud" "Modern cloud provider roots often live here."
  printf '%s\t%s\t%s\t%s\t%s\n' "icloud-drive" "iCloud Drive" "~/Library/Mobile Documents" "cleanroom cloud" "iCloud Drive and app document storage."
  printf '%s\t%s\t%s\t%s\t%s\n' "browser-profiles" "Browser Profiles" "~/Library/Application Support/Google/Chrome" "cleanroom browsers" "Browser profiles are protected; Cleanroom only inventories and cleans nested caches."
  printf '%s\t%s\t%s\t%s\t%s\n' "keychains" "Keychains" "~/Library/Keychains" "cleanroom protect" "Credential storage should remain protected and is never cleaned by Cleanroom."
}

permission_status() {
  local path="$1"
  if [[ ! -e "$path" ]]; then
    printf 'missing'
  elif [[ -d "$path" ]]; then
    if ls "$path" >/dev/null 2>&1; then
      printf 'accessible'
    elif [[ -r "$path" || -x "$path" ]]; then
      printf 'limited'
    else
      printf 'blocked'
    fi
  elif [[ -r "$path" ]]; then
    printf 'accessible'
  else
    printf 'blocked'
  fi
}

permissions() {
  local rows
  rows="$(permission_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title path command guidance expanded exists_flag readable listable status
    while IFS=$'\t' read -r id title path command guidance; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      if [[ -e "$expanded" ]]; then exists_flag=true; else exists_flag=false; fi
      if [[ -r "$expanded" ]]; then readable=true; else readable=false; fi
      if [[ -d "$expanded" ]] && ls "$expanded" >/dev/null 2>&1; then listable=true; else listable=false; fi
      status="$(permission_status "$expanded")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","path":"%s","exists":%s,"readable":%s,"listable":%s,"status":"%s","command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$exists_flag" \
        "$readable" \
        "$listable" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$command" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom permissions${RESET}"
  printf 'Read-only access audit. If important existing paths show blocked/limited, grant Full Disk Access to the terminal or app running cleanroom.\n\n'
  printf '%-12s %-22s %-28s %s\n' "status" "id" "next command" "path"
  local id title path command guidance expanded status
  while IFS=$'\t' read -r id title path command guidance; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    status="$(permission_status "$expanded")"
    printf '%-12s %-22s %-28s %s\n' "$status" "$id" "$command" "$expanded"
    printf '  %s\n' "$guidance"
  done <<<"$rows"
}

guard_status() {
  local path="$1"
  local reason
  if is_dangerous_path "$path"; then
    printf '%s\t%s\n' "refused-dangerous" "Broad system, home, Library, or personal folder paths are never removed directly."
    return 0
  fi
  reason="$(protected_removal_reason "$path" || true)"
  if [[ -n "$reason" ]]; then
    printf '%s\t%s\n' "refused-protected" "$reason"
    return 0
  fi
  if is_excluded "$path"; then
    printf '%s\t%s\n' "excluded" "Matched a user-provided --exclude or config exclude."
    return 0
  fi
  printf '%s\t%s\n' "allowed" "No built-in guard blocks this path; cleanup still requires a matching rule and --apply."
}

guard() {
  [[ "${#PATH_ARGS[@]}" -gt 0 ]] || die "guard requires at least one path"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 path expanded exists_flag kb status reason line
    for path in "${PATH_ARGS[@]}"; do
      expanded="$(expand_path "$path")"
      if [[ -e "$expanded" ]]; then
        exists_flag=true
        kb="$(size_kb "$expanded")"
      else
        exists_flag=false
        kb=0
      fi
      line="$(guard_status "$expanded")"
      status="${line%%$'\t'*}"
      reason="${line#*$'\t'}"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","exists":%s,"size_kb":%s,"size":"%s","status":"%s","reason":"%s"}' \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$exists_flag" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$reason" | json_escape)"
    done
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom guard${RESET}"
  printf '%-18s %-8s %-8s %s\n' "status" "exists" "size" "path"
  local path expanded exists_label kb status reason line
  for path in "${PATH_ARGS[@]}"; do
    expanded="$(expand_path "$path")"
    if [[ -e "$expanded" ]]; then
      exists_label=yes
      kb="$(size_kb "$expanded")"
    else
      exists_label=no
      kb=0
    fi
    line="$(guard_status "$expanded")"
    status="${line%%$'\t'*}"
    reason="${line#*$'\t'}"
    printf '%-18s %-8s %-8s %s\n' "$status" "$exists_label" "$(human_kb "$kb")" "$expanded"
    printf '  %s\n' "$reason"
  done
}

doctor() {
  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    printf '"version":"%s",' "$(printf '%s' "$VERSION" | json_escape)"
    printf '"platform":{"shell":"%s","macos":"%s","architecture":"%s"},' \
      "$(printf '%s' "${SHELL:-unknown}" | json_escape)" \
      "$(sw_vers -productVersion 2>/dev/null | json_escape || printf 'unknown')" \
      "$(uname -m | json_escape)"
    printf '"config":{"loaded":%s,"path":"%s","excludes":%s},' \
      "$(if [[ "$CONFIG_LOADED" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(printf '%s' "${CONFIG_FILE:-}" | json_escape)" \
      "${#EXCLUDES[@]}"
    disk_json
    printf ',"tools":['
    local first=1 tool required status
    for tool in du find awk sort xargs shasum sqlite3 plutil tmutil brew xcrun; do
      case "$tool" in
        brew|xcrun) required=false ;;
        *) required=true ;;
      esac
      if command -v "$tool" >/dev/null 2>&1; then
        status="ok"
      elif [[ "$required" == true ]]; then
        status="missing"
      else
        status="optional-missing"
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","required":%s,"status":"%s"}' "$tool" "$required" "$status"
    done
    printf ']'
    printf ',"safety":{"protected_present":%s,"rules_catalog":%s,"protected_catalog":%s}' \
      "$(protected_present_count)" \
      "$(if [[ -f "$(rules_file)" ]]; then echo true; else echo false; fi)" \
      "$(if [[ -f "$(protected_file)" ]]; then echo true; else echo false; fi)"
    printf '}\n'
    return 0
  fi

  log "${BOLD}cleanroom doctor${RESET}"
  printf '%-28s %s\n' "version" "$VERSION"
  printf '%-28s %s\n' "shell" "${SHELL:-unknown}"
  printf '%-28s %s\n' "macOS" "$(sw_vers -productVersion 2>/dev/null || echo unknown)"
  printf '%-28s %s\n' "architecture" "$(uname -m)"
  printf '%-28s %s\n' "config" "$(if [[ "$CONFIG_LOADED" -eq 1 ]]; then echo "$CONFIG_FILE"; else echo "not loaded"; fi)"
  printf '%-28s %s\n' "excludes" "${#EXCLUDES[@]}"
  printf '%-28s ' "disk"
  df -h /System/Volumes/Data 2>/dev/null | awk 'NR==2 {print $4 " free, " $5 " used"}' || df -h / | awk 'NR==2 {print $4 " free, " $5 " used"}'

  printf '\n%s\n' "${BOLD}Tools${RESET}"
  local tool
  for tool in du find awk sort xargs sqlite3 plutil tmutil; do
    if command -v "$tool" >/dev/null 2>&1; then
      printf '%-28s %s\n' "$tool" "ok"
    else
      printf '%-28s missing\n' "$tool"
    fi
  done
  if command -v brew >/dev/null 2>&1; then
    printf '%-28s %s\n' "brew" "ok"
  else
    printf '%-28s %s\n' "brew" "optional missing"
  fi
  if command -v xcrun >/dev/null 2>&1; then
    printf '%-28s %s\n' "xcrun" "ok"
  else
    printf '%-28s %s\n' "xcrun" "optional missing"
  fi

  printf '\n%s\n' "${BOLD}Protected data check${RESET}"
  printf 'Run `cleanroom protect` for the full protected path audit.\n'
  local protected=(
    "$HOME/Library/Keychains"
    "$HOME/Library/Application Support/Google/Chrome"
    "$HOME/Library/Mail"
    "$HOME/Library/Mobile Documents"
    "$HOME/Library/Application Support/MobileSync/Backup"
    "$HOME/Pictures/Photos Library.photoslibrary"
  )
  local p
  for p in "${protected[@]}"; do
    [[ -e "$p" ]] && printf '%-28s present, protected\n' "$(basename "$p")"
  done
  return 0
}

init_config() {
  local file
  file="${CONFIG_FILE:-$(config_default_path)}"
  file="$(expand_path "$file")"
  if [[ -e "$file" && "$ASSUME_YES" -ne 1 ]]; then
    die "Config already exists: $file"
  fi
  mkdir -p "$(dirname "$file")"
  cat >"$file" <<'EOF'
# cleanroom config
# Data only: this file is not executed as shell.

# preset can be: safe, dev, ai, deep
preset=dev

# stale node_modules and virtualenv threshold
days=30

# Optional categories
include_app_caches=true
include_package_stores=true
include_toolchains=true
include_diagnostics=false
include_node_stale=true
include_venv_stale=false
include_dev_heavy=false
include_snapshots=false
include_ai_workspaces=false
include_ai_models=false
include_containers=false
include_installers=false
include_download_artifacts=false
include_screenshots=false
include_cleanroom_state=false
include_metadata=false
include_quicklook=false
include_font_caches=false
include_web_caches=false
include_saved_state=false
include_project_caches=false
include_updater_caches=false
include_browser_caches=false
include_device_backups=false

# Apply safety
trash=false
# log_file=~/.local/state/cleanroom/runs/custom.log

# Protect custom paths from deletion.
# Add one exclude=... line per path.
# exclude=~/Desktop/important-project
EOF
  ok "Wrote config: $file"
}

ask_yes_no() {
  local prompt="$1"
  local answer
  printf '%s [y/N]: ' "$prompt"
  read -r answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

interactive() {
  log "${BOLD}cleanroom interactive${RESET}"
  warn "Interactive mode still dry-runs unless --apply is passed."
  ask_yes_no "Include safe app cache folders?" && INCLUDE_APP_CACHES=1
  ask_yes_no "Include package-manager stores?" && INCLUDE_PACKAGE_STORES=1
  ask_yes_no "Include language/toolchain caches?" && INCLUDE_TOOLCHAINS=1
  ask_yes_no "Include old diagnostic reports older than ${DAYS} days?" && INCLUDE_DIAGNOSTICS=1
  ask_yes_no "Include old downloaded installers older than ${DAYS} days?" && INCLUDE_INSTALLERS=1
  ask_yes_no "Include old downloadable artifacts in Downloads older than ${DAYS} days?" && INCLUDE_DOWNLOAD_ARTIFACTS=1
  ask_yes_no "Include old screenshots and screen recordings older than ${DAYS} days?" && INCLUDE_SCREENSHOTS=1
  ask_yes_no "Include old cleanroom-created state older than ${DAYS} days?" && INCLUDE_CLEANROOM_STATE=1
  ask_yes_no "Include filesystem metadata clutter?" && INCLUDE_METADATA=1
  ask_yes_no "Include Quick Look thumbnail caches?" && INCLUDE_QUICKLOOK=1
  ask_yes_no "Include user font cache databases?" && INCLUDE_FONT_CACHES=1
  ask_yes_no "Include Safari and WebKit cache folders?" && INCLUDE_WEB_CACHES=1
  ask_yes_no "Include saved app window/session state?" && INCLUDE_SAVED_STATE=1
  ask_yes_no "Include project cache artifacts?" && INCLUDE_PROJECT_CACHES=1
  ask_yes_no "Include Sparkle/Squirrel app updater caches?" && INCLUDE_UPDATER_CACHES=1
  ask_yes_no "Include Chromium/Firefox browser cache folders?" && INCLUDE_BROWSER_CACHES=1
  ask_yes_no "Include old local iPhone/iPad backups older than ${DAYS} days?" && INCLUDE_DEVICE_BACKUPS=1
  ask_yes_no "Include stale node_modules older than ${DAYS} days?" && INCLUDE_NODE_STALE=1
  ask_yes_no "Include stale Python virtualenvs older than ${DAYS} days?" && INCLUDE_VENV_STALE=1
  ask_yes_no "Include heavy SDK/simulator cleanup?" && INCLUDE_DEV_HEAVY=1
  ask_yes_no "Include local snapshot thinning?" && INCLUDE_SNAPSHOTS=1
  ask_yes_no "Include AI-agent workspace cleanup?" && INCLUDE_AI_WORKSPACES=1
  ask_yes_no "Include downloaded AI model cleanup?" && INCLUDE_AI_MODELS=1
  ask_yes_no "Include container VM disk cleanup?" && INCLUDE_CONTAINERS=1
  ask_yes_no "Empty current user Trash?" && INCLUDE_USER_TRASH=1
  clean
}

categories() {
  cat <<'EOF'
cleanroom categories

Default safe cleanup:
  Rebuildable user caches, logs older than 7 days, npm/Yarn/Gradle cache, Xcode DerivedData.

--include-app-caches:
  Nested app cache folders only. Does not remove browser profiles, password databases,
  cookies, bookmarks, or full app profile directories.

--include-package-stores:
  Rebuildable package-manager stores such as pnpm, CocoaPods repos, Gradle caches,
  and Cargo registry cache.

--include-toolchains:
  Rebuildable language/toolchain caches such as Go build/module cache, pip, uv,
  Poetry, SwiftPM, Maven, Composer, RubyGems, and Bundler cache.

--include-diagnostics:
  Old user diagnostic reports and CrashReporter files older than --days.

--include-node-stale:
  node_modules older than --days under Desktop/Documents/Downloads.

--include-venv-stale:
  Python virtualenv folders older than --days under Desktop/Documents/Downloads.
  Only folders containing pyvenv.cfg are removed.

--include-installers:
  Old downloaded installer files in ~/Downloads, such as .dmg, .pkg, .mpkg,
  .xip, .ipsw, and .iso files older than --days.

--include-download-artifacts:
  Old downloadable artifacts directly in ~/Downloads, such as installers,
  disk images, .zip/.rar/.7z, and tar/gzip/xz/bzip archives older than --days.
  This does not remove arbitrary documents, photos, folders, or nested files.

--include-screenshots:
  Old screenshot and screen recording files under Desktop, Downloads, and
  Documents. Only known screenshot/recording filenames older than --days are
  targeted; arbitrary images and videos are not removed.

--include-cleanroom-state:
  Old cleanroom-created audit logs, storage snapshots, and recoverable
  ~/.Trash/cleanroom-* folders older than --days. This only targets state
  created by cleanroom and is never included in presets.

--include-metadata:
  Filesystem metadata clutter such as .DS_Store, AppleDouble ._* files,
  __MACOSX folders, Thumbs.db, Desktop.ini, and similar removable metadata
  under Desktop/Documents/Downloads or paths passed to cleanroom metadata.

--include-quicklook:
  Rebuildable Quick Look thumbnail and preview caches. macOS recreates these
  when Finder, Spotlight, or file dialogs need previews again.

--include-font-caches:
  Rebuildable Apple Type Services and Font Registry user cache databases.
  Actual fonts in ~/Library/Fonts, /Library/Fonts, and System font folders are
  never removed.

--include-web-caches:
  Safari and WebKit cache folders only. History, cookies, passwords, bookmarks,
  website data, Keychains, and browser profiles are never removed.

--include-saved-state:
  Saved app window/session restoration state. Apps may reopen without their
  previous windows, but documents and app profiles are never removed.

--include-project-caches:
  Rebuildable project cache artifacts such as __pycache__, .pytest_cache,
  .mypy_cache, .ruff_cache, .tox, .nox, htmlcov, and .coverage under Desktop,
  Documents, and Downloads. Source, .git, node_modules, and virtualenv folders
  are not targeted by this category.

--include-updater-caches:
  Rebuildable Sparkle and Squirrel updater cache/staging data. Apps, app profiles,
  browser profiles, passwords, cookies, bookmarks, and settings are not targeted.

--include-browser-caches:
  Rebuildable Chromium and Firefox cache folders only. Browser profiles, password
  databases, cookies, bookmarks, sessions, extensions, and settings are not targeted.

--include-device-backups:
  High-impact cleanup for local iPhone/iPad backups under MobileSync older than
  --days. Requires --trash, is never included in presets, and should only be used
  after confirming another backup exists.

--include-dev-heavy:
  Xcode device support, unavailable simulators, simulator app data, Android NDK,
  and Android system images.

--include-ai-workspaces:
  Generated AI-agent recordings, scratch data, local brain/memory, implicit data,
  and local conversation caches where known.

--include-ai-models:
  Downloaded local AI model stores such as LM Studio, Ollama, Hugging Face, torch hub,
  ModelScope, and Whisper cache.

--include-containers:
  Local container VM disks and image stores for Docker Desktop, Colima, Lima, and
  Podman. This can remove containers, images, and volumes.

--include-user-trash:
  Empty ~/.Trash. This is irreversible and intentionally not included in presets.

--trash:
  Move cleanroom path removals to ~/.Trash/cleanroom-* during --apply runs.
  Commands delegated to system tools, such as snapshot thinning or simulator reset,
  may still be irreversible.

Presets:
  safe  default cleanup only
  dev   safe + app caches + package/toolchain stores + stale node_modules + stale virtualenvs
  deep  dev + heavy SDKs + snapshots + AI workspaces
EOF
}

clean() {
  if [[ "$PREFLIGHT" -eq 1 ]]; then
    preflight
    return 0
  fi
  if [[ "$APPLY" -eq 1 ]]; then
    warn "Apply mode enabled."
    [[ "$TRASH" -eq 1 ]] && warn "Trash mode enabled."
  else
    warn "Dry-run mode. Pass --apply to actually delete."
  fi
  confirm_apply
  ensure_apply_log
  [[ "$APPLY" -eq 1 ]] && warn "Apply log: $LOG_FILE"
  disk_line
  safe_clean
  clean_logs
  clean_diagnostics
  clean_package_stores
  clean_toolchains
  clean_app_caches
  clean_dev_heavy
  clean_installers
  clean_download_artifacts
  clean_screenshots
  clean_cleanroom_state
  clean_metadata
  clean_quicklook
  clean_font_caches
  clean_web_caches
  clean_saved_state
  clean_project_caches
  clean_updater_caches
  clean_browser_caches
  clean_device_backups
  clean_node_stale
  clean_venv_stale
  clean_snapshots
  clean_ai_workspaces
  clean_ai_models
  clean_containers
  clean_user_trash
  printf '\n%s\n' "${BOLD}After${RESET}"
  disk_line
  [[ "$APPLY" -eq 1 && "$TRASH" -eq 1 ]] && warn "Review ~/.Trash/cleanroom-$RUN_ID before emptying Trash."
  return 0
}

apply_preset() {
  case "$1" in
    safe)
      ;;
    dev)
      INCLUDE_APP_CACHES=1
      INCLUDE_PACKAGE_STORES=1
      INCLUDE_TOOLCHAINS=1
      INCLUDE_NODE_STALE=1
      INCLUDE_VENV_STALE=1
      ;;
    ai)
      INCLUDE_AI_WORKSPACES=1
      INCLUDE_AI_MODELS=1
      ;;
    deep)
      INCLUDE_APP_CACHES=1
      INCLUDE_PACKAGE_STORES=1
      INCLUDE_TOOLCHAINS=1
      INCLUDE_NODE_STALE=1
      INCLUDE_VENV_STALE=1
      INCLUDE_DEV_HEAVY=1
      INCLUDE_SNAPSHOTS=1
      INCLUDE_AI_WORKSPACES=1
      ;;
    *)
      die "Unknown preset: $1"
      ;;
  esac
}

if [[ "$#" -eq 0 ]]; then
  usage
  exit 0
fi

case "${1:-}" in
  overview|map|snapshot|diff|state|permissions|review|scan|system-data|plan|large|brokenlinks|quarantine|metadata|quicklook|fontcaches|font-caches|webcaches|web-caches|savedstate|saved-state|projectcaches|project-caches|updaters|updater-caches|browsercaches|browser-caches|duplicates|documents|desktop|screenshots|archives|downloads|installers|nodes|venvs|virtualenvs|apps|uninstallers|appreview|appdata|libraries|cloud|cloudfiles|cloud-files|personal|communications|comms|browsers|leftovers|backups|xcode|android|startup|loginitems|trash|caches|diagnostics|packages|npm-cache|npmcache|yarn-cache|yarncache|pnpm-store|pnpmstore|cocoapods-cache|pod-cache|podcache|pip-cache|pipcache|receipts|homebrew|homebrew-cleanup|brewcleanup|toolchains|containers|snapshots|report|clean|history|restore|interactive|doctor|protect|guard|rules|categories|init-config|help)
    ACTION="$1"
    shift
    ;;
esac

args=("$@")
for ((i = 0; i < ${#args[@]}; i++)); do
  if [[ "${args[$i]}" == "--config" && $((i + 1)) -lt ${#args[@]} ]]; then
    CONFIG_FILE="${args[$((i + 1))]}"
  fi
done

if [[ -z "$CONFIG_FILE" ]]; then
  default_config="$(config_default_path)"
  [[ -f "$default_config" ]] && CONFIG_FILE="$default_config"
fi

if [[ -n "$CONFIG_FILE" && "$ACTION" != "init-config" ]]; then
  load_config "$CONFIG_FILE"
fi

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --apply) APPLY=1 ;;
    --trash) TRASH=1 ;;
    --yes) ASSUME_YES=1 ;;
    --verbose) VERBOSE=1 ;;
    --json) JSON=1 ;;
    --redact) REDACT=1 ;;
    --preflight) PREFLIGHT=1 ;;
    --output)
      shift
      [[ -n "${1:-}" ]] || die "--output requires a path"
      OUTPUT_FILE="${1:-}"
      ;;
    --config)
      shift
      CONFIG_FILE="${1:-}"
      ;;
    --log)
      shift
      [[ -n "${1:-}" ]] || die "--log requires a path"
      LOG_FILE="$(expand_path "${1:-}")"
      ;;
    --exclude)
      shift
      add_exclude "${1:-}"
      ;;
    --preset)
      shift
      apply_preset "${1:-}"
      ;;
    --days)
      shift
      [[ "${1:-}" =~ ^[0-9]+$ ]] || die "--days requires a number"
      DAYS="$1"
      ;;
    --limit)
      shift
      [[ "${1:-}" =~ ^[0-9]+$ ]] || die "--limit requires a number"
      LIMIT="$1"
      ;;
    --min-mb)
      shift
      [[ "${1:-}" =~ ^[0-9]+$ ]] || die "--min-mb requires a number"
      MIN_MB="$1"
      ;;
    --include-dev-heavy) INCLUDE_DEV_HEAVY=1 ;;
    --include-node-stale) INCLUDE_NODE_STALE=1 ;;
    --include-venv-stale) INCLUDE_VENV_STALE=1 ;;
    --include-installers) INCLUDE_INSTALLERS=1 ;;
    --include-download-artifacts|--include-downloads-artifacts|--include-downloadartifacts) INCLUDE_DOWNLOAD_ARTIFACTS=1 ;;
    --include-screenshots|--include-screen-recordings|--include-screenrecordings) INCLUDE_SCREENSHOTS=1 ;;
    --include-cleanroom-state|--include-cleanroomstate) INCLUDE_CLEANROOM_STATE=1 ;;
    --include-package-stores) INCLUDE_PACKAGE_STORES=1 ;;
    --include-toolchains) INCLUDE_TOOLCHAINS=1 ;;
    --include-diagnostics) INCLUDE_DIAGNOSTICS=1 ;;
    --include-app-caches) INCLUDE_APP_CACHES=1 ;;
    --include-snapshots) INCLUDE_SNAPSHOTS=1 ;;
    --include-user-trash) INCLUDE_USER_TRASH=1 ;;
    --include-ai-workspaces) INCLUDE_AI_WORKSPACES=1 ;;
    --include-ai-models) INCLUDE_AI_MODELS=1 ;;
    --include-containers) INCLUDE_CONTAINERS=1 ;;
    --include-metadata) INCLUDE_METADATA=1 ;;
    --include-quicklook) INCLUDE_QUICKLOOK=1 ;;
    --include-font-caches|--include-fontcaches) INCLUDE_FONT_CACHES=1 ;;
    --include-web-caches|--include-webcaches) INCLUDE_WEB_CACHES=1 ;;
    --include-saved-state|--include-savedstate) INCLUDE_SAVED_STATE=1 ;;
    --include-project-caches|--include-projectcaches) INCLUDE_PROJECT_CACHES=1 ;;
    --include-updater-caches|--include-updatercaches|--include-updaters) INCLUDE_UPDATER_CACHES=1 ;;
    --include-browser-caches|--include-browsercaches) INCLUDE_BROWSER_CACHES=1 ;;
    --include-device-backups|--include-devicebackups|--include-ios-backups|--include-mobile-backups) INCLUDE_DEVICE_BACKUPS=1 ;;
    --include-gemini) INCLUDE_GEMINI=1; INCLUDE_AI_WORKSPACES=1 ;;
    --include-lmstudio) INCLUDE_LMSTUDIO=1; INCLUDE_AI_MODELS=1 ;;
    -h|--help) usage; exit 0 ;;
    -v|--version) echo "$VERSION"; exit 0 ;;
    *)
      if [[ "$ACTION" == "guard" || "$ACTION" == "diff" || "$ACTION" == "large" || "$ACTION" == "brokenlinks" || "$ACTION" == "quarantine" || "$ACTION" == "metadata" || "$ACTION" == "projectcaches" || "$ACTION" == "project-caches" || "$ACTION" == "duplicates" || "$ACTION" == "documents" || "$ACTION" == "screenshots" || "$ACTION" == "archives" || "$ACTION" == "nodes" || "$ACTION" == "venvs" || "$ACTION" == "virtualenvs" || "$ACTION" == "apps" || "$ACTION" == "uninstallers" || "$ACTION" == "appreview" || "$ACTION" == "cloudfiles" || "$ACTION" == "cloud-files" || "$ACTION" == "leftovers" ]]; then
        PATH_ARGS+=("$1")
      else
        die "Unknown option: $1"
      fi
      ;;
  esac
  shift
done

case "$ACTION" in
  overview) overview ;;
  map) map ;;
  snapshot) snapshot ;;
  diff) snapshot_diff ;;
  state) state ;;
  permissions) permissions ;;
  review) review ;;
  scan) scan ;;
  system-data) system_data ;;
  plan) plan ;;
  large) large ;;
  brokenlinks) brokenlinks ;;
  quarantine) quarantine ;;
  metadata) metadata ;;
  quicklook) quicklook ;;
  fontcaches|font-caches) fontcaches ;;
  webcaches|web-caches) webcaches ;;
  savedstate|saved-state) savedstate ;;
  projectcaches|project-caches) projectcaches ;;
  updaters|updater-caches) updaters ;;
  browsercaches|browser-caches) browsercaches ;;
  duplicates) duplicates ;;
  documents) documents ;;
  desktop) desktop ;;
  screenshots) screenshots ;;
  archives) archives ;;
  downloads) downloads ;;
  installers) installers ;;
  nodes) nodes ;;
  venvs|virtualenvs) venvs ;;
  apps) apps ;;
  uninstallers) uninstallers ;;
  appreview) appreview ;;
  appdata) appdata ;;
  libraries) libraries ;;
  cloud) cloud ;;
  cloudfiles|cloud-files) cloudfiles ;;
  personal) personal ;;
  communications|comms) communications ;;
  browsers) browsers ;;
  leftovers) leftovers ;;
  backups) backups ;;
  xcode) xcode ;;
  android) android ;;
  startup) startup ;;
  loginitems) loginitems ;;
  trash) trash ;;
  caches) caches ;;
  diagnostics) diagnostics ;;
  packages) packages ;;
  npm-cache|npmcache) npm_cache ;;
  yarn-cache|yarncache) yarn_cache ;;
  pnpm-store|pnpmstore) pnpm_store ;;
  cocoapods-cache|pod-cache|podcache) cocoapods_cache ;;
  pip-cache|pipcache) pip_cache ;;
  receipts) receipts ;;
  homebrew) homebrew ;;
  homebrew-cleanup|brewcleanup) homebrew_cleanup ;;
  toolchains) toolchains ;;
  containers) containers ;;
  snapshots) snapshots ;;
  report) report ;;
  clean) clean ;;
  history) history ;;
  restore) restore ;;
  interactive) interactive ;;
  doctor) doctor ;;
  protect) protect ;;
  guard) guard ;;
  rules) rules ;;
  categories) categories ;;
  init-config) init_config ;;
  help) usage ;;
  *) die "Unknown action: $ACTION" ;;
esac
