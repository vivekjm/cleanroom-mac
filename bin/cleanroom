        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom container storage${RESET}"
  printf 'Review-only inventory. Container cleanup is high-impact and opt-in.\n\n'
  printf '%-10s %-20s %-16s %s\n' "size" "id" "runtime" "preview command"
