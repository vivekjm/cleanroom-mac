disk_line() {
  df -h /System/Volumes/Data 2>/dev/null || df -h /
}

json_escape() {
  LC_ALL=C awk '
    {
      gsub(/\\/, "\\\\")
      gsub(/"/, "\\\"")
      gsub(/\t/, "\\t")
      gsub(/\r/, "\\r")
      printf "%s%s", (NR > 1 ? "\\n" : ""), $0
    }
  '
}

redact_stream() {
  if [[ "$REDACT" -ne 1 ]]; then
    cat
    return 0
  fi

  local home tmp short user_home tail
  home="${HOME%/}"
  tmp="${TMPDIR:-}"
  tmp="${tmp%/}"
  short="${USER:-}"
  [[ -n "$short" ]] || short="$(id -un 2>/dev/null || true)"
  user_home=""
  if [[ "$home" == /Users/* ]]; then
    tail="${home#/Users/}"
    user_home="/Users/${tail%%/*}"
  elif [[ -n "$short" ]]; then
    user_home="/Users/$short"
  fi

  awk \
    -v home="$home" \
    -v user_home="$user_home" \
    -v tmp="$tmp" \
    -v tmp_repl='$TMPDIR' \
    'function repl(s, from, to,    i, out) {
       if (from == "") return s
       out = ""
       while ((i = index(s, from)) > 0) {
         out = out substr(s, 1, i - 1) to
         s = substr(s, i + length(from))
       }
       return out s
     }
     {
       line = $0
       line = repl(line, home, "~")
       line = repl(line, user_home, "/Users/USER")
       line = repl(line, tmp, tmp_repl)
       print line
     }'
}

redact_string() {
  printf '%s\n' "$1" | redact_stream | sed -n '1p'
}

shell_quote() {
  printf '%q' "$1"
}

leftover_command() {
  local base="$1"
  local query
  printf '%s' "$base"
  for query in "${PATH_ARGS[@]}"; do
    [[ -z "$query" ]] && continue
    printf ' %s' "$(shell_quote "$query")"
  done
  printf ' --limit %s' "$LIMIT"
}

disk_json() {
  local line
  line="$(df -k /System/Volumes/Data 2>/dev/null | awk 'NR==2 {print $2, $3, $4, $5, $9}')"
  if [[ -z "$line" ]]; then
    line="$(df -k / | awk 'NR==2 {print $2, $3, $4, $5, $9}')"
  fi
  awk -v values="$line" 'BEGIN {
    split(values, a, " ")
    printf "\"disk\":{\"size_kb\":%s,\"used_kb\":%s,\"available_kb\":%s,\"capacity\":\"%s\",\"mount\":\"%s\"}", a[1], a[2], a[3], a[4], a[5]
  }'
}

preflight_rows() {
  printf '%s\t%s\t%s\t%s\n' "default-caches" "Default rebuildable caches" "rebuildable" "Trash mode can recover direct removals when --trash is used."
  printf '%s\t%s\t%s\t%s\n' "old-logs" "Old user logs" "low-risk" "Trash mode can recover direct removals when --trash is used."
  [[ "$INCLUDE_APP_CACHES" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "app-caches" "Nested app cache folders" "rebuildable" "Profiles, passwords, cookies, bookmarks, and settings stay protected."
  [[ "$INCLUDE_PACKAGE_STORES" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "package-stores" "Package-manager stores" "rebuildable" "Dependencies may need to be downloaded again."
  [[ "$INCLUDE_TOOLCHAINS" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "toolchains" "Language/toolchain caches" "rebuildable" "Dependencies and build caches may need to be downloaded or rebuilt."
  [[ "$INCLUDE_DIAGNOSTICS" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "diagnostics" "Old diagnostic reports" "low-risk" "Trash mode can recover direct removals when --trash is used."
  [[ "$INCLUDE_INSTALLERS" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "installers" "Old downloaded installers" "opt-in" "Trash mode can recover direct removals when --trash is used."
  [[ "$INCLUDE_DOWNLOAD_ARTIFACTS" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "download-artifacts" "Old downloadable artifacts" "opt-in" "Only installer, disk image, and archive-style files directly under ~/Downloads older than ${DAYS} days are targeted."
  [[ "$INCLUDE_SCREENSHOTS" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "screenshots" "Old screenshots and screen recordings" "privacy-sensitive" "Only known screenshot and screen recording filenames older than ${DAYS} days under Desktop, Downloads, and Documents are targeted."
  [[ "$INCLUDE_CLEANROOM_STATE" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "cleanroom-state" "Old cleanroom-created state" "maintenance" "Only cleanroom run logs, snapshots, and cleanroom Trash folders older than ${DAYS} days are targeted."
  [[ "$INCLUDE_METADATA" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "metadata" "Filesystem metadata clutter" "low-risk" "Trash mode can recover direct removals when --trash is used."
  [[ "$INCLUDE_QUICKLOOK" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "quicklook" "Quick Look caches" "rebuildable" "Trash mode can recover direct cache removals when --trash is used."
  [[ "$INCLUDE_FONT_CACHES" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "font-caches" "Font cache databases" "rebuildable" "Actual font files stay protected; macOS recreates font caches as needed."
  [[ "$INCLUDE_WEB_CACHES" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "web-caches" "Safari/WebKit caches" "rebuildable" "Safari history, cookies, bookmarks, passwords, and profiles stay protected."
  [[ "$INCLUDE_SAVED_STATE" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "saved-state" "Saved Application State" "rebuildable" "Apps may forget restored windows; app documents and profiles stay protected."
  [[ "$INCLUDE_PROJECT_CACHES" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "project-caches" "Project cache artifacts" "rebuildable" "Only known cache folders/files are targeted; source and dependency folders stay protected."
  [[ "$INCLUDE_UPDATER_CACHES" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "updater-caches" "App updater caches" "rebuildable" "Only Sparkle/Squirrel updater cache and staging data is targeted; apps and profiles stay protected."
  [[ "$INCLUDE_BROWSER_CACHES" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "browser-caches" "Chromium/Firefox browser caches" "rebuildable" "Profiles, passwords, cookies, bookmarks, sessions, extensions, and settings stay protected."
  [[ "$INCLUDE_DEVICE_BACKUPS" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "device-backups" "Old local iPhone/iPad backups" "high-impact" "Only direct MobileSync backup folders older than ${DAYS} days are targeted; --trash is required."
  [[ "$INCLUDE_NODE_STALE" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "node-modules" "Stale node_modules" "rebuildable" "Dependencies may need to be installed again."
  [[ "$INCLUDE_VENV_STALE" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "python-virtualenvs" "Stale Python virtualenvs" "rebuildable" "Virtualenvs may need to be recreated."
  [[ "$INCLUDE_DEV_HEAVY" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "dev-heavy" "Heavy SDK and simulator data" "high-impact" "Some SDKs, symbols, or simulator app state may need reinstalling or resetting."
  [[ "$INCLUDE_SNAPSHOTS" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "snapshots" "Local Time Machine snapshots" "system-tool" "Snapshot thinning is delegated to tmutil and is not recoverable through cleanroom Trash."
  [[ "$INCLUDE_AI_WORKSPACES" -eq 1 || "$INCLUDE_GEMINI" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "ai-workspaces" "Generated AI workspace state" "destructive-opt-in" "Generated recordings, scratch, brain, implicit data, and local conversations may be removed."
  [[ "$INCLUDE_AI_MODELS" -eq 1 || "$INCLUDE_LMSTUDIO" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "ai-models" "Downloaded local AI models" "large-opt-in" "Model files and backends may need to be downloaded again."
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "containers" "Container VM disks and stores" "high-impact" "This can remove local containers, images, volumes, and VM disks."
  [[ "$INCLUDE_USER_TRASH" -eq 1 ]] && printf '%s\t%s\t%s\t%s\n' "user-trash" "Current user Trash" "irreversible" "Emptying ~/.Trash is irreversible and ignores --trash."
  return 0
}

preflight_warnings() {
  [[ "$APPLY" -eq 1 ]] && printf '%s\n' "Apply mode is enabled; without --preflight this run would delete selected data."
  [[ "$APPLY" -eq 0 ]] && printf '%s\n' "Dry-run mode is selected; clean would preview removals without deleting."
  [[ "$TRASH" -eq 1 ]] && printf '%s\n' "Trash mode is enabled for cleanroom-managed direct path removals."
  [[ "$TRASH" -eq 0 && "$APPLY" -eq 1 ]] && printf '%s\n' "Trash mode is not enabled; cleanroom-managed direct removals would use rm -rf."
  [[ "$INCLUDE_USER_TRASH" -eq 1 ]] && printf '%s\n' "User Trash cleanup is irreversible and is not recoverable through cleanroom Trash mode."
  [[ "$INCLUDE_SNAPSHOTS" -eq 1 ]] && printf '%s\n' "Snapshot thinning is delegated to tmutil and is not recoverable through cleanroom Trash mode."
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] && printf '%s\n' "Container cleanup can remove local containers, images, volumes, and VM disks."
  [[ "$INCLUDE_DEV_HEAVY" -eq 1 ]] && printf '%s\n' "Heavy developer cleanup can remove SDK/support files or simulator app state."
  [[ "$INCLUDE_AI_MODELS" -eq 1 || "$INCLUDE_LMSTUDIO" -eq 1 ]] && printf '%s\n' "AI model cleanup removes downloaded model files and backend extensions."
  printf '%s\n' "Protected browser profiles, password databases, Keychains, Photos, Mail, Messages, and cloud-sync roots stay guarded."
  return 0
}

preflight() {
  local rows warnings
  rows="$(preflight_rows)"
  warnings="$(preflight_warnings)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    printf '"version":"%s",' "$(printf '%s' "$VERSION" | json_escape)"
    printf '"action":"clean",'
    printf '"apply":%s,"trash":%s,"yes":%s,"days":%s,' \
      "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(if [[ "$TRASH" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(if [[ "$ASSUME_YES" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$DAYS"
    printf '"log_path":"%s",' "$(printf '%s' "${LOG_FILE:-$(default_log_file)}" | json_escape)"
    printf '"categories":['
    local first=1 id title safety recoverability
    while IFS=$'\t' read -r id title safety recoverability; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","safety":"%s","recoverability":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
        "$(printf '%s' "$recoverability" | json_escape)"
    done <<<"$rows"
    printf '],"warnings":['
    first=1
    local warning
    while IFS= read -r warning; do
      [[ -z "$warning" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '"%s"' "$(printf '%s' "$warning" | json_escape)"
    done <<<"$warnings"
    printf ']}\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom clean preflight${RESET}"
  printf 'No files are scanned or deleted in preflight mode.\n\n'
  printf '%-18s %-26s %-18s %s\n' "id" "category" "safety" "recoverability"
  local id title safety recoverability
  while IFS=$'\t' read -r id title safety recoverability; do
    [[ -z "${id:-}" ]] && continue
    printf '%-18s %-26s %-18s %s\n' "$id" "$title" "$safety" "$recoverability"
  done <<<"$rows"
  printf '\n%s\n' "${BOLD}Warnings${RESET}"
  local warning
  while IFS= read -r warning; do
    [[ -z "$warning" ]] && continue
    printf '%s\n' "- $warning"
  done <<<"$warnings"
}

confirm_apply() {
  [[ "$APPLY" -eq 1 ]] || return 0
  [[ "$ASSUME_YES" -eq 1 ]] && return 0
  warn "About to delete selected cache/artifact files."
  [[ "$TRASH" -eq 1 ]] && warn "Trash mode is enabled; cleanroom path deletions move to ~/.Trash."
  warn "Protected data like browser passwords and Keychains is not deleted."
  [[ "$INCLUDE_AI_MODELS" -eq 1 ]] && warn "AI model cleanup removes downloaded model files."
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] && warn "Container cleanup can remove local container VM disks and volumes."
  [[ "$INCLUDE_CLEANROOM_STATE" -eq 1 ]] && warn "Cleanroom state cleanup can remove old restore folders from ~/.Trash."
  [[ "$INCLUDE_USER_TRASH" -eq 1 ]] && warn "User Trash cleanup permanently empties ~/.Trash."
  printf 'Continue? Type "clean" to proceed: '
  local answer
  read -r answer
  [[ "$answer" == "clean" ]] || die "Cancelled."
}

default_log_file() {
  printf '%s\n' "$HOME/.local/state/cleanroom/runs/$RUN_ID.log"
}

log_dir() {
  printf '%s\n' "$HOME/.local/state/cleanroom/runs"
}

snapshot_dir() {
  printf '%s\n' "$HOME/.local/state/cleanroom/snapshots"
}

default_snapshot_file() {
  printf '%s\n' "$(snapshot_dir)/snapshot-$RUN_ID.json"
}

latest_snapshot_files() {
  local dir
  dir="$(snapshot_dir)"
  [[ -d "$dir" ]] || return 1
  find "$dir" -type f -name 'snapshot-*.json' -exec ls -t {} + 2>/dev/null | head -2
}

latest_log_file() {
  local dir
  dir="$(log_dir)"
  [[ -d "$dir" ]] || return 1
  find "$dir" -type f -name '*.log' -exec ls -t {} + 2>/dev/null | head -1
}

ensure_apply_log() {
  [[ "$APPLY" -eq 1 ]] || return 0
  [[ -n "$LOG_FILE" ]] || LOG_FILE="$(default_log_file)"
  mkdir -p "$(dirname "$LOG_FILE")"
  if [[ ! -f "$LOG_FILE" ]]; then
    {
      printf '# cleanroom apply log\n'
      printf 'version=%s\n' "$VERSION"
      printf 'run_id=%s\n' "$RUN_ID"
      printf 'mode=%s\n' "$(if [[ "$TRASH" -eq 1 ]]; then echo trash; else echo delete; fi)"
      printf 'started_at=%s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
      printf 'timestamp\taction\tstatus\tsize_kb\tpath\ttarget\n'
    } >>"$LOG_FILE"
  fi
}

history() {
  local dir count file
  dir="$(log_dir)"
  if [[ ! -d "$dir" ]]; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '[]\n'
      return 0
    fi
    warn "No cleanroom history found: $dir"
    return 0
  fi
  count=0
  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    find "$dir" -type f -name '*.log' -exec ls -t {} + 2>/dev/null |
      while IFS= read -r file; do
        [[ -f "$file" ]] || continue
        count=$((count + 1))
        [[ "$count" -gt "$LIMIT" ]] && break
        local started mode entries status title summary size
        started="$(awk -F= '/^started_at=/{print $2; exit}' "$file")"
        mode="$(awk -F= '/^mode=/{print $2; exit}' "$file")"
        entries="$(awk -F '\t' '$2 == "trash" && $3 == "ok" {count++} END {print count + 0}' "$file")"
        if [[ "${mode:-}" == "trash" && "${entries:-0}" -gt 0 ]]; then
          status="restorable"
          summary="Items were moved to Trash where possible and may be restorable."
        else
          status="record"
          summary="Cleanup record saved."
        fi
        title="Cleanup on ${started:-unknown date}"
        size="${entries:-0} items"
        [[ "$count" -gt 1 ]] && printf ','
        printf '{'
        printf '"id":"cleanup-history-%s",' "$count"
        printf '"title":"%s",' "$(printf '%s' "$title" | json_escape)"
        printf '"status":"%s",' "$(printf '%s' "$status" | json_escape)"
        printf '"mode":"%s",' "$(printf '%s' "${mode:-unknown}" | json_escape)"
        printf '"size":"%s",' "$(printf '%s' "$size" | json_escape)"
        printf '"started":"%s",' "$(printf '%s' "${started:-unknown}" | json_escape)"
        printf '"summary":"%s",' "$(printf '%s' "$summary" | json_escape)"
        printf '"record_path":"%s"' "$(printf '%s' "$file" | json_escape)"
        printf '}'
      done
    printf ']\n'
    return 0
  fi
  printf '%s\n' "${BOLD}cleanroom history${RESET}"
  find "$dir" -type f -name '*.log' -exec ls -t {} + 2>/dev/null |
    while IFS= read -r file; do
      [[ -f "$file" ]] || continue
      count=$((count + 1))
      [[ "$count" -gt "$LIMIT" ]] && break
      local started mode entries
      started="$(awk -F= '/^started_at=/{print $2; exit}' "$file")"
      mode="$(awk -F= '/^mode=/{print $2; exit}' "$file")"
      entries="$(awk -F '\t' '$2 == "trash" && $3 == "ok" {count++} END {print count + 0}' "$file")"
      printf '%s  mode=%s  trash_entries=%s\n  %s\n' "${started:-unknown}" "${mode:-unknown}" "$entries" "$file"
    done
}

history_fast() {
  local dir total latest_file latest_started latest_mode latest_entries status summary size
  dir="$(log_dir)"
  total=0
  latest_file=""
  if [[ -d "$dir" ]]; then
    total="$(find "$dir" -type f -name '*.log' 2>/dev/null | awk 'END {print NR + 0}')"
    latest_file="$(latest_log_file || true)"
  fi
  if [[ -n "$latest_file" && -f "$latest_file" ]]; then
    latest_started="$(awk -F= '/^started_at=/{print $2; exit}' "$latest_file")"
    latest_mode="$(awk -F= '/^mode=/{print $2; exit}' "$latest_file")"
    latest_entries="$(awk -F '\t' '$2 == "trash" && $3 == "ok" {count++} END {print count + 0}' "$latest_file")"
    status="Review"
    summary="Latest cleanup was ${latest_started:-recent}. Restore details are available from cleanup history."
  else
    latest_started=""
    latest_mode="none"
    latest_entries=0
    status="Clear"
    summary="No cleanup history found yet."
  fi
  size="${total} run"
  [[ "$total" -eq 1 ]] || size="${total} runs"

  if [[ "$JSON" -eq 1 ]]; then
    printf '[{"id":"cleanup-history","title":"Past Cleanups","count":%s,"size":"%s","status":"%s","safety":"Review only","summary":"%s","latest_mode":"%s","restorable_items":%s,"mode":"fast"}]\n' \
      "$total" \
      "$(printf '%s' "$size" | json_escape)" \
      "$(printf '%s' "$status" | json_escape)" \
      "$(printf '%s' "$summary" | json_escape)" \
      "$(printf '%s' "$latest_mode" | json_escape)" \
      "${latest_entries:-0}"
    return 0
  fi

  printf '%s\n' "${BOLD}quick cleanup history${RESET}"
  printf 'Fast summary. Log paths are hidden for the desktop app.\n\n'
  printf '%-18s %s\n' "Past Cleanups" "$size"
  printf '%-18s %s\n' "Latest" "${latest_started:-None yet}"
  printf '%-18s %s\n' "Restorable Items" "${latest_entries:-0}"
}

restore() {
  local file restored skipped missing collisions line timestamp action status size path target
  if [[ -n "$LOG_FILE" ]]; then
    file="$LOG_FILE"
  else
    file="$(latest_log_file || true)"
  fi
  [[ -n "${file:-}" ]] || die "No apply logs found. Pass --log PATH."
  file="$(expand_path "$file")"
  [[ -f "$file" ]] || die "Restore log not found: $file"

  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$ASSUME_YES" -eq 1 ]] || {
      warn "About to restore Trash-mode entries from: $file"
      printf 'Continue? Type "restore" to proceed: '
      local answer
      read -r answer
      [[ "$answer" == "restore" ]] || die "Cancelled."
    }
    warn "Restore apply mode enabled."
  else
    warn "Restore dry-run mode. Pass --apply to move files back."
  fi

  restored=0
  skipped=0
  missing=0
  collisions=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" || "$line" == \#* || "$line" == timestamp$'\t'* ]] && continue
    IFS=$'\t' read -r timestamp action status size path target <<<"$line"
    [[ "$action" == "trash" && "$status" == "ok" ]] || continue
    [[ -n "${path:-}" && -n "${target:-}" ]] || { skipped=$((skipped + 1)); continue; }
    if [[ ! -e "$target" ]]; then
      missing=$((missing + 1))
      [[ "$VERBOSE" -eq 1 ]] && warn "missing trash item: $target"
      continue
    fi
    if [[ -e "$path" ]]; then
      collisions=$((collisions + 1))
      warn "not restoring because destination exists: $path"
      continue
    fi
    if [[ "$APPLY" -eq 1 ]]; then
      mkdir -p "$(dirname "$path")"
      if mv "$target" "$path"; then
        restored=$((restored + 1))
        [[ "$VERBOSE" -eq 1 ]] && log "restored $target -> $path"
      else
        warn "restore failed: $target -> $path"
        skipped=$((skipped + 1))
      fi
    else
      printf 'would restore %8s  %s -> %s\n' "$(human_kb "${size:-0}")" "$target" "$path"
      restored=$((restored + 1))
    fi
  done <"$file"

  printf 'restore summary: restored=%s missing=%s collisions=%s skipped=%s\n' "$restored" "$missing" "$collisions" "$skipped"
}

record_apply() {
  [[ "$APPLY" -eq 1 ]] || return 0
  ensure_apply_log
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$(date '+%Y-%m-%d %H:%M:%S %Z')" \
    "${1:-remove}" \
    "${2:-unknown}" \
    "${3:-0}" \
    "${4:-}" \
    "${5:-}" >>"$LOG_FILE"
}

canonical_existing_path() {
  local path="$1"
  local dir base
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$base") || printf '%s\n' "$path"
  else
    printf '%s\n' "$path"
  fi
}

is_dangerous_path() {
  local path home
  path="$(canonical_existing_path "$1")"
  home="$(canonical_existing_path "$HOME")"
  case "$path" in
    ""|"/"|"/System"|"/Library"|"/Applications"|"/Users"|"$home"|"$home/Library"|"$home/Documents"|"$home/Desktop"|"$home/Downloads"|"$home/Library/Application Support")
      return 0
      ;;
  esac
  return 1
}

protected_removal_reason() {
  local path="$1"
  local file id type protected_path reason expanded protected_canonical path_canonical
  file="$(protected_file)"
  [[ -f "$file" ]] || return 1
  path_canonical="$(canonical_existing_path "$path")"

  while IFS=$'\t' read -r id type protected_path reason; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$protected_path")"
    protected_canonical="$(canonical_existing_path "$expanded")"
    if [[ "$path_canonical" == "$protected_canonical" || "$protected_canonical" == "$path_canonical/"* ]]; then
      printf '%s: %s\n' "$id" "$reason"
      return 0
    fi
  done < <(tail -n +2 "$file")
  return 1
}

is_protected_removal_path() {
  protected_removal_reason "$1" >/dev/null
}

trash_path() {
  local path="$1"
  local trash_dir base target n
  trash_dir="$HOME/.Trash/cleanroom-$RUN_ID"
  mkdir -p "$trash_dir"
  base="$(basename "$path")"
  target="$trash_dir/$base"
  n=1
  while [[ -e "$target" ]]; do
    target="$trash_dir/$base.$n"
    n=$((n + 1))
  done
  mv "$path" "$target"
  printf '%s\n' "$target"
}

delete_path() {
  local path="$1"
  local kb target
  [[ -e "$path" ]] || return 0
  if is_dangerous_path "$path"; then
    warn "refusing dangerous path: $path"
    record_apply "remove" "refused-dangerous" "0" "$path" ""
    return 0
  fi
  local protected_reason
  protected_reason="$(protected_removal_reason "$path" || true)"
  if [[ -n "$protected_reason" ]]; then
    warn "refusing protected path: $path ($protected_reason)"
    record_apply "remove" "refused-protected" "0" "$path" ""
    return 0
  fi
  kb="$(size_kb "$path")"
  if [[ "$TRASH" -eq 1 ]]; then
    target="$(trash_path "$path" 2>/dev/null || true)"
    if [[ -n "$target" ]]; then
      record_apply "trash" "ok" "$kb" "$path" "$target"
      [[ "$VERBOSE" -eq 1 ]] && log "moved $(human_kb "$kb")  $path -> $target"
    else
      warn "Could not move to Trash: $path"
      record_apply "trash" "failed" "$kb" "$path" ""
    fi
  else
    if rm -rf "$path" 2>/dev/null; then
      record_apply "delete" "ok" "$kb" "$path" ""
      [[ "$VERBOSE" -eq 1 ]] && log "removed $(human_kb "$kb")  $path"
    else
      warn "Could not remove: $path"
      record_apply "delete" "failed" "$kb" "$path" ""
    fi
  fi
  return 0
}

delete_user_trash_child() {
  local path="$1"
  local trash_dir="$HOME/.Trash"
  local kb
  [[ -e "$path" ]] || return 0
  case "$path" in
    "$trash_dir"/*) ;;
    *)
      warn "refusing non-Trash path during Trash cleanup: $path"
      record_apply "empty-trash" "refused" "0" "$path" ""
      return 0
      ;;
  esac
  kb="$(size_kb "$path")"
  if rm -rf "$path" 2>/dev/null; then
    record_apply "empty-trash" "ok" "$kb" "$path" ""
    [[ "$VERBOSE" -eq 1 ]] && log "emptied $(human_kb "$kb")  $path"
  else
    warn "Could not empty Trash item: $path"
    record_apply "empty-trash" "failed" "$kb" "$path" ""
  fi
  return 0
}

run_rm() {
  local path="$1"
  path="$(expand_path "$path")"
  [[ -e "$path" ]] || return 0
  if is_excluded "$path"; then
    [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded path: $path"
    return 0
  fi

  local kb
  kb="$(size_kb "$path")"
  if [[ "$APPLY" -eq 1 ]]; then
    delete_path "$path"
  else
    printf 'would remove %8s  %s\n' "$(human_kb "$kb")" "$path"
  fi
  return 0
}

run_find_delete_children() {
  local path="$1"
  path="$(expand_path "$path")"
  [[ -d "$path" ]] || return 0
  if is_excluded "$path"; then
    [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded path: $path"
    return 0
  fi
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$VERBOSE" -eq 1 ]] && log "clearing children of $path"
    find "$path" -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
      while IFS= read -r -d '' child; do
        delete_path "$child"
      done || true
  else
    print_size "$path"
  fi
}

safe_clean() {
  log "${BOLD}Safe rebuildable caches${RESET}"
  run_find_delete_children "~/Library/Caches"
  run_find_delete_children "~/.cache"
  run_rm "~/.npm/_cacache"
  run_rm "~/.npm/_logs"
  run_rm "~/.npm/_npx"
  run_rm "~/.yarn/cache"
  run_rm "~/.yarn/berry"
  run_rm "~/.gradle/caches"
  run_rm "~/.gradle/daemon"
  run_rm "~/.gradle/native"
  run_rm "~/.gradle/workers"
  run_rm "~/Library/pnpm/store"
  run_rm "~/Library/Developer/Xcode/DerivedData"
  run_rm "~/Library/Developer/CoreSimulator/Caches"

  if command -v brew >/dev/null 2>&1; then
    if [[ "$APPLY" -eq 1 ]]; then
      if [[ "$TRASH" -eq 1 ]]; then
        run_find_delete_children "~/Library/Caches/Homebrew"
      else
        brew cleanup -s >/dev/null 2>&1 || true
        run_find_delete_children "~/Library/Caches/Homebrew"
      fi
    else
      print_size "~/Library/Caches/Homebrew"
    fi
  fi
}

clean_package_stores() {
  [[ "$INCLUDE_PACKAGE_STORES" -eq 1 ]] || return 0
  log "${BOLD}Package manager stores${RESET}"
  run_rm "~/Library/pnpm/store"
  run_rm "~/.pnpm-store"
  run_rm "~/.cocoapods/repos"
  run_rm "~/.gradle-tangibly-release/caches"
  run_rm "~/.gradle-tangibly-release/wrapper"
  run_rm "~/.gradle-tangibly-release/native"
  run_rm "~/.cargo/registry/cache"
}

clean_toolchains() {
  [[ "$INCLUDE_TOOLCHAINS" -eq 1 ]] || return 0
  log "${BOLD}Language and toolchain caches${RESET}"
  local id ecosystem paths category preview apply description path
  while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    while IFS= read -r path; do
      path="${path#"${path%%[![:space:]]*}"}"
      path="${path%"${path##*[![:space:]]}"}"
      [[ -z "$path" ]] && continue
      run_rm "$path"
    done < <(printf '%s\n' "$paths" | tr ';' '\n')
  done < <(toolchain_rows)
}

clean_logs() {
  log "${BOLD}Old logs${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    find "$HOME/Library/Logs" -type f -mtime +7 -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_path "$path"
      done || true
    find "$HOME/Library/Logs" -mindepth 1 -type d -empty -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_path "$path"
      done || true
  else
    print_size "~/Library/Logs"
  fi
}

clean_old_files_dir() {
  local dir="$1"
  dir="$(expand_path "$dir")"
  [[ -d "$dir" ]] || return 0
  if [[ "$APPLY" -eq 1 ]]; then
    find "$dir" -type f -mtime +"$DAYS" -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_path "$path"
      done || true
    find "$dir" -mindepth 1 -type d -empty -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_path "$path"
      done || true
  else
    print_size "$dir"
  fi
}

clean_diagnostics() {
  [[ "$INCLUDE_DIAGNOSTICS" -eq 1 ]] || return 0
  log "${BOLD}Old diagnostic reports older than ${DAYS} days${RESET}"
  clean_old_files_dir "~/Library/DiagnosticReports"
  clean_old_files_dir "~/Library/Application Support/CrashReporter"
}

clean_app_caches() {
  [[ "$INCLUDE_APP_CACHES" -eq 1 ]] || return 0
  log "${BOLD}App cache folders only${RESET}"
  local roots=(
    "$HOME/Library/Application Support/Google"
    "$HOME/Library/Application Support/Microsoft Edge"
    "$HOME/Library/Application Support/Arc"
    "$HOME/Library/Application Support/Code"
    "$HOME/Library/Application Support/Cursor"
    "$HOME/Library/Application Support/Slack"
    "$HOME/Library/Application Support/BraveSoftware"
    "$HOME/Library/Application Support/Comet"
    "$HOME/Library/Application Support/Trae"
  )
  local root
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    if [[ "$APPLY" -eq 1 ]]; then
      find "$root" -type d \( \
        -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
        -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
        -o -name 'Crashpad' \
      \) -prune -print0 2>/dev/null |
        while IFS= read -r -d '' path; do
          delete_path "$path"
        done || true
    else
      local total
      total="$(cache_dir_kb_under "$root")"
      [[ -n "$total" ]] || total=0
      printf 'would clean %8s  %s cache folders\n' "$(human_kb "$total")" "$root"
    fi
  done
  return 0
}

quicklook_specs() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "quicklook-thumbnail-cache" "Quick Look Thumbnail Cache" "~/Library/Caches/com.apple.QuickLook.thumbnailcache" "rebuildable" "cleanroom quicklook" "cleanroom clean --apply --trash --include-quicklook" "User Quick Look thumbnail cache. macOS rebuilds thumbnails as needed."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "quicklook-thumbnails-agent" "Quick Look Thumbnails Agent" "~/Library/Caches/com.apple.quicklook.ThumbnailsAgent" "rebuildable" "cleanroom quicklook" "cleanroom clean --apply --trash --include-quicklook" "Thumbnail agent cache. macOS recreates it while browsing files."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "quicklook-daemon-cache" "Quick Look Daemon Cache" "~/Library/Caches/com.apple.QuickLookDaemon" "rebuildable" "cleanroom quicklook" "cleanroom clean --apply --trash --include-quicklook" "Quick Look daemon preview cache."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "quicklook-container-cache" "Quick Look Container Cache" "~/Library/Containers/com.apple.QuickLook.thumbnailcache/Data/Library/Caches" "rebuildable" "cleanroom quicklook" "cleanroom clean --apply --trash --include-quicklook" "Sandboxed Quick Look thumbnail cache."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "quicklook-agent-container-cache" "Quick Look Agent Container Cache" "~/Library/Containers/com.apple.quicklook.ThumbnailsAgent/Data/Library/Caches" "rebuildable" "cleanroom quicklook" "cleanroom clean --apply --trash --include-quicklook" "Sandboxed thumbnails agent cache."
}

quicklook_rows() {
  local id title path_template category preview apply description path kb
  while IFS=$'\t' read -r id title path_template category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    path="$(expand_path "$path_template")"
    kb="$(size_kb "$path")"
    printf '%012d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$id" "$title" "$path" "$category" "$preview" "$apply" "$description"
  done < <(quicklook_specs) | sort -rn
}

fixed_location_fast_rows() {
  local specs_fn="$1"
  local id title path_template category preview apply description path present sort_key
  while IFS=$'\t' read -r id title path_template category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    path="$(expand_path "$path_template")"
    if [[ -e "$path" ]]; then
      present=1
      sort_key=1
    else
      present=0
      sort_key=0
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$sort_key" "$id" "$title" "$path" "$category" "$present" "$preview" "$apply" "$description"
  done < <("$specs_fn") | sort -rn
}

fixed_location_fast_json() {
  local rows="$1"
  printf '['
  local first=1 sort_key id title path category present preview apply description exists_json size_label
  while IFS=$'\t' read -r sort_key id title path category present preview apply description; do
    [[ -z "${id:-}" ]] && continue
    if [[ "${present:-0}" == "1" ]]; then
      exists_json=true
      size_label="Review"
    else
      exists_json=false
      size_label="Not found"
    fi
    [[ "$first" -eq 0 ]] && printf ','
    first=0
    printf '{"id":"%s","title":"%s","path":"%s","exists":%s,"category":"%s","size_kb":0,"size":"%s","mode":"fast","preview_command":"%s","apply_command":"%s","description":"%s"}' \
      "$(printf '%s' "$id" | json_escape)" \
      "$(printf '%s' "$title" | json_escape)" \
      "$(printf '%s' "$path" | json_escape)" \
      "$exists_json" \
      "$(printf '%s' "$category" | json_escape)" \
      "$(printf '%s' "$size_label" | json_escape)" \
      "$(printf '%s' "$preview" | json_escape)" \
      "$(printf '%s' "$apply" | json_escape)" \
      "$(printf '%s' "$description" | json_escape)"
  done <<<"$rows"
  printf ']\n'
}

fixed_location_fast_text() {
  local rows="$1"
  local title="$2"
  local note="$3"
  printf '%s\n' "${BOLD}${title}${RESET}"
  printf '%s\n\n' "$note"
  if [[ -z "$rows" ]]; then
    printf 'No known locations found.\n'
    return 0
  fi
  printf '%-10s %-28s %s\n' "status" "bucket" "path"
  local sort_key id bucket path category present preview apply description status_label
  while IFS=$'\t' read -r sort_key id bucket path category present preview apply description; do
    [[ -z "${id:-}" ]] && continue
    if [[ "${present:-0}" == "1" ]]; then
      status_label="Review"
    else
      status_label="Not found"
    fi
    printf '%-10s %-28s %s\n' "$status_label" "$bucket" "$path"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

quicklook_fast() {
  local rows
  rows="$(fixed_location_fast_rows quicklook_specs)"
  if [[ "$JSON" -eq 1 ]]; then
    fixed_location_fast_json "$rows"
    return 0
  fi
  fixed_location_fast_text "$rows" "quick Quick Look cache review" "Fast review. Sizes are skipped so the desktop app stays responsive."
}

quicklook_total_kb() {
  local total=0 kb id title path category preview apply description kb_num
  while IFS=$'\t' read -r kb id title path category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(quicklook_rows)
  printf '%s\n' "$total"
}

quicklook() {
  local rows
  rows="$(quicklook_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title path category preview apply description kb_num
    while IFS=$'\t' read -r kb id title path category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","path":"%s","exists":%s,"category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$(if [[ -e "$path" ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Quick Look caches${RESET}"
  printf 'Review-only inventory. Cleanup is opt-in with --include-quicklook.\n\n'
  printf '%-10s %-30s %s\n' "size" "bucket" "path"
  local kb id title path category preview apply description
  while IFS=$'\t' read -r kb id title path category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-30s %s\n' "$(human_kb "$kb")" "$title" "$path"
    printf '  %s\n' "$description"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-quicklook\n'
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-quicklook\n'
}

