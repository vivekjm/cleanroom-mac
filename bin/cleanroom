#!/usr/bin/env bash
set -euo pipefail

VERSION="0.30.0"
APPLY=0
VERBOSE=0
ASSUME_YES=0
JSON=0
DAYS=30
LIMIT=20
MIN_MB=500
ACTION="scan"
CONFIG_FILE=""
CONFIG_LOADED=0
OUTPUT_FILE=""
LOG_FILE=""
TRASH=0
RUN_ID="$(date '+%Y%m%d-%H%M%S')-$$"
EXCLUDES=()
PATH_ARGS=()
INCLUDE_DEV_HEAVY=0
INCLUDE_NODE_STALE=0
INCLUDE_GEMINI=0
INCLUDE_LMSTUDIO=0
INCLUDE_AI_WORKSPACES=0
INCLUDE_AI_MODELS=0
INCLUDE_PACKAGE_STORES=0
INCLUDE_TOOLCHAINS=0
INCLUDE_CONTAINERS=0
INCLUDE_APP_CACHES=0
INCLUDE_SNAPSHOTS=0
INCLUDE_USER_TRASH=0
INCLUDE_INSTALLERS=0

RED="$(printf '\033[31m')"
GREEN="$(printf '\033[32m')"
YELLOW="$(printf '\033[33m')"
BOLD="$(printf '\033[1m')"
RESET="$(printf '\033[0m')"

usage() {
  cat <<'EOF'
cleanroom - safe macOS storage cleaner

Usage:
  cleanroom overview [--json]
  cleanroom scan [options]
  cleanroom plan [--json]
  cleanroom large [PATH] [--min-mb N] [--limit N] [--json]
  cleanroom duplicates [PATH] [--min-mb N] [--limit N] [--json]
  cleanroom downloads [--days N] [--limit N] [--json]
  cleanroom installers [--days N] [--limit N] [--json]
  cleanroom nodes [PATH] [--days N] [--limit N] [--json]
  cleanroom apps [PATH] [--limit N] [--json]
  cleanroom browsers [--json]
  cleanroom leftovers QUERY... [--limit N] [--json] [--apply --trash]
  cleanroom backups [--json]
  cleanroom xcode [--json]
  cleanroom startup [--json]
  cleanroom trash [--json]
  cleanroom caches [--json]
  cleanroom packages [--json]
  cleanroom toolchains [--json]
  cleanroom snapshots [--json]
  cleanroom report [--output PATH]
  cleanroom clean [options]
  cleanroom history [--limit N]
  cleanroom restore [--log PATH] [--apply]
  cleanroom interactive [options]
  cleanroom doctor [--json]
  cleanroom protect [--json]
  cleanroom guard PATH... [--json]
  cleanroom rules [--json]
  cleanroom categories
  cleanroom init-config [--config PATH]
  cleanroom help

Actions:
  overview             Show a read-only storage dashboard and next steps.
  scan                 Show disk usage and likely cleanup candidates.
  plan                 Rank safe cleanup opportunities and show copyable commands.
  large                List largest files for review without deleting anything.
  duplicates           Find exact duplicate files for review without deleting anything.
  downloads            List old Downloads files for manual review.
  installers           List old downloaded installer files for review.
  nodes                List stale node_modules folders for review.
  apps                 List largest app bundles for review without uninstalling.
  browsers             Inventory browser profile and cache footprint.
  leftovers            Find app leftovers by search term. Apply requires --trash.
  backups              Inventory local iPhone/iPad backups for review.
  xcode                Inventory Xcode build, archive, DeviceSupport, and simulator storage.
  startup              List LaunchAgents and LaunchDaemons for review.
  trash                Inventory current user Trash contents.
  caches               Inventory safe and opt-in cache buckets.
  packages             Inventory package-manager caches and stores.
  toolchains           Inventory language/toolchain caches and stores.
  snapshots            List local Time Machine snapshots for review.
  report               Write a Markdown cleanup report. Prints to stdout by default.
  clean                Clean safe rebuildable caches. Dry-run unless --apply is passed.
  history              List recent apply logs.
  restore              Restore files moved by --trash from an apply log. Dry-run unless --apply.
  interactive          Choose cleanup categories in a guided prompt.
  doctor               Check platform, dependencies, permissions, and risky state.
  protect              Audit protected personal data that cleanroom will not remove.
  guard                Explain whether specific paths are removable by cleanroom.
  rules                List cleanup rules, safety level, opt-in flag, and affected paths.
  categories           Explain cleanup categories and safety levels.
  init-config          Write a starter config file.

Options:
  --apply              Actually delete files. Without this, clean only previews.
  --trash              Move deleted files to ~/.Trash/cleanroom-* instead of rm -rf.
  --yes                Do not prompt before --apply cleanup.
  --verbose            Print every path touched.
  --json               Emit JSON for overview, scan, plan, large, duplicates, downloads,
                       installers, nodes, apps, browsers, leftovers, startup, trash,
                       backups, xcode, caches, packages, toolchains, snapshots, doctor,
                       protect, guard, or rules.
  --output PATH        Output path for report.
  --log PATH           Write apply audit log here. Default: ~/.local/state/cleanroom/runs/*.log.
  --config PATH        Load config file. Default: ~/.config/cleanroom/config.
  --exclude PATH       Never remove this path. Can be passed multiple times.
  --days N             Age threshold for stale node_modules. Default: 30.
  --limit N            Number of history entries or large files to show. Default: 20.
  --min-mb N           Minimum file size for large-file discovery. Default: 500.
  --preset NAME        Enable a useful group: safe, dev, deep.
                       safe: default rebuildable caches.
                       dev: safe + app caches + package/toolchain stores + stale node_modules.
                       deep: dev + heavy SDKs + snapshots + AI workspaces.
  --include-dev-heavy  Include heavier developer data:
                       Xcode device support, simulator app data, Android NDK/system images.
  --include-node-stale Remove node_modules older than --days from Desktop/Documents/Downloads.
  --include-package-stores
                       Include rebuildable package stores like CocoaPods repos and pnpm store.
  --include-toolchains Include rebuildable language/toolchain caches like Go, pip, uv,
                       SwiftPM, Maven, Composer, RubyGems, and Bundler.
  --include-app-caches Include safe cache folders inside Google/Chrome, VS Code, Cursor, Slack, etc.
                       Does not remove profiles, passwords, cookies, bookmarks, or settings wholesale.
  --include-snapshots  Ask Time Machine to thin local snapshots.
  --include-user-trash Empty ~/.Trash during apply. This is irreversible.
  --include-installers Remove old downloaded installer files from ~/Downloads.
  --include-ai-workspaces
                       Remove generated AI-agent workspace state: recordings, scratch, brain,
                       implicit data, and local conversation caches where known.
  --include-ai-models  Remove downloaded local AI models/backends from LM Studio, Ollama,
                       Hugging Face cache, and similar known stores.
  --include-containers Remove local container VM disks for Colima/Lima. This can remove containers.
  --include-gemini     Alias for --include-ai-workspaces.
  --include-lmstudio   Alias for --include-ai-models.
  -h, --help           Show help.
  -v, --version        Show version.

Safety:
  cleanroom does NOT delete browser profiles, password databases, Keychains, Photos libraries,
  Mail, iCloud Drive, or app profile folders by default.

Examples:
  cleanroom overview
  cleanroom overview --json
  cleanroom scan
  cleanroom scan --json
  cleanroom plan
  cleanroom plan --json
  cleanroom large ~/Documents --min-mb 250 --limit 30
  cleanroom large --json ~/Downloads
  cleanroom duplicates ~/Documents --min-mb 100
  cleanroom duplicates --json ~/Downloads
  cleanroom downloads
  cleanroom downloads --days 30 --limit 50
  cleanroom downloads --json
  cleanroom installers
  cleanroom installers --days 30 --limit 50
  cleanroom installers --json
  cleanroom nodes
  cleanroom nodes --days 45 --limit 30
  cleanroom nodes --json ~/Documents
  cleanroom apps
  cleanroom apps --json /Applications
  cleanroom browsers
  cleanroom browsers --json
  cleanroom leftovers adobe
  cleanroom leftovers adobe --apply --trash
  cleanroom leftovers zoom --json
  cleanroom backups
  cleanroom backups --json
  cleanroom xcode
  cleanroom xcode --json
  cleanroom startup
  cleanroom startup --json
  cleanroom trash
  cleanroom trash --json
  cleanroom caches
  cleanroom caches --json
  cleanroom packages
  cleanroom packages --json
  cleanroom toolchains
  cleanroom toolchains --json
  cleanroom snapshots
  cleanroom snapshots --json
  cleanroom report --output cleanroom-report.md
  cleanroom doctor
  cleanroom doctor --json
  cleanroom protect
  cleanroom protect --json
  cleanroom guard ~/Library/Application\ Support/Google/Chrome
  cleanroom rules
  cleanroom rules --json
  cleanroom categories
  cleanroom init-config
  cleanroom interactive
  cleanroom clean
  cleanroom clean --preset dev
  cleanroom clean --apply --trash --preset dev
  cleanroom history
  cleanroom restore --log ~/.local/state/cleanroom/runs/RUN.log
  cleanroom restore --log ~/.local/state/cleanroom/runs/RUN.log --apply
  cleanroom clean --apply --include-app-caches
  cleanroom clean --include-user-trash
  cleanroom clean --apply --include-user-trash
  cleanroom clean --apply --include-dev-heavy --include-node-stale --days 45
EOF
}

log() { printf '%s\n' "$*"; }
warn() { printf '%s%s%s\n' "$YELLOW" "$*" "$RESET" >&2; }
ok() { printf '%s%s%s\n' "$GREEN" "$*" "$RESET"; }
die() { printf '%s%s%s\n' "$RED" "$*" "$RESET" >&2; exit 1; }

expand_path() {
  local path="$1"
  path="${path/#\~/$HOME}"
  printf '%s\n' "$path"
}

config_default_path() {
  printf '%s\n' "$HOME/.config/cleanroom/config"
}

script_dir() {
  local source="${BASH_SOURCE[0]}"
  cd "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

repo_root() {
  local dir
  dir="$(script_dir)"
  if [[ -f "$dir/../data/cleanup-rules.tsv" ]]; then
    (cd "$dir/.." >/dev/null 2>&1 && pwd)
  elif [[ -f "$dir/../share/cleanroom/data/cleanup-rules.tsv" ]]; then
    (cd "$dir/../share/cleanroom" >/dev/null 2>&1 && pwd)
  else
    printf '%s\n' "$dir"
  fi
}

rules_file() {
  local root
  root="$(repo_root)"
  if [[ -f "$root/data/cleanup-rules.tsv" ]]; then
    printf '%s\n' "$root/data/cleanup-rules.tsv"
  else
    printf '%s\n' ""
  fi
}

protected_file() {
  local root
  root="$(repo_root)"
  if [[ -f "$root/data/protected-paths.tsv" ]]; then
    printf '%s\n' "$root/data/protected-paths.tsv"
  else
    printf '%s\n' ""
  fi
}

truthy() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

add_exclude() {
  local path
  path="$(expand_path "$1")"
  [[ -n "$path" ]] && EXCLUDES+=("$path")
}

is_excluded() {
  local path="$1"
  local excluded
  [[ "${#EXCLUDES[@]}" -eq 0 ]] && return 1
  for excluded in "${EXCLUDES[@]}"; do
    [[ -z "$excluded" ]] && continue
    if [[ "$path" == "$excluded" || "$path" == "$excluded/"* ]]; then
      return 0
    fi
  done
  return 1
}

load_config() {
  local file="$1"
  file="$(expand_path "$file")"
  [[ -f "$file" ]] || return 0
  CONFIG_LOADED=1

  local line key value
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" != *"="* ]] && continue

    key="${line%%=*}"
    value="${line#*=}"
    key="${key//[[:space:]]/}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    value="${value%\"}"
    value="${value#\"}"

    case "$key" in
      preset) apply_preset "$value" ;;
      days) [[ "$value" =~ ^[0-9]+$ ]] && DAYS="$value" ;;
      include_app_caches) truthy "$value" && INCLUDE_APP_CACHES=1 ;;
      include_package_stores) truthy "$value" && INCLUDE_PACKAGE_STORES=1 ;;
      include_toolchains) truthy "$value" && INCLUDE_TOOLCHAINS=1 ;;
      include_node_stale) truthy "$value" && INCLUDE_NODE_STALE=1 ;;
      include_dev_heavy) truthy "$value" && INCLUDE_DEV_HEAVY=1 ;;
      include_snapshots) truthy "$value" && INCLUDE_SNAPSHOTS=1 ;;
      include_ai_workspaces) truthy "$value" && INCLUDE_AI_WORKSPACES=1 ;;
      include_ai_models) truthy "$value" && INCLUDE_AI_MODELS=1 ;;
      include_containers) truthy "$value" && INCLUDE_CONTAINERS=1 ;;
      include_user_trash) truthy "$value" && INCLUDE_USER_TRASH=1 ;;
      include_installers) truthy "$value" && INCLUDE_INSTALLERS=1 ;;
      trash) truthy "$value" && TRASH=1 ;;
      log_file) LOG_FILE="$(expand_path "$value")" ;;
      exclude) add_exclude "$value" ;;
    esac
  done <"$file"
}

exists() {
  local path
  path="$(expand_path "$1")"
  [[ -e "$path" ]]
}

size_kb() {
  local path
  path="$(expand_path "$1")"
  [[ -e "$path" ]] || { printf '0'; return; }
  local out
  out="$(du -sk "$path" 2>/dev/null || true)"
  if [[ -z "$out" ]]; then
    printf '0'
  else
    printf '%s\n' "$out" | awk '{print $1; exit}'
  fi
}

human_kb() {
  awk -v kb="${1:-0}" 'BEGIN {
    bytes = kb * 1024
    split("B KB MB GB TB", units, " ")
    i = 1
    while (bytes >= 1024 && i < 5) { bytes /= 1024; i++ }
    if (i <= 2) printf "%.0f%s", bytes, units[i]
    else printf "%.1f%s", bytes, units[i]
  }'
}

print_size() {
  local path="$1"
  local kb
  kb="$(size_kb "$path")"
  printf '%8s  %s\n' "$(human_kb "$kb")" "$path"
}

sum_existing_kb() {
  local total=0
  local path kb
  for path in "$@"; do
    kb="$(size_kb "$path")"
    total=$((total + kb))
  done
  printf '%s\n' "$total"
}

app_cache_kb() {
  local roots=(
    "$HOME/Library/Application Support/Google"
    "$HOME/Library/Application Support/Microsoft Edge"
    "$HOME/Library/Application Support/Arc"
    "$HOME/Library/Application Support/Code"
    "$HOME/Library/Application Support/Cursor"
    "$HOME/Library/Application Support/Slack"
    "$HOME/Library/Application Support/BraveSoftware"
    "$HOME/Library/Application Support/Comet"
    "$HOME/Library/Application Support/Trae"
  )
  local total=0
  local root found
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    found="$(find "$root" -type d \( \
      -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
      -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
      -o -name 'Crashpad' \
    \) -prune -exec du -sk {} + 2>/dev/null | awk '{total += $1} END {print total + 0}' || true)"
    total=$((total + ${found:-0}))
  done
  printf '%s\n' "$total"
}

cache_dir_kb_under() {
  local root="$1"
  [[ -d "$root" ]] || { printf '0\n'; return 0; }
  find "$root" -type d \( \
    -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
    -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
    -o -name 'Crashpad' \
  \) -prune -exec du -sk {} + 2>/dev/null | awk '{total += $1} END {print total + 0}' || true
}

stale_node_kb() {
  local total=0
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root kb
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    while IFS= read -r path; do
      kb="$(size_kb "$path")"
      total=$((total + kb))
    done < <(find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print 2>/dev/null)
  done
  printf '%s\n' "$total"
}

candidate_paths() {
  cat <<'EOF'
~/Library/Caches
~/Library/Logs
~/Library/Developer
~/Library/Android
~/Library/pnpm
~/.npm
~/.yarn
~/.gradle
~/.cache
~/.gemini
~/.lmstudio
~/.ollama
~/.cache/huggingface
~/.cocoapods
~/.colima
~/.lima
~/.codex
~/Library/Application Support
~/Documents
~/Desktop
~/Downloads
EOF
}

report_candidate_paths() {
  cat <<'EOF'
~/Library/Caches
~/Library/Logs
~/Library/Developer
~/Library/Android
~/Library/pnpm
~/.npm
~/.yarn
~/.gradle
~/.cache
~/.gemini
~/.lmstudio
~/.ollama
~/.cache/huggingface
~/.cocoapods
~/.colima
~/.lima
~/.codex
EOF
}

disk_line() {
  df -h /System/Volumes/Data 2>/dev/null || df -h /
}

json_escape() {
  sed 's/\\/\\\\/g; s/"/\\"/g'
}

shell_quote() {
  printf '%q' "$1"
}

leftover_command() {
  local base="$1"
  local query
  printf '%s' "$base"
  for query in "${PATH_ARGS[@]}"; do
    [[ -z "$query" ]] && continue
    printf ' %s' "$(shell_quote "$query")"
  done
  printf ' --limit %s' "$LIMIT"
}

disk_json() {
  local line
  line="$(df -k /System/Volumes/Data 2>/dev/null | awk 'NR==2 {print $2, $3, $4, $5, $9}')"
  if [[ -z "$line" ]]; then
    line="$(df -k / | awk 'NR==2 {print $2, $3, $4, $5, $9}')"
  fi
  awk -v values="$line" 'BEGIN {
    split(values, a, " ")
    printf "\"disk\":{\"size_kb\":%s,\"used_kb\":%s,\"available_kb\":%s,\"capacity\":\"%s\",\"mount\":\"%s\"}", a[1], a[2], a[3], a[4], a[5]
  }'
}

confirm_apply() {
  [[ "$APPLY" -eq 1 ]] || return 0
  [[ "$ASSUME_YES" -eq 1 ]] && return 0
  warn "About to delete selected cache/artifact files."
  [[ "$TRASH" -eq 1 ]] && warn "Trash mode is enabled; cleanroom path deletions move to ~/.Trash."
  warn "Protected data like browser passwords and Keychains is not deleted."
  [[ "$INCLUDE_AI_MODELS" -eq 1 ]] && warn "AI model cleanup removes downloaded model files."
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] && warn "Container cleanup can remove local container VM disks and volumes."
  [[ "$INCLUDE_USER_TRASH" -eq 1 ]] && warn "User Trash cleanup permanently empties ~/.Trash."
  printf 'Continue? Type "clean" to proceed: '
  local answer
  read -r answer
  [[ "$answer" == "clean" ]] || die "Cancelled."
}

default_log_file() {
  printf '%s\n' "$HOME/.local/state/cleanroom/runs/$RUN_ID.log"
}

log_dir() {
  printf '%s\n' "$HOME/.local/state/cleanroom/runs"
}

latest_log_file() {
  local dir
  dir="$(log_dir)"
  [[ -d "$dir" ]] || return 1
  find "$dir" -type f -name '*.log' -exec ls -t {} + 2>/dev/null | head -1
}

ensure_apply_log() {
  [[ "$APPLY" -eq 1 ]] || return 0
  [[ -n "$LOG_FILE" ]] || LOG_FILE="$(default_log_file)"
  mkdir -p "$(dirname "$LOG_FILE")"
  if [[ ! -f "$LOG_FILE" ]]; then
    {
      printf '# cleanroom apply log\n'
      printf 'version=%s\n' "$VERSION"
      printf 'run_id=%s\n' "$RUN_ID"
      printf 'mode=%s\n' "$(if [[ "$TRASH" -eq 1 ]]; then echo trash; else echo delete; fi)"
      printf 'started_at=%s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
      printf 'timestamp\taction\tstatus\tsize_kb\tpath\ttarget\n'
    } >>"$LOG_FILE"
  fi
}

history() {
  local dir count file
  dir="$(log_dir)"
  if [[ ! -d "$dir" ]]; then
    warn "No cleanroom history found: $dir"
    return 0
  fi
  count=0
  printf '%s\n' "${BOLD}cleanroom history${RESET}"
  find "$dir" -type f -name '*.log' -exec ls -t {} + 2>/dev/null |
    while IFS= read -r file; do
      [[ -f "$file" ]] || continue
      count=$((count + 1))
      [[ "$count" -gt "$LIMIT" ]] && break
      local started mode entries
      started="$(awk -F= '/^started_at=/{print $2; exit}' "$file")"
      mode="$(awk -F= '/^mode=/{print $2; exit}' "$file")"
      entries="$(awk -F '\t' '$2 == "trash" && $3 == "ok" {count++} END {print count + 0}' "$file")"
      printf '%s  mode=%s  trash_entries=%s\n  %s\n' "${started:-unknown}" "${mode:-unknown}" "$entries" "$file"
    done
}

restore() {
  local file restored skipped missing collisions line timestamp action status size path target
  if [[ -n "$LOG_FILE" ]]; then
    file="$LOG_FILE"
  else
    file="$(latest_log_file || true)"
  fi
  [[ -n "${file:-}" ]] || die "No apply logs found. Pass --log PATH."
  file="$(expand_path "$file")"
  [[ -f "$file" ]] || die "Restore log not found: $file"

  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$ASSUME_YES" -eq 1 ]] || {
      warn "About to restore Trash-mode entries from: $file"
      printf 'Continue? Type "restore" to proceed: '
      local answer
      read -r answer
      [[ "$answer" == "restore" ]] || die "Cancelled."
    }
    warn "Restore apply mode enabled."
  else
    warn "Restore dry-run mode. Pass --apply to move files back."
  fi

  restored=0
  skipped=0
  missing=0
  collisions=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" || "$line" == \#* || "$line" == timestamp$'\t'* ]] && continue
    IFS=$'\t' read -r timestamp action status size path target <<<"$line"
    [[ "$action" == "trash" && "$status" == "ok" ]] || continue
    [[ -n "${path:-}" && -n "${target:-}" ]] || { skipped=$((skipped + 1)); continue; }
    if [[ ! -e "$target" ]]; then
      missing=$((missing + 1))
      [[ "$VERBOSE" -eq 1 ]] && warn "missing trash item: $target"
      continue
    fi
    if [[ -e "$path" ]]; then
      collisions=$((collisions + 1))
      warn "not restoring because destination exists: $path"
      continue
    fi
    if [[ "$APPLY" -eq 1 ]]; then
      mkdir -p "$(dirname "$path")"
      if mv "$target" "$path"; then
        restored=$((restored + 1))
        [[ "$VERBOSE" -eq 1 ]] && log "restored $target -> $path"
      else
        warn "restore failed: $target -> $path"
        skipped=$((skipped + 1))
      fi
    else
      printf 'would restore %8s  %s -> %s\n' "$(human_kb "${size:-0}")" "$target" "$path"
      restored=$((restored + 1))
    fi
  done <"$file"

  printf 'restore summary: restored=%s missing=%s collisions=%s skipped=%s\n' "$restored" "$missing" "$collisions" "$skipped"
}

record_apply() {
  [[ "$APPLY" -eq 1 ]] || return 0
  ensure_apply_log
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$(date '+%Y-%m-%d %H:%M:%S %Z')" \
    "${1:-remove}" \
    "${2:-unknown}" \
    "${3:-0}" \
    "${4:-}" \
    "${5:-}" >>"$LOG_FILE"
}

canonical_existing_path() {
  local path="$1"
  local dir base
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$base") || printf '%s\n' "$path"
  else
    printf '%s\n' "$path"
  fi
}

is_dangerous_path() {
  local path home
  path="$(canonical_existing_path "$1")"
  home="$(canonical_existing_path "$HOME")"
  case "$path" in
    ""|"/"|"/System"|"/Library"|"/Applications"|"/Users"|"$home"|"$home/Library"|"$home/Documents"|"$home/Desktop"|"$home/Downloads"|"$home/Library/Application Support")
      return 0
      ;;
  esac
  return 1
}

protected_removal_reason() {
  local path="$1"
  local file id type protected_path reason expanded protected_canonical path_canonical
  file="$(protected_file)"
  [[ -f "$file" ]] || return 1
  path_canonical="$(canonical_existing_path "$path")"

  while IFS=$'\t' read -r id type protected_path reason; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$protected_path")"
    protected_canonical="$(canonical_existing_path "$expanded")"
    if [[ "$path_canonical" == "$protected_canonical" || "$protected_canonical" == "$path_canonical/"* ]]; then
      printf '%s: %s\n' "$id" "$reason"
      return 0
    fi
  done < <(tail -n +2 "$file")
  return 1
}

is_protected_removal_path() {
  protected_removal_reason "$1" >/dev/null
}

trash_path() {
  local path="$1"
  local trash_dir base target n
  trash_dir="$HOME/.Trash/cleanroom-$RUN_ID"
  mkdir -p "$trash_dir"
  base="$(basename "$path")"
  target="$trash_dir/$base"
  n=1
  while [[ -e "$target" ]]; do
    target="$trash_dir/$base.$n"
    n=$((n + 1))
  done
  mv "$path" "$target"
  printf '%s\n' "$target"
}

delete_path() {
  local path="$1"
  local kb target
  [[ -e "$path" ]] || return 0
  if is_dangerous_path "$path"; then
    warn "refusing dangerous path: $path"
    record_apply "remove" "refused-dangerous" "0" "$path" ""
    return 0
  fi
  local protected_reason
  protected_reason="$(protected_removal_reason "$path" || true)"
  if [[ -n "$protected_reason" ]]; then
    warn "refusing protected path: $path ($protected_reason)"
    record_apply "remove" "refused-protected" "0" "$path" ""
    return 0
  fi
  kb="$(size_kb "$path")"
  if [[ "$TRASH" -eq 1 ]]; then
    target="$(trash_path "$path" 2>/dev/null || true)"
    if [[ -n "$target" ]]; then
      record_apply "trash" "ok" "$kb" "$path" "$target"
      [[ "$VERBOSE" -eq 1 ]] && log "moved $(human_kb "$kb")  $path -> $target"
    else
      warn "Could not move to Trash: $path"
      record_apply "trash" "failed" "$kb" "$path" ""
    fi
  else
    if rm -rf "$path" 2>/dev/null; then
      record_apply "delete" "ok" "$kb" "$path" ""
      [[ "$VERBOSE" -eq 1 ]] && log "removed $(human_kb "$kb")  $path"
    else
      warn "Could not remove: $path"
      record_apply "delete" "failed" "$kb" "$path" ""
    fi
  fi
  return 0
}

delete_user_trash_child() {
  local path="$1"
  local trash_dir="$HOME/.Trash"
  local kb
  [[ -e "$path" ]] || return 0
  case "$path" in
    "$trash_dir"/*) ;;
    *)
      warn "refusing non-Trash path during Trash cleanup: $path"
      record_apply "empty-trash" "refused" "0" "$path" ""
      return 0
      ;;
  esac
  kb="$(size_kb "$path")"
  if rm -rf "$path" 2>/dev/null; then
    record_apply "empty-trash" "ok" "$kb" "$path" ""
    [[ "$VERBOSE" -eq 1 ]] && log "emptied $(human_kb "$kb")  $path"
  else
    warn "Could not empty Trash item: $path"
    record_apply "empty-trash" "failed" "$kb" "$path" ""
  fi
}

run_rm() {
  local path="$1"
  path="$(expand_path "$path")"
  [[ -e "$path" ]] || return 0
  if is_excluded "$path"; then
    [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded path: $path"
    return 0
  fi

  local kb
  kb="$(size_kb "$path")"
  if [[ "$APPLY" -eq 1 ]]; then
    delete_path "$path"
  else
    printf 'would remove %8s  %s\n' "$(human_kb "$kb")" "$path"
  fi
}

run_find_delete_children() {
  local path="$1"
  path="$(expand_path "$path")"
  [[ -d "$path" ]] || return 0
  if is_excluded "$path"; then
    [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded path: $path"
    return 0
  fi
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$VERBOSE" -eq 1 ]] && log "clearing children of $path"
    find "$path" -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
      while IFS= read -r -d '' child; do
        delete_path "$child"
      done || true
  else
    print_size "$path"
  fi
}

safe_clean() {
  log "${BOLD}Safe rebuildable caches${RESET}"
  run_find_delete_children "~/Library/Caches"
  run_find_delete_children "~/.cache"
  run_rm "~/.npm/_cacache"
  run_rm "~/.npm/_logs"
  run_rm "~/.npm/_npx"
  run_rm "~/.yarn/cache"
  run_rm "~/.yarn/berry"
  run_rm "~/.gradle/caches"
  run_rm "~/.gradle/daemon"
  run_rm "~/.gradle/native"
  run_rm "~/.gradle/workers"
  run_rm "~/Library/pnpm/store"
  run_rm "~/Library/Developer/Xcode/DerivedData"
  run_rm "~/Library/Developer/CoreSimulator/Caches"

  if command -v brew >/dev/null 2>&1; then
    if [[ "$APPLY" -eq 1 ]]; then
      if [[ "$TRASH" -eq 1 ]]; then
        run_find_delete_children "~/Library/Caches/Homebrew"
      else
        brew cleanup -s >/dev/null 2>&1 || true
        run_find_delete_children "~/Library/Caches/Homebrew"
      fi
    else
      print_size "~/Library/Caches/Homebrew"
    fi
  fi
}

clean_package_stores() {
  [[ "$INCLUDE_PACKAGE_STORES" -eq 1 ]] || return 0
  log "${BOLD}Package manager stores${RESET}"
  run_rm "~/Library/pnpm/store"
  run_rm "~/.pnpm-store"
  run_rm "~/.cocoapods/repos"
  run_rm "~/.gradle-tangibly-release/caches"
  run_rm "~/.gradle-tangibly-release/wrapper"
  run_rm "~/.gradle-tangibly-release/native"
  run_rm "~/.cargo/registry/cache"
}

clean_toolchains() {
  [[ "$INCLUDE_TOOLCHAINS" -eq 1 ]] || return 0
  log "${BOLD}Language and toolchain caches${RESET}"
  local id ecosystem paths category preview apply description path
  while IFS=$'\t' read -r id ecosystem paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    while IFS= read -r path; do
      path="${path#"${path%%[![:space:]]*}"}"
      path="${path%"${path##*[![:space:]]}"}"
      [[ -z "$path" ]] && continue
      run_rm "$path"
    done < <(printf '%s\n' "$paths" | tr ';' '\n')
  done < <(toolchain_rows)
}

clean_logs() {
  log "${BOLD}Old logs${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    find "$HOME/Library/Logs" -type f -mtime +7 -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_path "$path"
      done || true
    find "$HOME/Library/Logs" -mindepth 1 -type d -empty -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_path "$path"
      done || true
  else
    print_size "~/Library/Logs"
  fi
}

clean_app_caches() {
  [[ "$INCLUDE_APP_CACHES" -eq 1 ]] || return 0
  log "${BOLD}App cache folders only${RESET}"
  local roots=(
    "$HOME/Library/Application Support/Google"
    "$HOME/Library/Application Support/Microsoft Edge"
    "$HOME/Library/Application Support/Arc"
    "$HOME/Library/Application Support/Code"
    "$HOME/Library/Application Support/Cursor"
    "$HOME/Library/Application Support/Slack"
    "$HOME/Library/Application Support/BraveSoftware"
    "$HOME/Library/Application Support/Comet"
    "$HOME/Library/Application Support/Trae"
  )
  local root
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    if [[ "$APPLY" -eq 1 ]]; then
      find "$root" -type d \( \
        -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
        -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
        -o -name 'Crashpad' \
      \) -prune -print0 2>/dev/null |
        while IFS= read -r -d '' path; do
          delete_path "$path"
        done || true
    else
      local total
      total="$(cache_dir_kb_under "$root")"
      [[ -n "$total" ]] || total=0
      printf 'would clean %8s  %s cache folders\n' "$(human_kb "$total")" "$root"
    fi
  done
  return 0
}

clean_dev_heavy() {
  [[ "$INCLUDE_DEV_HEAVY" -eq 1 ]] || return 0
  log "${BOLD}Heavy developer artifacts${RESET}"
  run_rm "~/Library/Developer/Xcode/iOS DeviceSupport"
  run_rm "~/Library/Developer/Xcode/watchOS DeviceSupport"
  run_rm "~/Library/Developer/Xcode/tvOS DeviceSupport"
  run_rm "~/Library/Android/sdk/ndk"
  run_rm "~/Library/Android/sdk/system-images"
  run_rm "~/Library/Android/sdk/.downloadIntermediates"
  run_rm "~/Library/Android/sdk/.temp"

  if [[ "$APPLY" -eq 1 ]] && command -v xcrun >/dev/null 2>&1; then
    xcrun simctl shutdown all >/dev/null 2>&1 || true
    xcrun simctl delete unavailable >/dev/null 2>&1 || true
    xcrun simctl erase all >/dev/null 2>&1 || true
  elif command -v xcrun >/dev/null 2>&1; then
    warn "would reset iOS Simulator app data because --include-dev-heavy is set"
  fi
}

clean_snapshots() {
  [[ "$INCLUDE_SNAPSHOTS" -eq 1 ]] || return 0
  log "${BOLD}Local snapshots${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    tmutil thinlocalsnapshots / 999999999999 4 2>/dev/null || true
  else
    tmutil listlocalsnapshots / 2>/dev/null || true
  fi
}

