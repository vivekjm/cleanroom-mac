communications_total_kb() {
  local total=0 id title kind path guidance expanded kb
  while IFS=$'\t' read -r id title kind path guidance; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    kb="$(size_kb "$expanded")"
    total=$((total + kb))
  done < <(communications_rows)
  printf '%s\n' "$total"
}

communications() {
  local rows
  rows="$(communications_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title kind path guidance expanded kb
    while IFS=$'\t' read -r id title kind path guidance; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$expanded")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","kind":"%s","path":"%s","exists":%s,"size_kb":%s,"size":"%s","protected":true,"guidance":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$(if [[ -e "$expanded" ]]; then echo true; else echo false; fi)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom protected communications storage${RESET}"
  printf 'Review-only inventory. cleanroom does not delete Mail or Messages data, attachments, accounts, chats, or indexes.\n\n'
  printf '%-10s %-20s %-26s %s\n' "size" "kind" "location" "path"
  local id title kind path guidance expanded kb
  while IFS=$'\t' read -r id title kind path guidance; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] || continue
    kb="$(size_kb "$expanded")"
    printf '%-10s %-20s %-26s %s\n' "$(human_kb "$kb")" "$kind" "$title" "$expanded"
    printf '  %s\n' "$guidance"
  done <<<"$rows"
  printf '\nUse this to explain large Mail/Messages storage. Manage cleanup inside Mail, Messages, iCloud settings, or after verified backups.\n'
}

backup_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || { printf '\n'; return 0; }
  plutil -extract "$key" raw -o - "$file" 2>/dev/null || true
}

backup_rows() {
  local root="$HOME/Library/Application Support/MobileSync/Backup"
  [[ -d "$root" ]] || return 0
  local path info kb epoch device product last_backup
  while IFS= read -r -d '' path; do
    info="$path/Info.plist"
    kb="$(size_kb "$path")"
    epoch="$(path_mtime_epoch "$path")"
    device="$(backup_value "$info" "Device Name")"
    product="$(backup_value "$info" "Product Name")"
    last_backup="$(backup_value "$info" "Last Backup Date")"
    [[ -n "$device" ]] || device="$(basename "$path")"
    printf '%012d\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$device" "$product" "$last_backup" "$path"
  done < <(find "$root" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null) |
    sort -rn |
    head -n "$LIMIT"
  return 0
}

backup_cleanup_rows() {
  local cutoff kb epoch device product last_backup path
  cutoff=$(( $(date +%s) - DAYS * 86400 ))
  while IFS=$'\t' read -r kb epoch device product last_backup path; do
    [[ -z "${path:-}" ]] && continue
    [[ "${epoch:-0}" -le "$cutoff" ]] || continue
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$device" "$product" "$last_backup" "$path"
  done < <(backup_rows)
}

device_backup_trash_path() {
  local path="$1"
  local root target kb
  root="$(canonical_existing_path "$HOME/Library/Application Support/MobileSync/Backup")"
  path="$(canonical_existing_path "$path")"

  case "$path" in
    "$root"/*) ;;
    *)
      warn "refusing non-MobileSync backup path: $path"
      record_apply "device-backup" "refused-scope" "0" "$path" ""
      return 0
      ;;
  esac

  if [[ "$(dirname "$path")" != "$root" ]]; then
    warn "refusing nested MobileSync backup item: $path"
    record_apply "device-backup" "refused-nested" "0" "$path" ""
    return 0
  fi

  if is_excluded "$path"; then
    [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded device backup: $path"
    return 0
  fi

  kb="$(size_kb "$path")"
  if [[ "$APPLY" -eq 1 ]]; then
    target="$(trash_path "$path" 2>/dev/null || true)"
    if [[ -n "$target" ]]; then
      record_apply "trash" "ok" "$kb" "$path" "$target"
      [[ "$VERBOSE" -eq 1 ]] && log "moved device backup $(human_kb "$kb")  $path -> $target"
    else
      warn "Could not move device backup to Trash: $path"
      record_apply "trash" "failed" "$kb" "$path" ""
    fi
  else
    printf 'would remove %8s  %s\n' "$(human_kb "$kb")" "$path"
  fi
  return 0
}

clean_device_backups() {
  [[ "$INCLUDE_DEVICE_BACKUPS" -eq 1 ]] || return 0
  log "${BOLD}Old local iPhone/iPad backups older than ${DAYS} days${RESET}"
  [[ "$TRASH" -eq 1 ]] || die "--include-device-backups requires --trash so backups can be restored from the apply log."
  if [[ "$APPLY" -eq 1 && "$ASSUME_YES" -ne 1 ]]; then
    warn "This can remove local iPhone/iPad backups that may be the only copy of device data."
    printf 'Continue? Type "device backups" to proceed: '
    local answer
    read -r answer
    [[ "$answer" == "device backups" ]] || die "Cancelled."
  fi

  local rows kb epoch device product last_backup path
  rows="$(backup_cleanup_rows)"
  if [[ -z "$rows" ]]; then
    printf 'No local device backups older than %s days found.\n' "$DAYS"
    return 0
  fi
  while IFS=$'\t' read -r kb epoch device product last_backup path; do
    [[ -z "${path:-}" ]] && continue
    device_backup_trash_path "$path"
  done <<<"$rows"
  return 0
}

backups() {
  local rows root cutoff
  root="$HOME/Library/Application Support/MobileSync/Backup"
  rows="$(backup_rows)"
  cutoff=$(( $(date +%s) - DAYS * 86400 ))

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch device product last_backup path kb_num
    while IFS=$'\t' read -r kb epoch device product last_backup path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","device_name":"%s","product_name":"%s","last_backup":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","protected":true,"cleanup_eligible":%s,"cleanup_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$device" | json_escape)" \
        "$(printf '%s' "$product" | json_escape)" \
        "$(printf '%s' "$last_backup" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "$(file_mtime_iso "${epoch:-0}" | json_escape)" \
        "$(if [[ "${epoch:-0}" -le "$cutoff" ]]; then echo true; else echo false; fi)" \
        "$(printf 'cleanroom clean --include-device-backups --days %s --apply --trash' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom local iPhone/iPad backups${RESET}"
  printf 'Review-first inventory. Cleanup is high-impact, opt-in, limited to backups older than --days, and requires --trash.\n'
  printf 'Path: %s\n\n' "$root"
  if [[ -z "$rows" ]]; then
    printf 'No local MobileSync backups found.\n'
    return 0
  fi
  printf '%-10s %-12s %-24s %-20s %s\n' "size" "modified" "device" "product" "path"
  local kb epoch device product last_backup path
  while IFS=$'\t' read -r kb epoch device product last_backup path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %-12s %-24s %-20s %s\n' "$(human_kb "$kb")" "$(file_mtime_iso "${epoch:-0}")" "$device" "$product" "$path"
    [[ -n "$last_backup" ]] && printf '  last backup: %s\n' "$last_backup"
  done <<<"$rows"
  printf '\nPreferred: manage these through Finder or Apple Devices after confirming you have another backup.\n'
  printf 'Opt-in cleanup preview: cleanroom clean --include-device-backups --days %s --trash\n' "$DAYS"
  printf 'Opt-in cleanup apply: cleanroom clean --include-device-backups --days %s --apply --trash\n' "$DAYS"
}

