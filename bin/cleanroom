  [[ "$INCLUDE_AI_WORKSPACES" -eq 1 || "$INCLUDE_GEMINI" -eq 1 ]] || return 0
  log "${BOLD}AI agent workspace data${RESET}"
  local id app kind safety path preview apply description
  while IFS=$'\t' read -r id app kind safety path preview apply description; do
    [[ -z "${path:-}" || "$safety" != "generated-workspace" ]] && continue
    run_rm "$path"
  done < <(ai_workspace_rows)
}

clean_ai_models() {
  [[ "$INCLUDE_AI_MODELS" -eq 1 || "$INCLUDE_LMSTUDIO" -eq 1 ]] || return 0
  log "${BOLD}Local AI models and backends${RESET}"
  local id app kind safety path preview apply description
  while IFS=$'\t' read -r id app kind safety path preview apply description; do
    [[ -z "${path:-}" || "$safety" != "downloaded-models" ]] && continue
    run_rm "$path"
  done < <(ai_model_rows)
}

