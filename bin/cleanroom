android() {
  local rows
  rows="$(
    local id title safety paths preview apply notes kb
    while IFS=$'\t' read -r id title safety paths preview apply notes; do
      kb="$(paths_field_kb "$paths")"
      printf '%012d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$id" "$title" "$safety" "$paths" "$preview" "$apply" "$notes"
    done < <(android_rows) | sort -rn
  )"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title safety paths preview apply notes kb_num present
    while IFS=$'\t' read -r kb id title safety paths preview apply notes; do
      [[ -z "${id:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      if [[ "$kb_num" -gt 0 ]]; then
        present=true
      else
        present=false
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","safety":"%s","paths":"%s","present":%s,"size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","notes":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$present" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$notes" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Android storage${RESET}"
  printf 'Review-only inventory. Cleanup commands are dry-runs unless --apply is passed.\n\n'
  printf '%-10s %-25s %-12s %s\n' "size" "item" "safety" "paths"
  local kb id title safety paths preview apply notes
  while IFS=$'\t' read -r kb id title safety paths preview apply notes; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-25s %-12s %s\n' "$(human_kb "$kb")" "$title" "$safety" "$paths"
    printf '  preview: %s\n' "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  %s\n' "$notes"
  done <<<"$rows"
}

plist_value() {
  local file="$1"
  local key="$2"
  plutil -extract "$key" raw -o - "$file" 2>/dev/null || true
}

startup_program() {
  local plist="$1" program
  program="$(plist_value "$plist" "Program")"
  if [[ -z "$program" ]]; then
    program="$(plutil -p "$plist" 2>/dev/null | awk '
      /"ProgramArguments"/ {in_args=1; next}
      in_args && /\]/ {exit}
      in_args && /=>/ {
        sub(/^[[:space:]]*[0-9]+ => "/, "")
        sub(/"$/, "")
        print
        exit
      }
    ' || true)"
  fi
  printf '%s\n' "$program"
}

startup_rows() {
  local entries=(
    "user	LaunchAgent	$HOME/Library/LaunchAgents"
    "local	LaunchAgent	/Library/LaunchAgents"
    "local	LaunchDaemon	/Library/LaunchDaemons"
  )
  local entry scope type dir plist label disabled status program
  for entry in "${entries[@]}"; do
    IFS=$'\t' read -r scope type dir <<<"$entry"
    [[ -d "$dir" ]] || continue
    find "$dir" -maxdepth 1 -type f -name '*.plist' -print0 2>/dev/null |
      while IFS= read -r -d '' plist; do
        label="$(plist_value "$plist" "Label")"
        [[ -n "$label" ]] || label="$(basename "$plist" .plist)"
        disabled="$(plist_value "$plist" "Disabled")"
        if [[ "$disabled" == "true" ]]; then
          status="disabled"
        else
          status="enabled"
        fi
        program="$(startup_program "$plist")"
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$scope" "$type" "$status" "$label" "$program" "$plist"
      done
  done | awk -v limit="$LIMIT" 'NR <= limit'
}

startup_count() {
  startup_rows | awk 'END {print NR + 0}'
}

loginitem_manage_command() {
  printf 'open x-apple.systempreferences:com.apple.LoginItems-Settings.extension'
}

loginitem_rows() {
  command -v osascript >/dev/null 2>&1 || return 0
  local script_output
  script_output="$(osascript 2>/dev/null <<APPLESCRIPT || true
set output to ""
tell application "System Events"
  repeat with itemRef in login items
    set itemName to name of itemRef as text
    set itemHidden to hidden of itemRef as text
    set itemPath to ""
    try
      set itemPath to POSIX path of (path of itemRef as alias)
    end try
    set output to output & itemName & tab & itemHidden & tab & itemPath & linefeed
  end repeat
end tell
return output
APPLESCRIPT
)"
  local name hidden path expanded kb
  while IFS=$'\t' read -r name hidden path; do
    [[ -n "${name:-}" ]] || continue
    expanded=""
    kb=0
    if [[ -n "${path:-}" ]]; then
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$expanded")"
    fi
    printf '%012d\t%s\t%s\t%s\n' "$kb" "$name" "${hidden:-unknown}" "$expanded"
  done <<<"$script_output" | sort -rn
}

loginitems() {
  local rows
  rows="$(loginitem_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb name hidden path kb_num
    while IFS=$'\t' read -r kb name hidden path; do
      [[ -z "${name:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","hidden":"%s","path":"%s","present":%s,"size_kb":%s,"size":"%s","manage_command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$hidden" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$(if [[ -n "$path" && -e "$path" ]]; then echo true; else echo false; fi)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(loginitem_manage_command | json_escape)" \
        "$(printf '%s' "Review Login Items in System Settings. cleanroom does not disable or remove them." | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Login Items${RESET}"
  printf 'Review-only inventory. cleanroom does not disable, remove, or change Login Items.\n'
  printf 'Manage them in System Settings > General > Login Items.\n\n'
  if ! command -v osascript >/dev/null 2>&1; then
    printf 'osascript not found; Login Items cannot be inspected on this system.\n'
    return 0
  fi
  if [[ -z "$rows" ]]; then
    printf 'No Login Items reported by System Events, or access was denied.\n'
    return 0
  fi
  printf '%-10s %-8s %s\n' "size" "hidden" "name"
  local kb name hidden path
  while IFS=$'\t' read -r kb name hidden path; do
    [[ -z "${name:-}" ]] && continue
    printf '%-10s %-8s %s\n' "$(human_kb "$kb")" "$hidden" "$name"
    [[ -n "$path" ]] && printf '  path: %s\n' "$path"
  done <<<"$rows"
  printf '\nManage: %s\n' "$(loginitem_manage_command)"
}

startup() {
  local rows
  rows="$(startup_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 scope type status label program plist
    while IFS=$'\t' read -r scope type status label program plist; do
      [[ -z "${plist:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"scope":"%s","type":"%s","status":"%s","label":"%s","program":"%s","path":"%s"}' \
        "$(printf '%s' "$scope" | json_escape)" \
        "$(printf '%s' "$type" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$label" | json_escape)" \
        "$(printf '%s' "$program" | json_escape)" \
        "$(printf '%s' "$plist" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom startup items${RESET}"
  printf 'Review-only list. cleanroom does not unload, disable, or remove startup items.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No LaunchAgents or LaunchDaemons found.\n'
    return 0
  fi
  printf '%-8s %-13s %-9s %-36s %s\n' "scope" "type" "status" "label" "path"
  local scope type status label program plist
  while IFS=$'\t' read -r scope type status label program plist; do
    [[ -z "${plist:-}" ]] && continue
    printf '%-8s %-13s %-9s %-36s %s\n' "$scope" "$type" "$status" "$label" "$plist"
    [[ -n "$program" ]] && printf '  program: %s\n' "$program"
  done <<<"$rows"
  printf '\nReview login items in System Settings > General > Login Items.\n'
}

trash_rows() {
  local dir="$HOME/.Trash"
  [[ -d "$dir" ]] || return 0
  find "$dir" -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\n' "$(size_kb "$path")" "$path"
    done |
    sort -rn |
    awk -v limit="$LIMIT" 'NR <= limit' || true
}

trash_total_kb() {
  size_kb "~/.Trash"
}

count_files_under() {
  local path="$1"
  [[ -d "$path" ]] || { printf '0\n'; return; }
  find "$path" -type f 2>/dev/null | awk 'END {print NR + 0}'
}

count_dirs_matching() {
  local pattern="$1"
  find "$(dirname "$pattern")" -mindepth 1 -maxdepth 1 -type d -name "$(basename "$pattern")" 2>/dev/null | awk 'END {print NR + 0}'
}

cleanroom_trash_total_kb() {
  local total=0 path kb
  while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    kb="$(size_kb "$path")"
    total=$((total + kb))
  done < <(find "$HOME/.Trash" -mindepth 1 -maxdepth 1 -type d -name 'cleanroom-*' 2>/dev/null)
  printf '%s\n' "$total"
}

cleanroom_state_cleanup_rows() {
  local cutoff path kind kb epoch age_days
  cutoff=$(( $(date +%s) - DAYS * 86400 ))

  if [[ -d "$(log_dir)" ]]; then
    while IFS= read -r -d '' path; do
      epoch="$(path_mtime_epoch "$path")"
      [[ "${epoch:-0}" -le "$cutoff" ]] || continue
      kb="$(size_kb "$path")"
      age_days=$((($(date +%s) - epoch) / 86400))
      printf '%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "run-log" "$path"
    done < <(find "$(log_dir)" -type f -name '*.log' -mtime +"$DAYS" -print0 2>/dev/null)
  fi

  if [[ -d "$(snapshot_dir)" ]]; then
    while IFS= read -r -d '' path; do
      epoch="$(path_mtime_epoch "$path")"
      [[ "${epoch:-0}" -le "$cutoff" ]] || continue
      kb="$(size_kb "$path")"
      age_days=$((($(date +%s) - epoch) / 86400))
      printf '%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "snapshot" "$path"
    done < <(find "$(snapshot_dir)" -type f -name 'snapshot-*.json' -mtime +"$DAYS" -print0 2>/dev/null)
  fi

  if [[ -d "$HOME/.Trash" ]]; then
    while IFS= read -r -d '' path; do
      epoch="$(path_mtime_epoch "$path")"
      [[ "${epoch:-0}" -le "$cutoff" ]] || continue
      kb="$(size_kb "$path")"
      age_days=$((($(date +%s) - epoch) / 86400))
      printf '%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "recoverable-trash" "$path"
    done < <(find "$HOME/.Trash" -mindepth 1 -maxdepth 1 -type d -name 'cleanroom-*' -mtime +"$DAYS" -print0 2>/dev/null)
  fi
}

cleanroom_state_cleanup_total_kb() {
  cleanroom_state_cleanup_rows | tab_rows_total_kb
}

state_rows() {
  local runs snapshots trash_pattern trash_kb
  runs="$(log_dir)"
  snapshots="$(snapshot_dir)"
  trash_pattern="$HOME/.Trash/cleanroom-*"
  trash_kb="$(cleanroom_trash_total_kb)"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$(size_kb "$runs")" "run-logs" "Apply logs" "$runs" "$(count_files_under "$runs")" "cleanroom history" "Audit logs for applied cleanup and restore operations."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$(size_kb "$snapshots")" "snapshots" "Storage snapshots" "$snapshots" "$(count_files_under "$snapshots")" "cleanroom diff" "Timestamped storage snapshot JSON files for before/after comparisons."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$trash_kb" "recoverable-trash" "Recoverable Trash folders" "$trash_pattern" "$(count_dirs_matching "$trash_pattern")" "cleanroom restore --log PATH" "Files moved by cleanroom --trash runs. Review before emptying Trash."
}

state() {
  local rows
  rows="$(state_rows | sort -rn)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title path count command description
    while IFS=$'\t' read -r kb id title path count command description; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","path":"%s","count":%s,"size_kb":%s,"size":"%s","command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "${count:-0}" \
        "${kb:-0}" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$command" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom state${RESET}"
  printf 'Read-only inventory of files cleanroom creates for audit, snapshots, and recoverable Trash mode.\n\n'
  printf '%-10s %-8s %-20s %-28s %s\n' "size" "count" "id" "next command" "path"
  local kb id title path count command description
  while IFS=$'\t' read -r kb id title path count command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-8s %-20s %-28s %s\n' "$(human_kb "${kb:-0}")" "${count:-0}" "$id" "$command" "$path"
    printf '  %s\n' "$description"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-cleanroom-state --days %s\n' "$DAYS"
  printf 'Apply cleanup with: cleanroom clean --apply --include-cleanroom-state --days %s\n' "$DAYS"
}

clean_cleanroom_state() {
  [[ "$INCLUDE_CLEANROOM_STATE" -eq 1 ]] || return 0
  log "${BOLD}Old cleanroom-created state older than ${DAYS} days${RESET}"
  local rows kb epoch age_days kind path
  rows="$(cleanroom_state_cleanup_rows)"
  if [[ -z "$rows" ]]; then
    printf 'No old cleanroom-created state found.\n'
    return 0
  fi
  while IFS=$'\t' read -r kb epoch age_days kind path; do
    [[ -z "${path:-}" ]] && continue
    if [[ "$kind" == "recoverable-trash" ]]; then
      if [[ "$APPLY" -eq 1 ]]; then
        delete_user_trash_child "$path"
      else
        printf 'would empty  %8s  %s\n' "$(human_kb "$kb")" "$path"
      fi
    else
      run_rm "$path"
    fi
  done <<<"$rows"
  return 0
}

trash() {
  local rows total
  rows="$(trash_rows || true)"
  total="$(trash_total_kb)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"total_kb":%s,"total":"%s","items":[' "$total" "$(human_kb "$total" | json_escape)"
    local first=1 kb kb_num path
    while IFS=$'\t' read -r kb path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$rows"
    printf ']}\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Trash${RESET}"
  printf 'Review-only inventory. Emptying Trash is opt-in and irreversible.\n'
  printf 'Total: %s  Limit: %s\n\n' "$(human_kb "$total")" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'Trash is empty.\n'
    return 0
  fi
  local kb path
  while IFS=$'\t' read -r kb path; do
    [[ -z "${path:-}" ]] && continue
    printf '%8s  %s\n' "$(human_kb "$kb")" "$path"
  done <<<"$rows"
  printf '\nPreview emptying Trash with: cleanroom clean --include-user-trash\n'
  printf 'Empty Trash with: cleanroom clean --include-user-trash --apply\n'
}

