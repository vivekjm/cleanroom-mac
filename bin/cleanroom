aitool_rows() {
  local id app kind safety path preview apply description expanded kb
  while IFS=$'\t' read -r id app kind safety path preview apply description; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    kb="$(size_kb "$expanded")"
    printf '%012d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$id" "$app" "$kind" "$safety" "$expanded" "$preview" "$apply" "$description"
  done < <(ai_workspace_rows; ai_model_rows) | sort -rn
}

aitools_total_kb() {
  aitool_rows | tab_rows_total_kb
}

aitools() {
  local rows
  rows="$(aitool_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id app kind safety path preview apply description kb_num present
    while IFS=$'\t' read -r kb id app kind safety path preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      if [[ "$kb_num" -gt 0 ]]; then
        present=true
      else
        present=false
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","app":"%s","kind":"%s","safety":"%s","path":"%s","present":%s,"size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$app" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$present" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom AI tools storage${RESET}"
  printf 'Review-only inventory for generated AI-agent state and downloaded local models.\n'
  printf 'Cleanup is opt-in: use --include-ai-workspaces for generated state and --include-ai-models for downloaded model stores.\n\n'
  if [[ -z "$rows" ]]; then
    printf 'No known AI tool storage locations found.\n'
    return 0
  fi
  printf '%-10s %-22s %-18s %-20s %s\n' "size" "app" "kind" "safety" "path"
  local kb id app kind safety path preview apply description
  while IFS=$'\t' read -r kb id app kind safety path preview apply description; do
    [[ -z "${id:-}" ]] && continue
    [[ "${kb:-0}" == "000000000000" ]] && continue
    printf '%-10s %-22s %-18s %-20s %s\n' "$(human_kb "$kb")" "$app" "$kind" "$safety" "$path"
    printf '  apply: %s\n' "$apply"
    printf '  %s\n' "$description"
  done <<<"$rows"
  printf '\nPasswords, browser profiles, cookies, bookmarks, Keychains, and broad app profiles stay protected.\n'
}

aitools_fast() {
  if [[ "$JSON" -eq 1 ]]; then
    cat <<'EOF'
[{"id":"gemini-generated-state","title":"Gemini / Antigravity Generated State","app":"Gemini / Antigravity","kind":"workspace state","safety":"generated-workspace","size":"Review","status":"Review","summary":"Recordings, scratch folders, local brain or memory data, implicit state, conversations, and generated browser rendering caches can be reviewed in the deep AI Tools view.","mode":"fast"},{"id":"lmstudio-model-storage","title":"LM Studio Model Storage","app":"LM Studio","kind":"models and backends","safety":"downloaded-models","size":"Review","status":"Review","summary":"Downloaded model files, backend runtimes, extensions, and temporary downloads can usually be downloaded again if needed.","mode":"fast"},{"id":"ollama-model-storage","title":"Ollama Model Storage","app":"Ollama","kind":"models","safety":"downloaded-models","size":"Review","status":"Review","summary":"Downloaded Ollama model blobs and manifests are treated as optional model storage, not personal credentials.","mode":"fast"},{"id":"shared-model-caches","title":"Shared Local Model Caches","app":"Hugging Face, ModelScope, PyTorch, Whisper, llama.cpp, GPT4All, Jan, AnythingLLM","kind":"models","safety":"downloaded-models","size":"Review","status":"Review","summary":"Known local model caches and app model stores are grouped here for a quick desktop review; open the deep AI Tools view for exact sizes.","mode":"fast"},{"id":"ai-safety-boundary","title":"AI Safety Boundary","app":"Cleanroom","kind":"safety","safety":"Protected","size":"Protected","status":"Protected","summary":"Browser profiles, saved passwords, cookies, bookmarks, Keychains, and broad app profiles stay protected.","mode":"fast"}]
EOF
    return 0
  fi

  printf '%s\n' "${BOLD}quick AI tools storage${RESET}"
  printf 'Instant desktop summary. Exact model and workspace sizing is skipped for responsiveness.\n\n'
  printf '%-28s %-20s %s\n' "area" "safety" "summary"
  printf '%-28s %-20s %s\n' "Gemini / Antigravity" "generated-workspace" "Generated recordings, scratch, brain, implicit state, conversations, and rendering caches."
  printf '%-28s %-20s %s\n' "LM Studio" "downloaded-models" "Models, backend runtimes, extensions, and temporary downloads."
  printf '%-28s %-20s %s\n' "Shared model caches" "downloaded-models" "Hugging Face, ModelScope, PyTorch, Whisper, llama.cpp, GPT4All, Jan, and AnythingLLM."
  printf '%-28s %-20s %s\n' "Safety boundary" "Protected" "Passwords, browser profiles, cookies, bookmarks, Keychains, and app profiles stay protected."
}

clean_containers() {
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] || return 0
  log "${BOLD}Container VM disks${RESET}"
  local id runtime paths safety preview apply description path
  while IFS=$'\t' read -r id runtime paths safety preview apply description; do
    [[ -z "${id:-}" ]] && continue
    while IFS= read -r path; do
      path="${path#"${path%%[![:space:]]*}"}"
      path="${path%"${path##*[![:space:]]}"}"
      [[ -z "$path" ]] && continue
      run_rm "$path"
    done < <(printf '%s\n' "$paths" | tr ';' '\n')
  done < <(container_rows)
}

clean_node_stale() {
  [[ "$INCLUDE_NODE_STALE" -eq 1 ]] || return 0
  log "${BOLD}Stale node_modules older than ${DAYS} days${RESET}"
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print 2>/dev/null |
      while IFS= read -r path; do
        run_rm "$path"
      done
  done
  return 0
}

clean_venv_stale() {
  [[ "$INCLUDE_VENV_STALE" -eq 1 ]] || return 0
  log "${BOLD}Stale Python virtualenvs older than ${DAYS} days${RESET}"
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root marker path
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 9 -type f -name pyvenv.cfg -mtime +"$DAYS" -print0 2>/dev/null |
      while IFS= read -r -d '' marker; do
        path="$(dirname "$marker")"
        [[ -f "$path/pyvenv.cfg" ]] || continue
        run_rm "$path"
      done
  done
  return 0
}

clean_installers() {
  [[ "$INCLUDE_INSTALLERS" -eq 1 ]] || return 0
  log "${BOLD}Old downloaded installers older than ${DAYS} days${RESET}"
  local path
  if [[ "$APPLY" -eq 1 ]]; then
    installer_find_expr |
      while IFS= read -r -d '' path; do
        run_rm "$path"
      done || true
  else
    installer_rows |
      while IFS=$'\t' read -r kb epoch age_days path; do
        [[ -z "${path:-}" ]] && continue
        printf 'would remove %8s  %s\n' "$(human_kb "$kb")" "$path"
      done
  fi
}

clean_download_artifacts() {
  [[ "$INCLUDE_DOWNLOAD_ARTIFACTS" -eq 1 ]] || return 0
  log "${BOLD}Old downloadable artifacts older than ${DAYS} days${RESET}"
  local rows kb epoch age_days kind path
  rows="$(download_artifact_rows)"
  if [[ -z "$rows" ]]; then
    printf 'No old downloadable artifacts found in ~/Downloads.\n'
    return 0
  fi
  while IFS=$'\t' read -r kb epoch age_days kind path; do
    [[ -z "${path:-}" ]] && continue
    run_rm "$path"
  done <<<"$rows"
  return 0
}

clean_screenshots() {
  [[ "$INCLUDE_SCREENSHOTS" -eq 1 ]] || return 0
  log "${BOLD}Old screenshots and screen recordings older than ${DAYS} days${RESET}"
  local rows kb epoch age_days path
  rows="$(screenshot_rows)"
  if [[ -z "$rows" ]]; then
    printf 'No old screenshot or screen recording files found.\n'
    return 0
  fi
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    run_rm "$path"
  done <<<"$rows"
  return 0
}

clean_user_trash() {
  [[ "$INCLUDE_USER_TRASH" -eq 1 ]] || return 0
  log "${BOLD}User Trash${RESET}"
  local dir="$HOME/.Trash"
  [[ -d "$dir" ]] || return 0
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$TRASH" -eq 1 ]] && warn "--trash is ignored for --include-user-trash because items are already in Trash."
    find "$dir" -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_user_trash_child "$path"
      done || true
  else
    print_size "~/.Trash"
  fi
}

scan() {
  local paths=()
  local candidate
  while IFS= read -r candidate; do paths+=("$candidate"); done < <(candidate_paths)
  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    disk_json
    printf ',"candidates":['
    local first=1
    local path expanded kb
    for path in "${paths[@]}"; do
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$path")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s}' "$(printf '%s' "$expanded" | json_escape)" "$kb"
    done
    printf ']}'
    printf '\n'
    return 0
  fi

  log "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Common cleanup candidates${RESET}"
  local path
  for path in "${paths[@]}"; do print_size "$path"; done

  printf '\n%s\n' "${BOLD}Largest home folders${RESET}"
  du -x -d 1 -h "$HOME" 2>/dev/null | sort -h | tail -25 || true

  printf '\n%s\n' "${BOLD}Largest user files over 500MB${RESET}"
  find "$HOME" -xdev -type f -size +500M -print0 2>/dev/null |
    xargs -0 du -h 2>/dev/null | sort -h | tail -30 || true
}

