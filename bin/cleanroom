paths_field_kb() {
  local field="$1"
  local total=0 path kb
  while IFS= read -r path; do
    path="${path#"${path%%[![:space:]]*}"}"
    path="${path%"${path##*[![:space:]]}"}"
    [[ -z "$path" ]] && continue
    kb="$(size_kb "$path")"
    total=$((total + kb))
  done < <(printf '%s\n' "$field" | tr ';' '\n')
  printf '%s\n' "$total"
}

caches() {
  local rows
  rows="$(cache_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id category paths preview apply description kb
    while IFS=$'\t' read -r id category paths preview apply description; do
      [[ -z "${id:-}" ]] && continue
      if [[ "$id" == "safe-app-caches" ]]; then
        kb="$(app_cache_kb)"
      elif [[ "$id" == "updater-caches" ]]; then
        kb="$(updatercache_total_kb)"
      elif [[ "$id" == "browser-caches" ]]; then
        kb="$(browsercache_total_kb)"
      else
        kb="$(paths_field_kb "$paths")"
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","category":"%s","paths":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom caches${RESET}"
  printf 'Review-only inventory. Use the preview command before applying cleanup.\n\n'
  printf '%-10s %-20s %-12s %s\n' "size" "id" "category" "preview command"
  local id category paths preview apply description kb
  while IFS=$'\t' read -r id category paths preview apply description; do
    [[ -z "${id:-}" ]] && continue
    if [[ "$id" == "safe-app-caches" ]]; then
      kb="$(app_cache_kb)"
    elif [[ "$id" == "updater-caches" ]]; then
      kb="$(updatercache_total_kb)"
    elif [[ "$id" == "browser-caches" ]]; then
      kb="$(browsercache_total_kb)"
    else
      kb="$(paths_field_kb "$paths")"
    fi
    printf '%-10s %-20s %-12s %s\n' "$(human_kb "$kb")" "$id" "$category" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

