libraries() {
  local rows
  rows="$(library_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title kind path guidance expanded kb
    while IFS=$'\t' read -r id title kind path guidance; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$expanded")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","kind":"%s","path":"%s","exists":%s,"size_kb":%s,"size":"%s","protected":true,"guidance":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$(if [[ -e "$expanded" ]]; then echo true; else echo false; fi)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom protected media libraries${RESET}"
  printf 'Review-only inventory. cleanroom does not delete Photos, Music, TV, iMovie, GarageBand, or Logic libraries.\n\n'
  printf '%-10s %-8s %-24s %s\n' "size" "kind" "library" "path"
  local id title kind path guidance expanded kb
  while IFS=$'\t' read -r id title kind path guidance; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] || continue
    kb="$(size_kb "$expanded")"
    printf '%-10s %-8s %-24s %s\n' "$(human_kb "$kb")" "$kind" "$title" "$expanded"
    printf '  %s\n' "$guidance"
  done <<<"$rows"
  printf '\nUse this to explain large Documents/Media storage. Manage libraries in their owning apps or after verified backups.\n'
}

libraries_fast() {
  local rows
  rows="$(library_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title kind path guidance expanded exists status summary
    while IFS=$'\t' read -r id title kind path guidance; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      if [[ -e "$expanded" ]]; then
        exists=true
        status="Protected"
        summary="Present. Review in the owning app or Finder after a verified backup."
      else
        exists=false
        status="Not found"
        summary="No matching library was found at the usual location."
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","name":"%s","category":"%s","path":"%s","exists":%s,"size":"Protected","status":"%s","safety":"Protected","summary":"%s","guidance":"%s","mode":"fast"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$exists" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$summary" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}quick media library review${RESET}"
  printf 'Fast protected inventory. Sizes are skipped so Photos, Music, TV, iMovie, GarageBand, and Logic do not slow the app down.\n\n'
  printf '%-12s %-8s %-24s %s\n' "status" "kind" "library" "location"
  local id title kind path guidance expanded status location
  while IFS=$'\t' read -r id title kind path guidance; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    if [[ -e "$expanded" ]]; then
      status="Protected"
    else
      status="Not found"
    fi
    location="$expanded"
    case "$location" in
      "$HOME") location="~" ;;
      "$HOME"/*) location="~/${location#"$HOME"/}" ;;
    esac
    printf '%-12s %-8s %-24s %s\n' "$status" "$kind" "$title" "$location"
    printf '  %s\n' "$guidance"
  done <<<"$rows"
  printf '\nUse this for a fast explanation of large Documents/Media storage. Open the owning app for exact cleanup decisions.\n'
}

