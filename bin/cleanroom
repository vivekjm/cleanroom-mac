  cleanroom leftovers QUERY... [--limit N] [--json] [--apply --trash]
  cleanroom backups [--json]
  cleanroom backups-fast [--json]
  cleanroom xcode [--json]
  cleanroom xcode-fast [--json]
  cleanroom android [--json]
  cleanroom startup [--json]
  cleanroom startup-fast [--json]
  cleanroom loginitems [--json]
