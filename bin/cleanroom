paths_field_kb() {
  local field="$1"
  local total=0 path kb
  while IFS= read -r path; do
    path="${path#"${path%%[![:space:]]*}"}"
    path="${path%"${path##*[![:space:]]}"}"
    [[ -z "$path" ]] && continue
    kb="$(size_kb "$path")"
    total=$((total + kb))
  done < <(printf '%s\n' "$field" | tr ';' '\n')
  printf '%s\n' "$total"
}

paths_field_present() {
  local field="$1"
  local path expanded
  while IFS= read -r path; do
    path="${path#"${path%%[![:space:]]*}"}"
    path="${path%"${path##*[![:space:]]}"}"
    [[ -z "$path" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] && return 0
  done < <(printf '%s\n' "$field" | tr ';' '\n')
  return 1
}

paths_present_count() {
  local count=0 path expanded
  for path in "$@"; do
    [[ -z "${path:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] && count=$((count + 1))
  done
  printf '%s\n' "$count"
}

caches() {
  local rows
  rows="$(cache_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id category paths preview apply description kb
    while IFS=$'\t' read -r id category paths preview apply description; do
      [[ -z "${id:-}" ]] && continue
      if [[ "$id" == "safe-app-caches" ]]; then
        kb="$(app_cache_kb)"
      elif [[ "$id" == "updater-caches" ]]; then
        kb="$(updatercache_total_kb)"
      elif [[ "$id" == "browser-caches" ]]; then
        kb="$(browsercache_total_kb)"
      else
        kb="$(paths_field_kb "$paths")"
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","category":"%s","paths":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom caches${RESET}"
  printf 'Review-only inventory. Use the preview command before applying cleanup.\n\n'
  printf '%-10s %-20s %-12s %s\n' "size" "id" "category" "preview command"
  local id category paths preview apply description kb
  while IFS=$'\t' read -r id category paths preview apply description; do
    [[ -z "${id:-}" ]] && continue
    if [[ "$id" == "safe-app-caches" ]]; then
      kb="$(app_cache_kb)"
    elif [[ "$id" == "updater-caches" ]]; then
      kb="$(updatercache_total_kb)"
    elif [[ "$id" == "browser-caches" ]]; then
      kb="$(browsercache_total_kb)"
    else
      kb="$(paths_field_kb "$paths")"
    fi
    printf '%-10s %-20s %-12s %s\n' "$(human_kb "$kb")" "$id" "$category" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

caches_instant_json() {
  cat <<'EOF'
[{"id":"recommended-caches","title":"Recommended Cache Cleanup","category":"Rebuildable","size":"Review","safety":"Rebuildable","summary":"Standard app caches, old logs, npm, Yarn, pnpm, Xcode, simulator, and Homebrew cache areas can usually be rebuilt.","mode":"instant"},{"id":"app-caches","title":"App Cache Folders","category":"Protected","size":"Review","safety":"Protected","summary":"Cleanroom targets nested cache folders only. Browser profiles, cookies, bookmarks, settings, and passwords stay protected.","mode":"instant"},{"id":"preview-cache","title":"Preview Cache","category":"Rebuildable","size":"Review","safety":"Rebuildable","summary":"Quick Look thumbnail and preview caches can be recreated by macOS after cleanup.","mode":"instant"},{"id":"font-cache","title":"Font Cache","category":"Rebuildable","size":"Review","safety":"Rebuildable","summary":"Font cache databases are rebuildable. Actual font files are not part of cache cleanup.","mode":"instant"},{"id":"web-cache","title":"Web Cache","category":"Rebuildable","size":"Review","safety":"Rebuildable","summary":"Safari and WebKit cache folders are separate from browser history, cookies, bookmarks, passwords, and profiles.","mode":"instant"},{"id":"window-state","title":"Window State","category":"Rebuildable","size":"Review","safety":"Rebuildable","summary":"Saved app window/session state can be cleared without touching documents or app profile data.","mode":"instant"},{"id":"project-caches","title":"Project Cache Artifacts","category":"Rebuildable","size":"Review","safety":"Rebuildable","summary":"Known build and test cache artifacts are handled separately from source code, .git folders, dependencies, and virtualenvs.","mode":"instant"},{"id":"browser-caches","title":"Browser Caches","category":"Protected","size":"Review","safety":"Protected","summary":"Only cache folders are considered. Password stores, profiles, bookmarks, sessions, extensions, cookies, and settings stay protected.","mode":"instant"}]
EOF
}

caches_instant() {
  if [[ "$JSON" -eq 1 ]]; then
    caches_instant_json
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom instant cache overview${RESET}"
  printf 'High-level desktop cache overview. No deep sizing was run and no files were changed.\n\n'
  printf '%-22s %-12s %s\n' "area" "safety" "summary"
  printf '%-22s %-12s %s\n' "Recommended caches" "Rebuildable" "Standard app, log, package, Xcode, simulator, and Homebrew caches."
  printf '%-22s %-12s %s\n' "App caches" "Protected" "Nested cache folders only; profiles and passwords stay guarded."
  printf '%-22s %-12s %s\n' "Preview cache" "Rebuildable" "Quick Look thumbnails can be recreated by macOS."
  printf '%-22s %-12s %s\n' "Browser caches" "Protected" "Cache folders are separate from passwords, cookies, bookmarks, and profiles."
}

caches_fast_rows() {
  local core package quicklook fontcache webcache savedstate updater
  core="$(sum_existing_kb "~/Library/Logs" "~/.npm/_cacache" "~/.npm/_logs" "~/.npm/_npx" "~/.yarn/cache" "~/.yarn/berry" "~/Library/pnpm/store")"
  package="$(sum_existing_kb "~/Library/Caches/CocoaPods" "~/Library/Caches/Homebrew")"
  quicklook="$(quicklook_total_kb)"
  fontcache="$(fontcache_total_kb)"
  webcache="$(webcache_total_kb)"
  savedstate="$(savedstate_total_kb)"
  updater="$(updatercache_total_kb)"

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$core" "core-caches" "Core Caches" "rebuildable" "cleanroom clean" "Fast estimate from logs, npm, Yarn, and pnpm stores." "$(human_kb "$core")"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$package" "package-caches" "Package Caches" "rebuildable" "cleanroom packages" "Fast estimate from Homebrew and CocoaPods caches. Gradle and broad package roots are skipped here for speed." "$(human_kb "$package")"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$quicklook" "quicklook-caches" "Quick Look" "rebuildable" "cleanroom quicklook" "Thumbnail and preview caches that macOS can rebuild." "$(human_kb "$quicklook")"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$fontcache" "font-caches" "Font Caches" "rebuildable" "cleanroom fontcaches" "User font cache databases. Actual font files stay protected." "$(human_kb "$fontcache")"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$webcache" "web-caches" "Safari/WebKit" "rebuildable" "cleanroom webcaches" "Safari and WebKit cache folders only; profiles and passwords stay protected." "$(human_kb "$webcache")"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$savedstate" "saved-state" "Saved State" "rebuildable" "cleanroom savedstate" "App window/session restoration state. Documents and profiles stay protected." "$(human_kb "$savedstate")"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$updater" "updater-caches" "Updater Caches" "rebuildable" "cleanroom updaters" "Sparkle and Squirrel updater cache/staging data." "$(human_kb "$updater")"
  printf '0\t%s\t%s\t%s\t%s\t%s\t%s\n' "browser-caches" "Browser Caches" "protected" "cleanroom browsercaches" "Open Browser Caches for focused sizing. Profiles, passwords, cookies, bookmarks, and sessions stay protected." "Review"
  printf '0\t%s\t%s\t%s\t%s\t%s\t%s\n' "user-cache-review" "User Cache Review" "review" "cleanroom caches" "Broad ~/.cache and ~/Library/Caches sizing is available in deep Caches review and skipped here for speed." "Review"
  printf '0\t%s\t%s\t%s\t%s\t%s\t%s\n' "app-caches-review" "App Cache Review" "protected" "cleanroom caches" "Deep app cache sizing is available separately. Cleanroom only targets nested cache folders and keeps profiles, passwords, cookies, bookmarks, and settings protected." "Review"
}

caches_fast() {
  local rows
  rows="$(caches_fast_rows | sort -rn)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title category command guidance display
    while IFS=$'\t' read -r kb id title category command guidance display; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","category":"%s","size_kb":%s,"size":"%s","command":"%s","guidance":"%s","mode":"fast"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "${kb:-0}" \
        "$(printf '%s' "${display:-$(human_kb "${kb:-0}")}" | json_escape)" \
        "$(printf '%s' "$command" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom quick caches${RESET}"
  printf 'Fast read-only cache summary for the desktop app. Deep nested app cache sizing is skipped.\n\n'
  printf '%-10s %-18s %-12s %s\n' "size" "id" "category" "review"
  local kb id title category command guidance display
  while IFS=$'\t' read -r kb id title category command guidance display; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-18s %-12s %s\n' "${display:-$(human_kb "${kb:-0}")}" "$id" "$category" "$title"
    printf '  %s\n' "$guidance"
  done <<<"$rows"
}

