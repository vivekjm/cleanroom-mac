  cleanroom clean --apply --include-dev-heavy --include-node-stale --include-venv-stale --days 45
EOF
}

log() { printf '%s\n' "$*"; }
warn() { printf '%s%s%s\n' "$YELLOW" "$*" "$RESET" >&2; }
ok() { printf '%s%s%s\n' "$GREEN" "$*" "$RESET"; }
die() { printf '%s%s%s\n' "$RED" "$*" "$RESET" >&2; exit 1; }

expand_path() {
  local path="$1"
  path="${path/#\~/$HOME}"
  printf '%s\n' "$path"
}

config_default_path() {
  printf '%s\n' "$HOME/.config/cleanroom/config"
}

script_dir() {
  local source="${BASH_SOURCE[0]}"
  cd "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

repo_root() {
  local dir
  dir="$(script_dir)"
  if [[ -f "$dir/../data/cleanup-rules.tsv" ]]; then
    (cd "$dir/.." >/dev/null 2>&1 && pwd)
  elif [[ -f "$dir/../share/cleanroom/data/cleanup-rules.tsv" ]]; then
    (cd "$dir/../share/cleanroom" >/dev/null 2>&1 && pwd)
  else
    printf '%s\n' "$dir"
  fi
}

rules_file() {
  local root
  root="$(repo_root)"
  if [[ -f "$root/data/cleanup-rules.tsv" ]]; then
    printf '%s\n' "$root/data/cleanup-rules.tsv"
  else
    printf '%s\n' ""
  fi
}

protected_file() {
  local root
  root="$(repo_root)"
  if [[ -f "$root/data/protected-paths.tsv" ]]; then
    printf '%s\n' "$root/data/protected-paths.tsv"
  else
    printf '%s\n' ""
  fi
}

truthy() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

add_exclude() {
  local path
  path="$(expand_path "$1")"
  [[ -n "$path" ]] && EXCLUDES+=("$path")
}

is_excluded() {
  local path="$1"
  local excluded
  [[ "${#EXCLUDES[@]}" -eq 0 ]] && return 1
  for excluded in "${EXCLUDES[@]}"; do
    [[ -z "$excluded" ]] && continue
    if [[ "$path" == "$excluded" || "$path" == "$excluded/"* ]]; then
      return 0
    fi
  done
  return 1
}

load_config() {
  local file="$1"
  file="$(expand_path "$file")"
  [[ -f "$file" ]] || return 0
  CONFIG_LOADED=1

  local line key value
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" != *"="* ]] && continue

    key="${line%%=*}"
    value="${line#*=}"
    key="${key//[[:space:]]/}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    value="${value%\"}"
    value="${value#\"}"

    case "$key" in
      preset) apply_preset "$value" ;;
      days) [[ "$value" =~ ^[0-9]+$ ]] && DAYS="$value" ;;
      include_app_caches) truthy "$value" && INCLUDE_APP_CACHES=1 ;;
      include_package_stores) truthy "$value" && INCLUDE_PACKAGE_STORES=1 ;;
      include_toolchains) truthy "$value" && INCLUDE_TOOLCHAINS=1 ;;
      include_diagnostics) truthy "$value" && INCLUDE_DIAGNOSTICS=1 ;;
      include_node_stale) truthy "$value" && INCLUDE_NODE_STALE=1 ;;
      include_venv_stale) truthy "$value" && INCLUDE_VENV_STALE=1 ;;
      include_dev_heavy) truthy "$value" && INCLUDE_DEV_HEAVY=1 ;;
      include_snapshots) truthy "$value" && INCLUDE_SNAPSHOTS=1 ;;
      include_ai_workspaces) truthy "$value" && INCLUDE_AI_WORKSPACES=1 ;;
      include_ai_models) truthy "$value" && INCLUDE_AI_MODELS=1 ;;
      include_containers) truthy "$value" && INCLUDE_CONTAINERS=1 ;;
      include_user_trash) truthy "$value" && INCLUDE_USER_TRASH=1 ;;
      include_installers) truthy "$value" && INCLUDE_INSTALLERS=1 ;;
      include_download_artifacts) truthy "$value" && INCLUDE_DOWNLOAD_ARTIFACTS=1 ;;
      include_screenshots) truthy "$value" && INCLUDE_SCREENSHOTS=1 ;;
      include_cleanroom_state) truthy "$value" && INCLUDE_CLEANROOM_STATE=1 ;;
      include_metadata) truthy "$value" && INCLUDE_METADATA=1 ;;
      include_quicklook) truthy "$value" && INCLUDE_QUICKLOOK=1 ;;
      include_font_caches) truthy "$value" && INCLUDE_FONT_CACHES=1 ;;
      include_web_caches) truthy "$value" && INCLUDE_WEB_CACHES=1 ;;
      include_saved_state) truthy "$value" && INCLUDE_SAVED_STATE=1 ;;
      include_project_caches) truthy "$value" && INCLUDE_PROJECT_CACHES=1 ;;
      include_updater_caches) truthy "$value" && INCLUDE_UPDATER_CACHES=1 ;;
      include_browser_caches) truthy "$value" && INCLUDE_BROWSER_CACHES=1 ;;
      include_device_backups) truthy "$value" && INCLUDE_DEVICE_BACKUPS=1 ;;
      trash) truthy "$value" && TRASH=1 ;;
      log_file) LOG_FILE="$(expand_path "$value")" ;;
      exclude) add_exclude "$value" ;;
    esac
  done <"$file"
}

exists() {
  local path
  path="$(expand_path "$1")"
  [[ -e "$path" ]]
}

size_kb() {
  local path
  path="$(expand_path "$1")"
  [[ -e "$path" ]] || { printf '0'; return; }
  local out
  out="$(du -sk "$path" 2>/dev/null || true)"
  if [[ -z "$out" ]]; then
    printf '0'
  else
    printf '%s\n' "$out" | awk '{print $1; exit}'
  fi
}

human_kb() {
  awk -v kb="${1:-0}" 'BEGIN {
    bytes = kb * 1024
    split("B KB MB GB TB", units, " ")
    i = 1
    while (bytes >= 1024 && i < 5) { bytes /= 1024; i++ }
    if (i <= 2) printf "%.0f%s", bytes, units[i]
    else printf "%.1f%s", bytes, units[i]
  }'
}

print_size() {
  local path="$1"
  local kb
  kb="$(size_kb "$path")"
  printf '%8s  %s\n' "$(human_kb "$kb")" "$path"
}

sum_existing_kb() {
  local total=0
  local path kb
  for path in "$@"; do
    kb="$(size_kb "$path")"
    total=$((total + kb))
  done
  printf '%s\n' "$total"
}

app_cache_kb() {
  local roots=(
    "$HOME/Library/Application Support/Google"
    "$HOME/Library/Application Support/Microsoft Edge"
    "$HOME/Library/Application Support/Arc"
    "$HOME/Library/Application Support/Code"
    "$HOME/Library/Application Support/Cursor"
    "$HOME/Library/Application Support/Slack"
    "$HOME/Library/Application Support/BraveSoftware"
    "$HOME/Library/Application Support/Comet"
    "$HOME/Library/Application Support/Trae"
  )
  local total=0
  local root found
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    found="$(find "$root" -type d \( \
      -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
      -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
      -o -name 'Crashpad' \
    \) -prune -exec du -sk {} + 2>/dev/null | awk '{total += $1} END {print total + 0}' || true)"
    total=$((total + ${found:-0}))
  done
  printf '%s\n' "$total"
}

cache_dir_kb_under() {
  local root="$1"
  [[ -d "$root" ]] || { printf '0\n'; return 0; }
  find "$root" -type d \( \
    -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
    -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
    -o -name 'Crashpad' \
  \) -prune -exec du -sk {} + 2>/dev/null | awk '{total += $1} END {print total + 0}' || true
}

stale_node_kb() {
  local total=0
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root kb
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    while IFS= read -r path; do
      kb="$(size_kb "$path")"
      total=$((total + kb))
    done < <(find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print 2>/dev/null)
  done
  printf '%s\n' "$total"
}

stale_venv_kb() {
  local total=0
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root path kb
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      kb="$(size_kb "$(dirname "$path")")"
      total=$((total + kb))
    done < <(find "$root" -maxdepth 9 -type f -name pyvenv.cfg -mtime +"$DAYS" -print0 2>/dev/null)
  done
  printf '%s\n' "$total"
}

