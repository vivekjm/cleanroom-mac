#!/usr/bin/env bash
set -euo pipefail

VERSION="0.6.0"
APPLY=0
VERBOSE=0
ASSUME_YES=0
JSON=0
DAYS=30
ACTION="scan"
CONFIG_FILE=""
CONFIG_LOADED=0
OUTPUT_FILE=""
LOG_FILE=""
TRASH=0
RUN_ID="$(date '+%Y%m%d-%H%M%S')-$$"
EXCLUDES=()
INCLUDE_DEV_HEAVY=0
INCLUDE_NODE_STALE=0
INCLUDE_GEMINI=0
INCLUDE_LMSTUDIO=0
INCLUDE_AI_WORKSPACES=0
INCLUDE_AI_MODELS=0
INCLUDE_PACKAGE_STORES=0
INCLUDE_CONTAINERS=0
INCLUDE_APP_CACHES=0
INCLUDE_SNAPSHOTS=0

RED="$(printf '\033[31m')"
GREEN="$(printf '\033[32m')"
YELLOW="$(printf '\033[33m')"
BOLD="$(printf '\033[1m')"
RESET="$(printf '\033[0m')"

usage() {
  cat <<'EOF'
cleanroom - safe macOS storage cleaner

Usage:
  cleanroom scan [options]
  cleanroom report [--output PATH]
  cleanroom clean [options]
  cleanroom interactive [options]
  cleanroom doctor
  cleanroom categories
  cleanroom init-config [--config PATH]
  cleanroom help

Actions:
  scan                 Show disk usage and likely cleanup candidates.
  report               Write a Markdown cleanup report. Prints to stdout by default.
  clean                Clean safe rebuildable caches. Dry-run unless --apply is passed.
  interactive          Choose cleanup categories in a guided prompt.
  doctor               Check platform, dependencies, permissions, and risky state.
  categories           Explain cleanup categories and safety levels.
  init-config          Write a starter config file.

Options:
  --apply              Actually delete files. Without this, clean only previews.
  --trash              Move deleted files to ~/.Trash/cleanroom-* instead of rm -rf.
  --yes                Do not prompt before --apply cleanup.
  --verbose            Print every path touched.
  --json               Emit JSON for scan.
  --output PATH        Output path for report.
  --log PATH           Write apply audit log here. Default: ~/.local/state/cleanroom/runs/*.log.
  --config PATH        Load config file. Default: ~/.config/cleanroom/config.
  --exclude PATH       Never remove this path. Can be passed multiple times.
  --days N             Age threshold for stale node_modules. Default: 30.
  --preset NAME        Enable a useful group: safe, dev, deep.
                       safe: default rebuildable caches.
                       dev: safe + app caches + package stores + stale node_modules.
                       deep: dev + heavy SDKs + snapshots + AI workspaces.
  --include-dev-heavy  Include heavier developer data:
                       Xcode device support, simulator app data, Android NDK/system images.
  --include-node-stale Remove node_modules older than --days from Desktop/Documents/Downloads.
  --include-package-stores
                       Include rebuildable package stores like CocoaPods repos and pnpm store.
  --include-app-caches Include safe cache folders inside Google/Chrome, VS Code, Cursor, Slack, etc.
                       Does not remove profiles, passwords, cookies, bookmarks, or settings wholesale.
  --include-snapshots  Ask Time Machine to thin local snapshots.
  --include-ai-workspaces
                       Remove generated AI-agent workspace state: recordings, scratch, brain,
                       implicit data, and local conversation caches where known.
  --include-ai-models  Remove downloaded local AI models/backends from LM Studio, Ollama,
                       Hugging Face cache, and similar known stores.
  --include-containers Remove local container VM disks for Colima/Lima. This can remove containers.
  --include-gemini     Alias for --include-ai-workspaces.
  --include-lmstudio   Alias for --include-ai-models.
  -h, --help           Show help.
  -v, --version        Show version.

Safety:
  cleanroom does NOT delete browser profiles, password databases, Keychains, Photos libraries,
  Mail, iCloud Drive, or app profile folders by default.

Examples:
  cleanroom scan
  cleanroom scan --json
  cleanroom report --output cleanroom-report.md
  cleanroom doctor
  cleanroom categories
  cleanroom init-config
  cleanroom interactive
  cleanroom clean
  cleanroom clean --preset dev
  cleanroom clean --apply --trash --preset dev
  cleanroom clean --apply --include-app-caches
  cleanroom clean --apply --include-dev-heavy --include-node-stale --days 45
EOF
}

log() { printf '%s\n' "$*"; }
warn() { printf '%s%s%s\n' "$YELLOW" "$*" "$RESET" >&2; }
ok() { printf '%s%s%s\n' "$GREEN" "$*" "$RESET"; }
die() { printf '%s%s%s\n' "$RED" "$*" "$RESET" >&2; exit 1; }

expand_path() {
  local path="$1"
  path="${path/#\~/$HOME}"
  printf '%s\n' "$path"
}

config_default_path() {
  printf '%s\n' "$HOME/.config/cleanroom/config"
}

truthy() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

add_exclude() {
  local path
  path="$(expand_path "$1")"
  [[ -n "$path" ]] && EXCLUDES+=("$path")
}

is_excluded() {
  local path="$1"
  local excluded
  [[ "${#EXCLUDES[@]}" -eq 0 ]] && return 1
  for excluded in "${EXCLUDES[@]}"; do
    [[ -z "$excluded" ]] && continue
    if [[ "$path" == "$excluded" || "$path" == "$excluded/"* ]]; then
      return 0
    fi
  done
  return 1
}

load_config() {
  local file="$1"
  file="$(expand_path "$file")"
  [[ -f "$file" ]] || return 0
  CONFIG_LOADED=1

  local line key value
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" != *"="* ]] && continue

    key="${line%%=*}"
    value="${line#*=}"
    key="${key//[[:space:]]/}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    value="${value%\"}"
    value="${value#\"}"

    case "$key" in
      preset) apply_preset "$value" ;;
      days) [[ "$value" =~ ^[0-9]+$ ]] && DAYS="$value" ;;
      include_app_caches) truthy "$value" && INCLUDE_APP_CACHES=1 ;;
      include_package_stores) truthy "$value" && INCLUDE_PACKAGE_STORES=1 ;;
      include_node_stale) truthy "$value" && INCLUDE_NODE_STALE=1 ;;
      include_dev_heavy) truthy "$value" && INCLUDE_DEV_HEAVY=1 ;;
      include_snapshots) truthy "$value" && INCLUDE_SNAPSHOTS=1 ;;
      include_ai_workspaces) truthy "$value" && INCLUDE_AI_WORKSPACES=1 ;;
      include_ai_models) truthy "$value" && INCLUDE_AI_MODELS=1 ;;
      include_containers) truthy "$value" && INCLUDE_CONTAINERS=1 ;;
      trash) truthy "$value" && TRASH=1 ;;
      log_file) LOG_FILE="$(expand_path "$value")" ;;
      exclude) add_exclude "$value" ;;
    esac
  done <"$file"
}

exists() {
  local path
  path="$(expand_path "$1")"
  [[ -e "$path" ]]
}

size_kb() {
  local path
  path="$(expand_path "$1")"
  [[ -e "$path" ]] || { printf '0'; return; }
  local out
  out="$(du -sk "$path" 2>/dev/null || true)"
  if [[ -z "$out" ]]; then
    printf '0'
  else
    printf '%s\n' "$out" | awk '{print $1; exit}'
  fi
}

human_kb() {
  awk -v kb="${1:-0}" 'BEGIN {
    bytes = kb * 1024
    split("B KB MB GB TB", units, " ")
    i = 1
    while (bytes >= 1024 && i < 5) { bytes /= 1024; i++ }
    if (i <= 2) printf "%.0f%s", bytes, units[i]
    else printf "%.1f%s", bytes, units[i]
  }'
}

print_size() {
  local path="$1"
  local kb
  kb="$(size_kb "$path")"
  printf '%8s  %s\n' "$(human_kb "$kb")" "$path"
}

candidate_paths() {
  cat <<'EOF'
~/Library/Caches
~/Library/Logs
~/Library/Developer
~/Library/Android
~/Library/pnpm
~/.npm
~/.yarn
~/.gradle
~/.cache
~/.gemini
~/.lmstudio
~/.ollama
~/.cache/huggingface
~/.cocoapods
~/.colima
~/.lima
~/.codex
~/Library/Application Support
~/Documents
~/Desktop
~/Downloads
EOF
}

report_candidate_paths() {
  cat <<'EOF'
~/Library/Caches
~/Library/Logs
~/Library/Developer
~/Library/Android
~/Library/pnpm
~/.npm
~/.yarn
~/.gradle
~/.cache
~/.gemini
~/.lmstudio
~/.ollama
~/.cache/huggingface
~/.cocoapods
~/.colima
~/.lima
~/.codex
EOF
}

disk_line() {
  df -h /System/Volumes/Data 2>/dev/null || df -h /
}

json_escape() {
  sed 's/\\/\\\\/g; s/"/\\"/g'
}

disk_json() {
  local line
  line="$(df -k /System/Volumes/Data 2>/dev/null | awk 'NR==2 {print $2, $3, $4, $5, $9}')"
  if [[ -z "$line" ]]; then
    line="$(df -k / | awk 'NR==2 {print $2, $3, $4, $5, $9}')"
  fi
  awk -v values="$line" 'BEGIN {
    split(values, a, " ")
    printf "\"disk\":{\"size_kb\":%s,\"used_kb\":%s,\"available_kb\":%s,\"capacity\":\"%s\",\"mount\":\"%s\"}", a[1], a[2], a[3], a[4], a[5]
  }'
}

confirm_apply() {
  [[ "$APPLY" -eq 1 ]] || return 0
  [[ "$ASSUME_YES" -eq 1 ]] && return 0
  warn "About to delete selected cache/artifact files."
  [[ "$TRASH" -eq 1 ]] && warn "Trash mode is enabled; cleanroom path deletions move to ~/.Trash."
  warn "Protected data like browser passwords and Keychains is not deleted."
  [[ "$INCLUDE_AI_MODELS" -eq 1 ]] && warn "AI model cleanup removes downloaded model files."
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] && warn "Container cleanup can remove local container VM disks and volumes."
  printf 'Continue? Type "clean" to proceed: '
  local answer
  read -r answer
  [[ "$answer" == "clean" ]] || die "Cancelled."
}

default_log_file() {
  printf '%s\n' "$HOME/.local/state/cleanroom/runs/$RUN_ID.log"
}

ensure_apply_log() {
  [[ "$APPLY" -eq 1 ]] || return 0
  [[ -n "$LOG_FILE" ]] || LOG_FILE="$(default_log_file)"
  mkdir -p "$(dirname "$LOG_FILE")"
  if [[ ! -f "$LOG_FILE" ]]; then
    {
      printf '# cleanroom apply log\n'
      printf 'version=%s\n' "$VERSION"
      printf 'run_id=%s\n' "$RUN_ID"
      printf 'mode=%s\n' "$(if [[ "$TRASH" -eq 1 ]]; then echo trash; else echo delete; fi)"
      printf 'started_at=%s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
      printf 'timestamp\taction\tstatus\tsize_kb\tpath\ttarget\n'
    } >>"$LOG_FILE"
  fi
}

record_apply() {
  [[ "$APPLY" -eq 1 ]] || return 0
  ensure_apply_log
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$(date '+%Y-%m-%d %H:%M:%S %Z')" \
    "${1:-remove}" \
    "${2:-unknown}" \
    "${3:-0}" \
    "${4:-}" \
    "${5:-}" >>"$LOG_FILE"
}

canonical_existing_path() {
  local path="$1"
  local dir base
  dir="$(dirname "$path")"
  base="$(basename "$path")"
  if [[ -d "$dir" ]]; then
    (cd "$dir" 2>/dev/null && printf '%s/%s\n' "$(pwd -P)" "$base") || printf '%s\n' "$path"
  else
    printf '%s\n' "$path"
  fi
}

is_dangerous_path() {
  local path home
  path="$(canonical_existing_path "$1")"
  home="$(canonical_existing_path "$HOME")"
  case "$path" in
    ""|"/"|"/System"|"/Library"|"/Applications"|"/Users"|"$home"|"$home/Library"|"$home/Documents"|"$home/Desktop"|"$home/Downloads"|"$home/Library/Application Support")
      return 0
      ;;
  esac
  return 1
}

trash_path() {
  local path="$1"
  local trash_dir base target n
  trash_dir="$HOME/.Trash/cleanroom-$RUN_ID"
  mkdir -p "$trash_dir"
  base="$(basename "$path")"
  target="$trash_dir/$base"
  n=1
  while [[ -e "$target" ]]; do
    target="$trash_dir/$base.$n"
    n=$((n + 1))
  done
  mv "$path" "$target"
  printf '%s\n' "$target"
}

delete_path() {
  local path="$1"
  local kb target
  [[ -e "$path" ]] || return 0
  if is_dangerous_path "$path"; then
    warn "refusing dangerous path: $path"
    record_apply "remove" "refused-dangerous" "0" "$path" ""
    return 0
  fi
  kb="$(size_kb "$path")"
  if [[ "$TRASH" -eq 1 ]]; then
    target="$(trash_path "$path" 2>/dev/null || true)"
    if [[ -n "$target" ]]; then
      record_apply "trash" "ok" "$kb" "$path" "$target"
      [[ "$VERBOSE" -eq 1 ]] && log "moved $(human_kb "$kb")  $path -> $target"
    else
      warn "Could not move to Trash: $path"
      record_apply "trash" "failed" "$kb" "$path" ""
    fi
  else
    if rm -rf "$path" 2>/dev/null; then
      record_apply "delete" "ok" "$kb" "$path" ""
      [[ "$VERBOSE" -eq 1 ]] && log "removed $(human_kb "$kb")  $path"
    else
      warn "Could not remove: $path"
      record_apply "delete" "failed" "$kb" "$path" ""
    fi
  fi
  return 0
}

run_rm() {
  local path="$1"
  path="$(expand_path "$path")"
  [[ -e "$path" ]] || return 0
  if is_excluded "$path"; then
    [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded path: $path"
    return 0
  fi

  local kb
  kb="$(size_kb "$path")"
  if [[ "$APPLY" -eq 1 ]]; then
    delete_path "$path"
  else
    printf 'would remove %8s  %s\n' "$(human_kb "$kb")" "$path"
  fi
}

run_find_delete_children() {
  local path="$1"
  path="$(expand_path "$path")"
  [[ -d "$path" ]] || return 0
  if is_excluded "$path"; then
    [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded path: $path"
    return 0
  fi
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$VERBOSE" -eq 1 ]] && log "clearing children of $path"
    find "$path" -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
      while IFS= read -r -d '' child; do
        delete_path "$child"
      done || true
  else
    print_size "$path"
  fi
}

safe_clean() {
  log "${BOLD}Safe rebuildable caches${RESET}"
  run_find_delete_children "~/Library/Caches"
  run_find_delete_children "~/.cache"
  run_rm "~/.npm/_cacache"
  run_rm "~/.npm/_logs"
  run_rm "~/.npm/_npx"
  run_rm "~/.yarn/cache"
  run_rm "~/.yarn/berry"
  run_rm "~/.gradle/caches"
  run_rm "~/.gradle/daemon"
  run_rm "~/.gradle/native"
  run_rm "~/.gradle/workers"
  run_rm "~/Library/pnpm/store"
  run_rm "~/Library/Developer/Xcode/DerivedData"
  run_rm "~/Library/Developer/CoreSimulator/Caches"

  if command -v brew >/dev/null 2>&1; then
    if [[ "$APPLY" -eq 1 ]]; then
      if [[ "$TRASH" -eq 1 ]]; then
        run_find_delete_children "~/Library/Caches/Homebrew"
      else
        brew cleanup -s >/dev/null 2>&1 || true
        run_find_delete_children "~/Library/Caches/Homebrew"
      fi
    else
      print_size "~/Library/Caches/Homebrew"
    fi
  fi
}

clean_package_stores() {
  [[ "$INCLUDE_PACKAGE_STORES" -eq 1 ]] || return 0
  log "${BOLD}Package manager stores${RESET}"
  run_rm "~/Library/pnpm/store"
  run_rm "~/.pnpm-store"
  run_rm "~/.cocoapods/repos"
  run_rm "~/.gradle-tangibly-release/caches"
  run_rm "~/.gradle-tangibly-release/wrapper"
  run_rm "~/.gradle-tangibly-release/native"
  run_rm "~/.cargo/registry/cache"
}

clean_logs() {
  log "${BOLD}Old logs${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    find "$HOME/Library/Logs" -type f -mtime +7 -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_path "$path"
      done || true
    find "$HOME/Library/Logs" -mindepth 1 -type d -empty -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_path "$path"
      done || true
  else
    print_size "~/Library/Logs"
  fi
}

clean_app_caches() {
  [[ "$INCLUDE_APP_CACHES" -eq 1 ]] || return 0
  log "${BOLD}App cache folders only${RESET}"
  local roots=(
    "$HOME/Library/Application Support/Google"
    "$HOME/Library/Application Support/Code"
    "$HOME/Library/Application Support/Cursor"
    "$HOME/Library/Application Support/Slack"
    "$HOME/Library/Application Support/BraveSoftware"
    "$HOME/Library/Application Support/Comet"
    "$HOME/Library/Application Support/Trae"
  )
  local root
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    if [[ "$APPLY" -eq 1 ]]; then
      find "$root" -type d \( \
        -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
        -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
        -o -name 'Crashpad' \
      \) -prune -print0 2>/dev/null |
        while IFS= read -r -d '' path; do
          delete_path "$path"
        done || true
    else
      local total
      total="$(find "$root" -type d \( \
        -name 'Cache' -o -name 'Code Cache' -o -name 'GPUCache' -o -name 'DawnCache' \
        -o -name 'ShaderCache' -o -name 'GrShaderCache' -o -name 'CachedData' \
        -o -name 'Crashpad' \
      \) -prune -exec du -sk {} + 2>/dev/null | awk '{total += $1} END {print total + 0}' || true)"
      [[ -n "$total" ]] || total=0
      printf 'would clean %8s  %s cache folders\n' "$(human_kb "$total")" "$root"
    fi
  done
  return 0
}

clean_dev_heavy() {
  [[ "$INCLUDE_DEV_HEAVY" -eq 1 ]] || return 0
  log "${BOLD}Heavy developer artifacts${RESET}"
  run_rm "~/Library/Developer/Xcode/iOS DeviceSupport"
  run_rm "~/Library/Developer/Xcode/watchOS DeviceSupport"
  run_rm "~/Library/Developer/Xcode/tvOS DeviceSupport"
  run_rm "~/Library/Android/sdk/ndk"
  run_rm "~/Library/Android/sdk/system-images"
  run_rm "~/Library/Android/sdk/.downloadIntermediates"
  run_rm "~/Library/Android/sdk/.temp"

  if [[ "$APPLY" -eq 1 ]] && command -v xcrun >/dev/null 2>&1; then
    xcrun simctl shutdown all >/dev/null 2>&1 || true
    xcrun simctl delete unavailable >/dev/null 2>&1 || true
    xcrun simctl erase all >/dev/null 2>&1 || true
  elif command -v xcrun >/dev/null 2>&1; then
    warn "would reset iOS Simulator app data because --include-dev-heavy is set"
  fi
}

clean_snapshots() {
  [[ "$INCLUDE_SNAPSHOTS" -eq 1 ]] || return 0
  log "${BOLD}Local snapshots${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    tmutil thinlocalsnapshots / 999999999999 4 2>/dev/null || true
  else
    tmutil listlocalsnapshots / 2>/dev/null || true
  fi
}

clean_ai_workspaces() {
  [[ "$INCLUDE_AI_WORKSPACES" -eq 1 || "$INCLUDE_GEMINI" -eq 1 ]] || return 0
  log "${BOLD}AI agent workspace data${RESET}"
  local roots=(antigravity antigravity-backup antigravity-ide)
  local root
  for root in "${roots[@]}"; do
    run_rm "~/.gemini/$root/browser_recordings"
    run_rm "~/.gemini/$root/scratch"
    run_rm "~/.gemini/$root/brain"
    run_rm "~/.gemini/$root/implicit"
    run_rm "~/.gemini/$root/conversations"
  done
  run_rm "~/.gemini/antigravity-browser-profile/GraphiteDawnCache"
  run_rm "~/.gemini/antigravity-browser-profile/GrShaderCache"
  run_rm "~/.gemini/antigravity-browser-profile/ShaderCache"
}

clean_ai_models() {
  [[ "$INCLUDE_AI_MODELS" -eq 1 || "$INCLUDE_LMSTUDIO" -eq 1 ]] || return 0
  log "${BOLD}Local AI models and backends${RESET}"
  run_rm "~/.lmstudio/models"
  run_rm "~/.lmstudio/extensions/backends"
  run_rm "~/.lmstudio/.internal/temp-downloads"
  run_rm "~/.ollama/models"
  run_rm "~/.cache/huggingface/hub"
  run_rm "~/.cache/modelscope"
  run_rm "~/.cache/torch/hub"
  run_rm "~/.cache/whisper"
}

clean_containers() {
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] || return 0
  log "${BOLD}Container VM disks${RESET}"
  run_rm "~/.colima"
  run_rm "~/.lima"
  run_rm "~/Library/Containers/com.docker.docker/Data/vms"
}

clean_node_stale() {
  [[ "$INCLUDE_NODE_STALE" -eq 1 ]] || return 0
  log "${BOLD}Stale node_modules older than ${DAYS} days${RESET}"
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print 2>/dev/null |
      while IFS= read -r path; do
        run_rm "$path"
      done
  done
  return 0
}

scan() {
  local paths=()
  local candidate
  while IFS= read -r candidate; do paths+=("$candidate"); done < <(candidate_paths)
  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    disk_json
    printf ',"candidates":['
    local first=1
    local path expanded kb
    for path in "${paths[@]}"; do
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$path")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s}' "$(printf '%s' "$expanded" | json_escape)" "$kb"
    done
    printf ']}'
    printf '\n'
    return 0
  fi

  log "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Common cleanup candidates${RESET}"
  local path
  for path in "${paths[@]}"; do print_size "$path"; done

  printf '\n%s\n' "${BOLD}Largest home folders${RESET}"
  du -x -d 1 -h "$HOME" 2>/dev/null | sort -h | tail -25 || true

  printf '\n%s\n' "${BOLD}Largest user files over 500MB${RESET}"
  find "$HOME" -xdev -type f -size +500M -print0 2>/dev/null |
    xargs -0 du -h 2>/dev/null | sort -h | tail -30 || true
}

report_body() {
  local now
  now="$(date '+%Y-%m-%d %H:%M:%S %Z')"
  printf '# cleanroom report\n\n'
  printf '%s\n' "- Generated: $now"
  printf '%s\n\n' "- Version: $VERSION"

  printf '## Disk\n\n```text\n'
  disk_line
  printf '```\n\n'

  printf '## Cleanup Candidates\n\n'
  printf '| Size | Path |\n| ---: | --- |\n'
  local path kb
  while IFS= read -r path; do
    kb="$(size_kb "$path")"
    printf '| %s | `%s` |\n' "$(human_kb "$kb")" "$(expand_path "$path")"
  done < <(report_candidate_paths)

  printf '\n## Largest Cleanup Candidates\n\n```text\n'
  while IFS= read -r path; do
    kb="$(size_kb "$path")"
    printf '%012d\t%s\t%s\n' "$kb" "$(human_kb "$kb")" "$(expand_path "$path")"
  done < <(report_candidate_paths) | sort -n | tail -20 | awk -F '\t' '{printf "%8s  %s\n", $2, $3}'
  printf '```\n\n'

  printf 'Broad personal folders such as `~/Documents`, `~/Desktop`, `~/Downloads`, and `~/Library/Application Support` are intentionally not recursively measured in this quick report. Run `cleanroom scan` when you want the heavier full view.\n\n'

  printf '## Large File Hints Over 500MB\n\n```text\n'
  if command -v mdfind >/dev/null 2>&1; then
    mdfind -onlyin "$HOME" 'kMDItemFSSize > 524288000' 2>/dev/null |
      head -100 |
      while IFS= read -r path; do
        [[ -f "$path" ]] && print_size "$path"
      done | sort -h | tail -30 || true
  else
    printf 'Spotlight mdfind is not available on this system.\n'
  fi
  printf '```\n\n'

  printf '## Safety Notes\n\n'
  printf 'cleanroom does not delete browser profiles, password databases, Keychains, Photos, Mail, or iCloud Drive by default.\n'
}

report() {
  if [[ -n "$OUTPUT_FILE" ]]; then
    report_body >"$(expand_path "$OUTPUT_FILE")"
    ok "Wrote report: $(expand_path "$OUTPUT_FILE")"
  else
    report_body
  fi
}

doctor() {
  log "${BOLD}cleanroom doctor${RESET}"
  printf '%-28s %s\n' "version" "$VERSION"
  printf '%-28s %s\n' "shell" "${SHELL:-unknown}"
  printf '%-28s %s\n' "macOS" "$(sw_vers -productVersion 2>/dev/null || echo unknown)"
  printf '%-28s %s\n' "architecture" "$(uname -m)"
  printf '%-28s %s\n' "config" "$(if [[ "$CONFIG_LOADED" -eq 1 ]]; then echo "$CONFIG_FILE"; else echo "not loaded"; fi)"
  printf '%-28s %s\n' "excludes" "${#EXCLUDES[@]}"
  printf '%-28s ' "disk"
  df -h /System/Volumes/Data 2>/dev/null | awk 'NR==2 {print $4 " free, " $5 " used"}' || df -h / | awk 'NR==2 {print $4 " free, " $5 " used"}'

  printf '\n%s\n' "${BOLD}Tools${RESET}"
  local tool
  for tool in du find awk sort xargs sqlite3 tmutil; do
    if command -v "$tool" >/dev/null 2>&1; then
      printf '%-28s %s\n' "$tool" "ok"
    else
      printf '%-28s missing\n' "$tool"
    fi
  done
  if command -v brew >/dev/null 2>&1; then
    printf '%-28s %s\n' "brew" "ok"
  else
    printf '%-28s %s\n' "brew" "optional missing"
  fi
  if command -v xcrun >/dev/null 2>&1; then
    printf '%-28s %s\n' "xcrun" "ok"
  else
    printf '%-28s %s\n' "xcrun" "optional missing"
  fi

  printf '\n%s\n' "${BOLD}Protected data check${RESET}"
  local protected=(
    "$HOME/Library/Keychains"
    "$HOME/Library/Application Support/Google/Chrome"
    "$HOME/Library/Mail"
    "$HOME/Library/Mobile Documents"
    "$HOME/Pictures/Photos Library.photoslibrary"
  )
  local p
  for p in "${protected[@]}"; do
    [[ -e "$p" ]] && printf '%-28s present, protected\n' "$(basename "$p")"
  done
  return 0
}

init_config() {
  local file
  file="${CONFIG_FILE:-$(config_default_path)}"
  file="$(expand_path "$file")"
  if [[ -e "$file" && "$ASSUME_YES" -ne 1 ]]; then
    die "Config already exists: $file"
  fi
  mkdir -p "$(dirname "$file")"
  cat >"$file" <<'EOF'
# cleanroom config
# Data only: this file is not executed as shell.

# preset can be: safe, dev, deep
preset=dev

# stale node_modules threshold
days=30

# Optional categories
include_app_caches=true
include_package_stores=true
include_node_stale=true
include_dev_heavy=false
include_snapshots=false
include_ai_workspaces=false
include_ai_models=false
include_containers=false

# Apply safety
trash=false
# log_file=~/.local/state/cleanroom/runs/custom.log

# Protect custom paths from deletion.
# Add one exclude=... line per path.
# exclude=~/Desktop/important-project
EOF
  ok "Wrote config: $file"
}

ask_yes_no() {
  local prompt="$1"
  local answer
  printf '%s [y/N]: ' "$prompt"
  read -r answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

interactive() {
  log "${BOLD}cleanroom interactive${RESET}"
  warn "Interactive mode still dry-runs unless --apply is passed."
  ask_yes_no "Include safe app cache folders?" && INCLUDE_APP_CACHES=1
  ask_yes_no "Include package-manager stores?" && INCLUDE_PACKAGE_STORES=1
  ask_yes_no "Include stale node_modules older than ${DAYS} days?" && INCLUDE_NODE_STALE=1
  ask_yes_no "Include heavy SDK/simulator cleanup?" && INCLUDE_DEV_HEAVY=1
  ask_yes_no "Include local snapshot thinning?" && INCLUDE_SNAPSHOTS=1
  ask_yes_no "Include AI-agent workspace cleanup?" && INCLUDE_AI_WORKSPACES=1
  ask_yes_no "Include downloaded AI model cleanup?" && INCLUDE_AI_MODELS=1
  ask_yes_no "Include container VM disk cleanup?" && INCLUDE_CONTAINERS=1
  clean
}

categories() {
  cat <<'EOF'
cleanroom categories

Default safe cleanup:
  Rebuildable user caches, logs older than 7 days, npm/Yarn/Gradle cache, Xcode DerivedData.

--include-app-caches:
  Nested app cache folders only. Does not remove browser profiles, password databases,
  cookies, bookmarks, or full app profile directories.

--include-package-stores:
  Rebuildable package-manager stores such as pnpm, CocoaPods repos, Gradle caches,
  and Cargo registry cache.

--include-node-stale:
  node_modules older than --days under Desktop/Documents/Downloads.

--include-dev-heavy:
  Xcode device support, unavailable simulators, simulator app data, Android NDK,
  and Android system images.

--include-ai-workspaces:
  Generated AI-agent recordings, scratch data, local brain/memory, implicit data,
  and local conversation caches where known.

--include-ai-models:
  Downloaded local AI model stores such as LM Studio, Ollama, Hugging Face, torch hub,
  ModelScope, and Whisper cache.

--include-containers:
  Local container VM disks for Colima/Lima/Docker Desktop. This can remove containers,
  images, and volumes.

--trash:
  Move cleanroom path removals to ~/.Trash/cleanroom-* during --apply runs.
  Commands delegated to system tools, such as snapshot thinning or simulator reset,
  may still be irreversible.

Presets:
  safe  default cleanup only
  dev   safe + app caches + package stores + stale node_modules
  deep  dev + heavy SDKs + snapshots + AI workspaces
EOF
}

clean() {
  if [[ "$APPLY" -eq 1 ]]; then
    warn "Apply mode enabled."
    [[ "$TRASH" -eq 1 ]] && warn "Trash mode enabled."
  else
    warn "Dry-run mode. Pass --apply to actually delete."
  fi
  confirm_apply
  ensure_apply_log
  [[ "$APPLY" -eq 1 ]] && warn "Apply log: $LOG_FILE"
  disk_line
  safe_clean
  clean_logs
  clean_package_stores
  clean_app_caches
  clean_dev_heavy
  clean_node_stale
  clean_snapshots
  clean_ai_workspaces
  clean_ai_models
  clean_containers
  printf '\n%s\n' "${BOLD}After${RESET}"
  disk_line
  [[ "$APPLY" -eq 1 && "$TRASH" -eq 1 ]] && warn "Review ~/.Trash/cleanroom-$RUN_ID before emptying Trash."
  return 0
}

apply_preset() {
  case "$1" in
    safe)
      ;;
    dev)
      INCLUDE_APP_CACHES=1
      INCLUDE_PACKAGE_STORES=1
      INCLUDE_NODE_STALE=1
      ;;
    deep)
      INCLUDE_APP_CACHES=1
      INCLUDE_PACKAGE_STORES=1
      INCLUDE_NODE_STALE=1
      INCLUDE_DEV_HEAVY=1
      INCLUDE_SNAPSHOTS=1
      INCLUDE_AI_WORKSPACES=1
      ;;
    *)
      die "Unknown preset: $1"
      ;;
  esac
}

if [[ "$#" -eq 0 ]]; then
  usage
  exit 0
fi

case "${1:-}" in
  scan|report|clean|interactive|doctor|categories|init-config|help)
    ACTION="$1"
    shift
    ;;
esac

args=("$@")
for ((i = 0; i < ${#args[@]}; i++)); do
  if [[ "${args[$i]}" == "--config" && $((i + 1)) -lt ${#args[@]} ]]; then
    CONFIG_FILE="${args[$((i + 1))]}"
  fi
done

if [[ -z "$CONFIG_FILE" ]]; then
  default_config="$(config_default_path)"
  [[ -f "$default_config" ]] && CONFIG_FILE="$default_config"
fi

if [[ -n "$CONFIG_FILE" && "$ACTION" != "init-config" ]]; then
  load_config "$CONFIG_FILE"
fi

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --apply) APPLY=1 ;;
    --trash) TRASH=1 ;;
    --yes) ASSUME_YES=1 ;;
    --verbose) VERBOSE=1 ;;
    --json) JSON=1 ;;
    --output)
      shift
      [[ -n "${1:-}" ]] || die "--output requires a path"
      OUTPUT_FILE="${1:-}"
      ;;
    --config)
      shift
      CONFIG_FILE="${1:-}"
      ;;
    --log)
      shift
      [[ -n "${1:-}" ]] || die "--log requires a path"
      LOG_FILE="$(expand_path "${1:-}")"
      ;;
    --exclude)
      shift
      add_exclude "${1:-}"
      ;;
    --preset)
      shift
      apply_preset "${1:-}"
      ;;
    --days)
      shift
      [[ "${1:-}" =~ ^[0-9]+$ ]] || die "--days requires a number"
      DAYS="$1"
      ;;
    --include-dev-heavy) INCLUDE_DEV_HEAVY=1 ;;
    --include-node-stale) INCLUDE_NODE_STALE=1 ;;
    --include-package-stores) INCLUDE_PACKAGE_STORES=1 ;;
    --include-app-caches) INCLUDE_APP_CACHES=1 ;;
    --include-snapshots) INCLUDE_SNAPSHOTS=1 ;;
    --include-ai-workspaces) INCLUDE_AI_WORKSPACES=1 ;;
    --include-ai-models) INCLUDE_AI_MODELS=1 ;;
    --include-containers) INCLUDE_CONTAINERS=1 ;;
    --include-gemini) INCLUDE_GEMINI=1; INCLUDE_AI_WORKSPACES=1 ;;
    --include-lmstudio) INCLUDE_LMSTUDIO=1; INCLUDE_AI_MODELS=1 ;;
    -h|--help) usage; exit 0 ;;
    -v|--version) echo "$VERSION"; exit 0 ;;
    *) die "Unknown option: $1" ;;
  esac
  shift
done

case "$ACTION" in
  scan) scan ;;
  report) report ;;
  clean) clean ;;
  interactive) interactive ;;
  doctor) doctor ;;
  categories) categories ;;
  init-config) init_config ;;
  help) usage ;;
  *) die "Unknown action: $ACTION" ;;
esac
