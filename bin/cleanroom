    local first=1 kb id title safety path preview apply notes kb_num
    while IFS=$'\t' read -r kb id title safety path preview apply notes; do
      [[ -z "${id:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","safety":"%s","path":"%s","present":%s,"size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","notes":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
