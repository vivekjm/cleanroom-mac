RED="$(printf '\033[31m')"
GREEN="$(printf '\033[32m')"
YELLOW="$(printf '\033[33m')"
BOLD="$(printf '\033[1m')"
RESET="$(printf '\033[0m')"

usage() {
  cat <<'EOF'
cleanroom - safe macOS storage cleaner

Usage:
  cleanroom dashboard [--json]
  cleanroom overview [--json]
  cleanroom map [--json]
  cleanroom map-fast [--json]
  cleanroom snapshot [--json] [--output PATH]
  cleanroom snapshot-fast [--json] [--output PATH]
  cleanroom diff [BEFORE.json AFTER.json] [--json]
  cleanroom state [--json]
  cleanroom state-fast [--json]
  cleanroom permissions [--json]
  cleanroom review [--json]
  cleanroom scan [options]
  cleanroom system-data [--json]
  cleanroom system-data-fast [--json]
  cleanroom plan [--json]
  cleanroom plan-fast [--json]
  cleanroom large [PATH] [--min-mb N] [--limit N] [--json]
  cleanroom large-fast [PATH] [--min-mb N] [--limit N] [--json]
  cleanroom brokenlinks [PATH] [--limit N] [--json]
  cleanroom brokenlinks-fast [PATH] [--limit N] [--json]
  cleanroom quarantine [PATH] [--limit N] [--json]
  cleanroom quarantine-fast [PATH] [--limit N] [--json]
