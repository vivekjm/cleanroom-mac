  local rows
  rows="$(diagnostic_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title paths category preview apply description kb
    while IFS=$'\t' read -r id title paths category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb="$(paths_field_kb "$paths")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom diagnostics${RESET}"
  printf 'Review-only inventory. Diagnostic report cleanup is opt-in.\n\n'
  printf '%-10s %-22s %-18s %s\n' "size" "id" "category" "preview command"
  local id title paths category preview apply description kb
  while IFS=$'\t' read -r id title paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%-10s %-22s %-18s %s\n' "$(human_kb "$kb")" "$id" "$category" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

diagnostic_total_kb() {
  local id title paths category preview apply description total=0 kb
  while IFS=$'\t' read -r id title paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    total=$((total + kb))
  done < <(diagnostic_rows)
  printf '%s\n' "$total"
}

packages() {
  local rows
  rows="$(package_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id manager paths category preview apply kb
    while IFS=$'\t' read -r id manager paths category preview apply; do
      [[ -z "${id:-}" ]] && continue
      kb="$(paths_field_kb "$paths")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","manager":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$manager" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom package stores${RESET}"
  printf 'Review-only inventory. Use the preview command before applying cleanup.\n\n'
  printf '%-10s %-18s %-14s %-10s %s\n' "size" "id" "manager" "category" "preview command"
  local id manager paths category preview apply kb
  while IFS=$'\t' read -r id manager paths category preview apply; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%-10s %-18s %-14s %-10s %s\n' "$(human_kb "$kb")" "$id" "$manager" "$category" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
  done <<<"$rows"
}

npm_cache() {
  local command_label output status
  if ! command -v npm >/dev/null 2>&1; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":false,"apply":%s,"command":"","exit_code":127,"output":"%s"}\n' \
        "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "npm command not found" | json_escape)"
      return 0
    fi
    die "npm command not found"
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    command_label="npm cache clean --force"
  else
    command_label="npm cache verify"
  fi

  if [[ "$APPLY" -eq 1 && "$ASSUME_YES" -ne 1 ]]; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":true,"apply":true,"command":"%s","exit_code":2,"output":"%s"}\n' \
        "$(printf '%s' "$command_label" | json_escape)" \
        "$(printf '%s' "confirmation required; pass --yes to use --json with --apply" | json_escape)"
      return 2
    fi
    warn "Apply mode enabled for npm cache cleanup."
    warn "npm cache clean --force removes the npm cache and packages may need to download again."
    printf 'Continue? Type "clean" to proceed: '
    local answer
    IFS= read -r answer
    [[ "$answer" == "clean" ]] || die "Aborted."
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    if output="$(npm cache clean --force 2>&1)"; then
      status=0
      record_apply "npm-cache" "ok" "0" "$command_label" ""
    else
      status=$?
      record_apply "npm-cache" "failed" "0" "$command_label" ""
    fi
  else
    if output="$(npm cache verify 2>&1)"; then
      status=0
    else
      status=$?
    fi
  fi

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"available":true,"apply":%s,"command":"%s","exit_code":%s,"output":"%s"}\n' \
      "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(printf '%s' "$command_label" | json_escape)" \
      "$status" \
      "$(printf '%s' "$output" | json_escape)"
    return "$status"
  fi

  printf '%s\n' "${BOLD}cleanroom npm cache${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    printf 'Running: %s\n\n' "$command_label"
  else
    warn "Dry-run mode. Pass --apply --yes to run npm cache clean --force."
    printf 'Running: %s\n\n' "$command_label"
  fi
  if [[ -n "$output" ]]; then
    printf '%s\n' "$output"
  else
    printf 'npm reported no cache output.\n'
  fi
  return "$status"
}

yarn_cache() {
  local command_label output status
  if ! command -v yarn >/dev/null 2>&1; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":false,"apply":%s,"command":"","exit_code":127,"output":"%s"}\n' \
        "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "yarn command not found" | json_escape)"
      return 0
    fi
    die "yarn command not found"
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    command_label="yarn cache clean"
  else
    command_label="yarn cache dir"
  fi

  if [[ "$APPLY" -eq 1 && "$ASSUME_YES" -ne 1 ]]; then
    if [[ "$JSON" -eq 1 ]]; then
      printf '{"available":true,"apply":true,"command":"%s","exit_code":2,"output":"%s"}\n' \
        "$(printf '%s' "$command_label" | json_escape)" \
        "$(printf '%s' "confirmation required; pass --yes to use --json with --apply" | json_escape)"
      return 2
    fi
    warn "Apply mode enabled for Yarn cache cleanup."
    warn "Yarn cache clean removes cached packages and projects may need to download packages again."
    printf 'Continue? Type "clean" to proceed: '
    local answer
    IFS= read -r answer
    [[ "$answer" == "clean" ]] || die "Aborted."
  fi

  if [[ "$APPLY" -eq 1 ]]; then
    if output="$(yarn cache clean 2>&1)"; then
      status=0
      record_apply "yarn-cache" "ok" "0" "$command_label" ""
    else
      status=$?
      record_apply "yarn-cache" "failed" "0" "$command_label" ""
    fi
  else
    if output="$(yarn cache dir 2>&1)"; then
      status=0
    else
      command_label="yarn config get cacheFolder"
      if output="$(yarn config get cacheFolder 2>&1)"; then
        status=0
      else
        status=$?
      fi
    fi
  fi

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"available":true,"apply":%s,"command":"%s","exit_code":%s,"output":"%s"}\n' \
      "$(if [[ "$APPLY" -eq 1 ]]; then echo true; else echo false; fi)" \
      "$(printf '%s' "$command_label" | json_escape)" \
      "$status" \
      "$(printf '%s' "$output" | json_escape)"
    return "$status"
  fi

  printf '%s\n' "${BOLD}cleanroom Yarn cache${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    printf 'Running: %s\n\n' "$command_label"
  else
    warn "Dry-run mode. Pass --apply --yes to run yarn cache clean."
    printf 'Running: %s\n\n' "$command_label"
  fi
  if [[ -n "$output" ]]; then
    printf '%s\n' "$output"
  else
    printf 'Yarn reported no cache output.\n'
  fi
  return "$status"
}

