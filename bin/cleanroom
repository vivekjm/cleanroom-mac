map_rows_sized() {
  local id title paths category command description kb
  while IFS=$'\t' read -r id title paths category command description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%012d\t%s\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$id" "$title" "$paths" "$category" "$command" "$description"
  done < <(map_rows) | sort -rn
}

map() {
  local rows
  rows="$(map_rows_sized)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title paths category command description kb_num
    while IFS=$'\t' read -r kb id title paths category command description; do
      [[ -z "${id:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$command" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom storage map${RESET}"
  printf 'Read-only map of major focused storage buckets. Buckets can overlap when a smaller folder is also part of a larger parent.\n\n'
  printf '%-10s %-16s %-22s %s\n' "size" "category" "bucket" "next command"
  local kb id title paths category command description
  while IFS=$'\t' read -r kb id title paths category command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-16s %-22s %s\n' "$(human_kb "$kb")" "$category" "$id" "$command"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

snapshot_body() {
  local rows
  rows="$(map_rows_sized)"

  printf '{'
  printf '"version":"%s","run_id":"%s","created_at":"%s",' \
    "$(printf '%s' "$VERSION" | json_escape)" \
    "$(printf '%s' "$RUN_ID" | json_escape)" \
    "$(date '+%Y-%m-%d %H:%M:%S %Z' | json_escape)"
  disk_json
  printf ',"buckets":['
  local first=1 kb id title paths category command description kb_num
  while IFS=$'\t' read -r kb id title paths category command description; do
    [[ -z "${id:-}" ]] && continue
    kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
    [[ "$first" -eq 0 ]] && printf ','
    first=0
    printf '{"id":"%s","title":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","command":"%s","description":"%s"}' \
      "$(printf '%s' "$id" | json_escape)" \
      "$(printf '%s' "$title" | json_escape)" \
      "$(printf '%s' "$paths" | json_escape)" \
      "$(printf '%s' "$category" | json_escape)" \
      "$kb_num" \
      "$(human_kb "${kb:-0}" | json_escape)" \
      "$(printf '%s' "$command" | json_escape)" \
      "$(printf '%s' "$description" | json_escape)"
  done <<<"$rows"
  printf ']}'
  printf '\n'
}

snapshot() {
  if [[ "$JSON" -eq 1 ]]; then
    snapshot_body
    return 0
  fi

  local output rows
  if [[ -n "$OUTPUT_FILE" ]]; then
    output="$(expand_path "$OUTPUT_FILE")"
  else
    output="$(default_snapshot_file)"
  fi
  mkdir -p "$(dirname "$output")"
  snapshot_body >"$output"

  printf '%s\n' "${BOLD}cleanroom snapshot${RESET}"
  ok "Wrote snapshot: $output"
  printf '\nTop buckets:\n'
  rows="$(map_rows_sized | head -n 5)"
  printf '%-10s %-16s %s\n' "size" "category" "bucket"
  local kb id title paths category command description
  while IFS=$'\t' read -r kb id title paths category command description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-16s %s\n' "$(human_kb "$kb")" "$category" "$id"
  done <<<"$rows"
  printf '\nCompare snapshots manually or attach them to support reports. Snapshot data is read-only and contains paths plus sizes only.\n'
}

snapshot_diff() {
  local before after latest newest older
  if [[ "${#PATH_ARGS[@]}" -eq 0 ]]; then
    latest="$(latest_snapshot_files || true)"
    newest="$(printf '%s\n' "$latest" | sed -n '1p')"
    older="$(printf '%s\n' "$latest" | sed -n '2p')"
    [[ -n "${newest:-}" && -n "${older:-}" ]] || die "Need two snapshots. Run cleanroom snapshot twice or pass BEFORE.json AFTER.json."
    before="$older"
    after="$newest"
  elif [[ "${#PATH_ARGS[@]}" -eq 2 ]]; then
    before="$(expand_path "${PATH_ARGS[0]}")"
    after="$(expand_path "${PATH_ARGS[1]}")"
  else
    die "diff requires zero args for latest two snapshots, or BEFORE.json AFTER.json."
  fi
  [[ -f "$before" ]] || die "Snapshot not found: $before"
  [[ -f "$after" ]] || die "Snapshot not found: $after"

  if ! command -v python3 >/dev/null 2>&1; then
    die "diff requires python3 to parse snapshot JSON."
  fi

  python3 - "$before" "$after" "$JSON" <<'PY'
import json
import sys

before_path, after_path, json_mode = sys.argv[1], sys.argv[2], sys.argv[3] == "1"

with open(before_path, "r", encoding="utf-8") as handle:
    before = json.load(handle)
with open(after_path, "r", encoding="utf-8") as handle:
    after = json.load(handle)

before_buckets = {item.get("id", ""): item for item in before.get("buckets", []) if item.get("id")}
after_buckets = {item.get("id", ""): item for item in after.get("buckets", []) if item.get("id")}
items = []
for bucket_id in sorted(set(before_buckets) | set(after_buckets)):
    old = before_buckets.get(bucket_id, {})
    new = after_buckets.get(bucket_id, {})
    before_kb = int(old.get("size_kb") or 0)
    after_kb = int(new.get("size_kb") or 0)
    delta_kb = after_kb - before_kb
    source = new or old
    items.append({
        "id": bucket_id,
        "title": source.get("title", bucket_id),
        "category": source.get("category", ""),
        "before_kb": before_kb,
        "after_kb": after_kb,
        "delta_kb": delta_kb,
        "command": source.get("command", ""),
    })

items.sort(key=lambda item: (abs(item["delta_kb"]), item["after_kb"]), reverse=True)

def human(kb):
    value = kb * 1024.0
    units = ["B", "KB", "MB", "GB", "TB"]
    i = 0
    while abs(value) >= 1024 and i < len(units) - 1:
        value /= 1024.0
        i += 1
    if i <= 1:
        return f"{value:.0f}{units[i]}"
    return f"{value:.1f}{units[i]}"

if json_mode:
    payload = {
        "before_file": before_path,
        "after_file": after_path,
        "before_created_at": before.get("created_at", ""),
        "after_created_at": after.get("created_at", ""),
        "items": [
            {
                **item,
                "before": human(item["before_kb"]),
                "after": human(item["after_kb"]),
                "delta": human(item["delta_kb"]),
            }
            for item in items
        ],
    }
    print(json.dumps(payload, separators=(",", ":")))
    raise SystemExit(0)

print("\033[1mcleanroom snapshot diff\033[0m")
print(f"before: {before_path}")
print(f"after:  {after_path}")
print("")
print(f"{'delta':<10} {'after':<10} {'before':<10} {'category':<14} {'bucket':<20} next command")
shown = 0
for item in items:
    if item["delta_kb"] == 0 and shown >= 10:
        continue
    print(f"{human(item['delta_kb']):<10} {human(item['after_kb']):<10} {human(item['before_kb']):<10} {item['category']:<14} {item['id']:<20} {item['command']}")
    shown += 1
print("")
print("Positive deltas grew; negative deltas shrank. Snapshot diff is read-only.")
PY
}

large_rows() {
  local root="$1"
  find "$root" -xdev -type f -size "+${MIN_MB}M" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\n' "$(size_kb "$path")" "$path"
    done |
    sort -rn |
    head -n "$LIMIT" || true
}

large() {
  local root
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    root="$(expand_path "${PATH_ARGS[0]}")"
  else
    root="$HOME"
  fi
  [[ -e "$root" ]] || die "large path not found: $root"

  local rows
  rows="$(large_rows "$root")"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb kb_num path
    while IFS=$'\t' read -r kb path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom large files${RESET}"
  printf 'Review-only list. cleanroom does not delete these files.\n'
  printf 'Path: %s\n' "$root"
  printf 'Minimum: %sMB  Limit: %s\n\n' "$MIN_MB" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No files found over %sMB.\n' "$MIN_MB"
    return 0
  fi
  local kb path
  while IFS=$'\t' read -r kb path; do
    [[ -z "${path:-}" ]] && continue
    printf '%8s  %s\n' "$(human_kb "$kb")" "$path"
  done <<<"$rows"
}

brokenlinks_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    local path
    for path in "${PATH_ARGS[@]}"; do
      printf '%s\n' "$(expand_path "$path")"
    done
  else
    printf '%s\n' "$HOME/Documents"
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Downloads"
    printf '%s\n' "$HOME/Applications"
  fi
}

brokenlinks_rows() {
  local root path target epoch
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      if [[ -e "$path" ]]; then
        continue
      fi
      target="$(readlink "$path" 2>/dev/null || true)"
      epoch="$(path_mtime_epoch "$path")"
      printf '%012d\t%s\t%s\t%s\n' "$epoch" "$path" "$target" "$(dirname "$path")"
    done < <(find "$root" -xdev -type l -print0 2>/dev/null)
  done < <(brokenlinks_roots) | sort -rn | head -n "$LIMIT"
}

brokenlinks() {
  local rows
  rows="$(brokenlinks_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 epoch path target parent epoch_num
    while IFS=$'\t' read -r epoch path target parent; do
      [[ -z "${path:-}" ]] && continue
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","target":"%s","parent":"%s","modified_epoch":%s,"modified":"%s","review_command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$target" | json_escape)" \
        "$(printf '%s' "$parent" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf 'open -R %s' "$(shell_quote "$path")" | json_escape)" \
        "$(printf '%s' "Review broken links before removing them; they may belong to source trees or managed apps." | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom broken links${RESET}"
  printf 'Review-only list. cleanroom does not delete symlinks.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No broken symlinks found in readable search folders.\n'
    return 0
  fi
  printf '%-12s %s\n' "modified" "link -> target"
  local epoch path target parent epoch_num
  while IFS=$'\t' read -r epoch path target parent; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    printf '%-12s %s -> %s\n' "$(file_mtime_iso "${epoch_num:-0}")" "$path" "$target"
    printf '  reveal: open -R %s\n' "$(shell_quote "$path")"
  done <<<"$rows"
}

quarantine_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    local path
    for path in "${PATH_ARGS[@]}"; do
      printf '%s\n' "$(expand_path "$path")"
    done
  else
    printf '%s\n' "$HOME/Downloads"
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Documents"
    printf '%s\n' "$HOME/Applications"
  fi
}

quarantine_rows() {
  command -v xattr >/dev/null 2>&1 || return 0
  local root path value kb epoch
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      value="$(xattr -p com.apple.quarantine "$path" 2>/dev/null || true)"
      [[ -n "$value" ]] || continue
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      printf '%012d\t%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$path" "$value" "$(dirname "$path")"
    done < <(find "$root" -xdev \( -type f -o -type d -name '*.app' \) -print0 2>/dev/null)
  done < <(quarantine_roots) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

quarantine() {
  local rows
  rows="$(quarantine_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch path value parent kb_num epoch_num
    while IFS=$'\t' read -r kb epoch path value parent; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","parent":"%s","quarantine":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","review_command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$parent" | json_escape)" \
        "$(printf '%s' "$value" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf 'open -R %s' "$(shell_quote "$path")" | json_escape)" \
        "$(printf '%s' "Quarantine metadata marks downloaded content. Review before deleting or clearing attributes." | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom quarantined downloads${RESET}"
  printf 'Review-only list. cleanroom does not delete files or clear quarantine attributes.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if ! command -v xattr >/dev/null 2>&1; then
    printf 'xattr not found; quarantine metadata cannot be inspected on this system.\n'
    return 0
  fi
  if [[ -z "$rows" ]]; then
    printf 'No quarantine metadata found in readable search folders.\n'
    return 0
  fi
  printf '%-10s %-12s %s\n' "size" "modified" "path"
  local kb epoch path value parent epoch_num
  while IFS=$'\t' read -r kb epoch path value parent; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    printf '%-10s %-12s %s\n' "$(human_kb "$kb")" "$(file_mtime_iso "${epoch_num:-0}")" "$path"
    printf '  quarantine: %s\n' "$value"
    printf '  reveal: open -R %s\n' "$(shell_quote "$path")"
  done <<<"$rows"
}

metadata_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    local path
    for path in "${PATH_ARGS[@]}"; do
      printf '%s\n' "$(expand_path "$path")"
    done
  else
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Documents"
    printf '%s\n' "$HOME/Downloads"
  fi
}

metadata_kind() {
  local name="$1"
  case "$name" in
    .DS_Store) printf 'finder-metadata' ;;
    ._*|__MACOSX) printf 'appledouble' ;;
    Thumbs.db|ehthumbs.db|Desktop.ini) printf 'windows-metadata' ;;
    .TemporaryItems|.Trashes|.fseventsd) printf 'volume-metadata' ;;
    *) printf '' ;;
  esac
}

metadata_rows() {
  local root path name kind kb epoch
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      name="$(basename "$path")"
      kind="$(metadata_kind "$name")"
      [[ -n "$kind" ]] || continue
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      printf '%012d\t%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$kind" "$name" "$path"
    done < <(find "$root" -xdev \( \
      -name '.DS_Store' -o -name '._*' -o -name '__MACOSX' \
      -o -name 'Thumbs.db' -o -name 'ehthumbs.db' -o -name 'Desktop.ini' \
      -o -name '.TemporaryItems' -o -name '.Trashes' -o -name '.fseventsd' \
    \) -print0 2>/dev/null)
  done < <(metadata_roots) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

metadata() {
  local rows
  rows="$(metadata_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch kind name path kb_num epoch_num status reason line
    while IFS=$'\t' read -r kb epoch kind name path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      line="$(guard_status "$path")"
      status="${line%%$'\t'*}"
      reason="${line#*$'\t'}"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","name":"%s","kind":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","status":"%s","reason":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$reason" | json_escape)" \
        "$(printf 'cleanroom metadata --limit %s' "$LIMIT" | json_escape)" \
        "$(printf 'cleanroom metadata --apply --trash --limit %s' "$LIMIT" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom metadata clutter${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$TRASH" -eq 1 ]] || die "metadata apply requires --trash so files can be restored from the apply log."
    warn "Apply mode enabled for metadata clutter."
    warn "Trash mode required and enabled; matches move to ~/.Trash/cleanroom-$RUN_ID."
    [[ "$ASSUME_YES" -eq 1 ]] || {
      printf 'Continue? Type "metadata" to proceed: '
      local answer
      read -r answer
      [[ "$answer" == "metadata" ]] || die "Cancelled."
    }
    ensure_apply_log
    warn "Apply log: $LOG_FILE"
  else
    printf 'Preview list. Pass --apply --trash to move matched metadata files to a recoverable Trash folder.\n'
  fi

  printf 'Limit: %s\n' "$LIMIT"
  printf 'Paths: '
  local root first_root=1
  while IFS= read -r root; do
    [[ "$first_root" -eq 0 ]] && printf '; '
    first_root=0
    printf '%s' "$root"
  done < <(metadata_roots)
  printf '\n\n'

  if [[ -z "$rows" ]]; then
    printf 'No filesystem metadata clutter found.\n'
    return 0
  fi

  printf '%-10s %-18s %-12s %s\n' "size" "kind" "modified" "path"
  local kb epoch kind name path epoch_num removed refused skipped status_line status reason
  removed=0
  refused=0
  skipped=0
  while IFS=$'\t' read -r kb epoch kind name path; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    if [[ "$APPLY" -eq 1 ]]; then
      if [[ ! -e "$path" ]]; then
        skipped=$((skipped + 1))
        continue
      fi
      status_line="$(guard_status "$path")"
      status="${status_line%%$'\t'*}"
      reason="${status_line#*$'\t'}"
      if [[ "$status" != "allowed" ]]; then
        refused=$((refused + 1))
        warn "refusing metadata file: $path ($status: $reason)"
        record_apply "metadata" "$status" "$kb" "$path" ""
        continue
      fi
      printf '%-10s %-18s %-12s %s\n' "$(human_kb "$kb")" "$kind" "$(file_mtime_iso "${epoch_num:-0}")" "$path"
      delete_path "$path"
      removed=$((removed + 1))
    else
      printf '%-10s %-18s %-12s %s\n' "$(human_kb "$kb")" "$kind" "$(file_mtime_iso "${epoch_num:-0}")" "$path"
      printf '  reveal: open -R %s\n' "$(shell_quote "$path")"
    fi
  done <<<"$rows"

  if [[ "$APPLY" -eq 1 ]]; then
    printf '\nmetadata summary: moved=%s refused=%s skipped=%s\n' "$removed" "$refused" "$skipped"
    printf 'Restore with: cleanroom restore --log %s --apply\n' "$(shell_quote "$LOG_FILE")"
  else
    printf '\nApply cleanup with: cleanroom metadata --apply --trash\n'
  fi
}

clean_metadata() {
  [[ "$INCLUDE_METADATA" -eq 1 ]] || return 0
  log "${BOLD}Filesystem metadata clutter${RESET}"
  local path kb epoch kind name
  if [[ "$APPLY" -eq 1 ]]; then
    metadata_rows |
      while IFS=$'\t' read -r kb epoch kind name path; do
        [[ -z "${path:-}" ]] && continue
        run_rm "$path"
      done || true
  else
    metadata_rows |
      while IFS=$'\t' read -r kb epoch kind name path; do
        [[ -z "${path:-}" ]] && continue
        printf 'would remove %8s  %s\n' "$(human_kb "$kb")" "$path"
      done
  fi
}

metadata_total_kb() {
  local total=0 kb epoch kind name path kb_num
  while IFS=$'\t' read -r kb epoch kind name path; do
    [[ -z "${path:-}" ]] && continue
    kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(metadata_rows)
  printf '%s\n' "$total"
}

document_guard_status() {
  local path="$1"
  if is_dangerous_path "$path"; then
    printf 'refused-dangerous'
  elif is_protected_removal_path "$path"; then
    printf 'refused-protected'
  elif is_excluded "$path"; then
    printf 'excluded'
  else
    printf 'review'
  fi
}

document_item_kind() {
  local path="$1"
  if [[ -d "$path" ]]; then
    printf 'directory'
  elif [[ -f "$path" ]]; then
    printf 'file'
  else
    printf 'other'
  fi
}

documents_default_root() {
  if [[ -d "$HOME/Documents" ]]; then
    printf '%s\n' "$HOME/Documents"
  else
    printf '%s\n' "$HOME"
  fi
}

documents_rows() {
  local root="$1"
  find "$root" -xdev -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\t%s\t%s\n' "$(size_kb "$path")" "$(document_item_kind "$path")" "$(document_guard_status "$path")" "$path"
    done |
    sort -rn |
    head -n "$LIMIT" || true
}

documents() {
  local root
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    root="$(expand_path "${PATH_ARGS[0]}")"
  else
    root="$(documents_default_root)"
  fi
  [[ -e "$root" ]] || die "documents path not found: $root"
  [[ -d "$root" ]] || die "documents path must be a directory: $root"

  local rows
  rows="$(documents_rows "$root")"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb kb_num kind guard path name
    while IFS=$'\t' read -r kb kind guard path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      name="$(basename "$path")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","name":"%s","kind":"%s","guard_status":"%s","size_kb":%s,"size":"%s","review_command":"%s","large_files_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$guard" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf 'cleanroom documents %s --limit %s' "$(shell_quote "$path")" "$LIMIT" | json_escape)" \
        "$(printf 'cleanroom large %s --min-mb %s --limit %s' "$(shell_quote "$path")" "$MIN_MB" "$LIMIT" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Documents storage${RESET}"
  printf 'Review-only top-level size breakdown. cleanroom does not delete these files or folders.\n'
  printf 'Path: %s  Limit: %s\n\n' "$root" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No top-level items found.\n'
    return 0
  fi
  printf '%-10s %-10s %-18s %s\n' "size" "kind" "guard" "path"
  local kb kind guard path
  while IFS=$'\t' read -r kb kind guard path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %-10s %-18s %s\n' "$(human_kb "$kb")" "$kind" "$guard" "$path"
    if [[ "$kind" == "directory" ]]; then
      printf '  inspect: cleanroom documents %s --limit %s\n' "$(shell_quote "$path")" "$LIMIT"
      printf '  large files: cleanroom large %s --min-mb %s --limit %s\n' "$(shell_quote "$path")" "$MIN_MB" "$LIMIT"
    fi
  done <<<"$rows"
}

desktop() {
  PATH_ARGS=("$HOME/Desktop")
  documents
}

screenshot_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Downloads"
    printf '%s\n' "$HOME/Documents"
  fi
}

screenshot_name_matches() {
  local name="$1"
  case "$name" in
    Screenshot*|Screen\ Shot*|CleanShot*|CleanShot\ X*|Kap*|screen-recording*|Screen\ Recording*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

screenshot_rows() {
  local now root path name kb epoch age_days
  now="$(date '+%s')"
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    find "$root" -xdev -maxdepth 1 -type f -mtime +"$DAYS" -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        name="$(basename "$path")"
        screenshot_name_matches "$name" || continue
        case "$name" in
          *.png|*.jpg|*.jpeg|*.heic|*.tiff|*.gif|*.mov|*.mp4) ;;
          *) continue ;;
        esac
        kb="$(size_kb "$path")"
        epoch="$(path_mtime_epoch "$path")"
        if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
          age_days=$(((now - epoch) / 86400))
        else
          age_days=0
        fi
        printf '%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path"
      done
  done < <(screenshot_roots) |
    sort -rn |
    head -n "$LIMIT" || true
}

screenshots() {
  local rows
  rows="$(screenshot_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path kb_num
    while IFS=$'\t' read -r kb epoch age_days path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","name":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","age_days":%s,"review_command":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(basename "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "$(file_mtime_iso "${epoch:-0}" | json_escape)" \
        "${age_days:-0}" \
        "$(printf 'open -R %s' "$(shell_quote "$path")" | json_escape)" \
        "$(printf 'cleanroom clean --include-screenshots --days %s' "$DAYS" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-screenshots --days %s' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom screenshots${RESET}"
  printf 'Review-only list. cleanroom does not delete screenshots or screen recordings.\n'
  printf 'Older than: %s days  Limit: %s\n' "$DAYS" "$LIMIT"
  printf 'Paths: '
  local root first_root=1
  while IFS= read -r root; do
    [[ "$first_root" -eq 0 ]] && printf '; '
    first_root=0
    printf '%s' "$root"
  done < <(screenshot_roots)
  printf '\n\n'
  if [[ -z "$rows" ]]; then
    printf 'No matching screenshot files found.\n'
    return 0
  fi
  printf '%-10s %-9s %-12s %s\n' "size" "age" "modified" "path"
  local kb epoch age_days path
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %-12s %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$(file_mtime_iso "${epoch:-0}")" "$path"
    printf '  reveal: open -R %s\n' "$(shell_quote "$path")"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-screenshots --days %s\n' "$DAYS"
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-screenshots --days %s\n' "$DAYS"
}

screenshot_total_kb() {
  local total=0 kb epoch age_days path kb_num
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(screenshot_rows)
  printf '%s\n' "$total"
}

archive_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "$HOME/Downloads"
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Documents"
  fi
}

archive_kind() {
  local name="$1" lower
  lower="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
  case "$lower" in
    *.dmg|*.iso|*.img) printf 'disk-image' ;;
    *.zip|*.rar|*.7z|*.tar|*.tgz|*.tar.gz|*.tbz2|*.tar.bz2|*.txz|*.tar.xz|*.gz|*.bz2|*.xz) printf 'archive' ;;
    *) printf '' ;;
  esac
}

download_artifact_kind() {
  local name="$1" kind lower
  kind="$(archive_kind "$name")"
  if [[ -n "$kind" ]]; then
    printf '%s\n' "$kind"
    return 0
  fi
  lower="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
  case "$lower" in
    *.pkg|*.mpkg|*.xip|*.ipsw) printf 'installer\n' ;;
    *) printf '' ;;
  esac
}

archive_rows() {
  local now root path name kind kb epoch age_days
  now="$(date '+%s')"
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    find "$root" -xdev -maxdepth 1 -type f -mtime +"$DAYS" -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        name="$(basename "$path")"
        kind="$(archive_kind "$name")"
        [[ -n "$kind" ]] || continue
        kb="$(size_kb "$path")"
        epoch="$(path_mtime_epoch "$path")"
        if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
          age_days=$(((now - epoch) / 86400))
        else
          age_days=0
        fi
        printf '%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$kind" "$path"
      done
  done < <(archive_roots) |
    sort -rn |
    head -n "$LIMIT" || true
}

archives() {
  local rows
  rows="$(archive_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days kind path kb_num
    while IFS=$'\t' read -r kb epoch age_days kind path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","name":"%s","kind":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","age_days":%s,"review_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(basename "$path" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "$(file_mtime_iso "${epoch:-0}" | json_escape)" \
        "${age_days:-0}" \
        "$(printf 'open -R %s' "$(shell_quote "$path")" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom archives${RESET}"
  printf 'Review-only list. cleanroom does not delete archives or disk images.\n'
  printf 'Older than: %s days  Limit: %s\n' "$DAYS" "$LIMIT"
  printf 'Paths: '
  local root first_root=1
  while IFS= read -r root; do
    [[ "$first_root" -eq 0 ]] && printf '; '
    first_root=0
    printf '%s' "$root"
  done < <(archive_roots)
  printf '\n\n'
  if [[ -z "$rows" ]]; then
    printf 'No matching archive or disk image files found.\n'
    return 0
  fi
  printf '%-10s %-10s %-9s %-12s %s\n' "size" "kind" "age" "modified" "path"
  local kb epoch age_days kind path
  while IFS=$'\t' read -r kb epoch age_days kind path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %-10s %4sd     %-12s %s\n' "$(human_kb "$kb")" "$kind" "${age_days:-0}" "$(file_mtime_iso "${epoch:-0}")" "$path"
    printf '  reveal: open -R %s\n' "$(shell_quote "$path")"
  done <<<"$rows"
}

file_mtime_iso() {
  local epoch="$1"
  if [[ "$epoch" =~ ^[0-9]+$ && "$epoch" -gt 0 ]]; then
    date -r "$epoch" '+%Y-%m-%d' 2>/dev/null || printf 'unknown'
  else
    printf 'unknown'
  fi
}

path_mtime_epoch() {
  local path="$1" epoch
  epoch="$(stat -f '%m' "$path" 2>/dev/null || stat -c '%Y' "$path" 2>/dev/null || true)"
  [[ "$epoch" =~ ^[0-9]+$ ]] || epoch=0
  printf '%s\n' "$epoch"
}

downloads_rows() {
  local root="$HOME/Downloads"
  [[ -d "$root" ]] || return 0
  local now path kb epoch age_days
  now="$(date '+%s')"
  find "$root" -maxdepth 1 -type f -mtime +"$DAYS" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
        age_days=$(((now - epoch) / 86400))
      else
        age_days=0
      fi
      printf '%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path"
    done |
    sort -rn |
    head -n "$LIMIT" || true
}

download_artifact_rows() {
  local root="$HOME/Downloads"
  [[ -d "$root" ]] || return 0
  local now path name kind kb epoch age_days
  now="$(date '+%s')"
  find "$root" -xdev -maxdepth 1 -type f -mtime +"$DAYS" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      name="$(basename "$path")"
      kind="$(download_artifact_kind "$name")"
      [[ -n "$kind" ]] || continue
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
        age_days=$(((now - epoch) / 86400))
      else
        age_days=0
      fi
      printf '%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$kind" "$path"
    done |
    sort -rn |
    head -n "$LIMIT" || true
}

download_artifact_total_kb() {
  local total=0 kb epoch age_days kind path kb_num
  while IFS=$'\t' read -r kb epoch age_days kind path; do
    [[ -z "${path:-}" ]] && continue
    kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(download_artifact_rows)
  printf '%s\n' "$total"
}

downloads() {
  local rows root
  root="$HOME/Downloads"
  rows="$(downloads_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path kb_num
    while IFS=$'\t' read -r kb epoch age_days path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      local artifact_kind cleanup_eligible
      artifact_kind="$(download_artifact_kind "$(basename "$path")")"
      if [[ -n "$artifact_kind" ]]; then
        cleanup_eligible=true
      else
        cleanup_eligible=false
      fi
      printf '{"path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","age_days":%s,"artifact_kind":"%s","cleanup_eligible":%s,"preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "$(file_mtime_iso "${epoch:-0}" | json_escape)" \
        "${age_days:-0}" \
        "$(printf '%s' "$artifact_kind" | json_escape)" \
        "$cleanup_eligible" \
        "$(printf 'cleanroom clean --include-download-artifacts --days %s' "$DAYS" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-download-artifacts --days %s' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom old Downloads${RESET}"
  printf 'Review-only list. cleanroom does not delete Downloads files.\n'
  printf 'Path: %s\n' "$root"
  printf 'Older than: %s days  Limit: %s\n\n' "$DAYS" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No old Downloads files found.\n'
    return 0
  fi
  printf '%-10s %-9s %-12s %s\n' "size" "age" "modified" "path"
  local kb epoch age_days path
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %-12s %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$(file_mtime_iso "${epoch:-0}")" "$path"
  done <<<"$rows"
  printf '\nReview these manually in Finder before deleting anything.\n'
  printf 'Opt-in artifact preview: cleanroom clean --include-download-artifacts --days %s\n' "$DAYS"
  printf 'Opt-in artifact apply: cleanroom clean --apply --trash --include-download-artifacts --days %s\n' "$DAYS"
}

installer_find_expr() {
  [[ -d "$HOME/Downloads" ]] || return 0
  find "$HOME/Downloads" -maxdepth 1 -type f -mtime +"$DAYS" \( \
    -iname '*.dmg' -o -iname '*.pkg' -o -iname '*.mpkg' -o -iname '*.xip' \
    -o -iname '*.ipsw' -o -iname '*.iso' \
  \) -print0 2>/dev/null
}

installer_rows() {
  local now path kb epoch age_days
  now="$(date '+%s')"
  installer_find_expr |
    while IFS= read -r -d '' path; do
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
        age_days=$(((now - epoch) / 86400))
      else
        age_days=0
      fi
      printf '%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path"
    done |
    sort -rn |
    head -n "$LIMIT"
}

installer_total_kb() {
  local total=0 kb epoch age_days path kb_num
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(installer_rows)
  printf '%s\n' "$total"
}

installers() {
  local rows root
  root="$HOME/Downloads"
  rows="$(installer_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path kb_num
    while IFS=$'\t' read -r kb epoch age_days path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","age_days":%s,"preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "$(file_mtime_iso "${epoch:-0}" | json_escape)" \
        "${age_days:-0}" \
        "$(printf 'cleanroom clean --include-installers --days %s' "$DAYS" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-installers --days %s' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom old installers${RESET}"
  printf 'Review-only list. cleanroom only removes these with --include-installers and --apply.\n'
  printf 'Path: %s\n' "$root"
  printf 'Types: dmg, pkg, mpkg, xip, ipsw, iso\n'
  printf 'Older than: %s days  Limit: %s\n\n' "$DAYS" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No old installer files found.\n'
    return 0
  fi
  printf '%-10s %-9s %-12s %s\n' "size" "age" "modified" "path"
  local kb epoch age_days path
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %-12s %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$(file_mtime_iso "${epoch:-0}")" "$path"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-installers --days %s\n' "$DAYS"
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-installers --days %s\n' "$DAYS"
}

node_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "$HOME/Documents"
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Downloads"
  fi
}

node_rows() {
  local now root path kb epoch age_days
  now="$(date '+%s')"
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        kb="$(size_kb "$path")"
        epoch="$(path_mtime_epoch "$path")"
        if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
          age_days=$(((now - epoch) / 86400))
        else
          age_days=0
        fi
        printf '%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path"
      done
  done < <(node_roots) | sort -rn | head -n "$LIMIT"
}

nodes() {
  local rows
  rows="$(node_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path kb_num
    while IFS=$'\t' read -r kb epoch age_days path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"age_days":%s,"preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "${age_days:-0}" \
        "$(printf 'cleanroom clean --include-node-stale --days %s' "$DAYS" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-node-stale --days %s' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom stale node_modules${RESET}"
  printf 'Review-only list. cleanroom only removes these with --include-node-stale and --apply.\n'
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf 'Path: %s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf 'Paths: ~/Documents, ~/Desktop, ~/Downloads\n'
  fi
  printf 'Older than: %s days  Limit: %s\n\n' "$DAYS" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No stale node_modules folders found.\n'
    return 0
  fi
  printf '%-10s %-9s %s\n' "size" "age" "path"
  local kb epoch age_days path
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$path"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-node-stale --days %s\n' "$DAYS"
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-node-stale --days %s\n' "$DAYS"
}

venv_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "$HOME/Documents"
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Downloads"
  fi
}

venv_rows() {
  local now root marker path kb epoch age_days
  now="$(date '+%s')"
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 9 -type f -name pyvenv.cfg -mtime +"$DAYS" -print0 2>/dev/null |
      while IFS= read -r -d '' marker; do
        path="$(dirname "$marker")"
        [[ -f "$path/pyvenv.cfg" ]] || continue
        kb="$(size_kb "$path")"
        epoch="$(path_mtime_epoch "$marker")"
        if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
          age_days=$(((now - epoch) / 86400))
        else
          age_days=0
        fi
        printf '%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path" "$marker"
      done
  done < <(venv_roots) | sort -rn | head -n "$LIMIT"
}

venvs() {
  local rows
  rows="$(venv_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path marker kb_num
    while IFS=$'\t' read -r kb epoch age_days path marker; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","marker":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"age_days":%s,"preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$marker" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "${age_days:-0}" \
        "$(printf 'cleanroom clean --include-venv-stale --days %s' "$DAYS" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-venv-stale --days %s' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom stale Python virtualenvs${RESET}"
  printf 'Review-only list. cleanroom only removes these with --include-venv-stale and --apply.\n'
  printf 'Only folders containing pyvenv.cfg are considered virtualenv cleanup candidates.\n'
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf 'Path: %s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf 'Paths: ~/Documents, ~/Desktop, ~/Downloads\n'
  fi
  printf 'Older than: %s days  Limit: %s\n\n' "$DAYS" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No stale Python virtualenv folders found.\n'
    return 0
  fi
  printf '%-10s %-9s %s\n' "size" "age" "path"
  local kb epoch age_days path marker
  while IFS=$'\t' read -r kb epoch age_days path marker; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$path"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-venv-stale --days %s\n' "$DAYS"
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-venv-stale --days %s\n' "$DAYS"
}

duplicate_candidates() {
  local root="$1"
  find "$root" -xdev -type f -size "+${MIN_MB}M" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      local hash kb
      hash="$(shasum -a 256 "$path" 2>/dev/null | awk '{print $1}' || true)"
      [[ -n "$hash" ]] || continue
      kb="$(size_kb "$path")"
      printf '%s\t%012d\t%s\n' "$hash" "$kb" "$path"
    done |
    sort -k1,1 -k2,2nr
}

duplicates_json_group() {
  local hash="$1"
  local size_kb="$2"
  shift 2
  local count="$#"
  [[ "$count" -gt 1 ]] || return 0
  local reclaim_kb
  reclaim_kb=$((size_kb * (count - 1)))
  printf '{"hash":"%s","size_kb":%s,"size":"%s","count":%s,"potential_reclaim_kb":%s,"potential_reclaim":"%s","paths":[' \
    "$(printf '%s' "$hash" | json_escape)" \
    "$size_kb" \
    "$(human_kb "$size_kb" | json_escape)" \
    "$count" \
    "$reclaim_kb" \
    "$(human_kb "$reclaim_kb" | json_escape)"
  local first=1 path
  for path in "$@"; do
    [[ "$first" -eq 0 ]] && printf ','
    first=0
    printf '"%s"' "$(printf '%s' "$path" | json_escape)"
  done
  printf ']}'
}

duplicates_text_group() {
  local hash="$1"
  local size_kb="$2"
  shift 2
  local count="$#"
  [[ "$count" -gt 1 ]] || return 0
  local reclaim_kb path
  reclaim_kb=$((size_kb * (count - 1)))
  printf 'duplicate group  count=%s  each=%s  potential reclaim=%s\n' "$count" "$(human_kb "$size_kb")" "$(human_kb "$reclaim_kb")"
  printf '  hash: %s\n' "$hash"
  for path in "$@"; do
    printf '  %s\n' "$path"
  done
  printf '\n'
}

duplicates() {
  local root
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    root="$(expand_path "${PATH_ARGS[0]}")"
  else
    root="$HOME"
  fi
  [[ -e "$root" ]] || die "duplicates path not found: $root"
  command -v shasum >/dev/null 2>&1 || die "duplicates requires shasum"

  local rows_file
  rows_file="$(mktemp)"
  duplicate_candidates "$root" >"$rows_file"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
  else
    printf '%s\n' "${BOLD}cleanroom duplicate files${RESET}"
    printf 'Review-only list. cleanroom does not delete duplicate files.\n'
    printf 'Path: %s\n' "$root"
    printf 'Minimum: %sMB  Limit: %s groups\n\n' "$MIN_MB" "$LIMIT"
  fi

  local current_hash="" current_size=0 hash kb path emitted=0 json_first=1
  local group_paths=()

  flush_duplicate_group() {
    [[ -n "$current_hash" ]] || return 0
    [[ "${#group_paths[@]}" -gt 1 ]] || return 0
    [[ "$emitted" -lt "$LIMIT" ]] || return 0
    if [[ "$JSON" -eq 1 ]]; then
      [[ "$json_first" -eq 0 ]] && printf ','
      json_first=0
      duplicates_json_group "$current_hash" "$current_size" "${group_paths[@]}"
    else
      duplicates_text_group "$current_hash" "$current_size" "${group_paths[@]}"
    fi
    emitted=$((emitted + 1))
  }

  while IFS=$'\t' read -r hash kb path; do
    [[ -z "${hash:-}" || -z "${path:-}" ]] && continue
    if [[ -n "$current_hash" && "$hash" != "$current_hash" ]]; then
      flush_duplicate_group
      group_paths=()
    fi
    current_hash="$hash"
    current_size="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
    group_paths+=("$path")
  done <"$rows_file"
  flush_duplicate_group

  rm -f "$rows_file"
  if [[ "$JSON" -eq 1 ]]; then
    printf ']\n'
  elif [[ "$emitted" -eq 0 ]]; then
    printf 'No exact duplicates found over %sMB.\n' "$MIN_MB"
  fi
}

app_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "/Applications"
    printf '%s\n' "$HOME/Applications"
  fi
}

app_rows() {
  local root="$1"
  [[ -d "$root" ]] || return 0
  find "$root" -maxdepth 2 -type d -name '*.app' -prune -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\t%s\n' "$(size_kb "$path")" "$(basename "$path" .app)" "$path"
    done
}

apps() {
  local rows
  rows="$(
    while IFS= read -r root; do
      app_rows "$root"
    done < <(app_roots) | sort -rn | head -n "$LIMIT"
  )"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb kb_num name path
    while IFS=$'\t' read -r kb name path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom app bundles${RESET}"
  printf 'Review-only list. cleanroom does not uninstall apps.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No app bundles found.\n'
    return 0
  fi
  local kb name path
  while IFS=$'\t' read -r kb name path; do
    [[ -z "${path:-}" ]] && continue
    printf '%8s  %s\n  %s\n' "$(human_kb "$kb")" "$name" "$path"
  done <<<"$rows"
}

appreview_app_rows() {
  local root
  for root in "/Applications" "$HOME/Applications"; do
    app_rows "$root"
  done |
    while IFS=$'\t' read -r kb name path; do
      [[ -z "${path:-}" ]] && continue
      leftover_match_query "$name $path" >/dev/null || continue
      printf '%s\t%s\t%s\n' "$kb" "$name" "$path"
    done |
    sort -rn |
    head -n "$LIMIT"
}

uninstaller_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    local path
    for path in "${PATH_ARGS[@]}"; do
      printf '%s\t%s\n' "custom" "$(expand_path "$path")"
    done
  else
    printf '%s\t%s\n' "applications" "/Applications"
    printf '%s\t%s\n' "user-applications" "$HOME/Applications"
    printf '%s\t%s\n' "utilities" "/Applications/Utilities"
    printf '%s\t%s\n' "app-support" "$HOME/Library/Application Support"
    printf '%s\t%s\n' "local-app-support" "/Library/Application Support"
  fi
}

uninstaller_kind() {
  local path="$1" base
  base="$(basename "$path")"
  if [[ -d "$path" && "$base" == *.app ]]; then
    printf 'app'
  elif [[ -f "$path" && "$base" == *.pkg ]]; then
    printf 'pkg'
  elif [[ -f "$path" && "$base" == *.command ]]; then
    printf 'command'
  elif [[ -f "$path" && "$base" == *.tool ]]; then
    printf 'tool'
  elif [[ -f "$path" && "$base" == *.sh ]]; then
    printf 'script'
  else
    printf 'file'
  fi
}

uninstaller_open_command() {
  local path="$1" kind="$2"
  case "$kind" in
    app|pkg) printf 'open %s' "$(shell_quote "$path")" ;;
    *) printf 'open -R %s' "$(shell_quote "$path")" ;;
  esac
}

uninstaller_rows() {
  local root_id root path kb epoch kind name
  while IFS=$'\t' read -r root_id root; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      name="$(basename "$path")"
      kind="$(uninstaller_kind "$path")"
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      printf '%012d\t%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$kind" "$root_id" "$name" "$path"
    done < <(find "$root" -maxdepth 6 \( -type d -name '*.app' -o -type f \) \( -iname '*uninstall*' -o -iname '*uninstaller*' -o -iname '*remove*' \) -print0 2>/dev/null)
  done < <(uninstaller_roots) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

appreview_uninstaller_rows() {
  local root_id root path kb epoch kind name
  while IFS=$'\t' read -r root_id root; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      name="$(basename "$path")"
      leftover_match_query "$name $path" >/dev/null || continue
      kind="$(uninstaller_kind "$path")"
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      printf '%012d\t%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$kind" "$root_id" "$name" "$path"
    done < <(find "$root" -maxdepth 6 \( -type d -name '*.app' -o -type f \) \( -iname '*uninstall*' -o -iname '*uninstaller*' -o -iname '*remove*' \) -print0 2>/dev/null)
  done < <(
    printf '%s\t%s\n' "applications" "/Applications"
    printf '%s\t%s\n' "user-applications" "$HOME/Applications"
    printf '%s\t%s\n' "utilities" "/Applications/Utilities"
    printf '%s\t%s\n' "app-support" "$HOME/Library/Application Support"
    printf '%s\t%s\n' "local-app-support" "/Library/Application Support"
  ) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

uninstallers() {
  local rows
  rows="$(uninstaller_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch kind root_id name path kb_num epoch_num launch guidance
    while IFS=$'\t' read -r kb epoch kind root_id name path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      launch="$(uninstaller_open_command "$path" "$kind")"
      guidance="Use vendor uninstallers before cleaning leftovers. cleanroom only inventories these tools."
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","kind":"%s","root":"%s","path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","launch_command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$kind" | json_escape)" \
        "$(printf '%s' "$root_id" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf '%s' "$launch" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom vendor uninstallers${RESET}"
  printf 'Review-only inventory. cleanroom does not run, unload, disable, or remove uninstallers.\n'
  printf 'Use official/vendor uninstallers before cleaning app leftovers manually.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No matching uninstallers found in readable search folders.\n'
    return 0
  fi
  printf '%-10s %-9s %-12s %-18s %s\n' "size" "kind" "modified" "root" "name"
  local kb epoch kind root_id name path epoch_num
  while IFS=$'\t' read -r kb epoch kind root_id name path; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    printf '%-10s %-9s %-12s %-18s %s\n' "$(human_kb "$kb")" "$kind" "$(file_mtime_iso "${epoch_num:-0}")" "$root_id" "$name"
    printf '  path: %s\n' "$path"
    printf '  launch: %s\n' "$(uninstaller_open_command "$path" "$kind")"
  done <<<"$rows"
}

browser_specs() {
  printf '%s\t%s\t%s\t%s\n' "chrome" "Google Chrome" "~/Library/Application Support/Google/Chrome" "Chromium profile is protected; only nested cache folders are cleanup candidates."
  printf '%s\t%s\t%s\t%s\n' "brave" "Brave" "~/Library/Application Support/BraveSoftware/Brave-Browser" "Chromium profile is protected; only nested cache folders are cleanup candidates."
  printf '%s\t%s\t%s\t%s\n' "edge" "Microsoft Edge" "~/Library/Application Support/Microsoft Edge" "Chromium profile is protected; only nested cache folders are cleanup candidates."
  printf '%s\t%s\t%s\t%s\n' "arc" "Arc" "~/Library/Application Support/Arc" "Arc profile is protected; only nested cache folders are cleanup candidates."
  printf '%s\t%s\t%s\t%s\n' "firefox" "Firefox" "~/Library/Application Support/Firefox" "Firefox profile is protected; cache data lives mostly under ~/Library/Caches and default safe cleanup handles it."
  printf '%s\t%s\t%s\t%s\n' "safari" "Safari" "~/Library/Safari" "Safari profile is protected; cache data lives mostly under ~/Library/Caches and default safe cleanup handles it."
}

browser_cache_kb() {
  local id="$1"
  local profile="$2"
  case "$id" in
    firefox)
      sum_existing_kb "~/Library/Caches/Firefox" "~/Library/Caches/org.mozilla.firefox"
      ;;
    safari)
      sum_existing_kb "~/Library/Caches/com.apple.Safari" "~/Library/Caches/Safari" "~/Library/Containers/com.apple.Safari/Data/Library/Caches"
      ;;
    *)
      cache_dir_kb_under "$profile"
      ;;
  esac
}

browser_preview_command() {
  case "$1" in
    safari) printf 'cleanroom webcaches' ;;
    *) printf 'cleanroom browsercaches' ;;
  esac
}

browser_apply_command() {
  case "$1" in
    safari) printf 'cleanroom clean --apply --trash --include-web-caches' ;;
    *) printf 'cleanroom clean --apply --trash --include-browser-caches' ;;
  esac
}

browser_rows() {
  local id name profile_template notes profile profile_kb cache_kb protected_reason protected
  while IFS=$'\t' read -r id name profile_template notes; do
    [[ -z "${id:-}" ]] && continue
    profile="$(expand_path "$profile_template")"
    profile_kb="$(size_kb "$profile")"
    cache_kb="$(browser_cache_kb "$id" "$profile")"
    protected_reason="$(protected_removal_reason "$profile" || true)"
    if [[ -n "$protected_reason" ]]; then
      protected=true
    else
      protected=false
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$cache_kb" "$profile_kb" "$id" "$name" "$profile" "$protected" "$notes" "$protected_reason"
  done < <(browser_specs) | sort -rn
}

browsers() {
  local rows
  rows="$(browser_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 cache_kb profile_kb id name profile protected notes protected_reason
    while IFS=$'\t' read -r cache_kb profile_kb id name profile protected notes protected_reason; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","name":"%s","profile_path":"%s","profile_present":%s,"profile_size_kb":%s,"profile_size":"%s","cache_size_kb":%s,"cache_size":"%s","protected":%s,"preview_command":"%s","apply_command":"%s","notes":"%s","protected_reason":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$profile" | json_escape)" \
        "$(if [[ -e "$profile" ]]; then echo true; else echo false; fi)" \
        "${profile_kb:-0}" \
        "$(human_kb "${profile_kb:-0}" | json_escape)" \
        "${cache_kb:-0}" \
        "$(human_kb "${cache_kb:-0}" | json_escape)" \
        "$protected" \
        "$(browser_preview_command "$id" | json_escape)" \
        "$(browser_apply_command "$id" | json_escape)" \
        "$(printf '%s' "$notes" | json_escape)" \
        "$(printf '%s' "$protected_reason" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom browser storage${RESET}"
  printf 'Review-only inventory. Browser profiles, passwords, cookies, bookmarks, sessions, and settings stay protected.\n\n'
  printf '%-10s %-10s %-10s %-18s %s\n' "cache" "profile" "protected" "browser" "profile path"
  local cache_kb profile_kb id name profile protected notes protected_reason
  while IFS=$'\t' read -r cache_kb profile_kb id name profile protected notes protected_reason; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-10s %-10s %-18s %s\n' "$(human_kb "${cache_kb:-0}")" "$(human_kb "${profile_kb:-0}")" "$protected" "$name" "$profile"
    printf '  %s\n' "$notes"
    [[ -n "$protected_reason" ]] && printf '  protected: %s\n' "$protected_reason"
    printf '  preview: %s\n' "$(browser_preview_command "$id")"
    printf '  apply: %s\n' "$(browser_apply_command "$id")"
  done <<<"$rows"
}

appdata_roots() {
  printf '%s\t%s\n' "app-support" "~/Library/Application Support"
  printf '%s\t%s\n' "containers" "~/Library/Containers"
  printf '%s\t%s\n' "group-containers" "~/Library/Group Containers"
  printf '%s\t%s\n' "http-storages" "~/Library/HTTPStorages"
  printf '%s\t%s\n' "saved-state" "~/Library/Saved Application State"
  printf '%s\t%s\n' "webkit" "~/Library/WebKit"
  printf '%s\t%s\n' "local-app-support" "/Library/Application Support"
}

appdata_rows() {
  local category root_template root path kb
  while IFS=$'\t' read -r category root_template; do
    root="$(expand_path "$root_template")"
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      kb="$(size_kb "$path")"
      printf '%012d\t%s\t%s\n' "$kb" "$category" "$path"
    done < <(find "$root" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
  done < <(appdata_roots) | sort -rn | head -n "$LIMIT"
  true
}

appdata() {
  local rows
  rows="$(appdata_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb category path kb_num status reason line
    while IFS=$'\t' read -r kb category path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      line="$(guard_status "$path")"
      status="${line%%$'\t'*}"
      reason="${line#*$'\t'}"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","name":"%s","category":"%s","size_kb":%s,"size":"%s","status":"%s","reason":"%s","preview_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(basename "$path" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$reason" | json_escape)" \
        "$(printf 'cleanroom leftovers %s' "$(basename "$path")" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom app data folders${RESET}"
  printf 'Review-only inventory. cleanroom does not remove broad app data folders from this command.\n\n'
  if [[ -z "$rows" ]]; then
    printf 'No app data folders found.\n'
    return 0
  fi
  printf '%-10s %-18s %-18s %s\n' "size" "category" "status" "path"
  local kb category path status reason line
  while IFS=$'\t' read -r kb category path; do
    [[ -z "${path:-}" ]] && continue
    line="$(guard_status "$path")"
    status="${line%%$'\t'*}"
    reason="${line#*$'\t'}"
    printf '%-10s %-18s %-18s %s\n' "$(human_kb "$kb")" "$category" "$status" "$path"
    printf '  %s\n' "$reason"
    printf '  inspect: cleanroom leftovers %s\n' "$(basename "$path")"
  done <<<"$rows"
}

lower_text() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

leftover_match_query() {
  local haystack query query_lower
  haystack="$(lower_text "$1")"
  for query in "${PATH_ARGS[@]}"; do
    query_lower="$(lower_text "$query")"
    [[ -z "$query_lower" ]] && continue
    if [[ "$haystack" == *"$query_lower"* ]]; then
      printf '%s\n' "$query"
      return 0
    fi
  done
  return 1
}

leftover_roots() {
  printf '%s\t%s\t%s\n' "app-support" "~/Library/Application Support" "3"
  printf '%s\t%s\t%s\n' "caches" "~/Library/Caches" "3"
  printf '%s\t%s\t%s\n' "preferences" "~/Library/Preferences" "1"
  printf '%s\t%s\t%s\n' "saved-state" "~/Library/Saved Application State" "1"
  printf '%s\t%s\t%s\n' "containers" "~/Library/Containers" "1"
  printf '%s\t%s\t%s\n' "group-containers" "~/Library/Group Containers" "1"
  printf '%s\t%s\t%s\n' "http-storages" "~/Library/HTTPStorages" "1"
  printf '%s\t%s\t%s\n' "webkit" "~/Library/WebKit" "2"
  printf '%s\t%s\t%s\n' "logs" "~/Library/Logs" "2"
  printf '%s\t%s\t%s\n' "launch-agents" "~/Library/LaunchAgents" "1"
  printf '%s\t%s\t%s\n' "local-launch-agents" "/Library/LaunchAgents" "1"
  printf '%s\t%s\t%s\n' "local-launch-daemons" "/Library/LaunchDaemons" "1"
  printf '%s\t%s\t%s\n' "local-app-support" "/Library/Application Support" "2"
}

leftover_rows() {
  [[ "${#PATH_ARGS[@]}" -gt 0 ]] || die "leftovers requires at least one search term"
  local category root_template depth root path matched kb slash_count path_depth
  while IFS=$'\t' read -r category root_template depth; do
    root="$(expand_path "$root_template")"
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      matched="$(leftover_match_query "$path" || true)"
      [[ -n "$matched" ]] || continue
      kb="$(size_kb "$path")"
      slash_count="${path//[!\/]/}"
      path_depth="${#slash_count}"
      printf '%012d\t%06d\t%s\t%s\t%s\n' "$kb" "$path_depth" "$category" "$matched" "$path"
    done < <(find "$root" -mindepth 1 -maxdepth "$depth" \( -type d -o -type f \) -print0 2>/dev/null)
  done < <(leftover_roots) | sort -t $'\t' -k1,1rn -k2,2n | head -n "$LIMIT" | cut -f1,3-
}

json_queries_array() {
  local first=1 query
  printf '['
  for query in "${PATH_ARGS[@]}"; do
    [[ -z "$query" ]] && continue
    [[ "$first" -eq 0 ]] && printf ','
    first=0
    printf '"%s"' "$(printf '%s' "$query" | json_escape)"
  done
  printf ']'
}

leftovers() {
  local rows
  rows="$(leftover_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"queries":'
    json_queries_array
    printf ',"items":['
    local first=1 kb category matched path kb_num status reason line
    while IFS=$'\t' read -r kb category matched path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      line="$(guard_status "$path")"
      status="${line%%$'\t'*}"
      reason="${line#*$'\t'}"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","category":"%s","matched_query":"%s","size_kb":%s,"size":"%s","status":"%s","reason":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$matched" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$reason" | json_escape)" \
        "$(leftover_command "cleanroom leftovers" | json_escape)" \
        "$(leftover_command "cleanroom leftovers --apply --trash" | json_escape)"
    done <<<"$rows"
    printf ']}\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom app leftovers${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$TRASH" -eq 1 ]] || die "leftovers apply requires --trash so matches can be restored from the apply log."
    warn "Apply mode enabled for app leftovers."
    warn "Trash mode required and enabled; matches move to ~/.Trash/cleanroom-$RUN_ID."
    warn "Protected browser profiles, Keychains, backups, Photos, Mail, and broad Library folders are still refused."
    [[ "$ASSUME_YES" -eq 1 ]] || {
      printf 'Continue? Type "leftovers" to proceed: '
      local answer
      read -r answer
      [[ "$answer" == "leftovers" ]] || die "Cancelled."
    }
    ensure_apply_log
    warn "Apply log: $LOG_FILE"
  else
    printf 'Preview search. Pass --apply --trash to move matches to a recoverable Trash folder.\n'
  fi
  printf 'Queries: %s  Limit: %s\n\n' "${PATH_ARGS[*]}" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No matching leftovers found.\n'
    return 0
  fi
  printf '%-10s %-20s %-16s %s\n' "size" "category" "matched" "path"
  local kb category matched path removed refused skipped status_line status reason selected skip_nested
  local applied_leftover_roots=""
  removed=0
  refused=0
  skipped=0
  while IFS=$'\t' read -r kb category matched path; do
    [[ -z "${path:-}" ]] && continue
    if [[ "$APPLY" -eq 1 ]]; then
      if [[ ! -e "$path" ]]; then
        skipped=$((skipped + 1))
        continue
      fi
      skip_nested=0
      if [[ -n "$applied_leftover_roots" ]]; then
        while IFS= read -r selected; do
          [[ -z "$selected" ]] && continue
          if [[ "$path" == "$selected/"* ]]; then
            skip_nested=1
            break
          fi
        done <<<"$applied_leftover_roots"
      fi
      if [[ "$skip_nested" -eq 1 ]]; then
        skipped=$((skipped + 1))
        continue
      fi
      status_line="$(guard_status "$path")"
      status="${status_line%%$'\t'*}"
      reason="${status_line#*$'\t'}"
      if [[ "$status" != "allowed" ]]; then
        refused=$((refused + 1))
        warn "refusing leftover: $path ($status: $reason)"
        record_apply "leftover" "$status" "$kb" "$path" ""
        continue
      fi
      if is_excluded "$path"; then
        skipped=$((skipped + 1))
        [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded leftover: $path"
        continue
      fi
      printf '%-10s %-20s %-16s %s\n' "$(human_kb "$kb")" "$category" "$matched" "$path"
      delete_path "$path"
      applied_leftover_roots="${applied_leftover_roots}${path}"$'\n'
      removed=$((removed + 1))
    else
      printf '%-10s %-20s %-16s %s\n' "$(human_kb "$kb")" "$category" "$matched" "$path"
    fi
  done <<<"$rows"
  if [[ "$APPLY" -eq 1 ]]; then
    printf '\nleftovers summary: moved=%s refused=%s skipped=%s\n' "$removed" "$refused" "$skipped"
    printf 'Restore with: cleanroom restore --log %s --apply\n' "$(shell_quote "$LOG_FILE")"
  else
    printf '\nPreview command: %s\n' "$(leftover_command "cleanroom leftovers")"
    printf 'Recoverable cleanup: %s\n' "$(leftover_command "cleanroom leftovers --apply --trash")"
    printf 'Vendor uninstallers or app settings may still be required for complete removal.\n'
  fi
}

appreview_receipt_rows() {
  local root_id root_template root path kind name id kb epoch
  while IFS=$'\t' read -r root_id root_template; do
    root="$(expand_path "$root_template")"
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      name="$(basename "$path")"
      kind="${name##*.}"
      [[ "$kind" == "plist" || "$kind" == "bom" ]] || continue
      id="${name%.$kind}"
      leftover_match_query "$id $path" >/dev/null || continue
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      printf '%012d\t%012d\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$id" "$kind" "$root_id" "$path"
    done < <(find "$root" -maxdepth 1 -type f \( -name '*.plist' -o -name '*.bom' \) -print0 2>/dev/null)
  done < <(receipt_roots) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

appreview() {
  [[ "${#PATH_ARGS[@]}" -gt 0 ]] || die "appreview requires at least one app or vendor search term"

  local app_rows_value uninstaller_rows_value leftover_rows_value receipt_rows_value
  app_rows_value="$(appreview_app_rows)"
  uninstaller_rows_value="$(appreview_uninstaller_rows)"
  leftover_rows_value="$(leftover_rows)"
  receipt_rows_value="$(appreview_receipt_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"queries":'
    json_queries_array
    printf ',"apps":['
    local first=1 kb name path kb_num
    while IFS=$'\t' read -r kb name path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$app_rows_value"
    printf '],"uninstallers":['
    first=1
    local u_kb u_epoch u_kind u_root u_name u_path u_kb_num u_epoch_num
    while IFS=$'\t' read -r u_kb u_epoch u_kind u_root u_name u_path; do
      [[ -z "${u_path:-}" ]] && continue
      u_kb_num="$(printf '%s\n' "$u_kb" | sed 's/^0*//; s/^$/0/')"
      u_epoch_num="$(printf '%s\n' "${u_epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","kind":"%s","root":"%s","path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","launch_command":"%s"}' \
        "$(printf '%s' "$u_name" | json_escape)" \
        "$(printf '%s' "$u_kind" | json_escape)" \
        "$(printf '%s' "$u_root" | json_escape)" \
        "$(printf '%s' "$u_path" | json_escape)" \
        "$u_kb_num" \
        "$(human_kb "${u_kb:-0}" | json_escape)" \
        "${u_epoch_num:-0}" \
        "$(file_mtime_iso "${u_epoch_num:-0}" | json_escape)" \
        "$(uninstaller_open_command "$u_path" "$u_kind" | json_escape)"
    done <<<"$uninstaller_rows_value"
    printf '],"receipts":['
    first=1
    local r_kb r_epoch r_id r_kind r_root r_path r_kb_num r_epoch_num
    while IFS=$'\t' read -r r_kb r_epoch r_id r_kind r_root r_path; do
      [[ -z "${r_path:-}" ]] && continue
      r_kb_num="$(printf '%s\n' "$r_kb" | sed 's/^0*//; s/^$/0/')"
      r_epoch_num="$(printf '%s\n' "${r_epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","kind":"%s","root":"%s","path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","review_command":"%s"}' \
        "$(printf '%s' "$r_id" | json_escape)" \
        "$(printf '%s' "$r_kind" | json_escape)" \
        "$(printf '%s' "$r_root" | json_escape)" \
        "$(printf '%s' "$r_path" | json_escape)" \
        "$r_kb_num" \
        "$(human_kb "${r_kb:-0}" | json_escape)" \
        "${r_epoch_num:-0}" \
        "$(file_mtime_iso "${r_epoch_num:-0}" | json_escape)" \
        "$(printf 'cleanroom leftovers %s' "$(shell_quote "$r_id")" | json_escape)"
    done <<<"$receipt_rows_value"
    printf '],"leftovers":['
    first=1
    local l_kb l_category l_matched l_path l_kb_num l_status l_reason l_line
    while IFS=$'\t' read -r l_kb l_category l_matched l_path; do
      [[ -z "${l_path:-}" ]] && continue
      l_kb_num="$(printf '%s\n' "$l_kb" | sed 's/^0*//; s/^$/0/')"
      l_line="$(guard_status "$l_path")"
      l_status="${l_line%%$'\t'*}"
      l_reason="${l_line#*$'\t'}"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","category":"%s","matched_query":"%s","size_kb":%s,"size":"%s","status":"%s","reason":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$l_path" | json_escape)" \
        "$(printf '%s' "$l_category" | json_escape)" \
        "$(printf '%s' "$l_matched" | json_escape)" \
        "$l_kb_num" \
        "$(human_kb "${l_kb:-0}" | json_escape)" \
        "$(printf '%s' "$l_status" | json_escape)" \
        "$(printf '%s' "$l_reason" | json_escape)" \
        "$(leftover_command "cleanroom leftovers" | json_escape)" \
        "$(leftover_command "cleanroom leftovers --apply --trash" | json_escape)"
    done <<<"$leftover_rows_value"
    printf '],"guidance":"%s"}\n' "$(printf '%s' "Run vendor uninstallers first, then review leftovers. appreview never deletes anything." | json_escape)"
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom app removal review${RESET}"
  printf 'Review-only workflow. appreview does not uninstall apps, run tools, unload services, or delete leftovers.\n'
  printf 'Queries: %s  Limit: %s\n\n' "${PATH_ARGS[*]}" "$LIMIT"

  printf '%s\n' "${BOLD}App Bundles${RESET}"
  if [[ -z "$app_rows_value" ]]; then
    printf 'No matching app bundles found.\n'
  else
    local a_kb a_name a_path
    while IFS=$'\t' read -r a_kb a_name a_path; do
      [[ -z "${a_path:-}" ]] && continue
      printf '%8s  %s\n  %s\n' "$(human_kb "$a_kb")" "$a_name" "$a_path"
    done <<<"$app_rows_value"
  fi

  printf '\n%s\n' "${BOLD}Vendor Uninstallers${RESET}"
  if [[ -z "$uninstaller_rows_value" ]]; then
    printf 'No matching vendor uninstallers found.\n'
  else
    local u_kb u_epoch u_kind u_root u_name u_path u_epoch_num
    while IFS=$'\t' read -r u_kb u_epoch u_kind u_root u_name u_path; do
      [[ -z "${u_path:-}" ]] && continue
      u_epoch_num="$(printf '%s\n' "${u_epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      printf '%8s  %s  %s\n  %s\n  launch: %s\n' "$(human_kb "$u_kb")" "$(file_mtime_iso "${u_epoch_num:-0}")" "$u_name" "$u_path" "$(uninstaller_open_command "$u_path" "$u_kind")"
    done <<<"$uninstaller_rows_value"
  fi

  printf '\n%s\n' "${BOLD}Package Receipts${RESET}"
  if [[ -z "$receipt_rows_value" ]]; then
    printf 'No matching package receipts found.\n'
  else
    local r_kb r_epoch r_id r_kind r_root r_path r_epoch_num
    while IFS=$'\t' read -r r_kb r_epoch r_id r_kind r_root r_path; do
      [[ -z "${r_path:-}" ]] && continue
      r_epoch_num="$(printf '%s\n' "${r_epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      printf '%8s  %s  %s (%s)\n  %s\n' "$(human_kb "$r_kb")" "$(file_mtime_iso "${r_epoch_num:-0}")" "$r_id" "$r_kind" "$r_path"
    done <<<"$receipt_rows_value"
  fi

  printf '\n%s\n' "${BOLD}Leftover Candidates${RESET}"
  if [[ -z "$leftover_rows_value" ]]; then
    printf 'No matching leftovers found.\n'
  else
    local l_kb l_category l_matched l_path l_status l_reason l_line
    while IFS=$'\t' read -r l_kb l_category l_matched l_path; do
      [[ -z "${l_path:-}" ]] && continue
      l_line="$(guard_status "$l_path")"
      l_status="${l_line%%$'\t'*}"
      l_reason="${l_line#*$'\t'}"
      printf '%8s  %-16s %-18s %s\n' "$(human_kb "$l_kb")" "$l_category" "$l_status" "$l_path"
      printf '  %s\n' "$l_reason"
    done <<<"$leftover_rows_value"
  fi
  printf '\nNext step: run vendor uninstallers first if present, then use `cleanroom leftovers %s` for focused review.\n' "$(printf '%s' "${PATH_ARGS[*]}" | sed 's/ /\\ /g')"
}

