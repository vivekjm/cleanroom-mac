clean_containers() {
  [[ "$INCLUDE_CONTAINERS" -eq 1 ]] || return 0
  log "${BOLD}Container VM disks${RESET}"
  run_rm "~/.colima"
  run_rm "~/.lima"
  run_rm "~/Library/Containers/com.docker.docker/Data/vms"
}

clean_node_stale() {
  [[ "$INCLUDE_NODE_STALE" -eq 1 ]] || return 0
  log "${BOLD}Stale node_modules older than ${DAYS} days${RESET}"
  local roots=("$HOME/Documents" "$HOME/Desktop" "$HOME/Downloads")
  local root
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print 2>/dev/null |
      while IFS= read -r path; do
        run_rm "$path"
      done
  done
  return 0
}

clean_installers() {
  [[ "$INCLUDE_INSTALLERS" -eq 1 ]] || return 0
  log "${BOLD}Old downloaded installers older than ${DAYS} days${RESET}"
  local path
  if [[ "$APPLY" -eq 1 ]]; then
    installer_find_expr |
      while IFS= read -r -d '' path; do
        run_rm "$path"
      done || true
  else
    installer_rows |
      while IFS=$'\t' read -r kb epoch age_days path; do
        [[ -z "${path:-}" ]] && continue
        printf 'would remove %8s  %s\n' "$(human_kb "$kb")" "$path"
      done
  fi
}

clean_user_trash() {
  [[ "$INCLUDE_USER_TRASH" -eq 1 ]] || return 0
  log "${BOLD}User Trash${RESET}"
  local dir="$HOME/.Trash"
  [[ -d "$dir" ]] || return 0
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$TRASH" -eq 1 ]] && warn "--trash is ignored for --include-user-trash because items are already in Trash."
    find "$dir" -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        delete_user_trash_child "$path"
      done || true
  else
    print_size "~/.Trash"
  fi
}

scan() {
  local paths=()
  local candidate
  while IFS= read -r candidate; do paths+=("$candidate"); done < <(candidate_paths)
  if [[ "$JSON" -eq 1 ]]; then
    printf '{'
    disk_json
    printf ',"candidates":['
    local first=1
    local path expanded kb
    for path in "${paths[@]}"; do
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$path")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s}' "$(printf '%s' "$expanded" | json_escape)" "$kb"
    done
    printf ']}'
    printf '\n'
    return 0
  fi

  log "${BOLD}Disk${RESET}"
  disk_line
  printf '\n%s\n' "${BOLD}Common cleanup candidates${RESET}"
  local path
  for path in "${paths[@]}"; do print_size "$path"; done

  printf '\n%s\n' "${BOLD}Largest home folders${RESET}"
  du -x -d 1 -h "$HOME" 2>/dev/null | sort -h | tail -25 || true

  printf '\n%s\n' "${BOLD}Largest user files over 500MB${RESET}"
  find "$HOME" -xdev -type f -size +500M -print0 2>/dev/null |
    xargs -0 du -h 2>/dev/null | sort -h | tail -30 || true
}

large_rows() {
  local root="$1"
  find "$root" -xdev -type f -size "+${MIN_MB}M" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\n' "$(size_kb "$path")" "$path"
    done |
    sort -rn |
    head -n "$LIMIT" || true
}

large() {
  local root
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    root="$(expand_path "${PATH_ARGS[0]}")"
  else
    root="$HOME"
  fi
  [[ -e "$root" ]] || die "large path not found: $root"

  local rows
  rows="$(large_rows "$root")"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb kb_num path
    while IFS=$'\t' read -r kb path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom large files${RESET}"
  printf 'Review-only list. cleanroom does not delete these files.\n'
  printf 'Path: %s\n' "$root"
  printf 'Minimum: %sMB  Limit: %s\n\n' "$MIN_MB" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No files found over %sMB.\n' "$MIN_MB"
    return 0
  fi
  local kb path
  while IFS=$'\t' read -r kb path; do
    [[ -z "${path:-}" ]] && continue
    printf '%8s  %s\n' "$(human_kb "$kb")" "$path"
  done <<<"$rows"
}

file_mtime_iso() {
  local epoch="$1"
  if [[ "$epoch" =~ ^[0-9]+$ && "$epoch" -gt 0 ]]; then
    date -r "$epoch" '+%Y-%m-%d' 2>/dev/null || printf 'unknown'
  else
    printf 'unknown'
  fi
}

path_mtime_epoch() {
  local path="$1" epoch
  epoch="$(stat -f '%m' "$path" 2>/dev/null || stat -c '%Y' "$path" 2>/dev/null || true)"
  [[ "$epoch" =~ ^[0-9]+$ ]] || epoch=0
  printf '%s\n' "$epoch"
}

downloads_rows() {
  local root="$HOME/Downloads"
  [[ -d "$root" ]] || return 0
  local now path kb epoch age_days
  now="$(date '+%s')"
  find "$root" -maxdepth 1 -type f -mtime +"$DAYS" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
        age_days=$(((now - epoch) / 86400))
      else
        age_days=0
      fi
      printf '%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path"
    done |
    sort -rn |
    head -n "$LIMIT" || true
}

downloads() {
  local rows root
  root="$HOME/Downloads"
  rows="$(downloads_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path kb_num
    while IFS=$'\t' read -r kb epoch age_days path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","age_days":%s}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "$(file_mtime_iso "${epoch:-0}" | json_escape)" \
        "${age_days:-0}"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom old Downloads${RESET}"
  printf 'Review-only list. cleanroom does not delete Downloads files.\n'
  printf 'Path: %s\n' "$root"
  printf 'Older than: %s days  Limit: %s\n\n' "$DAYS" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No old Downloads files found.\n'
    return 0
  fi
  printf '%-10s %-9s %-12s %s\n' "size" "age" "modified" "path"
  local kb epoch age_days path
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %-12s %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$(file_mtime_iso "${epoch:-0}")" "$path"
  done <<<"$rows"
  printf '\nReview these manually in Finder before deleting anything.\n'
}

installer_find_expr() {
  [[ -d "$HOME/Downloads" ]] || return 0
  find "$HOME/Downloads" -maxdepth 1 -type f -mtime +"$DAYS" \( \
    -iname '*.dmg' -o -iname '*.pkg' -o -iname '*.mpkg' -o -iname '*.xip' \
    -o -iname '*.ipsw' -o -iname '*.iso' \
  \) -print0 2>/dev/null
}

installer_rows() {
  local now path kb epoch age_days
  now="$(date '+%s')"
  installer_find_expr |
    while IFS= read -r -d '' path; do
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
        age_days=$(((now - epoch) / 86400))
      else
        age_days=0
      fi
      printf '%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path"
    done |
    sort -rn |
    head -n "$LIMIT"
}

installer_total_kb() {
  local total=0 kb epoch age_days path kb_num
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(installer_rows)
  printf '%s\n' "$total"
}

installers() {
  local rows root
  root="$HOME/Downloads"
  rows="$(installer_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path kb_num
    while IFS=$'\t' read -r kb epoch age_days path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","age_days":%s,"preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "$(file_mtime_iso "${epoch:-0}" | json_escape)" \
        "${age_days:-0}" \
        "$(printf 'cleanroom clean --include-installers --days %s' "$DAYS" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-installers --days %s' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom old installers${RESET}"
  printf 'Review-only list. cleanroom only removes these with --include-installers and --apply.\n'
  printf 'Path: %s\n' "$root"
  printf 'Types: dmg, pkg, mpkg, xip, ipsw, iso\n'
  printf 'Older than: %s days  Limit: %s\n\n' "$DAYS" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No old installer files found.\n'
    return 0
  fi
  printf '%-10s %-9s %-12s %s\n' "size" "age" "modified" "path"
  local kb epoch age_days path
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %-12s %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$(file_mtime_iso "${epoch:-0}")" "$path"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-installers --days %s\n' "$DAYS"
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-installers --days %s\n' "$DAYS"
}

node_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "$HOME/Documents"
    printf '%s\n' "$HOME/Desktop"
    printf '%s\n' "$HOME/Downloads"
  fi
}

node_rows() {
  local now root path kb epoch age_days
  now="$(date '+%s')"
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    find "$root" -maxdepth 8 -type d -name node_modules -mtime +"$DAYS" -prune -print0 2>/dev/null |
      while IFS= read -r -d '' path; do
        kb="$(size_kb "$path")"
        epoch="$(path_mtime_epoch "$path")"
        if [[ "$epoch" -gt 0 && "$now" -ge "$epoch" ]]; then
          age_days=$(((now - epoch) / 86400))
        else
          age_days=0
        fi
        printf '%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$age_days" "$path"
      done
  done < <(node_roots) | sort -rn | head -n "$LIMIT"
}

nodes() {
  local rows
  rows="$(node_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch age_days path kb_num
    while IFS=$'\t' read -r kb epoch age_days path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"age_days":%s,"preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "${age_days:-0}" \
        "$(printf 'cleanroom clean --include-node-stale --days %s' "$DAYS" | json_escape)" \
        "$(printf 'cleanroom clean --apply --trash --include-node-stale --days %s' "$DAYS" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom stale node_modules${RESET}"
  printf 'Review-only list. cleanroom only removes these with --include-node-stale and --apply.\n'
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf 'Path: %s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf 'Paths: ~/Documents, ~/Desktop, ~/Downloads\n'
  fi
  printf 'Older than: %s days  Limit: %s\n\n' "$DAYS" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No stale node_modules folders found.\n'
    return 0
  fi
  printf '%-10s %-9s %s\n' "size" "age" "path"
  local kb epoch age_days path
  while IFS=$'\t' read -r kb epoch age_days path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %4sd     %s\n' "$(human_kb "$kb")" "${age_days:-0}" "$path"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-node-stale --days %s\n' "$DAYS"
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-node-stale --days %s\n' "$DAYS"
}

duplicate_candidates() {
  local root="$1"
  find "$root" -xdev -type f -size "+${MIN_MB}M" -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      local hash kb
      hash="$(shasum -a 256 "$path" 2>/dev/null | awk '{print $1}' || true)"
      [[ -n "$hash" ]] || continue
      kb="$(size_kb "$path")"
      printf '%s\t%012d\t%s\n' "$hash" "$kb" "$path"
    done |
    sort -k1,1 -k2,2nr
}

duplicates_json_group() {
  local hash="$1"
  local size_kb="$2"
  shift 2
  local count="$#"
  [[ "$count" -gt 1 ]] || return 0
  local reclaim_kb
  reclaim_kb=$((size_kb * (count - 1)))
  printf '{"hash":"%s","size_kb":%s,"size":"%s","count":%s,"potential_reclaim_kb":%s,"potential_reclaim":"%s","paths":[' \
    "$(printf '%s' "$hash" | json_escape)" \
    "$size_kb" \
    "$(human_kb "$size_kb" | json_escape)" \
    "$count" \
    "$reclaim_kb" \
    "$(human_kb "$reclaim_kb" | json_escape)"
  local first=1 path
  for path in "$@"; do
    [[ "$first" -eq 0 ]] && printf ','
    first=0
    printf '"%s"' "$(printf '%s' "$path" | json_escape)"
  done
  printf ']}'
}

duplicates_text_group() {
  local hash="$1"
  local size_kb="$2"
  shift 2
  local count="$#"
  [[ "$count" -gt 1 ]] || return 0
  local reclaim_kb path
  reclaim_kb=$((size_kb * (count - 1)))
  printf 'duplicate group  count=%s  each=%s  potential reclaim=%s\n' "$count" "$(human_kb "$size_kb")" "$(human_kb "$reclaim_kb")"
  printf '  hash: %s\n' "$hash"
  for path in "$@"; do
    printf '  %s\n' "$path"
  done
  printf '\n'
}

duplicates() {
  local root
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    root="$(expand_path "${PATH_ARGS[0]}")"
  else
    root="$HOME"
  fi
  [[ -e "$root" ]] || die "duplicates path not found: $root"
  command -v shasum >/dev/null 2>&1 || die "duplicates requires shasum"

  local rows_file
  rows_file="$(mktemp)"
  duplicate_candidates "$root" >"$rows_file"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
  else
    printf '%s\n' "${BOLD}cleanroom duplicate files${RESET}"
    printf 'Review-only list. cleanroom does not delete duplicate files.\n'
    printf 'Path: %s\n' "$root"
    printf 'Minimum: %sMB  Limit: %s groups\n\n' "$MIN_MB" "$LIMIT"
  fi

  local current_hash="" current_size=0 hash kb path emitted=0 json_first=1
  local group_paths=()

  flush_duplicate_group() {
    [[ -n "$current_hash" ]] || return 0
    [[ "${#group_paths[@]}" -gt 1 ]] || return 0
    [[ "$emitted" -lt "$LIMIT" ]] || return 0
    if [[ "$JSON" -eq 1 ]]; then
      [[ "$json_first" -eq 0 ]] && printf ','
      json_first=0
      duplicates_json_group "$current_hash" "$current_size" "${group_paths[@]}"
    else
      duplicates_text_group "$current_hash" "$current_size" "${group_paths[@]}"
    fi
    emitted=$((emitted + 1))
  }

  while IFS=$'\t' read -r hash kb path; do
    [[ -z "${hash:-}" || -z "${path:-}" ]] && continue
    if [[ -n "$current_hash" && "$hash" != "$current_hash" ]]; then
      flush_duplicate_group
      group_paths=()
    fi
    current_hash="$hash"
    current_size="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
    group_paths+=("$path")
  done <"$rows_file"
  flush_duplicate_group

  rm -f "$rows_file"
  if [[ "$JSON" -eq 1 ]]; then
    printf ']\n'
  elif [[ "$emitted" -eq 0 ]]; then
    printf 'No exact duplicates found over %sMB.\n' "$MIN_MB"
  fi
}

app_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    printf '%s\n' "$(expand_path "${PATH_ARGS[0]}")"
  else
    printf '%s\n' "/Applications"
    printf '%s\n' "$HOME/Applications"
  fi
}

app_rows() {
  local root="$1"
  [[ -d "$root" ]] || return 0
  find "$root" -maxdepth 2 -type d -name '*.app' -prune -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\t%s\n' "$(size_kb "$path")" "$(basename "$path" .app)" "$path"
    done
}

apps() {
  local rows
  rows="$(
    while IFS= read -r root; do
      app_rows "$root"
    done < <(app_roots) | sort -rn | head -n "$LIMIT"
  )"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb kb_num name path
    while IFS=$'\t' read -r kb name path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"name":"%s","path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom app bundles${RESET}"
  printf 'Review-only list. cleanroom does not uninstall apps.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No app bundles found.\n'
    return 0
  fi
  local kb name path
  while IFS=$'\t' read -r kb name path; do
    [[ -z "${path:-}" ]] && continue
    printf '%8s  %s\n  %s\n' "$(human_kb "$kb")" "$name" "$path"
  done <<<"$rows"
}

browser_specs() {
  printf '%s\t%s\t%s\t%s\n' "chrome" "Google Chrome" "~/Library/Application Support/Google/Chrome" "Chromium profile is protected; only nested cache folders are cleanup candidates."
  printf '%s\t%s\t%s\t%s\n' "brave" "Brave" "~/Library/Application Support/BraveSoftware/Brave-Browser" "Chromium profile is protected; only nested cache folders are cleanup candidates."
  printf '%s\t%s\t%s\t%s\n' "edge" "Microsoft Edge" "~/Library/Application Support/Microsoft Edge" "Chromium profile is protected; only nested cache folders are cleanup candidates."
  printf '%s\t%s\t%s\t%s\n' "arc" "Arc" "~/Library/Application Support/Arc" "Arc profile is protected; only nested cache folders are cleanup candidates."
  printf '%s\t%s\t%s\t%s\n' "firefox" "Firefox" "~/Library/Application Support/Firefox" "Firefox profile is protected; cache data lives mostly under ~/Library/Caches and default safe cleanup handles it."
  printf '%s\t%s\t%s\t%s\n' "safari" "Safari" "~/Library/Safari" "Safari profile is protected; cache data lives mostly under ~/Library/Caches and default safe cleanup handles it."
}

browser_cache_kb() {
  local id="$1"
  local profile="$2"
  case "$id" in
    firefox)
      sum_existing_kb "~/Library/Caches/Firefox" "~/Library/Caches/org.mozilla.firefox"
      ;;
    safari)
      sum_existing_kb "~/Library/Caches/com.apple.Safari" "~/Library/Caches/Safari" "~/Library/Containers/com.apple.Safari/Data/Library/Caches"
      ;;
    *)
      cache_dir_kb_under "$profile"
      ;;
  esac
}

browser_preview_command() {
  case "$1" in
    firefox|safari) printf 'cleanroom clean' ;;
    *) printf 'cleanroom clean --include-app-caches' ;;
  esac
}

browser_apply_command() {
  case "$1" in
    firefox|safari) printf 'cleanroom clean --apply --trash' ;;
    *) printf 'cleanroom clean --apply --trash --include-app-caches' ;;
  esac
}

browser_rows() {
  local id name profile_template notes profile profile_kb cache_kb protected_reason protected
  while IFS=$'\t' read -r id name profile_template notes; do
    [[ -z "${id:-}" ]] && continue
    profile="$(expand_path "$profile_template")"
    profile_kb="$(size_kb "$profile")"
    cache_kb="$(browser_cache_kb "$id" "$profile")"
    protected_reason="$(protected_removal_reason "$profile" || true)"
    if [[ -n "$protected_reason" ]]; then
      protected=true
    else
      protected=false
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$cache_kb" "$profile_kb" "$id" "$name" "$profile" "$protected" "$notes" "$protected_reason"
  done < <(browser_specs) | sort -rn
}

browsers() {
  local rows
  rows="$(browser_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 cache_kb profile_kb id name profile protected notes protected_reason
    while IFS=$'\t' read -r cache_kb profile_kb id name profile protected notes protected_reason; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","name":"%s","profile_path":"%s","profile_present":%s,"profile_size_kb":%s,"profile_size":"%s","cache_size_kb":%s,"cache_size":"%s","protected":%s,"preview_command":"%s","apply_command":"%s","notes":"%s","protected_reason":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$name" | json_escape)" \
        "$(printf '%s' "$profile" | json_escape)" \
        "$(if [[ -e "$profile" ]]; then echo true; else echo false; fi)" \
        "${profile_kb:-0}" \
        "$(human_kb "${profile_kb:-0}" | json_escape)" \
        "${cache_kb:-0}" \
        "$(human_kb "${cache_kb:-0}" | json_escape)" \
        "$protected" \
        "$(browser_preview_command "$id" | json_escape)" \
        "$(browser_apply_command "$id" | json_escape)" \
        "$(printf '%s' "$notes" | json_escape)" \
        "$(printf '%s' "$protected_reason" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom browser storage${RESET}"
  printf 'Review-only inventory. Browser profiles, passwords, cookies, bookmarks, sessions, and settings stay protected.\n\n'
  printf '%-10s %-10s %-10s %-18s %s\n' "cache" "profile" "protected" "browser" "profile path"
  local cache_kb profile_kb id name profile protected notes protected_reason
  while IFS=$'\t' read -r cache_kb profile_kb id name profile protected notes protected_reason; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-10s %-10s %-18s %s\n' "$(human_kb "${cache_kb:-0}")" "$(human_kb "${profile_kb:-0}")" "$protected" "$name" "$profile"
    printf '  %s\n' "$notes"
    [[ -n "$protected_reason" ]] && printf '  protected: %s\n' "$protected_reason"
    printf '  preview: %s\n' "$(browser_preview_command "$id")"
    printf '  apply: %s\n' "$(browser_apply_command "$id")"
  done <<<"$rows"
}

lower_text() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

leftover_match_query() {
  local haystack query query_lower
  haystack="$(lower_text "$1")"
  for query in "${PATH_ARGS[@]}"; do
    query_lower="$(lower_text "$query")"
    [[ -z "$query_lower" ]] && continue
    if [[ "$haystack" == *"$query_lower"* ]]; then
      printf '%s\n' "$query"
      return 0
    fi
  done
  return 1
}

leftover_roots() {
  printf '%s\t%s\t%s\n' "app-support" "~/Library/Application Support" "3"
  printf '%s\t%s\t%s\n' "caches" "~/Library/Caches" "3"
  printf '%s\t%s\t%s\n' "preferences" "~/Library/Preferences" "1"
  printf '%s\t%s\t%s\n' "saved-state" "~/Library/Saved Application State" "1"
  printf '%s\t%s\t%s\n' "containers" "~/Library/Containers" "1"
  printf '%s\t%s\t%s\n' "group-containers" "~/Library/Group Containers" "1"
  printf '%s\t%s\t%s\n' "http-storages" "~/Library/HTTPStorages" "1"
  printf '%s\t%s\t%s\n' "webkit" "~/Library/WebKit" "2"
  printf '%s\t%s\t%s\n' "logs" "~/Library/Logs" "2"
  printf '%s\t%s\t%s\n' "launch-agents" "~/Library/LaunchAgents" "1"
  printf '%s\t%s\t%s\n' "local-launch-agents" "/Library/LaunchAgents" "1"
  printf '%s\t%s\t%s\n' "local-launch-daemons" "/Library/LaunchDaemons" "1"
  printf '%s\t%s\t%s\n' "local-app-support" "/Library/Application Support" "2"
}

leftover_rows() {
  [[ "${#PATH_ARGS[@]}" -gt 0 ]] || die "leftovers requires at least one search term"
  local category root_template depth root path matched kb slash_count path_depth
  while IFS=$'\t' read -r category root_template depth; do
    root="$(expand_path "$root_template")"
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      matched="$(leftover_match_query "$path" || true)"
      [[ -n "$matched" ]] || continue
      kb="$(size_kb "$path")"
      slash_count="${path//[!\/]/}"
      path_depth="${#slash_count}"
      printf '%012d\t%06d\t%s\t%s\t%s\n' "$kb" "$path_depth" "$category" "$matched" "$path"
    done < <(find "$root" -mindepth 1 -maxdepth "$depth" \( -type d -o -type f \) -print0 2>/dev/null)
  done < <(leftover_roots) | sort -t $'\t' -k1,1rn -k2,2n | head -n "$LIMIT" | cut -f1,3-
}

json_queries_array() {
  local first=1 query
  printf '['
  for query in "${PATH_ARGS[@]}"; do
    [[ -z "$query" ]] && continue
    [[ "$first" -eq 0 ]] && printf ','
    first=0
    printf '"%s"' "$(printf '%s' "$query" | json_escape)"
  done
  printf ']'
}

leftovers() {
  local rows
  rows="$(leftover_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"queries":'
    json_queries_array
    printf ',"items":['
    local first=1 kb category matched path kb_num status reason line
    while IFS=$'\t' read -r kb category matched path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      line="$(guard_status "$path")"
      status="${line%%$'\t'*}"
      reason="${line#*$'\t'}"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","category":"%s","matched_query":"%s","size_kb":%s,"size":"%s","status":"%s","reason":"%s","preview_command":"%s","apply_command":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$(printf '%s' "$matched" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$reason" | json_escape)" \
        "$(leftover_command "cleanroom leftovers" | json_escape)" \
        "$(leftover_command "cleanroom leftovers --apply --trash" | json_escape)"
    done <<<"$rows"
    printf ']}\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom app leftovers${RESET}"
  if [[ "$APPLY" -eq 1 ]]; then
    [[ "$TRASH" -eq 1 ]] || die "leftovers apply requires --trash so matches can be restored from the apply log."
    warn "Apply mode enabled for app leftovers."
    warn "Trash mode required and enabled; matches move to ~/.Trash/cleanroom-$RUN_ID."
    warn "Protected browser profiles, Keychains, backups, Photos, Mail, and broad Library folders are still refused."
    [[ "$ASSUME_YES" -eq 1 ]] || {
      printf 'Continue? Type "leftovers" to proceed: '
      local answer
      read -r answer
      [[ "$answer" == "leftovers" ]] || die "Cancelled."
    }
    ensure_apply_log
    warn "Apply log: $LOG_FILE"
  else
    printf 'Preview search. Pass --apply --trash to move matches to a recoverable Trash folder.\n'
  fi
  printf 'Queries: %s  Limit: %s\n\n' "${PATH_ARGS[*]}" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No matching leftovers found.\n'
    return 0
  fi
  printf '%-10s %-20s %-16s %s\n' "size" "category" "matched" "path"
  local kb category matched path removed refused skipped status_line status reason selected skip_nested
  local applied_leftover_roots=""
  removed=0
  refused=0
  skipped=0
  while IFS=$'\t' read -r kb category matched path; do
    [[ -z "${path:-}" ]] && continue
    if [[ "$APPLY" -eq 1 ]]; then
      if [[ ! -e "$path" ]]; then
        skipped=$((skipped + 1))
        continue
      fi
      skip_nested=0
      if [[ -n "$applied_leftover_roots" ]]; then
        while IFS= read -r selected; do
          [[ -z "$selected" ]] && continue
          if [[ "$path" == "$selected/"* ]]; then
            skip_nested=1
            break
          fi
        done <<<"$applied_leftover_roots"
      fi
      if [[ "$skip_nested" -eq 1 ]]; then
        skipped=$((skipped + 1))
        continue
      fi
      status_line="$(guard_status "$path")"
      status="${status_line%%$'\t'*}"
      reason="${status_line#*$'\t'}"
      if [[ "$status" != "allowed" ]]; then
        refused=$((refused + 1))
        warn "refusing leftover: $path ($status: $reason)"
        record_apply "leftover" "$status" "$kb" "$path" ""
        continue
      fi
      if is_excluded "$path"; then
        skipped=$((skipped + 1))
        [[ "$VERBOSE" -eq 1 ]] && warn "skipping excluded leftover: $path"
        continue
      fi
      printf '%-10s %-20s %-16s %s\n' "$(human_kb "$kb")" "$category" "$matched" "$path"
      delete_path "$path"
      applied_leftover_roots="${applied_leftover_roots}${path}"$'\n'
      removed=$((removed + 1))
    else
      printf '%-10s %-20s %-16s %s\n' "$(human_kb "$kb")" "$category" "$matched" "$path"
    fi
  done <<<"$rows"
  if [[ "$APPLY" -eq 1 ]]; then
    printf '\nleftovers summary: moved=%s refused=%s skipped=%s\n' "$removed" "$refused" "$skipped"
    printf 'Restore with: cleanroom restore --log %s --apply\n' "$(shell_quote "$LOG_FILE")"
  else
    printf '\nPreview command: %s\n' "$(leftover_command "cleanroom leftovers")"
    printf 'Recoverable cleanup: %s\n' "$(leftover_command "cleanroom leftovers --apply --trash")"
    printf 'Vendor uninstallers or app settings may still be required for complete removal.\n'
  fi
}

backup_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || { printf '\n'; return 0; }
  plutil -extract "$key" raw -o - "$file" 2>/dev/null || true
}

backup_rows() {
  local root="$HOME/Library/Application Support/MobileSync/Backup"
  [[ -d "$root" ]] || return 0
  local path info kb epoch device product last_backup
  while IFS= read -r -d '' path; do
    info="$path/Info.plist"
    kb="$(size_kb "$path")"
    epoch="$(path_mtime_epoch "$path")"
    device="$(backup_value "$info" "Device Name")"
    product="$(backup_value "$info" "Product Name")"
    last_backup="$(backup_value "$info" "Last Backup Date")"
    [[ -n "$device" ]] || device="$(basename "$path")"
    printf '%012d\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$epoch" "$device" "$product" "$last_backup" "$path"
  done < <(find "$root" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null) |
    sort -rn |
    head -n "$LIMIT"
  return 0
}

backups() {
  local rows root
  root="$HOME/Library/Application Support/MobileSync/Backup"
  rows="$(backup_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch device product last_backup path kb_num
    while IFS=$'\t' read -r kb epoch device product last_backup path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","device_name":"%s","product_name":"%s","last_backup":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","protected":true}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$device" | json_escape)" \
        "$(printf '%s' "$product" | json_escape)" \
        "$(printf '%s' "$last_backup" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch:-0}" \
        "$(file_mtime_iso "${epoch:-0}" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom local iPhone/iPad backups${RESET}"
  printf 'Review-only inventory. cleanroom does not delete local device backups.\n'
  printf 'Path: %s\n\n' "$root"
  if [[ -z "$rows" ]]; then
    printf 'No local MobileSync backups found.\n'
    return 0
  fi
  printf '%-10s %-12s %-24s %-20s %s\n' "size" "modified" "device" "product" "path"
  local kb epoch device product last_backup path
  while IFS=$'\t' read -r kb epoch device product last_backup path; do
    [[ -z "${path:-}" ]] && continue
    printf '%-10s %-12s %-24s %-20s %s\n' "$(human_kb "$kb")" "$(file_mtime_iso "${epoch:-0}")" "$device" "$product" "$path"
    [[ -n "$last_backup" ]] && printf '  last backup: %s\n' "$last_backup"
  done <<<"$rows"
  printf '\nManage these through Finder or Apple Devices after confirming you have another backup.\n'
}

xcode_rows() {
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "derived-data" "DerivedData" "rebuildable" "~/Library/Developer/Xcode/DerivedData" "cleanroom clean" "cleanroom clean --apply --trash" "Xcode build intermediates and indexes. Usually safe to rebuild."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "simulator-caches" "Simulator Caches" "rebuildable" "~/Library/Developer/CoreSimulator/Caches" "cleanroom clean" "cleanroom clean --apply --trash" "CoreSimulator cache data. Recreated by simulator tooling."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "ios-device-support" "iOS DeviceSupport" "dev-heavy" "~/Library/Developer/Xcode/iOS DeviceSupport" "cleanroom clean --include-dev-heavy" "cleanroom clean --apply --trash --include-dev-heavy" "Symbols and support files for connected iOS versions. Xcode may recreate or redownload them."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "watchos-device-support" "watchOS DeviceSupport" "dev-heavy" "~/Library/Developer/Xcode/watchOS DeviceSupport" "cleanroom clean --include-dev-heavy" "cleanroom clean --apply --trash --include-dev-heavy" "watchOS support files that may be recreated by Xcode."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "tvos-device-support" "tvOS DeviceSupport" "dev-heavy" "~/Library/Developer/Xcode/tvOS DeviceSupport" "cleanroom clean --include-dev-heavy" "cleanroom clean --apply --trash --include-dev-heavy" "tvOS support files that may be recreated by Xcode."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "simulator-devices" "Simulator Devices" "high-impact" "~/Library/Developer/CoreSimulator/Devices" "cleanroom clean --include-dev-heavy" "cleanroom clean --apply --trash --include-dev-heavy" "Simulator app data can be reset by the dev-heavy flow. Review before applying."
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "xcode-archives" "Xcode Archives" "review-only" "~/Library/Developer/Xcode/Archives" "open Xcode Organizer" "manual review" "Signed app archives and dSYMs. Do not delete blindly; review in Xcode Organizer or backups first."
}

xcode() {
  local rows
  rows="$(
    local id title safety path_template preview apply notes path kb
    while IFS=$'\t' read -r id title safety path_template preview apply notes; do
      path="$(expand_path "$path_template")"
      kb="$(size_kb "$path")"
      printf '%012d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$id" "$title" "$safety" "$path" "$preview" "$apply" "$notes"
    done < <(xcode_rows) | sort -rn
  )"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title safety path preview apply notes kb_num
    while IFS=$'\t' read -r kb id title safety path preview apply notes; do
      [[ -z "${id:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","safety":"%s","path":"%s","present":%s,"size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","notes":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$(if [[ -e "$path" ]]; then echo true; else echo false; fi)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$notes" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Xcode storage${RESET}"
  printf 'Review-only inventory. Cleanup commands are dry-runs unless --apply is passed.\n\n'
  printf '%-10s %-22s %-12s %s\n' "size" "item" "safety" "path"
  local kb id title safety path preview apply notes
  while IFS=$'\t' read -r kb id title safety path preview apply notes; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-22s %-12s %s\n' "$(human_kb "$kb")" "$title" "$safety" "$path"
    printf '  preview: %s\n' "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  %s\n' "$notes"
  done <<<"$rows"
}

plist_value() {
  local file="$1"
  local key="$2"
  plutil -extract "$key" raw -o - "$file" 2>/dev/null || true
}

startup_program() {
  local plist="$1" program
  program="$(plist_value "$plist" "Program")"
  if [[ -z "$program" ]]; then
    program="$(plutil -p "$plist" 2>/dev/null | awk '
      /"ProgramArguments"/ {in_args=1; next}
      in_args && /\]/ {exit}
      in_args && /=>/ {
        sub(/^[[:space:]]*[0-9]+ => "/, "")
        sub(/"$/, "")
        print
        exit
      }
    ' || true)"
  fi
  printf '%s\n' "$program"
}

startup_rows() {
  local entries=(
    "user	LaunchAgent	$HOME/Library/LaunchAgents"
    "local	LaunchAgent	/Library/LaunchAgents"
    "local	LaunchDaemon	/Library/LaunchDaemons"
  )
  local entry scope type dir plist label disabled status program
  for entry in "${entries[@]}"; do
    IFS=$'\t' read -r scope type dir <<<"$entry"
    [[ -d "$dir" ]] || continue
    find "$dir" -maxdepth 1 -type f -name '*.plist' -print0 2>/dev/null |
      while IFS= read -r -d '' plist; do
        label="$(plist_value "$plist" "Label")"
        [[ -n "$label" ]] || label="$(basename "$plist" .plist)"
        disabled="$(plist_value "$plist" "Disabled")"
        if [[ "$disabled" == "true" ]]; then
          status="disabled"
        else
          status="enabled"
        fi
        program="$(startup_program "$plist")"
        printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$scope" "$type" "$status" "$label" "$program" "$plist"
      done
  done | awk -v limit="$LIMIT" 'NR <= limit'
}

startup_count() {
  startup_rows | awk 'END {print NR + 0}'
}

startup() {
  local rows
  rows="$(startup_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 scope type status label program plist
    while IFS=$'\t' read -r scope type status label program plist; do
      [[ -z "${plist:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"scope":"%s","type":"%s","status":"%s","label":"%s","program":"%s","path":"%s"}' \
        "$(printf '%s' "$scope" | json_escape)" \
        "$(printf '%s' "$type" | json_escape)" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$label" | json_escape)" \
        "$(printf '%s' "$program" | json_escape)" \
        "$(printf '%s' "$plist" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom startup items${RESET}"
  printf 'Review-only list. cleanroom does not unload, disable, or remove startup items.\n'
  printf 'Limit: %s\n\n' "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No LaunchAgents or LaunchDaemons found.\n'
    return 0
  fi
  printf '%-8s %-13s %-9s %-36s %s\n' "scope" "type" "status" "label" "path"
  local scope type status label program plist
  while IFS=$'\t' read -r scope type status label program plist; do
    [[ -z "${plist:-}" ]] && continue
    printf '%-8s %-13s %-9s %-36s %s\n' "$scope" "$type" "$status" "$label" "$plist"
    [[ -n "$program" ]] && printf '  program: %s\n' "$program"
  done <<<"$rows"
  printf '\nReview login items in System Settings > General > Login Items.\n'
}

trash_rows() {
  local dir="$HOME/.Trash"
  [[ -d "$dir" ]] || return 0
  find "$dir" -mindepth 1 -maxdepth 1 -print0 2>/dev/null |
    while IFS= read -r -d '' path; do
      printf '%012d\t%s\n' "$(size_kb "$path")" "$path"
    done |
    sort -rn |
    awk -v limit="$LIMIT" 'NR <= limit' || true
}

trash_total_kb() {
  size_kb "~/.Trash"
}

trash() {
  local rows total
  rows="$(trash_rows || true)"
  total="$(trash_total_kb)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '{"total_kb":%s,"total":"%s","items":[' "$total" "$(human_kb "$total" | json_escape)"
    local first=1 kb kb_num path
    while IFS=$'\t' read -r kb path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "$kb" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","size_kb":%s,"size":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)"
    done <<<"$rows"
    printf ']}\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Trash${RESET}"
  printf 'Review-only inventory. Emptying Trash is opt-in and irreversible.\n'
  printf 'Total: %s  Limit: %s\n\n' "$(human_kb "$total")" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'Trash is empty.\n'
    return 0
  fi
  local kb path
  while IFS=$'\t' read -r kb path; do
    [[ -z "${path:-}" ]] && continue
    printf '%8s  %s\n' "$(human_kb "$kb")" "$path"
  done <<<"$rows"
  printf '\nPreview emptying Trash with: cleanroom clean --include-user-trash\n'
  printf 'Empty Trash with: cleanroom clean --include-user-trash --apply\n'
}

