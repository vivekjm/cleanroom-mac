quicklook_rows() {
  local id title path_template category preview apply description path kb
  while IFS=$'\t' read -r id title path_template category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    path="$(expand_path "$path_template")"
    kb="$(size_kb "$path")"
    printf '%012d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$kb" "$id" "$title" "$path" "$category" "$preview" "$apply" "$description"
  done < <(quicklook_specs) | sort -rn
}

quicklook_total_kb() {
  local total=0 kb id title path category preview apply description kb_num
  while IFS=$'\t' read -r kb id title path category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
    total=$((total + kb_num))
  done < <(quicklook_rows)
  printf '%s\n' "$total"
}

quicklook() {
  local rows
  rows="$(quicklook_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title path category preview apply description kb_num
    while IFS=$'\t' read -r kb id title path category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","path":"%s","exists":%s,"category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$(if [[ -e "$path" ]]; then echo true; else echo false; fi)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom Quick Look caches${RESET}"
  printf 'Review-only inventory. Cleanup is opt-in with --include-quicklook.\n\n'
  printf '%-10s %-30s %s\n' "size" "bucket" "path"
  local kb id title path category preview apply description
  while IFS=$'\t' read -r kb id title path category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-30s %s\n' "$(human_kb "$kb")" "$title" "$path"
    printf '  %s\n' "$description"
  done <<<"$rows"
  printf '\nPreview cleanup with: cleanroom clean --include-quicklook\n'
  printf 'Apply cleanup with: cleanroom clean --apply --trash --include-quicklook\n'
}

