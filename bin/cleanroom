xcode_fast() {
  local rows
  rows="$(xcode_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title safety path_template preview apply notes path present status size summary
    while IFS=$'\t' read -r id title safety path_template preview apply notes; do
      [[ -z "${id:-}" ]] && continue
      path="$(expand_path "$path_template")"
      if [[ -e "$path" ]]; then
        present=true
        status="Review"
        size="Present"
        summary="$notes"
      else
        present=false
        status="Clear"
        size="Not found"
        summary="No known local Xcode storage found for this area."
      fi
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","safety":"%s","path":"%s","present":%s,"status":"%s","size":"%s","summary":"%s","mode":"fast"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$safety" | json_escape)" \
        "$(printf '%s' "$path" | json_escape)" \
        "$present" \
        "$(printf '%s' "$status" | json_escape)" \
        "$(printf '%s' "$size" | json_escape)" \
        "$(printf '%s' "$summary" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}quick Xcode storage${RESET}"
  printf 'Fast presence check. Exact sizing is skipped to keep the app responsive.\n\n'
  local id title safety path_template preview apply notes path status
  while IFS=$'\t' read -r id title safety path_template preview apply notes; do
    [[ -z "${id:-}" ]] && continue
    path="$(expand_path "$path_template")"
    if [[ -e "$path" ]]; then
      status="present"
    else
      status="not found"
    fi
    printf '%-12s %-22s %s\n' "$status" "$safety" "$title"
  done <<<"$rows"
}

