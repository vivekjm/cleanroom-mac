  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "anythingllm-models" "AnythingLLM" "models" "downloaded-models" "~/Library/Application Support/anythingllm-desktop/storage/models" "cleanroom aitools" "cleanroom clean --apply --trash --include-ai-models" "Downloaded AnythingLLM desktop model store."
