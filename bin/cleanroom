}

cloud() {
  local rows
  rows="$(cloud_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title provider path guidance expanded kb
    while IFS=$'\t' read -r id title provider path guidance; do
      [[ -z "${id:-}" ]] && continue
      expanded="$(expand_path "$path")"
      kb="$(size_kb "$expanded")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","provider":"%s","path":"%s","exists":%s,"size_kb":%s,"size":"%s","protected":true,"guidance":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$provider" | json_escape)" \
        "$(printf '%s' "$expanded" | json_escape)" \
        "$(if [[ -e "$expanded" ]]; then echo true; else echo false; fi)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom protected cloud storage${RESET}"
  printf 'Review-only inventory. cleanroom does not delete cloud-sync folders because local deletes may sync remotely.\n\n'
  printf '%-10s %-14s %-24s %s\n' "size" "provider" "location" "path"
  local id title provider path guidance expanded kb
  while IFS=$'\t' read -r id title provider path guidance; do
    [[ -z "${id:-}" ]] && continue
    expanded="$(expand_path "$path")"
    [[ -e "$expanded" ]] || continue
    kb="$(size_kb "$expanded")"
    printf '%-10s %-14s %-24s %s\n' "$(human_kb "$kb")" "$provider" "$title" "$expanded"
    printf '  %s\n' "$guidance"
  done <<<"$rows"
  printf '\nUse this to explain large Documents/iCloud/CloudStorage usage. Change files through the provider UI or after verified backups.\n'
}

cloudfiles_roots() {
  if [[ "${#PATH_ARGS[@]}" -gt 0 ]]; then
    local path
    for path in "${PATH_ARGS[@]}"; do
      printf '%s\n' "$(expand_path "$path")"
    done
  else
    printf '%s\n' "$HOME/Library/Mobile Documents"
    printf '%s\n' "$HOME/Library/CloudStorage"
    printf '%s\n' "$HOME/Dropbox"
    printf '%s\n' "$HOME/Google Drive"
    printf '%s\n' "$HOME/OneDrive"
    printf '%s\n' "$HOME/Box"
    printf '%s\n' "$HOME/Sync"
  fi
}

cloudfile_provider() {
  local root="$1" path="$2" rel first
  case "$root" in
    "$HOME/Library/Mobile Documents") printf '%s\n' "iCloud Drive"; return ;;
    "$HOME/Library/CloudStorage")
      rel="${path#"$root"/}"
      first="${rel%%/*}"
      [[ -n "$first" && "$first" != "$rel" ]] || first="CloudStorage"
      printf '%s\n' "$first"
      return
      ;;
  esac
  basename "$root"
}

cloudfiles_rows() {
  local root path kb epoch provider
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' path; do
      kb="$(size_kb "$path")"
      epoch="$(path_mtime_epoch "$path")"
      provider="$(cloudfile_provider "$root" "$path")"
      printf '%012d\t%012d\t%s\t%s\t%s\n' "$kb" "$epoch" "$provider" "$root" "$path"
    done < <(find "$root" -xdev -type f -size "+${MIN_MB}M" -print0 2>/dev/null)
  done < <(cloudfiles_roots) | sort -t $'\t' -k1,1rn -k2,2rn | head -n "$LIMIT"
}

cloudfiles_fast_rows() {
  command -v mdfind >/dev/null 2>&1 || return 2
  local root path bytes kb epoch provider min_bytes root_candidate
  min_bytes=$((MIN_MB * 1024 * 1024))
  while IFS= read -r root; do
    [[ -d "$root" ]] || continue
    mdfind -onlyin "$root" "kMDItemFSSize > $min_bytes" 2>/dev/null || true
  done < <(cloudfiles_roots) |
    sort -u |
    while IFS= read -r path; do
      [[ -f "$path" ]] || continue
      bytes="$(stat -f '%z' "$path" 2>/dev/null || stat -c '%s' "$path" 2>/dev/null || true)"
      [[ "$bytes" =~ ^[0-9]+$ ]] || bytes=0
      kb=$(((bytes + 1023) / 1024))
      epoch="$(path_mtime_epoch "$path")"
      provider="Cloud Storage"
      while IFS= read -r root_candidate; do
        [[ -d "$root_candidate" ]] || continue
        case "$path" in
          "$root_candidate"/*|"$root_candidate") provider="$(cloudfile_provider "$root_candidate" "$path")"; break ;;
        esac
      done < <(cloudfiles_roots)
      printf '%012d\t%012d\t%s\t%s\n' "$kb" "$epoch" "$provider" "$path"
    done |
    sort -t $'\t' -k1,1rn -k2,2rn |
    head -n "$LIMIT"
}

cloudfiles() {
  local rows
  rows="$(cloudfiles_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb epoch provider root path kb_num epoch_num
    while IFS=$'\t' read -r kb epoch provider root path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","root":"%s","provider":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","review_command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$root" | json_escape)" \
        "$(printf '%s' "$provider" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf 'open -R %s' "$(shell_quote "$path")" | json_escape)" \
        "$(printf '%s' "Review cloud files in Finder or the provider UI. Deleting local files may sync deletes remotely." | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom local cloud files${RESET}"
  printf 'Review-only list. cleanroom does not delete cloud files or evict local copies.\n'
  printf 'Minimum: %sMB  Limit: %s\n\n' "$MIN_MB" "$LIMIT"
  if [[ -z "$rows" ]]; then
    printf 'No local cloud-sync files found over %sMB in readable roots.\n' "$MIN_MB"
    return 0
  fi
  printf '%-10s %-12s %-18s %s\n' "size" "modified" "provider" "path"
  local kb epoch provider root path epoch_num
  while IFS=$'\t' read -r kb epoch provider root path; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    printf '%-10s %-12s %-18s %s\n' "$(human_kb "$kb")" "$(file_mtime_iso "${epoch_num:-0}")" "$provider" "$path"
    printf '  reveal: open -R %s\n' "$(shell_quote "$path")"
  done <<<"$rows"
  printf '\nReview these through Finder or the cloud provider UI. Local deletes can sync remotely.\n'
}

cloudfiles_fast() {
  local rows available=1
  rows="$(cloudfiles_fast_rows)" || available=0

  if [[ "$JSON" -eq 1 ]]; then
    if [[ "$available" -eq 0 ]]; then
      printf '{"available":false,"reason":"spotlight_unavailable","items":[]}\n'
      return 0
    fi
    printf '{"available":true,"items":['
    local first=1 kb epoch provider path kb_num epoch_num
    while IFS=$'\t' read -r kb epoch provider path; do
      [[ -z "${path:-}" ]] && continue
      kb_num="$(printf '%s\n' "${kb:-0}" | sed 's/^0*//; s/^$/0/')"
      epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"path":"%s","name":"%s","provider":"%s","size_kb":%s,"size":"%s","modified_epoch":%s,"modified":"%s","mode":"fast","guidance":"%s"}' \
        "$(printf '%s' "$path" | json_escape)" \
        "$(printf '%s' "$(basename "$path")" | json_escape)" \
        "$(printf '%s' "$provider" | json_escape)" \
        "$kb_num" \
        "$(human_kb "${kb:-0}" | json_escape)" \
        "${epoch_num:-0}" \
        "$(file_mtime_iso "${epoch_num:-0}" | json_escape)" \
        "$(printf '%s' "Review in Finder or the provider app. Deleting local cloud files may sync deletes remotely." | json_escape)"
    done <<<"$rows"
    printf ']}\n'
    return 0
  fi

  printf '%s\n' "${BOLD}quick local cloud files${RESET}"
  printf 'Fast Spotlight-backed review. cleanroom does not delete cloud files or evict local copies.\n'
  printf 'Minimum: %sMB  Limit: %s\n\n' "$MIN_MB" "$LIMIT"
  if [[ "$available" -eq 0 ]]; then
    printf 'Spotlight search is not available. Use Cloud Files when you want a deeper review.\n'
    return 0
  fi
  if [[ -z "$rows" ]]; then
    printf 'No large local cloud-sync files found in the Spotlight index.\n'
    return 0
  fi
  printf '%-10s %-12s %-18s %s\n' "size" "modified" "provider" "file"
  local kb epoch provider path epoch_num
  while IFS=$'\t' read -r kb epoch provider path; do
    [[ -z "${path:-}" ]] && continue
    epoch_num="$(printf '%s\n' "${epoch:-0}" | sed 's/^0*//; s/^$/0/')"
    printf '%-10s %-12s %-18s %s\n' "$(human_kb "$kb")" "$(file_mtime_iso "${epoch_num:-0}")" "$provider" "$(basename "$path")"
  done <<<"$rows"
}

