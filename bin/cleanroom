system_data() {
  local rows
  rows="$(system_data_rows)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 id title paths category preview apply description kb
    while IFS=$'\t' read -r id title paths category preview apply description; do
      [[ -z "${id:-}" ]] && continue
      kb="$(paths_field_kb "$paths")"
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","paths":"%s","category":"%s","size_kb":%s,"size":"%s","preview_command":"%s","apply_command":"%s","description":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$paths" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "$kb" \
        "$(human_kb "$kb" | json_escape)" \
        "$(printf '%s' "$preview" | json_escape)" \
        "$(printf '%s' "$apply" | json_escape)" \
        "$(printf '%s' "$description" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom System Data breakdown${RESET}"
  printf 'Review-only inventory of common folders macOS may count as System Data.\n\n'
  printf '%-10s %-22s %-12s %s\n' "size" "id" "category" "next command"
  local id title paths category preview apply description kb
  while IFS=$'\t' read -r id title paths category preview apply description; do
    [[ -z "${id:-}" ]] && continue
    kb="$(paths_field_kb "$paths")"
    printf '%-10s %-22s %-12s %s\n' "$(human_kb "$kb")" "$id" "$category" "$preview"
    printf '  apply: %s\n' "$apply"
    printf '  paths: %s\n' "$paths"
    printf '  %s\n' "$description"
  done <<<"$rows"
}

system_data_fast_rows() {
  local cache developer containers backups diagnostics protected_count developer_display containers_display backups_display
  cache="$(caches_fast_rows | tab_rows_total_kb)"
  developer=0
  if command -v mdfind >/dev/null 2>&1; then
    developer="$(developer_fast_rows | tab_rows_total_kb)"
  fi
  if [[ "${developer:-0}" -gt 0 ]]; then
    developer_display="$(human_kb "$developer")"
  else
    developer_display="Clear"
  fi
  containers=0
  if [[ "$(container_present_count)" -gt 0 ]]; then
    containers_display="Review"
  else
    containers_display="Clear"
  fi
  backups=0
  if [[ -n "$(backup_fast_rows)" ]]; then
    backups_display="Protected"
  else
    backups_display="Clear"
  fi
  diagnostics="$(diagnostic_total_kb)"
  protected_count="$(protected_present_count)"

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$cache" "caches" "Caches" "rebuildable" "cleanroom caches-fast" "Fast bounded estimate from rebuildable cache locations. Deep cache sizing stays in the focused Caches review." "$(human_kb "$cache")"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$developer" "developer" "Developer Data" "review" "cleanroom xcode" "Fast Spotlight-backed estimate for stale developer dependency folders. Use Xcode, Android, and Toolchains for focused reviews." "$developer_display"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$containers" "containers" "Container Storage" "high-impact" "cleanroom containers" "Docker, Colima, Lima, and Podman storage can be large and high-impact. Review before cleaning." "$containers_display"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$backups" "device-backups" "Device Backups" "protected" "cleanroom backups" "Local iPhone and iPad backups are protected because they may be the only copy of device data." "$backups_display"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$diagnostics" "diagnostics" "Logs and Diagnostics" "low-risk" "cleanroom diagnostics" "User logs, diagnostic reports, and crash reports are usually low-risk review targets." "$(human_kb "$diagnostics")"
  printf '0\t%s\t%s\t%s\t%s\t%s\t%s\n' "protected-personal" "Protected Personal Data" "protected" "cleanroom protect" "Cleanroom keeps Photos, Mail, Messages, cloud-sync roots, Keychains, and browser profiles protected by default. ${protected_count} protected locations are present." "Protected"
  printf '0\t%s\t%s\t%s\t%s\t%s\t%s\n' "deep-system-data" "Deep System Data Review" "review" "cleanroom system-data" "Run the deep System Data breakdown when you need exhaustive Library and Application Support sizing." "Deep review"
}

system_data_fast() {
  local rows
  rows="$(system_data_fast_rows | sort -rn)"

  if [[ "$JSON" -eq 1 ]]; then
    printf '['
    local first=1 kb id title category command guidance display
    while IFS=$'\t' read -r kb id title category command guidance display; do
      [[ -z "${id:-}" ]] && continue
      [[ "$first" -eq 0 ]] && printf ','
      first=0
      printf '{"id":"%s","title":"%s","category":"%s","size_kb":%s,"size":"%s","command":"%s","guidance":"%s"}' \
        "$(printf '%s' "$id" | json_escape)" \
        "$(printf '%s' "$title" | json_escape)" \
        "$(printf '%s' "$category" | json_escape)" \
        "${kb:-0}" \
        "$(printf '%s' "${display:-$(human_kb "${kb:-0}")}" | json_escape)" \
        "$(printf '%s' "$command" | json_escape)" \
        "$(printf '%s' "$guidance" | json_escape)"
    done <<<"$rows"
    printf ']\n'
    return 0
  fi

  printf '%s\n' "${BOLD}cleanroom quick System Data${RESET}"
  printf 'Fast read-only summary for the desktop app. Deep Library sizing is skipped.\n\n'
  printf '%-10s %-18s %-12s %s\n' "size" "id" "category" "next command"
  local kb id title category command guidance display
  while IFS=$'\t' read -r kb id title category command guidance display; do
    [[ -z "${id:-}" ]] && continue
    printf '%-10s %-18s %-12s %s\n' "${display:-$(human_kb "${kb:-0}")}" "$id" "$category" "$command"
    printf '  %s\n' "$guidance"
  done <<<"$rows"
}

