#compdef cleanroom

_cleanroom() {
  local -a commands options

  commands=(
    'overview:Show read-only storage dashboard'
    'map:Show major storage bucket map'
    'snapshot:Write a storage-map snapshot'
    'diff:Compare two storage snapshots'
    'state:Inventory cleanroom-created state files'
    'permissions:Audit access to protected macOS storage'
    'review:Show personal storage review checklist'
    'scan:Show disk usage and cleanup candidates'
    'system-data:Break down common System Data buckets'
    'plan:Rank cleanup opportunities'
    'large:List large files for review'
    'brokenlinks:List broken symlinks for review'
    'quarantine:List quarantined downloaded files'
    'metadata:Find removable filesystem metadata clutter'
    'quicklook:Inventory Quick Look thumbnail and preview caches'
    'fontcaches:Inventory user font cache databases'
    'font-caches:Alias for fontcaches'
    'webcaches:Inventory Safari and WebKit cache folders'
    'web-caches:Alias for webcaches'
    'savedstate:Inventory saved app window/session state'
    'saved-state:Alias for savedstate'
    'projectcaches:Inventory Python/dev project caches'
    'project-caches:Alias for projectcaches'
    'updaters:Inventory app updater cache and staging folders'
    'updater-caches:Alias for updaters'
    'browsercaches:Inventory Chromium and Firefox browser caches'
    'browser-caches:Alias for browsercaches'
    'duplicates:Find exact duplicate files for review'
    'documents:Rank top-level user folders/files'
    'desktop:Rank top-level Desktop files'
    'screenshots:List screenshots and screen recordings'
    'archives:List archive and disk image files'
    'downloads:List old Downloads files'
    'installers:List old downloaded installer files'
    'nodes:List stale node_modules folders'
    'venvs:List stale Python virtualenv folders'
    'apps:List large app bundles for review'
    'uninstallers:List vendor uninstallers and remover tools'
    'appreview:Review app bundles, uninstallers, receipts, and leftovers'
    'appdata:Rank large app support and container folders'
    'libraries:Inventory protected media and creative libraries'
    'cloud:Inventory protected cloud-sync storage'
    'cloudfiles:List large local cloud-sync files'
    'cloud-files:Alias for cloudfiles'
    'personal:Inventory protected personal app data'
    'communications:Inventory protected Mail and Messages storage'
    'comms:Alias for communications'
    'browsers:Inventory browser profile and cache footprint'
    'leftovers:Find or trash app leftovers by search term'
    'backups:Inventory local iPhone/iPad backups'
    'xcode:Inventory Xcode and simulator storage'
    'android:Inventory Android SDK and emulator storage'
    'startup:List LaunchAgents and LaunchDaemons'
    'loginitems:List user Login Items'
    'trash:Inventory current user Trash'
    'caches:Inventory cache buckets'
    'diagnostics:Inventory logs and diagnostic reports'
    'packages:Inventory package-manager stores'
    'npm-cache:Run npm cache verify or explicit clean'
    'npmcache:Alias for npm-cache'
    'yarn-cache:Show Yarn cache location or explicit clean'
    'yarncache:Alias for yarn-cache'
    'pnpm-store:Run pnpm store status or explicit prune'
    'pnpmstore:Alias for pnpm-store'
    'cocoapods-cache:List CocoaPods cache or explicit clean'
    'pod-cache:Alias for cocoapods-cache'
    'pip-cache:Show pip cache info or explicit purge'
    'pipcache:Alias for pip-cache'
    'receipts:Inventory macOS package installer receipts'
    'homebrew:Inventory Homebrew cache, Cellar, Caskroom, and logs'
    'homebrew-cleanup:Run Homebrew cleanup dry-run or apply'
    'brewcleanup:Alias for homebrew-cleanup'
    'toolchains:Inventory language/toolchain caches'
    'containers:Inventory container VM disks and stores'
    'snapshots:List local Time Machine snapshots'
    'report:Write a Markdown cleanup report'
    'clean:Preview or apply cleanup'
    'history:List recent apply logs'
    'restore:Restore files moved by Trash mode'
    'interactive:Choose cleanup categories with prompts'
    'doctor:Check platform and safety assumptions'
    'protect:Audit protected personal data'
    'guard:Check whether paths are removable'
    'rules:List cleanup rules and safety levels'
    'categories:Explain cleanup categories'
    'init-config:Write a starter config file'
    'help:Show help'
  )

  options=(
    '--apply[Actually delete files]'
    '--trash[Move direct removals to ~/.Trash]'
    '--yes[Skip confirmation prompt]'
    '--verbose[Print every path touched]'
    '--json[Emit JSON where supported]'
    '--redact[Redact personal paths in Markdown reports]'
    '--preflight[Summarize clean options without scanning or deleting]'
    '--output[Output path for report]:file:_files'
    '--log[Apply audit log path]:file:_files'
    '--limit[Number of history entries]:limit:'
    '--min-mb[Minimum file size for review commands]:megabytes:'
    '--config[Config file path]:file:_files'
    '--exclude[Protect path from deletion]:path:_files'
    '--days[Age threshold for stale node_modules and virtualenvs]:days:'
    '--preset[Enable preset]:preset:(safe dev ai deep)'
    '--include-dev-heavy[Include heavy developer artifacts]'
    '--include-node-stale[Remove stale node_modules]'
    '--include-venv-stale[Remove stale Python virtualenv folders]'
    '--include-installers[Remove old downloaded installers]'
    '--include-download-artifacts[Remove old installers, disk images, and archives from Downloads]'
    '--include-screenshots[Remove old screenshots and screen recordings]'
    '--include-cleanroom-state[Remove old cleanroom-created logs, snapshots, and recovery folders]'
    '--include-metadata[Remove filesystem metadata clutter]'
    '--include-quicklook[Remove Quick Look thumbnail and preview caches]'
    '--include-font-caches[Remove user font cache databases]'
    '--include-web-caches[Remove Safari and WebKit cache folders]'
    '--include-saved-state[Remove saved app window/session state]'
    '--include-project-caches[Remove Python/dev project cache artifacts]'
    '--include-updater-caches[Remove app updater cache and staging data]'
    '--include-browser-caches[Remove Chromium and Firefox browser cache folders]'
    '--include-device-backups[Remove old local iPhone/iPad backups through Trash mode]'
    '--include-package-stores[Include package-manager stores]'
    '--include-toolchains[Include language/toolchain caches]'
    '--include-diagnostics[Include old diagnostic reports]'
    '--include-app-caches[Include safe app cache folders]'
    '--include-snapshots[Thin local snapshots]'
    '--include-user-trash[Empty ~/.Trash during apply]'
    '--include-ai-workspaces[Include generated AI-agent workspace data]'
    '--include-ai-models[Include downloaded local AI model stores]'
    '--include-containers[Include local container VM disks and image stores]'
    '--include-gemini[Alias for AI workspaces]'
    '--include-lmstudio[Alias for AI models]'
    '(-h --help)'{-h,--help}'[Show help]'
    '(-v --version)'{-v,--version}'[Show version]'
  )

  _arguments \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe 'command' commands
      ;;
    args)
      _describe 'option' options
      ;;
  esac
}

_cleanroom "$@"
